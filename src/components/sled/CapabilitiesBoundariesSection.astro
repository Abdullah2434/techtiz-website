---
import Eyebrow from '../shared/Eyebrow.astro';
import SledPageWrap from './SledPageWrap.astro';
import { BOUNDARIES } from '../../lib/constants/pages/capabilities';
---

<section class="bg-white py-[100px]">
  <SledPageWrap>
    <div class="mb-10 max-w-[720px]">
      <Eyebrow text="What we don't do" showGlyph class="mb-3.5 text-amber" />
      <h2 class="text-[40px] leading-[1.1] font-extrabold text-yale-dark">Honest about the lane.</h2>
      <p class="mt-3.5 max-w-[620px] text-[15.5px] leading-[1.6] text-muted">
        Trust comes from knowing where the work ends. These six categories belong to the prime, to a specialist sub, to dedicated capture-consulting firms, or to nobody at all.
      </p>
    </div>

    <div class="grid grid-cols-2 gap-4 max-[900px]:grid-cols-1">
      {BOUNDARIES.map((b) => (
        <div class="grid grid-cols-[36px_1fr] gap-4 rounded-[10px] border border-line px-7 py-[26px]">
          <div class="grid size-9 place-items-center rounded-full bg-amber/10 text-lg font-bold text-amber">✕</div>
          <div>
            <h4 class="text-base font-extrabold leading-[1.3] text-yale">{b.heading}</h4>
            <p class="mt-1.5 text-[13.5px] leading-[1.55] text-muted">{b.body}</p>
          </div>
        </div>
      ))}
    </div>
  </SledPageWrap>
</section>
