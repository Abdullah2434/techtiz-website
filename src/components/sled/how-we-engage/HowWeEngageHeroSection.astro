---
import { HOW_WE_ENGAGE_HERO } from '../../../lib/constants/pages/how-we-engage';
import CtaButton from '../../shared/CtaButton.astro';
import Eyebrow from '../../shared/Eyebrow.astro';
import SledPageWrap from '../shared/SledPageWrap.astro';

const { eyebrow, heading, body, ctas } = HOW_WE_ENGAGE_HERO;
---

<section class="sled-page-hero relative overflow-hidden border-b border-line/60 bg-seasalt" data-screen-label="01 Hero">
  <div
    class="pointer-events-none absolute inset-0 z-0 bg-[url('/assets/hero-columns.png')] bg-cover bg-[position:right_center] bg-no-repeat"
    aria-hidden="true"
  />
  <div
    class="pointer-events-none absolute inset-0 z-[1] bg-[linear-gradient(100deg,var(--color-seasalt)_20%,rgba(248,248,248,0.80)_42%,rgba(248,248,248,0.30)_64%,transparent_86%)]"
    aria-hidden="true"
  />

  <SledPageWrap class="relative z-[2] py-[clamp(3.375rem,6vw,5.25rem)] pb-[clamp(2.5rem,4.5vw,3.75rem)]">
    <div class="sled-reveal max-w-[760px] is-visible" data-sled-reveal>
      <Eyebrow text={eyebrow} showGlyph class="mb-[18px]" />
      <h1 class="sled-h1 mb-[22px] max-w-[18ch] text-yale" set:html={heading} />
      <p class="max-w-[530px] text-[clamp(1.02rem,1.4vw,1.125rem)] leading-[1.55] text-muted">{body}</p>
      <div class="mt-7 flex flex-wrap gap-[14px]">
        {ctas.map((cta) => (
          <CtaButton
            href={cta.href}
            label={cta.label}
            variant={cta.variant}
            showArrow={false}
            beam={'beam' in cta ? cta.beam : false}
          />
        ))}
      </div>
    </div>
  </SledPageWrap>
</section>
