---
import Eyebrow from '../../shared/Eyebrow.astro';

interface Props {
  eyebrow: string;
  heading: string;
  body?: string;
  accentEyebrow?: boolean;
  class?: string;
}

const { eyebrow, heading, body, accentEyebrow = false, class: className = 'mb-[30px] max-w-[680px]' } = Astro.props;
---

<div class:list={['sled-reveal', className]} data-sled-reveal>
  <Eyebrow
    text={eyebrow}
    showGlyph
    class:list={[accentEyebrow && 'text-[#B33] [&_span:first-child]:bg-[#C44]']}
  />
  <h2 class="sled-h2 mt-3.5 leading-[1.1] text-yale-dark">{heading}</h2>
  {body && <p class="mt-3.5 text-[15px] leading-[1.6] text-muted">{body}</p>}
</div>
