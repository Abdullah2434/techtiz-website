---
import { FOOTER_CONTACT_INFO } from "../../lib/constants/footer-contact";
import { FOOTER_NAV_SECTIONS } from "../../lib/constants/footer-nav";
import { LEGAL_LINKS, SITE, SITE_COPYRIGHT } from "../../lib/constants/site";
import "../../styles/chrome.css";
import FooterContactInfoItem from "./FooterContactInfoItem.astro";
import FooterNavSection from "./FooterNavSection.astro";

const wrap =
  "relative mx-auto w-full max-w-[1400px] px-2 max-[600px]:px-[18px]";
---

<footer
  class="foot relative overflow-hidden bg-yale-dark py-20 pb-8 text-white/70"
>
  <div
    class="pointer-events-none absolute -bottom-10 -left-10 size-[260px] rotate-[15deg] opacity-60 bg-[linear-gradient(45deg,transparent_48%,rgba(24,176,230,0.14)_48%_52%,transparent_52%)] bg-size-[30px_30px]"
    aria-hidden="true"
  >
  </div>

  <div class={wrap}>
    <div
      class="relative mb-10 flex flex-wrap items-start justify-between gap-6 md:mb-14"
    >
      <div class="brand-foot min-w-0 max-w-xl">
        <a href="/" class="brand-mark inline-block">
          <img
            src={SITE.logo.light}
            alt={SITE.name}
            class="brand-logo block h-[30px] w-auto"
          />
        </a>
        <p
          class="my-[18px] mb-0 max-w-xl text-sm leading-[1.55] text-white/70 md:mb-[22px]"
        >
          {SITE.description}
        </p>
      </div>
      <div class="socials flex shrink-0 gap-2.5">
          <a
            href={SITE.socials.google}
            aria-label="Google"
            target="_blank"
            rel="noopener noreferrer"
            class="grid size-[34px] place-items-center rounded-md border border-white/18 text-white/70 transition-[color,border-color] duration-[180ms] ease-out hover:border-cyan hover:text-cyan"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M21.8055 10.0415H21V10H12V14H17.6515C16.827 16.3285 14.6115 18 12 18C8.6865 18 6 15.3135 6 12C6 8.6865 8.6865 6 12 6C13.5295 6 14.921 6.577 15.9805 7.5195L18.809 4.691C17.023 3.0265 14.634 2 12 2C6.4775 2 2 6.4775 2 12C2 17.5225 6.4775 22 12 22C17.5225 22 22 17.5225 22 12C22 11.3295 21.931 10.675 21.8055 10.0415Z"
              ></path>
            </svg>
          </a>
          <a
            href={SITE.socials.facebook}
            aria-label="Facebook"
            target="_blank"
            rel="noopener noreferrer"
            class="grid size-[34px] place-items-center rounded-md border border-white/18 text-white/70 transition-[color,border-color] duration-[180ms] ease-out hover:border-cyan hover:text-cyan"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M22 12C22 6.48 17.52 2 12 2C6.48 2 2 6.48 2 12C2 16.84 5.44 20.87 10 21.8V15H8V12H10V9.5C10 7.57 11.57 6 13.5 6H16V9H14C13.45 9 13 9.45 13 10V12H16V15H13V21.95C18.05 21.45 22 17.19 22 12Z"
              ></path>
            </svg>
          </a>
          <a
            href={SITE.socials.x}
            aria-label="X"
            target="_blank"
            rel="noopener noreferrer"
            class="grid size-[34px] place-items-center rounded-md border border-white/18 text-white/70 transition-[color,border-color] duration-[180ms] ease-out hover:border-cyan hover:text-cyan"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M18.2 2H21l-6.5 7.4L22 22h-6.6l-5.2-6.8L4.2 22H1.5l7-8L1.2 2h6.8l4.7 6.2L18.2 2zm-1.2 18h1.8L7.2 4H5.3l11.7 16z"
              ></path>
            </svg>
          </a>
          <a
            href={SITE.socials.linkedin}
            aria-label="LinkedIn"
            target="_blank"
            rel="noopener noreferrer"
            class="grid size-[34px] place-items-center rounded-md border border-white/18 text-white/70 transition-[color,border-color] duration-[180ms] ease-out hover:border-cyan hover:text-cyan"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14M8.6 18.3v-7.6H6.07v7.6H8.6m-1.27-8.67a1.45 1.45 0 0 0 1.45-1.45A1.45 1.45 0 0 0 7.33 6.7a1.46 1.46 0 0 0-1.46 1.46 1.46 1.46 0 0 0 1.46 1.45m11 8.67v-4.18c0-2.2-1.18-3.22-2.76-3.22a2.38 2.38 0 0 0-2.16 1.19v-1.02h-2.45v7.6h2.53v-4.22c0-1.12.43-1.78 1.39-1.78s1.4.62 1.4 1.78v4.22h2.55z"
              ></path>
            </svg>
          </a>
      </div>
    </div>

    <div
      class="foot-nav relative mb-10 grid min-w-0 grid-cols-1 items-stretch gap-8 md:mb-14 md:grid-cols-2 md:gap-x-10 md:gap-y-12 lg:grid-cols-3 lg:gap-x-0 lg:gap-y-0 lg:divide-x lg:divide-white/50 [&>div]:min-w-0 [&>div:last-child]:md:col-span-2 [&>div:last-child]:lg:col-span-1 [&>div]:lg:px-10 [&>div:first-child]:lg:pl-0 [&>div:last-child]:lg:pr-0"
    >
      {
        FOOTER_NAV_SECTIONS.map((section) => (
          <FooterNavSection title={section.title} links={section.links} />
        ))
      }
    </div>

    <div class="border-b border-white pt-6 pb-12">
      <div
        class="grid grid-cols-1 gap-4 sm:grid-cols-2 md:grid-cols-2 lg:grid-cols-4 md:gap-10 lg:gap-14"
      >
        {
          FOOTER_CONTACT_INFO.map((contact) => (
            <FooterContactInfoItem {...contact} />
          ))
        }
      </div>
    </div>

    <div
      class="strip relative flex items-center justify-between border-t border-white/10 pt-6 text-[13px] text-white/55 max-[600px]:flex-col max-[600px]:items-start max-[600px]:gap-3.5"
    >
      <div>{SITE_COPYRIGHT}</div>
      <nav
        class="legal flex w-full min-w-0 flex-wrap items-center gap-x-4 gap-y-2 sm:gap-x-6 max-[600px]:grid max-[600px]:grid-cols-3 max-[600px]:gap-x-3 max-[600px]:gap-y-2.5 max-[600px]:text-[12px]"
        aria-label="Legal and site links"
      >
        {
          LEGAL_LINKS.map((link) => (
            <a href={link.href} class="whitespace-nowrap hover:text-cyan">
              {link.label}
            </a>
          ))
        }
      </nav>
    </div>
  </div>
</footer>
