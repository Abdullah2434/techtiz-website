---
import Accessibility from '@lucide/astro/icons/accessibility';
import ChevronDown from '@lucide/astro/icons/chevron-down';
import Cloud from '@lucide/astro/icons/cloud';
import FingerprintPattern from '@lucide/astro/icons/fingerprint-pattern';
import HeartPulse from '@lucide/astro/icons/heart-pulse';
import LockKeyhole from '@lucide/astro/icons/lock-keyhole';
import ShieldCheck from '@lucide/astro/icons/shield-check';
import { SLED_CAPABILITIES_FRAMEWORKS } from '../../../lib/constants/pages/capabilities';
import Eyebrow from '../../shared/Eyebrow.astro';
import SledPageWrap from '../shared/SledPageWrap.astro';

const icons = {
  'shield-check': ShieldCheck,
  'fingerprint-pattern': FingerprintPattern,
  cloud: Cloud,
  accessibility: Accessibility,
  'lock-keyhole': LockKeyhole,
  'heart-pulse': HeartPulse,
} as const;
---

<section
  class="sled-section border-t border-line-soft bg-seasalt"
  data-screen-label="03 Compliance frameworks"
>
  <SledPageWrap>
    <div class="sled-reveal mb-[30px] max-w-[720px]" data-sled-reveal>
      <Eyebrow text={SLED_CAPABILITIES_FRAMEWORKS.eyebrow} showGlyph class="mb-4" />
      <h2 class="text-[clamp(1.7rem,2.5vw,2.3rem)] font-semibold leading-[1.12] tracking-[-0.02em] text-yale-dark">
        {SLED_CAPABILITIES_FRAMEWORKS.heading}
      </h2>
      <p class="mt-3.5 max-w-[640px] text-[15.5px] leading-[1.6] text-muted">
        {SLED_CAPABILITIES_FRAMEWORKS.body}
      </p>
    </div>

    <div class="sled-reveal border-t border-line" data-sled-spec-accordion data-sled-reveal>
      {
        SLED_CAPABILITIES_FRAMEWORKS.items.map((item, idx) => {
          const Icon = icons[item.icon];
          const isOpen = idx === 0;

          return (
            <div
              class:list={['sled-spec-item border-b border-line-soft', isOpen && 'is-open']}
              data-sled-spec-item
            >
              <button
                type="button"
                class="sled-spec-head sled-fw-spec-head group grid w-full grid-cols-[64px_1fr_auto] items-center gap-[22px] bg-transparent px-2 py-5 text-left max-[620px]:grid-cols-[44px_1fr] max-[620px]:gap-x-3.5 max-[620px]:gap-y-2.5"
                aria-expanded={isOpen ? 'true' : 'false'}
              >
                <span class="font-mono text-[1.9rem] font-semibold leading-none tracking-[-0.02em] text-line transition-colors duration-200 group-hover:text-cyan-strong [.sled-spec-item.is-open_&]:text-cyan">
                  {item.num}
                </span>
                <span class="flex items-center gap-3 text-[1.18rem] font-semibold text-yale transition-colors duration-200 group-hover:text-cyan-strong [.sled-spec-item.is-open_&]:text-yale">
                  <Icon class="size-[19px] shrink-0 text-cyan-strong" stroke-width="1.75" aria-hidden="true" />
                  {item.name}
                </span>
                <span class="flex items-center gap-4 max-[620px]:col-start-2 max-[620px]:justify-self-start">
                  <span
                    class:list={[
                      'sled-fw-status font-mono text-[10px] font-semibold tracking-[0.12em] uppercase',
                      `sled-fw-status--${item.statusVariant}`,
                    ]}
                  >
                    {item.status}
                  </span>
                  <span class="text-muted transition-[transform,color] duration-300 [.sled-spec-item.is-open_&]:rotate-180 [.sled-spec-item.is-open_&]:text-cyan-strong">
                    <ChevronDown class="size-5" aria-hidden="true" />
                  </span>
                </span>
              </button>
              <div class="sled-spec-body">
                <div class="sled-spec-body-inner">
                  <div class="flex flex-col gap-3.5 pb-6 pl-[86px] pr-2 max-[620px]:pl-2">
                    <p class="m-0 max-w-[64ch] text-sm leading-[1.55] text-muted">{item.body}</p>
                    <div class="sled-fw-facts flex flex-wrap gap-1.5">
                      {item.facts.map((fact) => (
                        <span
                          class="rounded-md border border-line bg-white px-2 py-1 font-mono text-[10.5px] text-muted [&_strong]:font-semibold [&_strong]:text-yale"
                          set:html={fact}
                        />
                      ))}
                    </div>
                  </div>
                </div>
              </div>
            </div>
          );
        })
      }
    </div>
  </SledPageWrap>
</section>
