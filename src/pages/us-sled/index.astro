---
import SledLayout from '../../layouts/SledLayout.astro';
import {
  SLED_HUB_SEO, SLED_HERO, TRUST_ITEMS, OUTCOMES_STATS, BACKBONE_CARDS, VEHICLES, WHY_CARDS
} from '../../lib/constants/pages/sled-hub';
import { SITE } from '../../lib/constants/site';

const { title, description, canonicalPath, ogImage } = SLED_HUB_SEO;
---

<SledLayout {title} {description} {canonicalPath} {ogImage} currentPage="/us-sled/">

<!-- HERO -->
<section class="sled-hero" id="top" data-screen-label="01 Hero">
  <div class="capitol-wrap" aria-hidden="true">
    <div class="capitol"></div>
  </div>
  <div class="overlay" aria-hidden="true"></div>
  <div class="grain" aria-hidden="true"></div>
  <div class="sparkles" aria-hidden="true">
    <span></span><span></span><span></span><span></span><span></span><span></span>
  </div>
  <div class="tsq-cluster" aria-hidden="true">
    <span class="a"></span><span class="b"></span><span class="c"></span>
    <span class="d"></span><span class="e"></span><span class="f"></span>
    <span class="g"></span><span class="h"></span>
  </div>

  <div class="wrap inner">
    <div class="lead">
      <span class="eyebrow"><span class="gl"></span> {SLED_HERO.eyebrow}</span>
      <h1 set:html={SLED_HERO.heading} />
      <p class="body">{SLED_HERO.body}</p>

      <div class="cta-row">
        {SLED_HERO.ctas.map(cta => (
          cta.variant === 'cta'
            ? <a href={cta.href} class="cta">{cta.label} <span class="arr"></span></a>
            : <a href={cta.href} class="btn-ghost-dark">{cta.label}</a>
        ))}
      </div>

      <div class="quick-stats">
        {SLED_HERO.stats.map(s => (
          <div class="qs">
            <div class="n">{s.n}</div>
            <div class="l">{s.l}</div>
          </div>
        ))}
      </div>

      <div class="disclaimer" style="margin-top: 28px;">
        <span class="tsq"></span>
        {SLED_HERO.disclaimer}
      </div>
    </div>
  </div>
</section>

<!-- TRUST STRIP -->
<div class="trust-strip">
  <div class="wrap">
    <div class="trust-row">
      <div class="trust-item">
        <div class="ti-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 3 6v6c0 5 3.8 8.3 9 10 5.2-1.7 9-5 9-10V6z"></path><path d="M9 12l2 2 4-4"></path></svg></div>
        <div class="ti-body">
          <span class="ti-l">SAM.gov UEI</span>
          <span class="ti-v pending">Add UEI</span>
        </div>
      </div>
      <div class="trust-item">
        <div class="ti-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2"></rect><path d="M3 9h18M8 14h3"></path></svg></div>
        <div class="ti-body">
          <span class="ti-l">CAGE Code</span>
          <span class="ti-v pending">Add CAGE</span>
        </div>
      </div>
      <div class="trust-item">
        <div class="ti-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l8 4.5v9L12 21l-8-4.5v-9z"></path><circle cx="12" cy="11" r="2.5"></circle><path d="M8.5 16c.6-1.8 2-2.6 3.5-2.6s2.9.8 3.5 2.6"></path></svg></div>
        <div class="ti-body">
          <span class="ti-l">Business size</span>
          <span class="ti-v pending">Small Business?</span>
        </div>
      </div>
      <div class="trust-item">
        <div class="ti-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2"></rect><path d="M7 4 V2 M17 4 V2 M3 10 h18"></path></svg></div>
        <div class="ti-body">
          <span class="ti-l">Federal classification</span>
          <span class="ti-v">NAICS 541511 · 541512 · 541519</span>
        </div>
      </div>
      <div class="trust-item">
        <div class="ti-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21 h18"></path><path d="M6 21 V8 l6 -4 l6 4 v13"></path></svg></div>
        <div class="ti-body">
          <span class="ti-l">State procurement</span>
          <span class="ti-v">NIGP 918-46 · 918-00</span>
        </div>
      </div>
      <div class="trust-item">
        <div class="ti-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><path d="M9 12 l2 2 l4 -4"></path></svg></div>
        <div class="ti-body">
          <span class="ti-l">Insurance</span>
          <span class="ti-v">Prime-routed</span>
        </div>
      </div>
      <div class="trust-item">
        <div class="ti-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><path d="M12 7 v5 l3 2"></path></svg></div>
        <div class="ti-body">
          <span class="ti-l">Response SLA</span>
          <span class="ti-v">1 business day</span>
        </div>
      </div>
      <a class="trust-item" href="/us-sled/operating-model/">
        <div class="ti-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 3 6v6c0 5 3.8 8.3 9 10 5.2-1.7 9-5 9-10V6z"></path><path d="M9 12l2 2 4-4"></path></svg></div>
        <div class="ti-body">
          <span class="ti-l">Compliance posture</span>
          <span class="ti-v">SOC 2 Type II in progress · NIST 800-171 aligned</span>
        </div>
      </a>
    </div>
  </div>
</div>

<!-- WHO WE ARE NOT -->
<div class="who-we-arent" style="background: var(--white); border-bottom: 1px solid var(--line); padding: 18px 0;">
  <div class="wrap" style="display: flex; align-items: center; gap: 16px; flex-wrap: wrap;">
    <span style="font-family: 'JetBrains Mono', monospace; font-size: 10.5px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--cyan-strong); flex-shrink: 0;">Who we are not</span>
    <p style="font-size: 13.5px; color: var(--muted); line-height: 1.55; margin: 0; flex: 1; min-width: 280px;">Techtiz is not a procurement intelligence firm. We are a technical implementation subcontractor for U.S. SLED primes. For RFP intelligence, our partners use Deltek GovWin and Bloomberg Government.</p>
  </div>
</div>

<!-- TWO STAGES -->
<section class="block two-stages" id="two-stages" data-screen-label="02 Two stages">
  <div class="wrap">
    <span class="eyebrow" style="margin-bottom: 14px; display: inline-flex; align-items: center;"><span class="gl"></span> Two engagement modes. One contract structure.</span>
    <div class="ts-header">
      <h2>Engage us pre-award, post-award, or both, the prime always stays the face to the agency.</h2>
      <p class="sub">Under teaming letter and NDA. Pre-award, we draft proposal volumes and build demo systems for your evaluation panel. Post-award, we deliver the technical workstream. Either way, white-labeled.</p>
    </div>

    <div class="toggle-pill" role="tablist">
      <button class="on" data-stage="pre" role="tab" aria-selected="true">
        <svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M9 9 l6 6 M15 9 l-6 6"></path></svg>
        Pre-Award Proposal Support
      </button>
      <button data-stage="post" role="tab" aria-selected="false">
        <svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 17 9 11 13 15 21 7"></polyline><polyline points="14 7 21 7 21 14"></polyline></svg>
        Post-Award Delivery
      </button>
    </div>

    <!-- PRE-BID PANEL -->
    <div class="stage-panel show" data-panel="pre">
      <div class="stage-side">
        <div class="stage-tag">Phase 01 · Pre-Award (under teaming letter + NDA)</div>
        <h3>Load the technical volume. Build the demo. Package past performance.</h3>
        <div class="pain-card">
          <div class="pain-label">The Pain Point</div>
          <p>"17 days to submission. Your architect is on another pursuit. Technical volume, compliance matrix, and orals demo all need owners."</p>
        </div>
        <div class="role-line">↳ Our role: <strong>Proposal-support services under teaming letter</strong></div>
      </div>
      <div class="svc-grid">
        <div class="svc-card"><span class="nu">01</span><div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4z"></path></svg></div><div class="body"><h4>Technical volume writing</h4><p>Solution architecture, approach, and methodology sections drafted to your outline and style guide.</p></div></div>
        <div class="svc-card"><span class="nu">02</span><div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"></polyline><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path></svg></div><div class="body"><h4>Compliance matrix preparation</h4><p>Line-by-line traceability against the SOW, every statutory requirement mapped to a proposal section, owner, and evidence.</p></div></div>
        <div class="svc-card"><span class="nu">03</span><div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 17 9 11 13 15 21 7"></polyline><polyline points="14 7 21 7 21 14"></polyline></svg></div><div class="body"><h4>LOE &amp; pricing input</h4><p>Bottom-up labor estimates with optimistic/likely/pessimistic ranges. Direct-to-pricing model handoff.</p></div></div>
        <div class="svc-card"><span class="nu">04</span><div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"></rect><path d="M8 21h8M12 17v4"></path></svg></div><div class="body"><h4>Demo &amp; POC builds for orals</h4><p>Working prototypes the evaluation panel can click, not slideware. Built in 2-3 weeks, ready for orals.</p></div></div>
        <div class="svc-card"><span class="nu">05</span><div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg></div><div class="body"><h4>Past-performance packaging</h4><p>Citation writeups, CPARS-equivalent narratives, and reference letters, in your prime-branded templates.</p></div></div>
        <div class="svc-card"><span class="nu">06</span><div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="8" r="4"></circle><path d="M19 8l2 2 3-3"></path></svg></div><div class="body"><h4>Key personnel resume tailoring</h4><p>Resume edits, role mapping, and LCAT alignment for proposed staff (yours or ours, named on your roster).</p></div></div>
      </div>
    </div>

    <!-- POST-BID PANEL -->
    <div class="stage-panel" data-panel="post">
      <div class="stage-side">
        <div class="stage-tag">Phase 02 · Post-Award</div>
        <h3>Deliver the technical workstream, under your name.</h3>
        <div class="pain-card">
          <div class="pain-label">The Pain Point</div>
          <p>"Kickoff Monday. You need senior engineers in seats, a sprint cadence the agency PM trusts, and zero compliance findings. Bench is thin, ramp-up is tight."</p>
        </div>
        <div class="role-line">↳ Our role: <strong>Back-office delivery · white-label</strong></div>
      </div>
      <div class="svc-grid">
        <div class="svc-card"><span class="nu">01</span><div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg></div><div class="body"><h4>Senior engineering surge</h4><p>Named, vetted engineers, not generic resumes. Cleared resources available; team scaling 2-20 FTEs.</p></div></div>
        <div class="svc-card"><span class="nu">02</span><div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10 10 0 0 1 12 20c-7 0-10-8-10-8a18.45 18.45 0 0 1 5.06-5.94"></path><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 10 8 10 8a18.5 18.5 0 0 1-2.16 3.19"></path><path d="M14.12 14.12a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line></svg></div><div class="body"><h4>White-label delivery</h4><p>All artifacts, code, comms, docs, demos, carry your prime brand. We never appear in agency-facing channels.</p></div></div>
        <div class="svc-card"><span class="nu">03</span><div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2"></rect><path d="M16 2 v4 M8 2 v4 M3 10 h18"></path></svg></div><div class="body"><h4>Sprint delivery under your PM</h4><p>We slot into your cadence, your tooling, your Definition of Done. Weekly burndown reports to your PM only.</p></div></div>
        <div class="svc-card"><span class="nu">04</span><div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L4 6v6c0 4 3.5 8 8 10 4.5-2 8-6 8-10V6z"></path></svg></div><div class="body"><h4>Compliance posture maintained</h4><p>CJIS, HIPAA, IRS Pub 1075, StateRAMP-aligned controls applied to our work, inside your authorization boundary.</p></div></div>
        <div class="svc-card"><span class="nu">05</span><div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><path d="M14 2v6h6 M9 13h6 M9 17h4"></path></svg></div><div class="body"><h4>Documentation &amp; KT</h4><p>Living architecture docs, runbooks, and ATO artifacts. KT package delivered before each milestone close.</p></div></div>
        <div class="svc-card"><span class="nu">06</span><div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg></div><div class="body"><h4>IV&amp;V response support</h4><p>Findings remediation, audit responses, and CAP narratives, turned in your templates within SLA.</p></div></div>
      </div>
    </div>
  </div>
</section>

<!-- ONSHORE PM-LED -->
<section class="block onshore" id="onshore" data-screen-label="03 Onshore PM-led">
  <div class="wrap">
    <span class="eyebrow" style="margin-bottom: 14px; display: inline-flex; align-items: center;"><span class="gl"></span> Delivery model</span>
    <div class="onshore-head">
      <h2>Onshore PM-led. Offshore-engineered. Prime-controlled, end to end.</h2>
      <p>US-based partner manager runs the engagement. Senior engineers in Lahore build the work. Agency sees the prime; the prime sees one accountable contact.</p>
    </div>
    <div class="clock-card">
      <div class="clock-left">
        <div class="label">24-hour delivery clock</div>
        <h3>~10 hours of timezone overlap, same-day responses, overnight progress.</h3>
      </div>
      <div class="clock-right">
        <div class="clock-ruler">
          <span>12a</span><span>3a</span><span>6a</span><span>9a</span><span>12p</span><span>3p</span><span>6p</span><span>9p</span><span>12a</span>
        </div>
        <div class="clock-bars">
          <div class="clock-bar pk">PK ENG · 11A-8P PKT</div>
          <div class="clock-bar us">US PM · 9A-6P ET</div>
        </div>
        <div class="clock-footer">
          <span>← Lahore picks up overnight</span>
          <span class="mid">~10h overlap</span>
          <span>US wraps the day →</span>
        </div>
      </div>
    </div>
    <div class="concerns-grid">
      <div class="concern-card">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"></circle><path d="M12 2 v2 M12 20 v2 M4.93 4.93 l1.41 1.41 M17.66 17.66 l1.41 1.41 M2 12 h2 M20 12 h2 M4.93 19.07 l1.41 -1.41 M17.66 6.34 l1.41 -1.41"></path></svg></div>
        <div><div class="num">Concern 01</div><h4>Follow-the-sun delivery without the 3 a.m. Slack pings.</h4><div class="pain"><strong>Pain:</strong> offshore vendors that bury PMs in async messages, gap on handoffs, stall on US-hours blockers.</div><div class="fix"><strong>Our fix:</strong> US engagement manager owns daily standup. Lahore picks up overnight. ~10 hours of US/PK overlap, same-day responses.</div></div>
      </div>
      <div class="concern-card">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"></rect><path d="M7 11 V7 a5 5 0 0 1 10 0 v4"></path></svg></div>
        <div><div class="num">Concern 02</div><h4>NDA-bound from the first 30-minute call.</h4><div class="pain"><strong>Pain:</strong> capture leads who can't share the RFP or past-performance set until paperwork clears.</div><div class="fix"><strong>Our fix:</strong> Mutual NDA ready to sign before the discovery call. Sensitive details stay in encrypted channels with audit trails.</div></div>
      </div>
      <div class="concern-card">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2 H6 a2 2 0 0 0 -2 2 v16 a2 2 0 0 0 2 2 h12 a2 2 0 0 0 2 -2 V8 z"></path><path d="M14 2 v6 h6"></path><circle cx="10" cy="14" r="2"></circle><path d="M10 16 v3"></path></svg></div>
        <div><div class="num">Concern 03</div><h4>IP assigned to you on day one.</h4><div class="pain"><strong>Pain:</strong> subcontractors who keep ownership of "reusable components" and license them back, complicating government IP rights.</div><div class="fix"><strong>Our fix:</strong> Period-of-performance IP assignment baked into the teaming letter. Code and artifacts belong to the prime.</div></div>
      </div>
      <div class="concern-card">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21 v-2 a4 4 0 0 0 -4 -4 H6 a4 4 0 0 0 -4 4 v2"></path><circle cx="9" cy="8" r="4"></circle><path d="M22 11 l-3 3 l-2 -2"></path></svg></div>
        <div><div class="num">Concern 04</div><h4>Named seniors. No bait-and-switch.</h4><div class="pain"><strong>Pain:</strong> principal engineers on the proposal, junior engineers on delivery. CPARS pain that shows up at year-end review.</div><div class="fix"><strong>Our fix:</strong> Resumes you propose are the engineers who execute. Substitutions only with prime + agency approval.</div></div>
      </div>
    </div>
  </div>
</section>

<!-- OPERATING PRINCIPLES -->
<section class="block principles" data-screen-label="04 Operating principles">
  <div class="wrap">
    <div class="principles-inner">
      <div class="left">
        <span class="eyebrow">Operating Principles</span>
        <h2>How we work behind a prime.</h2>
        <p>Four non-negotiables that govern every engagement. Signed into our teaming letter so there's no ambiguity.</p>
        <div class="locked">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"></rect><path d="M7 11 V7 a5 5 0 0 1 10 0 v4"></path></svg>
          Locked in teaming letter
        </div>
      </div>
      <div class="principle-grid">
        <div class="principle"><span class="num">01</span><div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10 10 0 0 1 12 20c-7 0-10-8-10-8a18.45 18.45 0 0 1 5.06-5.94"></path><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 10 8 10 8a18.5 18.5 0 0 1-2.16 3.19"></path><path d="M14.12 14.12a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line></svg></div><h3>You stay the only voice to the agency.</h3><p>Never in agency-facing emails, calls, or deliverables. No co-logos, no "powered by" footers. If the agency asks who built it, the answer is your name.</p></div>
        <div class="principle"><span class="num">02</span><div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4z"></path></svg></div><h3>Your brand on every artifact.</h3><p>Code, docs, decks, runbooks, and dashboards ship under your prime brand. Internal IP licensed to you for the period of performance.</p></div>
        <div class="principle"><span class="num">03</span><div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 L4 6 v6 c0 4 3.5 8 8 10 c4.5 -2 8 -6 8 -10 V6 z"></path><path d="M9 12 l2 2 l4 -4"></path></svg></div><h3>Compliance posture, kept.</h3><p>We operate inside your authorization boundary. CJIS, HIPAA, IRS Pub 1075, StateRAMP-aligned controls applied to our work. Audit-ready artifacts on demand.</p></div>
