---
import type { ServiceWorkflowData } from '../../lib/types/service';
import ServiceWorkflowIcon from './ServiceWorkflowIcon.astro';

interface Props extends ServiceWorkflowData {}

const {
  steps,
  highlightColor = '#18B0E6',
} = Astro.props;

const progressWidth = steps.length <= 4 ? '30%' : '100%';
---

<div class="relative w-full">
  <div class="mx-auto flex min-h-[600px] w-full max-w-[1400px] flex-col gap-8 overflow-x-hidden px-2 py-10 md:py-16">
    <div class="relative mb-12 w-full md:mb-16">
      <div class="flex items-center gap-3 md:gap-4 lg:gap-6">
        <span class="shrink-0 font-poppins text-[20px] leading-[120%] font-normal tracking-[-0.02em] whitespace-nowrap text-[#141414] sm:text-[24px] md:text-[30px] lg:text-[36px] xl:text-[42px]">
          From idea
        </span>
        <div class="relative h-1 flex-1 overflow-hidden rounded-full bg-[#D9D9D9]">
          <div
            class="absolute top-0 left-0 h-full origin-left rounded-full"
            style={`width: ${progressWidth}; background-color: ${highlightColor};`}
          />
        </div>
        <span class="shrink-0 font-poppins text-[20px] leading-[120%] font-normal tracking-[-0.02em] whitespace-nowrap text-[#141414] sm:text-[24px] md:text-[30px] lg:text-[36px] xl:text-[42px]">
          to impact
        </span>
      </div>
    </div>

    <div class="w-full overflow-x-auto">
      <div class="flex w-full flex-row gap-4 pb-2">
        {
          steps.map((step, index) => {
            const artifacts = step.artifacts?.slice(0, 4) ?? [];
            return (
              <article class="service-workflow-card relative shrink-0" data-workflow-card>
                <div class="workflow-card-inner group relative flex min-h-[391px] max-h-[391px] flex-col justify-between overflow-hidden rounded-lg bg-[#F3F7FB] p-6 shadow-sm transition-all duration-300">
                  <div
                    class="workflow-card-bg pointer-events-none absolute top-0 right-0 h-full w-full opacity-0 transition-opacity duration-300"
                    aria-hidden="true"
                  >
                    <svg
                      width="100%"
                      height="100%"
                      viewBox="0 0 338 391"
                      fill="none"
                      xmlns="http://www.w3.org/2000/svg"
                      preserveAspectRatio="none"
                    >
                      <g opacity="0.3">
                        <g opacity="0.1">
                          <path
                            d="M44.2109 320.492L311.851 405.701L579.492 490.909L226.643 673.341L44.2109 320.492Z"
                            fill="white"
                          />
                          <path
                            d="M579.5 490.91L311.86 405.702L44.2192 320.493L397.068 138.061L579.5 490.91Z"
                            fill="white"
                          />
                        </g>
                      </g>
                    </svg>
                  </div>

                  <div
                    class="workflow-card-icon relative z-10 mb-4 shrink-0 transition-colors duration-300"
                    style={`color: ${highlightColor}`}
                  >
                    <ServiceWorkflowIcon index={index} class="size-8" />
                  </div>

                  <div class="relative z-10 flex flex-col transition-all duration-300">
                    <h3 class="workflow-step-title text-[35px] leading-[120%] font-semibold tracking-[-0.02em] text-[#0A0C0D] transition-colors duration-300 md:text-[40px]">
                      {step.title}
                    </h3>
                    <p class="workflow-step-desc mt-3 text-[16px] leading-[130%] font-normal text-[#838383] transition-colors duration-300">
                      {step.description}
                    </p>
                    {artifacts.length > 0 && (
                      <div class="workflow-artifacts relative z-10 mt-5 max-h-0 overflow-hidden opacity-0 transition-all duration-700">
                        <p class="workflow-artifacts-label text-[16px] leading-[130%] font-normal text-[#0A0C0D]">
                          {step.subtitle || 'Artifacts'}
                        </p>
                        <div class="mt-2 flex flex-wrap gap-2">
                          {artifacts.map((artifact) => (
                            <span class="rounded-[2px] bg-[#FFFFFF4D] px-1.5 py-1.5 text-[12px] leading-[130%] font-normal text-white">
                              {artifact}
                            </span>
                          ))}
                        </div>
                      </div>
                    )}
                  </div>
                </div>
              </article>
            );
          })
        }
      </div>
    </div>
  </div>
</div>
