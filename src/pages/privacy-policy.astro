---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/shared/Header.astro";
import Footer from "../components/shared/Footer.astro";
import PrivacyPolicyContent from "../components/legal/PrivacyPolicyContent.astro";
import { PRIVACY_POLICY_SEO } from "../lib/constants/pages/privacy-policy";

const { title, description, canonicalPath } = PRIVACY_POLICY_SEO;
---

<BaseLayout {title} {description} {canonicalPath}>
  <Header />
  <main id="main-content" class="bg-white">
    <PrivacyPolicyContent />
  </main>
  <Footer />
</BaseLayout>
