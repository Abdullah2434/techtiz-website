---
import SledLayout from '../../layouts/SledLayout.astro';
import Eyebrow from '../../components/shared/Eyebrow.astro';
import CtaButton from '../../components/shared/CtaButton.astro';
import {
  CONTACT_SEO, CONTACT_HERO, SLA_ITEMS, WHAT_HAPPENS_NEXT, INTENT_OPTIONS,
  ROLE_OPTIONS, VEHICLE_OPTIONS, TIMING_OPTIONS, CEILING_OPTIONS, CLEARANCE_OPTIONS
} from '../../lib/constants/pages/contact';
import { SITE } from '../../lib/constants/site';

const { title, description, canonicalPath, ogImage } = CONTACT_SEO;
---

<SledLayout {title} {description} {canonicalPath} {ogImage} currentPage="/us-sled/contact/">

<!-- SLA STRIP -->
<section class="border-b border-line bg-white py-4">
  <div class="mx-auto max-w-[1280px] px-12 max-[1024px]:px-8 max-[900px]:px-6 max-[600px]:px-[18px] flex flex-wrap items-center gap-x-5 gap-y-2">
    <span class="shrink-0 font-mono text-[10.5px] font-bold tracking-[0.18em] uppercase text-cyan-strong">
      Our commitment to primes
    </span>
    {SLA_ITEMS.map(item => (
      <span class="inline-flex items-center gap-2 text-[13.5px] leading-[1.55] text-muted">
        <span class="inline-block size-2 rotate-15 bg-cyan" aria-hidden="true"></span>
        {item}
      </span>
    ))}
  </div>
</section>

<!-- FORM -->
<section class="bg-seasalt py-20">
  <div class="mx-auto max-w-[1280px] px-12 max-[1024px]:px-8 max-[900px]:px-6 max-[600px]:px-[18px]">
    <div class="grid grid-cols-[1.25fr_0.9fr] gap-10 items-start max-[1024px]:grid-cols-1">

      <!-- LEFT -->
      <div>
        <div class="mb-8 max-w-[860px]">
          <Eyebrow text={CONTACT_HERO.eyebrow} showGlyph />
          <h1 class="mt-4 text-[48px] font-extrabold leading-[1.05] tracking-[-0.022em] text-yale-dark" set:html={CONTACT_HERO.heading} />
          <p class="mt-3.5 text-[15.5px] leading-relaxed text-muted">{CONTACT_HERO.desc}</p>
        </div>

        <form class="rounded-2xl border border-line bg-white p-8 shadow-[0_18px_48px_-34px_rgba(14,38,64,0.30)]" id="intakeForm" novalidate>

          <div class="font-mono text-[10.5px] font-bold tracking-[0.18em] text-cyan-strong uppercase">Section 01</div>
          <div class="mt-2 text-[18px] font-extrabold text-yale-dark">About you</div>

          <div class="mt-6 grid grid-cols-2 gap-5 max-[720px]:grid-cols-1">
            <div>
              <label for="name" class="block text-[13.5px] font-semibold text-yale-dark">Full name <span class="text-amber">*</span></label>
              <input id="name" name="name" type="text" placeholder="Jane Doe" required class="mt-2 w-full rounded-xl border border-line bg-white px-4 py-3 text-[14px] text-ink outline-none transition-[border-color,box-shadow] duration-180 ease-out focus:border-yale focus:shadow-[0_0_0_4px_rgba(14,38,64,0.08)]" />
            </div>
            <div>
              <label for="email" class="block text-[13.5px] font-semibold text-yale-dark">Work email <span class="text-amber">*</span></label>
              <input id="email" name="email" type="email" placeholder="jane@firm.com" required class="mt-2 w-full rounded-xl border border-line bg-white px-4 py-3 text-[14px] text-ink outline-none transition-[border-color,box-shadow] duration-180 ease-out focus:border-yale focus:shadow-[0_0_0_4px_rgba(14,38,64,0.08)]" />
            </div>
          </div>

          <div class="mt-5 grid grid-cols-2 gap-5 max-[720px]:grid-cols-1">
            <div>
              <label for="firm" class="block text-[13.5px] font-semibold text-yale-dark">Prime firm name <span class="text-amber">*</span></label>
              <input id="firm" name="firm" type="text" placeholder="e.g. National Environmental Consulting LLP" required class="mt-2 w-full rounded-xl border border-line bg-white px-4 py-3 text-[14px] text-ink outline-none transition-[border-color,box-shadow] duration-180 ease-out focus:border-yale focus:shadow-[0_0_0_4px_rgba(14,38,64,0.08)]" />
            </div>
            <div>
              <label for="role" class="block text-[13.5px] font-semibold text-yale-dark">Your role</label>
              <select id="role" name="role" class="mt-2 w-full rounded-xl border border-line bg-white px-4 py-3 text-[14px] text-ink outline-none transition-[border-color,box-shadow] duration-180 ease-out focus:border-yale focus:shadow-[0_0_0_4px_rgba(14,38,64,0.08)]">
                {ROLE_OPTIONS.map(opt => <option>{opt}</option>)}
              </select>
            </div>
          </div>

          <div class="my-8 h-px bg-line"></div>
          <div class="font-mono text-[10.5px] font-bold tracking-[0.18em] text-cyan-strong uppercase">Section 02</div>
          <div class="mt-2 text-[18px] font-extrabold text-yale-dark">About the engagement</div>

          <div class="mt-6 grid grid-cols-2 gap-5 max-[720px]:grid-cols-1">
            <div>
              <label for="vehicle" class="block text-[13.5px] font-semibold text-yale-dark">Contract vehicle <span class="font-normal text-muted">(if known)</span></label>
              <select id="vehicle" name="vehicle" class="mt-2 w-full rounded-xl border border-line bg-white px-4 py-3 text-[14px] text-ink outline-none transition-[border-color,box-shadow] duration-180 ease-out focus:border-yale focus:shadow-[0_0_0_4px_rgba(14,38,64,0.08)]">
                {VEHICLE_OPTIONS.map(opt => <option>{opt}</option>)}
              </select>
            </div>
            <div>
              <label for="timing" class="block text-[13.5px] font-semibold text-yale-dark">Engagement timing</label>
              <select id="timing" name="timing" class="mt-2 w-full rounded-xl border border-line bg-white px-4 py-3 text-[14px] text-ink outline-none transition-[border-color,box-shadow] duration-180 ease-out focus:border-yale focus:shadow-[0_0_0_4px_rgba(14,38,64,0.08)]">
                {TIMING_OPTIONS.map(opt => <option>{opt}</option>)}
              </select>
            </div>
          </div>

          <div class="mt-5 grid grid-cols-2 gap-5 max-[720px]:grid-cols-1">
            <div>
              <label for="solicitation" class="block text-[13.5px] font-semibold text-yale-dark">Solicitation / RFP number <span class="font-normal text-muted">(optional)</span></label>
              <input id="solicitation" name="solicitation" type="text" placeholder="e.g. RFP-2026-0142" class="mt-2 w-full rounded-xl border border-line bg-white px-4 py-3 text-[14px] text-ink outline-none transition-[border-color,box-shadow] duration-180 ease-out focus:border-yale focus:shadow-[0_0_0_4px_rgba(14,38,64,0.08)]" />
            </div>
            <div>
              <label for="ceiling" class="block text-[13.5px] font-semibold text-yale-dark">Estimated contract ceiling <span class="font-normal text-muted">(optional)</span></label>
              <select id="ceiling" name="ceiling" class="mt-2 w-full rounded-xl border border-line bg-white px-4 py-3 text-[14px] text-ink outline-none transition-[border-color,box-shadow] duration-180 ease-out focus:border-yale focus:shadow-[0_0_0_4px_rgba(14,38,64,0.08)]">
                {CEILING_OPTIONS.map(opt => <option>{opt}</option>)}
              </select>
            </div>
          </div>

          <div class="mt-5 grid grid-cols-2 gap-5 max-[720px]:grid-cols-1">
            <div>
              <label for="clearance" class="block text-[13.5px] font-semibold text-yale-dark">Security clearance required <span class="font-normal text-muted">(optional)</span></label>
              <select id="clearance" name="clearance" class="mt-2 w-full rounded-xl border border-line bg-white px-4 py-3 text-[14px] text-ink outline-none transition-[border-color,box-shadow] duration-180 ease-out focus:border-yale focus:shadow-[0_0_0_4px_rgba(14,38,64,0.08)]">
                {CLEARANCE_OPTIONS.map(opt => <option>{opt}</option>)}
              </select>
            </div>
            <div aria-hidden="true"></div>
          </div>

          <div class="mt-5">
            <label for="desc" class="block text-[13.5px] font-semibold text-yale-dark">Brief description</label>
            <textarea id="desc" name="desc" placeholder="What's the engagement type? Subcontract under a master? Teaming letter in place or imminent? What technical surface area are you looking to staff?" class="mt-2 min-h-[120px] w-full resize-y rounded-xl border border-line bg-white px-4 py-3 text-[14px] text-ink outline-none transition-[border-color,box-shadow] duration-180 ease-out focus:border-yale focus:shadow-[0_0_0_4px_rgba(14,38,64,0.08)]"></textarea>
          </div>

          <div class="my-8 h-px bg-line"></div>
          <div class="font-mono text-[10.5px] font-bold tracking-[0.18em] text-cyan-strong uppercase">Section 03</div>
          <div class="mt-2 text-[18px] font-extrabold text-yale-dark">What you'd like from us</div>

          <div class="mt-6 grid grid-cols-2 gap-4 max-[720px]:grid-cols-1">
            {INTENT_OPTIONS.map((opt, i) => (
              <label
                class:list={[
                  'intent-option group cursor-pointer rounded-2xl border border-line bg-white p-5 transition-[border-color,background,transform,box-shadow] duration-180 ease-out hover:-translate-y-px hover:shadow-[0_16px_40px_-30px_rgba(14,38,64,0.28)] group-[.on]:border-yale group-[.on]:bg-seasalt',
                  { on: i === 0 },
                ]}
              >
                <input type="radio" name="intent" value={opt.value} checked={i === 0} class="sr-only" />
                <div class="flex items-start gap-3">
                  <span class="mt-1 grid size-5 shrink-0 place-items-center rounded-full border border-line bg-white">
                    <span class="hidden size-2 rounded-full bg-cyan group-[.on]:block" aria-hidden="true"></span>
                  </span>
                  <span>
                    <span class="l block text-[14.5px] font-extrabold leading-tight text-yale-dark">{opt.label}</span>
                    <span class="d mt-1 block text-[13.5px] leading-[1.55] text-muted">{opt.desc}</span>
                  </span>
                </div>
              </label>
            ))}
          </div>

          <div class="mt-7 flex flex-wrap items-center justify-between gap-4 border-t border-line pt-6">
            <div class="text-[13.5px] leading-[1.55] text-muted">All fields are confidential. NDA on request before review.</div>
            <button type="submit" class="inline-flex items-center justify-center gap-2.5 rounded-lg bg-yale px-6 py-3 text-sm font-bold text-white transition-[transform,background,box-shadow] duration-180 ease-out hover:-translate-y-px hover:bg-yale-dark hover:shadow-[0_16px_40px_-30px_rgba(14,38,64,0.38)]">
              Send to Techtiz <span aria-hidden="true">→</span>
            </button>
          </div>
        </form>

        <div class="hidden rounded-2xl border border-line bg-white px-10 py-14 text-center shadow-[0_18px_48px_-34px_rgba(14,38,64,0.30)] [&.is-visible]:block" id="formSuccess" role="status">
          <div class="mx-auto mb-[22px] grid size-14 place-items-center rounded-full bg-cyan-soft">
            <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="var(--cyan-strong)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7"></path></svg>
          </div>
          <h3 class="mb-2.5 text-2xl">Your inquiry is ready to send.</h3>
          <p class="mx-auto mb-6 max-w-[420px] text-[15px] leading-[1.55] text-muted">Your email client should have opened a pre-filled message to <strong class="text-yale">sled@techtiz.co</strong>. If it didn't, copy your details into an email to that address — we reply within one business day with a mutual NDA template.</p>
          <a id="formReset" href="#" class="inline-flex items-center justify-center rounded-lg border border-line bg-white px-5 py-3 text-sm font-bold text-yale transition-[border-color,background,color] duration-180 ease-out hover:border-yale hover:bg-seasalt">
            Submit another inquiry
          </a>
        </div>
      </div>

      <!-- RIGHT -->
      <aside>
        <div class="rounded-2xl border border-line bg-white p-6 shadow-[0_18px_48px_-34px_rgba(14,38,64,0.30)]">
          <div class="font-mono text-[10.5px] font-bold tracking-[0.18em] text-cyan-strong uppercase">What happens next</div>
          <h2 class="mt-3 text-[22px] font-extrabold leading-tight text-yale-dark">Three steps. Two of them are ours.</h2>
          <div class="mt-5 space-y-3.5">
            {WHAT_HAPPENS_NEXT.map(step => (
              <div class="flex gap-3 rounded-xl border border-line bg-seasalt p-4">
                <div class="grid size-10 shrink-0 place-items-center rounded-xl bg-white text-yale-dark">
                  <span class="font-mono text-[14px] font-extrabold">{step.n}</span>
                </div>
                <div class="text-[13.5px] leading-[1.55] text-muted">
                  <em class="block not-italic font-semibold text-yale-dark">{step.timing}</em>
                  {step.text}
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="mt-6 rounded-2xl border border-line bg-white p-6 shadow-[0_18px_48px_-34px_rgba(14,38,64,0.30)]">
          <div class="font-mono text-[10.5px] font-bold tracking-[0.18em] text-cyan-strong uppercase">Or skip the form</div>
          <h3 class="mt-3 text-[18px] font-extrabold leading-tight text-yale-dark">Email the SLED desk directly.</h3>
          <p class="mt-2 text-[13.5px] leading-[1.55] text-muted">If you'd rather start with a short email, send a one-line description of the engagement type and your role. Our U.S.-based partner manager routes it from there, usually within one business day.</p>
          <a class="mt-4 inline-flex items-center gap-2 rounded-xl border border-line bg-seasalt px-4 py-3 text-[14px] font-semibold text-yale transition-colors duration-180 ease-out hover:text-yale-dark" href={`mailto:${SITE.email.sled}`}>
            <svg class="size-4 opacity-70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            {SITE.email.sled}
          </a>
        </div>
      </aside>

    </div>
  </div>
</section>

</SledLayout>


<script>
  document.querySelectorAll('.intent-option').forEach(opt => {
    opt.addEventListener('click', () => {
      document.querySelectorAll('.intent-option').forEach(o => o.classList.remove('on'));
      opt.classList.add('on');
      const input = opt.querySelector('input') as HTMLInputElement;
      if(input) input.checked = true;
    });
  });

  (function() {
    const form = document.getElementById('intakeForm') as HTMLFormElement;
    const success = document.getElementById('formSuccess');
    if(!form) return;
    function val(id: string) { const el = document.getElementById(id) as HTMLInputElement; return el ? el.value.trim() : ''; }
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      let ok = true;
      ['name','email','firm'].forEach(function(id) {
        const el = document.getElementById(id) as HTMLInputElement;
        if(el && !el.value.trim()) { el.style.borderColor = 'var(--amber)'; ok = false; }
        else if(el) { el.style.borderColor = ''; }
      });
      if(!ok) return;
      const intentEl = form.querySelector('input[name="intent"]:checked');
      const intent = intentEl ? (intentEl.closest('.intent-option')?.querySelector('.l') as HTMLElement)?.textContent?.trim() : '—';
      const lines = [
        'U.S. SLED subcontract inquiry', '',
        'Name:        ' + val('name'),
        'Work email:  ' + val('email'),
        'Prime firm:  ' + val('firm'),
        'Role:        ' + val('role'),
        'Vehicle:     ' + val('vehicle'),
        'Timing:      ' + val('timing'),
        'Solicitation: ' + (val('solicitation') || '(not provided)'),
        'Ceiling:     ' + val('ceiling'),
        'Clearance:   ' + val('clearance'),
        'Requesting:  ' + intent,
        '', 'Description:', (val('desc') || '(none provided)')
      ];
      const subject = 'SLED subcontract inquiry — ' + (val('firm') || 'prime contractor');
      window.location.href = 'mailto:sled@techtiz.co?subject=' + encodeURIComponent(subject) + '&body=' + encodeURIComponent(lines.join('\n'));
      form.classList.add('hidden');
      if(success) {
        success.classList.add('is-visible');
        const y = success.getBoundingClientRect().top + window.scrollY - 140;
        window.scrollTo({ top: Math.max(0, y), behavior: 'smooth' });
      }
    });
    const reset = document.getElementById('formReset');
    if(reset) reset.addEventListener('click', function(e) {
      e.preventDefault();
      if(success) success.classList.remove('is-visible');
      form.reset();
      form.classList.remove('hidden');
    });
  })();
</script>
