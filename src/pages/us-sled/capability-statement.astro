---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE } from '../../lib/constants/site';

const seo = {
  title: 'Capability Statement | Techtiz · U.S. SLED Subcontractor',
  description: 'Techtiz capability statement for U.S. SLED prime contractors — core competencies, differentiators, codes, and contact. NDA-first, subcontract-only.',
  canonicalPath: '/us-sled/capability-statement/',
  ogImage: '/assets/logo.svg',
};
---

<BaseLayout {...seo}>

<div class="bg-seasalt py-8 print:bg-white print:py-0">
  <div class="mx-auto max-w-[980px] px-12 max-[1024px]:px-8 max-[900px]:px-6 max-[600px]:px-[18px] print:hidden">
    <div class="flex flex-wrap items-center justify-between gap-3 rounded-2xl border border-line bg-white px-5 py-4">
      <span class="font-mono text-[11px] font-bold tracking-[0.14em] uppercase text-muted">
        Capability Statement · pre-deploy draft
      </span>
      <div class="flex flex-wrap items-center gap-3">
        <a href="/us-sled/" class="text-[13.5px] font-semibold text-yale hover:text-yale-dark">← Back to SLED hub</a>
        <button
          class="inline-flex items-center justify-center rounded-lg bg-yale px-4 py-2.5 text-[13.5px] font-bold text-white transition-[transform,background,box-shadow] duration-180 ease-out hover:-translate-y-px hover:bg-yale-dark hover:shadow-[0_16px_40px_-30px_rgba(14,38,64,0.35)]"
          type="button"
          onclick="window.print()"
        >
          Save / print as PDF
        </button>
      </div>
    </div>
  </div>

  <div class="mx-auto mt-6 max-w-[980px] px-12 max-[1024px]:px-8 max-[900px]:px-6 max-[600px]:px-[18px] print:mt-0 print:max-w-none print:px-0">
    <div class="rounded-2xl border border-line bg-white p-10 shadow-[0_22px_60px_-46px_rgba(14,38,64,0.35)] print:rounded-none print:border-0 print:p-0 print:shadow-none">

  <!-- HEADER -->
      <div class="grid grid-cols-[1fr_320px] gap-8 items-start max-[900px]:grid-cols-1">
        <div>
          <img src={SITE.logo.dark} alt="Techtiz" class="h-[30px] w-auto" />
          <h1 class="mt-4 text-[34px] font-extrabold leading-[1.12] tracking-[-0.02em] text-yale-dark">
            U.S. SLED Technical Subcontractor
          </h1>
          <p class="mt-3 text-[14px] leading-[1.55] text-muted">
            Back-office engineering for state, local, and education prime contractors. NDA-first. Subcontract-only. We never face the agency.
          </p>
        </div>

        <div class="rounded-2xl border border-line bg-seasalt p-5">
          <div class="grid grid-cols-[1fr_auto] gap-x-4 gap-y-2 text-[13px]">
            <span class="font-mono text-[10px] font-bold tracking-[0.14em] uppercase text-cyan-strong">SAM.gov UEI</span>
            <span class="italic text-muted">add UEI</span>
            <span class="font-mono text-[10px] font-bold tracking-[0.14em] uppercase text-cyan-strong">CAGE Code</span>
            <span class="italic text-muted">add CAGE</span>
            <span class="font-mono text-[10px] font-bold tracking-[0.14em] uppercase text-cyan-strong">Business size</span>
            <span class="italic text-muted">confirm size</span>
          </div>
        </div>
      </div>

  <!-- INTRO -->
      <h2 class="mt-10 border-t border-line pt-8 font-mono text-[11px] font-bold tracking-[0.18em] uppercase text-yale-dark">Company snapshot</h2>
      <p class="mt-3 text-[14px] leading-[1.65] text-muted">
        Techtiz is an AI-native engineering studio that delivers specialized technical workstreams to U.S. SLED prime contractors under subcontract and NDA. We integrate into a prime's master subcontract as a white-labeled delivery team — writing technical volumes and building demos pre-award, and shipping engineering post-award — while the prime remains the sole face to the agency. Delivery is onshore-controlled and offshore-engineered across three time zones for follow-the-sun coverage.
      </p>

  <!-- CORE COMPETENCIES -->
      <h2 class="mt-10 font-mono text-[11px] font-bold tracking-[0.18em] uppercase text-yale-dark">Core competencies</h2>
      <ul class="mt-4 grid grid-cols-2 gap-x-8 gap-y-2 text-[13.5px] leading-[1.55] text-muted max-[720px]:grid-cols-1">
        <li><strong class="text-yale-dark">GIS &amp; spatial systems</strong> — mapping, ETL, statutory geospatial reporting</li>
        <li><strong class="text-yale-dark">AI &amp; intelligence</strong> — LLM/RAG systems, agents, ML pipelines in production</li>
        <li><strong class="text-yale-dark">Workflow automation</strong> — RPA, integrations, internal tooling</li>
        <li><strong class="text-yale-dark">Statutory document production</strong> — compliant, format-controlled output at volume</li>
        <li><strong class="text-yale-dark">Grant &amp; compliance reporting</strong> — on-deadline, zero-deficiency reporting</li>
        <li><strong class="text-yale-dark">Platform modernization</strong> — legacy migration without halting operations</li>
        <li><strong class="text-yale-dark">Pre-award proposal support</strong> — technical volumes, compliance matrices, orals demos</li>
        <li><strong class="text-yale-dark">Post-award delivery</strong> — engineers, sprints, KT, integration under your SOW</li>
      </ul>

  <!-- DIFFERENTIATORS -->
      <h2 class="mt-10 font-mono text-[11px] font-bold tracking-[0.18em] uppercase text-yale-dark">Differentiators</h2>
      <div class="mt-4 grid grid-cols-2 gap-5 max-[720px]:grid-cols-1">
        <div class="rounded-2xl border border-line bg-seasalt p-5"><h4 class="text-[14px] font-extrabold text-yale-dark">NDA-first, subcontract-only</h4><p class="mt-2 text-[13.5px] leading-[1.55] text-muted">A mutual NDA precedes any substantive exchange. We contract under the prime's terms and never engage the agency directly.</p></div>
        <div class="rounded-2xl border border-line bg-seasalt p-5"><h4 class="text-[14px] font-extrabold text-yale-dark">Onshore-controlled architecture</h4><p class="mt-2 text-[13.5px] leading-[1.55] text-muted">CONUS/Lahore air-gap, CJIS/CUI/FCI/FTI handling, background-checked U.S. personnel, per-state offshore restrictions.</p></div>
        <div class="rounded-2xl border border-line bg-seasalt p-5"><h4 class="text-[14px] font-extrabold text-yale-dark">Follow-the-sun delivery</h4><p class="mt-2 text-[13.5px] leading-[1.55] text-muted">Three-time-zone coverage compresses proposal and delivery cycles when the bench is thin.</p></div>
        <div class="rounded-2xl border border-line bg-seasalt p-5"><h4 class="text-[14px] font-extrabold text-yale-dark">Senior-led, plug-in ready</h4><p class="mt-2 text-[13.5px] leading-[1.55] text-muted">Specialized engineers and statutory-format expertise on hand, deployable inside a master subcontract.</p></div>
      </div>

  <!-- COMPLIANCE -->
      <h2 class="mt-10 font-mono text-[11px] font-bold tracking-[0.18em] uppercase text-yale-dark">Compliance &amp; security posture</h2>
      <div class="mt-4 flex flex-wrap gap-2">
        <span class="rounded-full border border-line bg-seasalt px-3 py-1 text-[12.5px] font-medium text-muted">NIST SP 800-171</span>
        <span class="rounded-full border border-line bg-seasalt px-3 py-1 text-[12.5px] font-medium text-muted">SOC 2</span>
        <span class="rounded-full border border-line bg-seasalt px-3 py-1 text-[12.5px] font-medium text-muted">StateRAMP</span>
        <span class="rounded-full border border-line bg-seasalt px-3 py-1 text-[12.5px] font-medium text-muted">CJIS</span>
        <span class="rounded-full border border-line bg-seasalt px-3 py-1 text-[12.5px] font-medium text-muted">Section 508 / VPAT</span>
        <span class="rounded-full border border-line bg-seasalt px-3 py-1 text-[12.5px] font-medium text-muted">CMMC</span>
        <span class="rounded-full border border-line bg-seasalt px-3 py-1 text-[12.5px] font-medium text-muted">HIPAA</span>
        <span class="rounded-full border border-line bg-seasalt px-3 py-1 text-[12.5px] font-medium text-muted">IRS Pub 1075</span>
      </div>

  <!-- PAST PERFORMANCE -->
      <h2 class="mt-10 font-mono text-[11px] font-bold tracking-[0.18em] uppercase text-yale-dark">
        Representative delivery <span class="font-sans text-[11px] font-medium tracking-normal text-muted normal-case">— summarized under NDA; partner names withheld</span>
      </h2>
      <div class="mt-4 grid grid-cols-3 gap-5 max-[720px]:grid-cols-1">
        <div class="rounded-2xl border border-line bg-seasalt p-5"><div class="font-mono text-[20px] font-extrabold text-yale-dark">35 / 35</div><div class="mt-2 text-[13.5px] leading-[1.55] text-muted">municipalities onboarded to a statewide platform rollout</div></div>
        <div class="rounded-2xl border border-line bg-seasalt p-5"><div class="font-mono text-[20px] font-extrabold text-yale-dark">0</div><div class="mt-2 text-[13.5px] leading-[1.55] text-muted">EGLE statutory format deficiencies across submitted filings</div></div>
        <div class="rounded-2xl border border-line bg-seasalt p-5"><div class="font-mono text-[20px] font-extrabold text-yale-dark">0</div><div class="mt-2 text-[13.5px] leading-[1.55] text-muted">late grant reports across the reporting cycle</div></div>
      </div>

  <!-- FOOTER -->
      <div class="mt-10 grid grid-cols-[1fr_320px] gap-8 border-t border-line pt-8 max-[900px]:grid-cols-1">
        <div>
          <h2 class="font-mono text-[11px] font-bold tracking-[0.18em] uppercase text-yale-dark">Codes &amp; classifications</h2>
          <div class="mt-4 grid gap-2 text-[13.5px] text-muted">
            <div class="grid grid-cols-[160px_1fr] gap-3"><span class="font-mono text-[10px] font-bold tracking-[0.14em] uppercase text-cyan-strong">NAICS</span><span>541511 · 541512</span></div>
            <div class="grid grid-cols-[160px_1fr] gap-3"><span class="font-mono text-[10px] font-bold tracking-[0.14em] uppercase text-cyan-strong">NIGP</span><span>918-46 · 918-00</span></div>
            <div class="grid grid-cols-[160px_1fr] gap-3"><span class="font-mono text-[10px] font-bold tracking-[0.14em] uppercase text-cyan-strong">SAM.gov UEI</span><span class="italic">add UEI</span></div>
            <div class="grid grid-cols-[160px_1fr] gap-3"><span class="font-mono text-[10px] font-bold tracking-[0.14em] uppercase text-cyan-strong">CAGE Code</span><span class="italic">add CAGE</span></div>
            <div class="grid grid-cols-[160px_1fr] gap-3"><span class="font-mono text-[10px] font-bold tracking-[0.14em] uppercase text-cyan-strong">Set-aside / size</span><span class="italic">confirm</span></div>
            <div class="grid grid-cols-[160px_1fr] gap-3"><span class="font-mono text-[10px] font-bold tracking-[0.14em] uppercase text-cyan-strong">Insurance</span><span>Prime-routed</span></div>
          </div>
        </div>
        <div class="rounded-2xl border border-line bg-seasalt p-5">
          <div class="font-mono text-[11px] font-bold tracking-[0.18em] uppercase text-yale-dark">Teaming contact</div>
          <div class="mt-3 text-[13.5px] leading-[1.6] text-muted">
            <strong class="text-yale-dark">Techtiz — SLED Partnerships</strong><br/>
            <a href={`mailto:${SITE.email.sled}`} class="font-semibold text-yale hover:text-yale-dark">{SITE.email.sled}</a><br/>
            Reply within 1 business day<br/>
            Lahore HQ · U.S. office
          </div>
        </div>
      </div>

      <p class="mt-8 rounded-2xl border border-line bg-seasalt p-5 text-[12.5px] leading-[1.55] text-muted">
        Pre-deploy draft. Italicized fields (UEI, CAGE, set-aside / size) are placeholders to confirm against SAM.gov before this statement is distributed. Compliance frameworks reflect current posture; confirm certification vs. roadmap status per framework before claiming.
      </p>

    </div>
  </div>
</div>

</BaseLayout>

