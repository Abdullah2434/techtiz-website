---
import { HUB_INQUIRY } from '../../lib/constants/pages/sled-hub';
import { SITE } from '../../lib/constants/site';
import Eyebrow from '../shared/Eyebrow.astro';
import SledPageWrap from './SledPageWrap.astro';

const inputClass =
  'w-full rounded-xl border border-line bg-white px-4 py-3.5 text-[14.5px] text-ink outline-none transition-[border-color,box-shadow,transform] duration-200 ease-out placeholder:text-[#9AA4B2] focus:border-cyan focus:shadow-[0_0_0_3px_rgba(24,176,230,0.18)] focus:-translate-y-px';
---

<section class="sled-section bg-seasalt" id="inquiry" data-screen-label="10 Inquiry form">
  <SledPageWrap>
    <div
      class="sled-reveal grid grid-cols-1 overflow-hidden rounded-2xl border border-line bg-white shadow-[0_32px_64px_-28px_rgba(14,38,64,0.22)] lg:grid-cols-[0.85fr_1.4fr]"
      data-sled-reveal
    >
      <aside class="relative overflow-hidden bg-yale-dark px-10 py-12 text-white max-[900px]:px-8 lg:px-12 lg:py-14">
        <div
          class="pointer-events-none absolute -bottom-10 -right-10 size-[240px] [background:repeating-linear-gradient(0deg,transparent_0_26px,rgba(24,176,230,0.06)_26px_27px),repeating-linear-gradient(90deg,transparent_0_26px,rgba(24,176,230,0.06)_26px_27px)]"
          aria-hidden="true"
        ></div>
        <div
          class="sled-hero-glow-a pointer-events-none absolute top-[-20%] left-[-15%] size-[200px] rounded-full bg-[radial-gradient(circle,rgba(24,176,230,0.2)_0%,transparent_70%)] blur-[60px] motion-reduce:hidden"
          aria-hidden="true"
        ></div>
        <div class="relative z-[2]">
          <Eyebrow text={HUB_INQUIRY.aside.eyebrow} onDark showGlyph class="mb-5" />
          <h2 class="mb-6 text-[clamp(1.75rem,3.5vw,2.375rem)] leading-[1.08] font-extrabold text-white">{HUB_INQUIRY.aside.heading}</h2>
          <p class="mb-8 text-[14.5px] leading-[1.68] text-white/82">{HUB_INQUIRY.aside.body}</p>
          <ul class="flex flex-col gap-4">
            {HUB_INQUIRY.aside.bullets.map((bullet) => (
              <li class="flex items-start gap-3 text-[14px] leading-[1.5] text-white/95">
                <svg class="mt-0.5 size-[18px] shrink-0 text-cyan" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"></circle><path d="M8 12 l2.5 2.5 L16 9"></path></svg>
                {bullet}
              </li>
            ))}
          </ul>
        </div>
      </aside>

      <form class="flex flex-col gap-6 px-10 py-10 max-[900px]:px-8 lg:px-12 lg:py-12" id="sledInquiryForm" novalidate>
        <div>
          <label class="mb-2.5 block font-mono text-[10.5px] tracking-[0.14em] uppercase text-muted">
            What do you need help with? <span class="text-cyan-strong">*</span>
          </label>
          <div class="grid grid-cols-1 gap-3.5 lg:grid-cols-2">
            {HUB_INQUIRY.needOptions.map((opt) => (
              <div
                data-sled-need-card
                class:list={[
                  'sled-need-card relative grid cursor-pointer grid-cols-[40px_1fr_20px] items-center gap-3 rounded-xl border border-line p-4 px-5',
                  opt.defaultOn && 'is-selected border-cyan bg-cyan-soft',
                ]}
                data-need={opt.id}
              >
                <div class="grid size-10 place-items-center rounded-lg bg-seasalt text-yale-dark">
                  {opt.id === 'pre' ? (
                    <svg class="size-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
                  ) : (
                    <svg class="size-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4.5 16.5 L3 21 l4.5 -1.5 M14 6 l4 4 -8 8 -4 0 0 -4 z"></path></svg>
                  )}
                </div>
                <div>
                  <h5 class="mb-0.5 text-[14.5px] font-bold text-yale-dark" data-sled-need-label>{opt.label}</h5>
                  <p class="m-0 font-mono text-[10.5px] tracking-[0.10em] uppercase text-muted">{opt.desc}</p>
                </div>
                <div class="sled-need-check relative size-[18px] rounded border-[1.5px] border-line transition-[border-color,background] duration-200 ease-out"></div>
              </div>
            ))}
          </div>
        </div>

        <div class="grid grid-cols-1 gap-4 lg:grid-cols-2">
          <div>
            <label class="mb-2 block font-mono text-[10.5px] tracking-[0.14em] uppercase text-muted" for="sled-iq-company">
              Company <span class="text-cyan-strong">*</span>
            </label>
            <input class={inputClass} type="text" id="sled-iq-company" name="company" placeholder="Prime contractor name" required />
          </div>
          <div>
            <label class="mb-2 block font-mono text-[10.5px] tracking-[0.14em] uppercase text-muted" for="sled-iq-role">Your role</label>
            <input class={inputClass} type="text" id="sled-iq-role" name="role" placeholder="e.g. Capture Manager, Delivery Lead" />
          </div>
        </div>

        <div class="grid grid-cols-1 gap-4 lg:grid-cols-2">
          <div>
            <label class="mb-2 block font-mono text-[10.5px] tracking-[0.14em] uppercase text-muted" for="sled-iq-rfp">
              {HUB_INQUIRY.form.rfpLabel}
            </label>
            <input
              class={inputClass}
              type="text"
              id="sled-iq-rfp"
              name="rfp"
              placeholder={HUB_INQUIRY.form.rfpPlaceholder}
            />
          </div>
          <div>
            <label class="mb-2 block font-mono text-[10.5px] tracking-[0.14em] uppercase text-muted" for="sled-iq-nda">
              {HUB_INQUIRY.form.ndaLabel}
            </label>
            <select class={inputClass} id="sled-iq-nda" name="nda">
              <option value="">{HUB_INQUIRY.form.ndaPlaceholder}</option>
              {HUB_INQUIRY.form.ndaOptions.map((opt) => <option>{opt}</option>)}
            </select>
          </div>
        </div>

        <div class="grid grid-cols-1 gap-4 lg:grid-cols-2">
          <div>
            <label class="mb-2 block font-mono text-[10.5px] tracking-[0.14em] uppercase text-muted" for="sled-iq-vehicle">Contract vehicle</label>
            <select class={inputClass} id="sled-iq-vehicle" name="vehicle">
              <option value="">Select…</option>
              {HUB_INQUIRY.vehicleOptions.map((v) => <option>{v}</option>)}
            </select>
          </div>
          <div>
            <label class="mb-2 block font-mono text-[10.5px] tracking-[0.14em] uppercase text-muted" for="sled-iq-agency">Agency / end customer</label>
            <input class={inputClass} type="text" id="sled-iq-agency" name="agency" placeholder="For teaming context only—we never contact the agency" />
          </div>
        </div>

        <div>
          <label class="mb-2 block font-mono text-[10.5px] tracking-[0.14em] uppercase text-muted" for="sled-iq-desc">
            Engagement description, contract #, scope, start date
          </label>
          <textarea
            class={`${inputClass} min-h-[120px] resize-y font-extrabold`}
            id="sled-iq-desc"
            name="desc"
            placeholder="Tell us about the pursuit and/or the active contract. What phase, what scope, what timing…"
          ></textarea>
        </div>

        <div class="grid grid-cols-1 gap-4 lg:grid-cols-2">
          <div>
            <label class="mb-2 block font-mono text-[10.5px] tracking-[0.14em] uppercase text-muted" for="sled-iq-email">
              Email <span class="text-cyan-strong">*</span>
            </label>
            <input class={inputClass} type="email" id="sled-iq-email" name="email" placeholder="you@prime.com" required />
          </div>
          <div>
            <label class="mb-2 block font-mono text-[10.5px] tracking-[0.14em] uppercase text-muted" for="sled-iq-phone">Phone</label>
            <input class={inputClass} type="tel" id="sled-iq-phone" name="phone" placeholder="+1 (XXX) XXX-XXXX" />
          </div>
        </div>

        <div class="flex flex-col gap-5 border-t border-line-soft pt-6 lg:flex-row lg:items-center lg:justify-between">
          <div class="max-w-[380px] font-mono text-[10.5px] font-extrabold leading-[1.5] tracking-[0.06em] uppercase text-muted">
            {HUB_INQUIRY.ndaNote}
          </div>
          <button
            type="submit"
            class="inline-flex items-center justify-center gap-2.5 rounded-xl bg-yale-dark px-7 py-3.5 text-[14.5px] font-bold text-white shadow-[0_10px_28px_-10px_rgba(14,38,64,0.45)] transition-[transform,box-shadow] duration-200 ease-out hover:-translate-y-0.5 hover:shadow-[0_16px_36px_-10px_rgba(14,38,64,0.5)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cyan"
          >
            <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
            {HUB_INQUIRY.submitLabel}
          </button>
        </div>
      </form>

      <div
        class="sled-inquiry-success min-h-[420px] flex-col items-center justify-center px-10 py-12 text-center lg:col-start-2 lg:row-start-1 max-[900px]:px-8 lg:px-12"
        id="sledInquirySuccess"
        role="status"
      >
        <div class="mx-auto mb-6 grid size-16 place-items-center rounded-full bg-cyan-soft shadow-[0_12px_28px_-12px_rgba(24,176,230,0.45)]">
          <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="var(--color-cyan-strong)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 13l4 4L19 7"></path></svg>
        </div>
        <h3 class="mb-3 text-2xl font-extrabold text-yale-dark">{HUB_INQUIRY.success.heading}</h3>
        <p
          class="mx-auto mb-7 max-w-[420px] text-[15px] leading-[1.58] text-muted"
          set:html={HUB_INQUIRY.success.body.replace('sled@techtiz.co', `<strong class="text-yale">${SITE.email.sled}</strong>`)}
        />
        <a
          class="inline-flex items-center justify-center rounded-xl border border-line bg-white px-7 py-3.5 text-[14.5px] font-bold text-yale-dark shadow-[0_8px_20px_-12px_rgba(21,58,95,0.15)] transition-[transform,background] duration-200 ease-out hover:-translate-y-0.5 hover:bg-seasalt"
          id="sledInquiryReset"
          href="#top"
        >
          {HUB_INQUIRY.success.resetLabel}
        </a>
      </div>
    </div>
  </SledPageWrap>
</section>
