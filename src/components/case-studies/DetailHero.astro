---
import { isVideoMedia } from '../../lib/utils/case-study';

interface Props {
  title: string;
  media: string;
}

const { title, media } = Astro.props;
const isVideo = isVideoMedia(media);
---

<section class="relative h-[340px] w-full md:h-[400px] lg:h-[420px]">
  {
    isVideo ? (
      <video src={media} autoplay muted loop playsinline class="size-full object-cover" />
    ) : (
      <img src={media} alt={title} class="size-full object-cover" loading="eager" decoding="async" />
    )
  }
  <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
  <div class="absolute bottom-0 left-0 z-10 p-8 md:ml-4 md:p-12" data-aos="zoom-in" data-aos-delay="500">
    <h1 class="max-w-3xl text-[32px] font-semibold leading-[1.2] tracking-[-0.02em] text-white md:text-[40px] lg:text-[48px]">
      {title}
    </h1>
  </div>
</section>
