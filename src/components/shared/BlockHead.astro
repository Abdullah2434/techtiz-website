---
interface Props {
  eyebrow: string;
  heading: string;
  sub?: string;
  rightLinkLabel?: string;
  rightLinkHref?: string;
}

const { eyebrow, heading, sub, rightLinkLabel, rightLinkHref } = Astro.props;
---

<div class="mb-14 flex items-end justify-between gap-12 max-[900px]:flex-col max-[900px]:items-start max-[900px]:gap-4 max-[900px]:mb-9">
  <div class="max-w-[700px]">
    <span class="inline-flex items-center font-mono text-[11px] font-bold tracking-[0.18em] uppercase text-cyan-strong mb-3.5">
      {eyebrow}
    </span>
    <h2 class="text-[44px] leading-[1.05] tracking-[-0.022em] text-yale font-extrabold max-[900px]:text-[30px] max-[600px]:text-[26px]" set:html={heading} />
    {sub && <p class="mt-3.5 max-w-[620px] text-[15.5px] text-muted">{sub}</p>}
  </div>
  {rightLinkLabel && rightLinkHref && (
    <div class="pb-1">
      <a
        href={rightLinkHref}
        class="inline-flex items-center gap-2 border-b-2 border-cyan pb-1 text-sm font-bold text-yale transition-[gap] duration-200 ease-out hover:gap-3.5"
      >
        {rightLinkLabel}
      </a>
    </div>
  )}
</div>
