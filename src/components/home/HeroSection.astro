---
import ChevronRight from "@lucide/astro/icons/chevron-right";
import { HOME_HERO } from "../../lib/constants/pages/home";
import CtaButton from "../shared/CtaButton.astro";
import Eyebrow from "../shared/Eyebrow.astro";
import PageWrap from "./PageWrap.astro";

const {
  eyebrow,
  sector,
  heading,
  headingAccent,
  body,
  cta,
} = HOME_HERO;
---

<section
  class="relative overflow-hidden bg-gradient-to-b from-white via-white to-seasalt py-[88px] pb-28 max-[900px]:py-14 max-[900px]:pb-20"
>
  <div
    class="pointer-events-none absolute inset-0 z-0 overflow-hidden"
    aria-hidden="true"
  >
    <div
      class="absolute top-[-8%] right-[8%] size-[min(42vw,520px)] rounded-full bg-[radial-gradient(circle,rgba(24,176,230,0.22)_0%,rgba(24,176,230,0)_70%)] blur-[72px] will-change-transform animate-[hero-glow-a_20s_ease-in-out_infinite_alternate] motion-reduce:animate-none"
    ></div>
    <div
      class="absolute bottom-[-12%] left-[-4%] size-[min(36vw,440px)] rounded-full bg-[radial-gradient(circle,rgba(21,58,95,0.14)_0%,rgba(21,58,95,0)_72%)] blur-[72px] will-change-transform animate-[hero-glow-b_24s_ease-in-out_infinite_alternate] motion-reduce:animate-none"
    ></div>
  </div>

  <PageWrap class="relative z-[2]">
    <div
      class="grid grid-cols-[1.05fr_1fr] items-center gap-20 max-[900px]:grid-cols-1 max-[900px]:gap-12"
    >
      <div
        class="flex min-w-0 flex-col items-start"
        data-aos="fade-right"
        data-aos-delay="100"
        data-aos-duration="1000"
      >
        <div
          class="home-sector-on mb-7 inline-flex w-fit max-w-full gap-0.5 rounded-full border border-line bg-white/90 p-[5px] shadow-[0_4px_12px_-6px_rgba(14,38,64,0.08)] backdrop-blur-sm max-[640px]:mb-5 max-[640px]:gap-0 max-[640px]:p-[3px]"
        >
          <span
            class="inline-flex items-center gap-2 rounded-full bg-yale px-4 py-2 text-[13px] font-semibold text-white max-[640px]:gap-1.5 max-[640px]:px-2.5 max-[640px]:py-1.5 max-[640px]:text-[11px]"
          >
            <span
              class="home-sector-dot inline-block size-2 rotate-[15deg] bg-cyan max-[640px]:size-1.5"
            ></span>
            {sector.international}
          </span>
          <a
            href={sector.sled.href}
            class="group inline-flex items-center gap-2 rounded-full px-4 py-2 text-[13px] font-semibold text-yale transition-[background,color] duration-200 hover:bg-cyan-soft hover:text-cyan-strong max-[640px]:gap-1 max-[640px]:px-2.5 max-[640px]:py-1.5 max-[640px]:text-[11px]"
            aria-label="View SLED Partnerships hub"
          >
            <span class="inline-block size-2 rotate-[15deg] bg-cyan max-[640px]:size-1.5"></span>
            {sector.sled.label}
            <ChevronRight
              class="size-3.5 transition-transform duration-220 group-hover:translate-x-1 max-[640px]:size-3"
              aria-hidden="true"
            />
          </a>
        </div>

        <Eyebrow
          text={eyebrow}
          showGlyph
          class="mb-7 flex w-full max-[640px]:mb-5 max-[640px]:text-[10px] max-[640px]:tracking-[0.14em]"
        />

        <h1
          class="mb-8 max-w-[640px] text-[48px] font-extrabold leading-[1.12] tracking-[-0.025em] text-yale max-[1024px]:text-[44px] max-[900px]:mb-7 max-[900px]:text-[clamp(28px,6.5vw,40px)] max-[900px]:leading-[1.14] max-[640px]:mb-5 max-[640px]:max-w-none max-[640px]:text-[clamp(24px,7.2vw,32px)] max-[480px]:text-[24px]"
        >
          {heading}{' '}
          <span class="inline-block text-cyan">{headingAccent}</span>{' '}
        </h1>

        <p class="mb-10 max-w-[500px] text-[17px] leading-[1.65] text-muted max-[900px]:mb-8 max-[640px]:mb-6 max-[640px]:max-w-none max-[640px]:text-[15px] max-[640px]:leading-[1.6] max-[480px]:text-[14px]">
          {body}
        </p>

        <CtaButton href={cta.href} label={cta.label} variant="primary" />
      </div>

      <div class="home-mockup-shell relative min-w-0" aria-hidden="true">
        <span
          class="home-float-a absolute top-[-14px] left-[-18px] size-[22px] rotate-[15deg] bg-cyan opacity-[0.22] max-[640px]:hidden"
        ></span>
        <span
          class="home-float-b absolute bottom-[-18px] right-[30%] size-3.5 rotate-[15deg] bg-cyan opacity-40 max-[640px]:hidden"
        ></span>
        <span
          class="home-float-c absolute top-[30%] right-[-28px] size-[30px] rotate-[15deg] bg-cyan opacity-[0.15] max-[640px]:hidden"
        ></span>

        <div
          class="home-build-flow"
          role="img"
          aria-label="A client brief becoming an AI-native build, shipped to production under your brand"
        >
          <div class="home-bf-brief">
            <span class="home-bf-chip-l">01 · Your brief</span>
            <span class="home-bf-chip-t">Customer onboarding flow · 6-wk scope</span>
          </div>

          <div class="home-bf-link" aria-hidden="true">
            <span class="home-bf-comet"></span>
          </div>

          <div class="home-bf-terminal">
            <div class="home-bf-bar">
              <span class="home-bf-dots" aria-hidden="true">
                <i></i><i></i><i></i>
              </span>
              <span class="home-bf-title">techtiz · build-os</span>
              <span class="home-bf-health">
                <span class="home-bf-blink"></span>
                Building
              </span>
            </div>
            <div class="home-bf-log">
              <div class="home-bf-ln" style="--i: 0">
                <span class="home-bf-p">›</span>
                brief.parse()
                <em>scope mapped · day 1</em>
              </div>
              <div class="home-bf-ln" style="--i: 1">
                <span class="home-bf-ok">✓</span>
                team assembled
                <em>3 senior eng · 2 AI agents</em>
              </div>
              <div class="home-bf-ln" style="--i: 2">
                <span class="home-bf-ok">✓</span>
                RAG pipeline live
                <em>evals 98.2% · $0.018 / run</em>
              </div>
              <div class="home-bf-ln" style="--i: 3">
                <span class="home-bf-ok">✓</span>
                accessibility audit
                <em>WCAG 2.2 AA · 0 failures</em>
              </div>
              <div class="home-bf-ln home-bf-ln-ship" style="--i: 4">
                <span class="home-bf-p">▶</span>
                ship v1.0 → production
                <span class="home-bf-caret" aria-hidden="true"></span>
              </div>
            </div>
          </div>

          <div class="home-bf-link home-bf-link-b" aria-hidden="true">
            <span class="home-bf-comet"></span>
          </div>

          <div class="home-bf-ship">
            <div class="home-bf-chrome">
              <span class="home-bf-dots home-bf-dots-light" aria-hidden="true">
                <i></i><i></i><i></i>
              </span>
              <span class="home-bf-url">app.yourbrand.com</span>
              <span class="home-bf-live">
                <span class="home-bf-blink"></span>
                Live
              </span>
            </div>
            <div class="home-bf-ui">
              <span class="home-bf-u home-bf-u-a"></span>
              <span class="home-bf-u home-bf-u-b"></span>
              <div class="home-bf-u-grid">
                <span></span><span></span><span></span>
              </div>
            </div>
            <div class="home-bf-cap">wk 6 · in production · your brand, your IP</div>
          </div>
        </div>
      </div>
    </div>
  </PageWrap>
</section>
