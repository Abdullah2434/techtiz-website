---
import { INDUSTRIES_DATA, INDUSTRY_TABS } from "../../lib/constants/pages/home";
import IndustryIcon from "./IndustryIcon.astro";
import PageWrap from "./PageWrap.astro";

const initial = INDUSTRIES_DATA.healthcare;
const IND_TRANSITION_MS = 400;
const IND_ICON_KEYS = [
  "heart",
  "growth",
  "house",
  "cart",
  "truck",
  "grad",
] as const;
---

<section
  class="relative overflow-hidden bg-yale-dark py-[110px] text-white max-[900px]:py-14"
>
  <div
    class="pointer-events-none absolute -top-[60px] -right-[60px] size-[320px] rotate-[15deg] opacity-70 bg-[linear-gradient(45deg,transparent_48%,rgba(24,176,230,0.12)_48%_52%,transparent_52%)] bg-size-[28px_28px]"
    aria-hidden="true"
  >
  </div>

  <PageWrap class="relative z-[2]">
    <div
      class="mb-14 flex items-end justify-between gap-12 max-[900px]:mb-9 max-[900px]:flex-col max-[900px]:items-start max-[900px]:gap-4"
      data-aos="fade-up"
      data-aos-delay="100"
    >
      <div class="max-w-[700px]">
        <span
          class="mb-3.5 inline-flex font-mono text-[11px] font-bold tracking-[0.18em] uppercase text-white"
          >Industries</span
        >
        <h2
          class="text-[44px] font-extrabold leading-[1.05] tracking-[-0.022em] text-white max-[900px]:text-[30px]"
        >
          Empowering diverse <span class="text-cyan">business ecosystems.</span>
        </h2>
        <p class="mt-3.5 max-w-[540px] text-[15px] text-white/72">
          Intelligent solutions tailored for specific industry challenges.
        </p>
      </div>
      <a
        href="/#industries"
        class="inline-flex items-center gap-2 border-b-2 border-cyan pb-1 text-sm font-bold text-cyan transition-[gap] duration-200 hover:gap-3.5"
      >
        Explore all →
      </a>
    </div>

    <div
      class="home-ind-tabs mb-[22px] flex flex-nowrap gap-2 overflow-x-auto pb-1 [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
      role="tablist"
      data-ind-tabs
      data-aos="fade-up"
      data-aos-delay="100"
    >
      {
        INDUSTRY_TABS.map((tab, i) => (
          <button
            type="button"
            class:list={[
              "home-ind-tab cursor-pointer rounded-[10px] px-6 py-3 text-sm font-semibold leading-none whitespace-nowrap text-white hover:border-cyan/30 hover:bg-white/8",
              i === 0 && "is-active",
            ]}
            role="tab"
            data-ind={tab.id}
            aria-selected={i === 0 ? "true" : "false"}
          >
            {tab.label}
          </button>
        ))
      }
    </div>

    <div
      class="home-ind-panel grid grid-cols-[1.1fr_1fr_0.9fr] gap-4 max-[900px]:grid-cols-1"
      data-ind-panel
      data-aos="fade-up"
      data-aos-delay="200"
    >
      <div
        class="home-ind-pane flex flex-col rounded-[14px] border border-white/10 bg-white/4 p-8 max-[600px]:p-6"
      >
        <div class="home-ind-stagger">
          <div class="mb-[18px] flex items-center gap-3" data-ind-icon-wrap>
            <div
              class="grid size-11 shrink-0 place-items-center rounded-[10px] bg-cyan/12 text-cyan"
            >
              <IndustryIcon name={initial.icon} />
            </div>
          </div>
          <h3
            class="mb-3 text-2xl font-extrabold leading-[1.2] text-white"
            data-ind-title
          >
            {initial.title}
          </h3>
          <p
            class="mb-[22px] text-[14.5px] leading-[1.6] text-white/72"
            data-ind-desc
          >
            {initial.desc}
          </p>
          <div class="mt-auto flex flex-col gap-2.5" data-ind-badges>
            {
              initial.badges.map((b) => (
                <span class="inline-flex w-fit max-w-full items-center gap-2.5 rounded-full border border-cyan/30 bg-cyan/8 px-4 py-2 font-mono text-xs tracking-[0.04em] text-cyan before:inline-block before:size-[7px] before:shrink-0 before:rotate-[15deg] before:bg-cyan before:content-['']">
                  <strong class="font-bold text-white">{b.strong}</strong>
                  {b.rest}
                </span>
              ))
            }
          </div>
        </div>
      </div>

      <div
        class="home-ind-pane flex flex-col rounded-[14px] border border-white/10 bg-white/4 p-8 max-[600px]:p-6"
      >
        <div class="home-ind-stagger">
          <div
            class="mb-4 font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-cyan"
          >
            Pain points we solve
          </div>
          <h4
            class="mb-[18px] text-base font-bold leading-[1.3] text-white"
            data-ind-ch-head
          >
            {initial.chHead}
          </h4>
          <div data-ind-challenges>
            {
              initial.challenges.map((c) => (
                <div class="border-t border-white/8 py-4 first:border-t-0 first:pt-0 last:pb-0">
                  <div class="mb-1.5 flex items-start gap-2.5 text-[14.5px] font-bold leading-[1.3] text-white before:mt-1.5 before:inline-block before:size-2 before:shrink-0 before:rotate-[15deg] before:bg-cyan before:content-['']">
                    {c.title}
                  </div>
                  <p class="pl-[18px] text-[13px] leading-[1.5] text-white/62">
                    {c.pain}
                  </p>
                </div>
              ))
            }
          </div>
        </div>
      </div>

      <div
        class="home-ind-pane relative overflow-hidden rounded-[14px] border border-yale-mid bg-yale p-8 max-[600px]:p-6"
      >
        <div
          class="pointer-events-none absolute -bottom-[30px] -right-[30px] size-[200px] rotate-[15deg] bg-[linear-gradient(45deg,transparent_48%,rgba(24,176,230,0.20)_48%_52%,transparent_52%)] bg-size-[22px_22px]"
          aria-hidden="true"
        >
        </div>
        <div class="relative z-[2] flex h-full flex-col home-ind-stagger">
          <div
            class="mb-7 grid size-11 place-items-center rounded-[10px] bg-white/10 text-cyan"
          >
            <IndustryIcon name="sparkle" />
          </div>
          <h3
            class="mb-3.5 max-w-[260px] text-[26px] font-extrabold leading-[1.15] text-white"
            data-ind-cta-title
          >
            {initial.cta}
          </h3>
          <p
            class="mb-7 text-[13.5px] leading-[1.55] text-white/72"
            data-ind-cta-sub
          >
            {initial.ctaSub}
          </p>
          <a
            href="/us-sled/contact/"
            class="mt-auto inline-flex w-full items-center justify-between rounded-lg border border-white/32 px-[22px] py-3.5 text-[14.5px] font-bold text-white transition-[background,border-color,color] duration-220 hover:border-cyan hover:bg-cyan hover:text-yale-dark"
          >
            Book intro call
            <span class="relative inline-block size-3.5" aria-hidden="true">
              <span
                class="absolute right-0 top-1/2 size-2 -translate-y-1/2 rotate-45 border-t-[1.8px] border-r-[1.8px] border-current"
              ></span>
              <span
                class="absolute left-0 right-1 top-1/2 h-[1.8px] -translate-y-1/2 bg-current"
              ></span>
            </span>
          </a>
        </div>
      </div>
    </div>

    <div class="hidden" aria-hidden="true" id="home-ind-icon-templates">
      {
        IND_ICON_KEYS.map((key) => (
          <div data-ind-icon={key}>
            <div class="grid size-11 shrink-0 place-items-center rounded-[10px] bg-cyan/12 text-cyan">
              <IndustryIcon name={key} />
            </div>
          </div>
        ))
      }
    </div>
  </PageWrap>
</section>

<script
  define:vars={{
    industriesData: INDUSTRIES_DATA,
    indTransitionMs: IND_TRANSITION_MS,
  }}
>
  const panel = document.querySelector("[data-ind-panel]");
  const tabs = document.querySelectorAll("[data-ind-tabs] [data-ind]");
  if (!panel || !tabs.length) return;

  const iconEl = panel.querySelector("[data-ind-icon-wrap]");
  const titleEl = panel.querySelector("[data-ind-title]");
  const descEl = panel.querySelector("[data-ind-desc]");
  const badgesEl = panel.querySelector("[data-ind-badges]");
  const chHeadEl = panel.querySelector("[data-ind-ch-head]");
  const chEl = panel.querySelector("[data-ind-challenges]");
  const ctaTitleEl = panel.querySelector("[data-ind-cta-title]");
  const ctaSubEl = panel.querySelector("[data-ind-cta-sub]");
  const panes = panel.querySelectorAll(".home-ind-pane");
  let activeKey = "healthcare";
  let animating = false;

  const iconTemplates = document.getElementById("home-ind-icon-templates");

  const getIconMarkup = (key) => {
    const template = iconTemplates?.querySelector(`[data-ind-icon="${key}"]`);
    return template?.innerHTML ?? "";
  };

  const wait = (ms) => new Promise((resolve) => setTimeout(resolve, ms));

  const setTabState = (tab, on) => {
    tab.setAttribute("aria-selected", on ? "true" : "false");
    tab.classList.toggle("is-active", on);
  };

  const updateContent = (key) => {
    const d = industriesData[key];
    if (!d) return;

    if (iconEl) {
      const markup = getIconMarkup(d.icon);
      if (markup) iconEl.innerHTML = markup;
    }
    if (titleEl) titleEl.textContent = d.title;
    if (descEl) descEl.textContent = d.desc;
    if (badgesEl) {
      badgesEl.innerHTML = d.badges
        .map(
          (b) =>
            `<span class="inline-flex w-fit max-w-full items-center gap-2.5 rounded-full border border-cyan/30 bg-cyan/8 px-4 py-2 font-mono text-xs tracking-[0.04em] text-cyan before:inline-block before:size-[7px] before:shrink-0 before:rotate-[15deg] before:bg-cyan before:content-['']"><strong class="font-bold text-white">${b.strong}</strong>${b.rest}</span>`,
        )
        .join("");
    }
    if (chHeadEl) chHeadEl.textContent = d.chHead;
    if (chEl) {
      chEl.innerHTML = d.challenges
        .map(
          (c) =>
            `<div class="border-t border-white/8 py-4 first:border-t-0 first:pt-0 last:pb-0"><div class="mb-1.5 flex items-start gap-2.5 text-[14.5px] font-bold leading-[1.3] text-white before:mt-1.5 before:inline-block before:size-2 before:shrink-0 before:rotate-[15deg] before:bg-cyan before:content-['']">${c.title}</div><p class="pl-[18px] text-[13px] leading-[1.5] text-white/62">${c.pain}</p></div>`,
        )
        .join("");
    }
    if (ctaTitleEl) ctaTitleEl.textContent = d.cta;
    if (ctaSubEl) ctaSubEl.textContent = d.ctaSub;
  };

  const runPanelTransition = async (key) => {
    if (animating || key === activeKey) return;
    animating = true;

    panes.forEach((pane) => {
      pane.classList.remove("home-ind-enter");
      pane.classList.add("home-ind-exit");
    });

    await wait(indTransitionMs);

    panel.classList.remove("home-ind-panel-ready");
    panel.classList.add("home-ind-revealing");
    updateContent(key);
    activeKey = key;

    panes.forEach((pane) => {
      pane.classList.remove("home-ind-exit");
      pane.classList.add("home-ind-enter");
    });

    await wait(20);

    panes.forEach((pane) => pane.classList.remove("home-ind-enter"));
    panel.classList.add("home-ind-panel-ready");

    await wait(indTransitionMs);

    panel.classList.remove("home-ind-revealing");
    animating = false;
  };

  panel.classList.add("home-ind-panel-ready");

  tabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      const key = tab.getAttribute("data-ind");
      if (!key || key === activeKey) return;

      tabs.forEach((t) => setTabState(t, t === tab));
      runPanelTransition(key);
    });
  });
</script>
