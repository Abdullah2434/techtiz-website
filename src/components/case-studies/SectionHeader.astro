---
import ChevronLeft from '@lucide/astro/icons/chevron-left';
import ChevronRight from '@lucide/astro/icons/chevron-right';

interface Props {
  title: string;
  description: string;
  showArrows?: boolean;
  arrowsId?: string;
}

const { title, description, showArrows = false, arrowsId = 'cs-carousel-arrows' } = Astro.props;
---

<div class="mb-0 flex flex-col items-start justify-between gap-y-3">
  <h2 class="cs-section-header-title mb-1 text-left">{title}</h2>
  <div class="cs-section-header-rule"></div>
  <div class="mb-3 flex w-full flex-wrap items-center justify-between gap-x-4 gap-y-4">
    <h3 class="cs-section-header-desc">{description}</h3>
    {
      showArrows && (
        <div class="flex shrink-0 items-center gap-2.5" id={arrowsId} data-cs-arrows>
          <button
            type="button"
            class="cs-arrow-btn"
            data-cs-scroll="left"
            aria-label="Previous success story"
            disabled
          >
            <ChevronLeft class="size-5" aria-hidden="true" />
          </button>
          <button
            type="button"
            class="cs-arrow-btn"
            data-cs-scroll="right"
            aria-label="Next success story"
          >
            <ChevronRight class="size-5" aria-hidden="true" />
          </button>
        </div>
      )
    }
  </div>
</div>
