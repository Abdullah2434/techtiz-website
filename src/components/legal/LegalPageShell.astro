---
interface Props {
  title: string;
}

const { title } = Astro.props;
const wrap = "mx-auto w-full max-w-[1200px] px-2 py-10 md:py-16";
---

<section class={wrap}>
  <div class="w-full">
    <h1 class="text-[32px] leading-tight font-medium text-ink md:text-[40px]">
      {title}
    </h1>
    <slot name="intro" />
    <div class="mt-10 space-y-10">
      <slot />
    </div>
  </div>
</section>
