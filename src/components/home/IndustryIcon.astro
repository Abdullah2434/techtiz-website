---
interface Props {
  name: string;
  class?: string;
}

const { name, class: extraClass = 'size-[22px]' } = Astro.props;
---

{name === 'heart' && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" class={extraClass}>
    <path d="M22 12h-4l-3 9L9 3l-3 9H2" />
  </svg>
)}
{name === 'growth' && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" class={extraClass}>
    <path d="M3 3v18h18" /><path d="M7 14l4-4 4 4 5-5" />
  </svg>
)}
{name === 'house' && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" class={extraClass}>
    <path d="M3 9l9-6 9 6v12H3z" /><path d="M9 21V12h6v9" />
  </svg>
)}
{name === 'cart' && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" class={extraClass}>
    <circle cx="9" cy="21" r="1" /><circle cx="20" cy="21" r="1" /><path d="M1 1h4l2.7 13.4a2 2 0 0 0 2 1.6h9.7a2 2 0 0 0 2-1.6L23 6H6" />
  </svg>
)}
{name === 'truck' && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" class={extraClass}>
    <rect x="1" y="3" width="15" height="13" /><polygon points="16 8 20 8 23 11 23 16 16 16 16 8" /><circle cx="5.5" cy="18.5" r="2.5" /><circle cx="18.5" cy="18.5" r="2.5" />
  </svg>
)}
{name === 'grad' && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" class={extraClass}>
    <path d="M2 3h20v14H2z" /><path d="M8 21h8M12 17v4" />
  </svg>
)}
{name === 'sparkle' && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" class={extraClass}>
    <path d="M12 2 L13.5 8.5 L20 10 L13.5 11.5 L12 18 L10.5 11.5 L4 10 L10.5 8.5 z" /><path d="M19 3 L19.7 5.3 L22 6 L19.7 6.7 L19 9 L18.3 6.7 L16 6 L18.3 5.3 z" />
  </svg>
)}
