---
import ChevronDown from '@lucide/astro/icons/chevron-down';
import Lock from '@lucide/astro/icons/lock';
import type { SledCaseStudy } from '../../../lib/constants/pages/sled-case-studies';
import { sectionHead } from '../../../lib/sled-case-studies/section-head';
import CtaButton from '../../shared/CtaButton.astro';
import Eyebrow from '../../shared/Eyebrow.astro';
import SledPageWrap from '../shared/SledPageWrap.astro';
import CaseStudyFailureTabs from './CaseStudyFailureTabs.astro';
import CaseStudyIcon from './CaseStudyIcon.astro';
import CaseStudyModHead from './CaseStudyModHead.astro';

interface Props {
  study: SledCaseStudy;
}

const { study } = Astro.props;

let sectionIdx = 0;

function sectionClass(tight = false) {
  const bg = sectionIdx % 2 === 0 ? 'bg-white' : 'bg-seasalt';
  sectionIdx += 1;
  return tight ? `sled-section-tight ${bg}` : `sled-section ${bg}`;
}

function factSub(fact: { small?: string; sub?: string }) {
  return fact.small ?? fact.sub ?? '';
}

function rowValue(row: { value?: string; valueHtml?: string }) {
  return row.valueHtml ?? row.value ?? '';
}

function estFlagText(flag: string | { text?: string }) {
  if (typeof flag === 'string') return flag;
  return flag.text ?? '';
}

function barWidth(bar: { width?: number; pct?: number | string; value?: number }) {
  if (typeof bar.width === 'number') return bar.width;
  if (typeof bar.value === 'number') return bar.value;
  if (typeof bar.pct === 'number') return bar.pct;
  if (typeof bar.pct === 'string') {
    const parsed = parseInt(bar.pct.replace(/[^\d]/g, ''), 10);
    return Number.isFinite(parsed) ? parsed : 0;
  }
  return 0;
}

function segmentWidth(seg: { pct?: number; width?: number }) {
  return seg.pct ?? seg.width ?? 0;
}

function eventTagLive(event: {
  tag?: { live?: string; past?: string };
  tagLive?: string;
}) {
  if (event.tag?.live) return event.tag.live;
  if (event.tagLive) return event.tagLive;
  return '';
}

function eventTagPast(event: {
  tag?: { live?: string; past?: string };
  tagPast?: string;
}) {
  if (event.tag?.past) return event.tag.past;
  if (event.tagPast) return event.tagPast;
  return '';
}

function segmentTier(seg: { tier?: string; variant?: string }) {
  return seg.tier ?? seg.variant ?? 'mid';
}

function legendTier(leg: object) {
  if ('tier' in leg && typeof leg.tier === 'string') return leg.tier;
  if ('variant' in leg && typeof leg.variant === 'string') return leg.variant;
  return 'mid';
}

function isLiveOnlySection(section: object | undefined) {
  if (!section || !('liveOnly' in section)) return true;
  return (section as { liveOnly?: boolean }).liveOnly !== false;
}

function statLabel(stat: object) {
  if ('l' in stat && typeof stat.l === 'string') return stat.l;
  if ('label' in stat && typeof stat.label === 'string') return stat.label;
  return '';
}

function statNumber(stat: object) {
  if ('n' in stat && typeof stat.n === 'string') return stat.n;
  if ('value' in stat && typeof stat.value === 'string') return stat.value;
  return '';
}

function statSuffix(stat: object) {
  if ('nSuffix' in stat && typeof stat.nSuffix === 'string') return stat.nSuffix;
  if ('valueSuffix' in stat && typeof stat.valueSuffix === 'string') return stat.valueSuffix;
  if ('nSmall' in stat && typeof stat.nSmall === 'string') return stat.nSmall;
  return '';
}

const tierBarClass: Record<string, string> = {
  nat: 'bg-yale',
  large: 'bg-cyan-strong',
  mid: 'bg-cyan',
  bout: 'bg-cyan-soft border border-line',
};

const tierLegendClass: Record<string, string> = {
  nat: 'bg-yale',
  large: 'bg-cyan-strong',
  mid: 'bg-cyan',
  bout: 'bg-cyan-soft border border-line',
};

function resolveCta(cta: NonNullable<SledCaseStudy['cta']>) {
  const hasDual = 'live' in cta && typeof cta.live === 'object';

  if (hasDual) {
    const live = cta.live as {
      eyebrow?: string;
      heading?: string;
      h2?: string;
      body?: string;
      buttons?: readonly { label: string; href: string; variant?: string }[];
    };
    const past = cta.past as {
      eyebrow?: string;
      heading?: string;
      h2?: string;
      body?: string;
      buttons?: readonly { label: string; href: string; variant?: string }[];
    };
    return {
      eyebrowLive: live.eyebrow ?? '',
      eyebrowPast: past.eyebrow ?? '',
      headingLive: live.heading ?? live.h2 ?? '',
      headingPast: past.heading ?? past.h2 ?? '',
      bodyLive: live.body ?? '',
      bodyPast: past.body ?? '',
      dualBody: true,
      buttons: live.buttons ?? past.buttons ?? ('buttons' in cta ? cta.buttons : []),
    };
  }

  const flat = cta as {
    eyebrow?: string | { live: string; past: string };
    heading?: string | { live: string; past: string };
    h2?: string;
    body?: string;
    buttons?: readonly { label: string; href: string; variant?: string }[];
  };

  const eyebrowLive =
    typeof flat.eyebrow === 'object' ? flat.eyebrow.live : (flat.eyebrow ?? '');
  const eyebrowPast =
    typeof flat.eyebrow === 'object' ? flat.eyebrow.past : eyebrowLive;
  const headingLive =
    typeof flat.heading === 'object'
      ? flat.heading.live
      : (flat.heading ?? flat.h2 ?? '');
  const headingPast =
    typeof flat.heading === 'object' ? flat.heading.past : headingLive;

  return {
    eyebrowLive,
    eyebrowPast,
    headingLive,
    headingPast,
    bodyLive: flat.body ?? '',
    bodyPast: flat.body ?? '',
    dualBody: false,
    buttons: flat.buttons ?? [],
  };
}

function ctaVariant(variant?: string) {
  if (variant === 'cyan') return 'cta' as const;
  if (variant === 'ghost') return 'ghost-dark' as const;
  return 'ghost-dark' as const;
}

const awardModel = 'awardModel' in study ? study.awardModel : undefined;
const awardHead = awardModel ? sectionHead(awardModel) : null;

const failureTabs = 'failureTabs' in study ? study.failureTabs : undefined;
const failureHead = failureTabs
  ? sectionHead('modHead' in failureTabs ? failureTabs.modHead : failureTabs)
  : null;
const failureAccent =
  failureTabs && 'modHead' in failureTabs && 'eyebrowAccent' in failureTabs.modHead
    ? Boolean(failureTabs.modHead.eyebrowAccent)
    : false;

const taskAllocation = 'taskAllocation' in study ? study.taskAllocation : undefined;
const taskHead = taskAllocation ? sectionHead(taskAllocation) : null;

const emphasis = 'emphasis' in study ? study.emphasis : undefined;
const evaluation = 'evaluation' in study ? study.evaluation : undefined;
const evalHead = emphasis
  ? sectionHead(emphasis)
  : evaluation
    ? sectionHead(evaluation)
    : null;

const capabilityGrid = 'capabilityGrid' in study ? study.capabilityGrid : undefined;
const capHead = capabilityGrid ? sectionHead(capabilityGrid) : null;

const pricing = 'pricing' in study ? study.pricing : undefined;
const priceHead = pricing ? sectionHead(pricing) : null;

const securityGrid = 'securityGrid' in study ? study.securityGrid : undefined;
const secHead = securityGrid ? sectionHead(securityGrid) : null;

const agency = 'agency' in study ? study.agency : undefined;
const agencyHead = agency ? sectionHead(agency) : null;
const agencyBody =
  agency && 'bodyHtml' in agency
    ? agency.bodyHtml
    : agency && 'body' in agency
      ? agency.body
      : '';

const competingField = 'competingField' in study ? study.competingField : undefined;
const fieldHead = competingField ? sectionHead(competingField) : null;

const response = 'response' in study ? study.response : undefined;
const responseHead = response ? sectionHead(response) : null;

const strategicQuestions =
  'strategicQuestions' in study ? study.strategicQuestions : undefined;
const stratHead = strategicQuestions ? sectionHead(strategicQuestions) : null;
const stratLiveOnly = isLiveOnlySection(strategicQuestions);

const techtizApproach = 'techtizApproach' in study ? study.techtizApproach : undefined;
const approachHead = techtizApproach ? sectionHead(techtizApproach) : null;
const approachLiveOnly = isLiveOnlySection(techtizApproach);

const ctaResolved = 'cta' in study ? resolveCta(study.cta) : null;

const keyDatesSection = 'keyDates' in study ? study.keyDates : undefined;
const keyDateGridClass =
  keyDatesSection && keyDatesSection.events.length > 4
    ? 'sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4'
    : 'sm:grid-cols-2 lg:grid-cols-4';

const barSegments =
  competingField && 'barSegments' in competingField
    ? competingField.barSegments
    : competingField && 'segments' in competingField
      ? competingField.segments
      : competingField && 'bar' in competingField
        ? competingField.bar.segments
        : undefined;

const fieldLegends =
  competingField && 'legends' in competingField
    ? competingField.legends
    : competingField && 'bar' in competingField
      ? competingField.bar.legends
      : undefined;

const techtizSlot =
  taskAllocation && 'techtizSlot' in taskAllocation
    ? taskAllocation.techtizSlot
    : taskAllocation?.canColumn && 'techtizSlot' in taskAllocation.canColumn
      ? taskAllocation.canColumn.techtizSlot
      : undefined;
---

{study.facts && study.facts.length > 0 && (
  <section class={sectionClass(true)}>
    <SledPageWrap>
      <div
        class="sled-reveal grid grid-cols-1 overflow-hidden rounded-[14px] border border-line-soft bg-white shadow-[0_8px_24px_-16px_rgba(21,58,95,0.12)] sm:grid-cols-2 lg:grid-cols-4"
        data-sled-reveal
      >
        {study.facts.map((fact, idx) => (
          <div
            class:list={[
              'border-line-soft px-[22px] py-5',
              idx > 0 && 'border-t sm:border-t-0 sm:border-l',
              idx === 1 && 'sm:border-t-0',
              idx >= 2 && 'lg:border-t-0',
            ]}
          >
            <div class="mb-2 font-mono text-[10px] tracking-[0.13em] text-cyan-strong uppercase">
              {fact.key}
            </div>
            <div class="text-[14.5px] font-bold text-yale">
              {fact.value}
              {factSub(fact) && (
                <small class="mt-0.5 block font-mono text-[11.5px] font-medium text-muted">
                  {factSub(fact)}
                </small>
              )}
            </div>
          </div>
        ))}
      </div>
    </SledPageWrap>
  </section>
)}

{'keyDates' in study && study.keyDates && (
  <section class={sectionClass()}>
    <SledPageWrap>
      <CaseStudyModHead {...sectionHead(study.keyDates)} />
      <ol
        class:list={[
          'sled-reveal grid grid-cols-1 gap-3',
          keyDateGridClass,
        ]}
        aria-label="Procurement schedule"
        data-sled-reveal
      >
        {study.keyDates.events.map((event, idx) => {
          const isHard = 'hard' in event && event.hard;
          const step = String(idx + 1).padStart(2, '0');
          const hasTag =
            ('tag' in event && event.tag) || ('tagLive' in event && event.tagLive);

          return (
            <li
              class:list={[
                'relative flex min-h-[100px] flex-col rounded-[14px] border border-line-soft bg-white p-5 shadow-[0_8px_24px_-16px_rgba(21,58,95,0.12)] transition-[border-color,box-shadow,transform] duration-200',
                isHard
                  ? 'border-cyan/35 border-t-[3px] border-t-cyan bg-yale-dark shadow-[0_12px_32px_-18px_rgba(14,38,64,0.35)]'
                  : 'border-l-[3px] border-l-cyan/35 hover:-translate-y-0.5 hover:border-cyan/25 hover:shadow-[0_12px_28px_-18px_rgba(21,58,95,0.18)] motion-reduce:hover:translate-y-0',
              ]}
            >
            
              <time
                class:list={[
                  'mb-2 block font-mono text-[11px] font-semibold tracking-[0.04em]',
                  isHard ? 'text-cyan' : 'text-cyan-strong',
                ]}
                datetime={event.date}
              >
                {event.date}
              </time>
              <p
                class:list={[
                  'text-[13px] font-bold',
                  isHard ? 'text-white' : 'text-ink',
                ]}
              >
                {event.label}
              </p>
              <p
                class:list={[
                  'mt-1.5 flex-1 text-[11.5px] leading-[1.45]',
                  isHard ? 'text-white/72' : 'text-muted',
                ]}
              >
                {event.detail}
              </p>
              {hasTag ? (
                <div class="mt-3">
                  <span
                    class:list={[
                      'sled-cs-live-only inline-flex items-center gap-1.5 rounded-md border px-2.5 py-1 font-mono text-[10px] font-bold tracking-[0.1em] uppercase',
                      isHard
                        ? 'border-green/35 bg-green/20 text-[#7DE9B6]'
                        : 'border-green/30 bg-green/12 text-[#1F7855]',
                    ]}
                  >
                    <span
                      class="sled-cs-live-dot size-1.5 rounded-full bg-green"
                      aria-hidden="true"
                    />
                    {eventTagLive(event)}
                  </span>
                  <span
                    class:list={[
                      'sled-cs-past-only hidden inline-flex items-center gap-1.5 rounded-md border px-2.5 py-1 font-mono text-[10px] font-bold tracking-[0.1em] uppercase',
                      isHard
                        ? 'border-white/20 bg-white/8 text-white/72'
                        : 'border-line bg-seasalt text-muted',
                    ]}
                  >
                    {eventTagPast(event)}
                  </span>
                </div>
              ) : null}
            </li>
          );
        })}
      </ol>
      {'foot' in study.keyDates && study.keyDates.foot && (
        <p class="sled-reveal mt-4 font-mono text-[11.5px] tracking-[0.04em] text-muted" data-sled-reveal>
          {'prefix' in study.keyDates.foot && study.keyDates.foot.prefix}
          {'live' in study.keyDates.foot && typeof study.keyDates.foot.live === 'string' && !('prefix' in study.keyDates.foot) ? (
            <>
              <span class="sled-cs-live-only">{study.keyDates.foot.live}</span>
              <span class="sled-cs-past-only hidden">{study.keyDates.foot.past}</span>
            </>
          ) : (
            <>
              <span class="sled-cs-live-only text-green">{study.keyDates.foot.live}</span>
              <span class="sled-cs-past-only hidden">{study.keyDates.foot.past}</span>
              {'suffix' in study.keyDates.foot && study.keyDates.foot.suffix}
            </>
          )}
        </p>
      )}
    </SledPageWrap>
  </section>
)}

{awardModel && awardHead && (
  <section class={sectionClass()}>
    <SledPageWrap>
      <CaseStudyModHead {...awardHead} />
      {'rows' in awardModel && awardModel.rows && (
        <div
          class="sled-reveal rounded-[14px] border border-line-soft border-t-[3px] border-t-cyan bg-white px-[34px] py-[30px] shadow-[0_8px_24px_-16px_rgba(21,58,95,0.12)]"
          data-sled-reveal
        >
          {awardModel.rows.map((row, idx) => (
            <div
              class:list={[
                'grid gap-[5px] py-[15px] sm:grid-cols-[180px_1fr] sm:gap-x-5',
                idx > 0 && 'border-t border-line-soft',
                idx === 0 && 'pt-1',
              ]}
            >
              <span class="pt-0.5 font-mono text-[10.5px] tracking-[0.1em] text-cyan-strong uppercase">
                {row.label}
              </span>
              <span class="text-sm leading-[1.55] text-ink [&_strong]:text-yale-dark" set:html={rowValue(row)} />
            </div>
          ))}
        </div>
      )}
      {'pools' in awardModel && awardModel.pools && (
        <div class="sled-reveal-stagger grid grid-cols-1 gap-4 lg:grid-cols-2" data-sled-reveal>
          {awardModel.pools.map((pool) => (
            <article
              class:list={[
                'overflow-hidden rounded-[14px] border border-line-soft bg-white shadow-[0_8px_24px_-16px_rgba(21,58,95,0.12)]',
                pool.variant === 'shelter' && 'border-t-[3px] border-t-green',
                pool.variant === 'open' && 'border-t-[3px] border-t-cyan',
              ]}
            >
              <div class="border-b border-line-soft px-6 py-5">
                <span class="mb-3 inline-flex items-center gap-2 font-mono text-[10.5px] font-bold tracking-[0.12em] text-cyan-strong uppercase">
                  <span
                    class:list={[
                      'size-2 rotate-[15deg] rounded-[2px]',
                      pool.variant === 'shelter' ? 'bg-green' : 'bg-cyan',
                    ]}
                    aria-hidden="true"
                  />
                  {pool.label}
                </span>
                <h3 class="text-[1.15rem] leading-[1.2] font-bold text-yale-dark">{pool.h3}</h3>
                <p class="mt-2 text-sm leading-[1.55] text-muted">{pool.p}</p>
                <div class="mt-4 font-mono text-[1.65rem] leading-none font-bold tracking-[-0.02em] text-yale-dark">
                  {pool.cap}
                  <small class="mt-1 block text-[11px] font-medium text-muted">{pool.capSmall}</small>
                </div>
              </div>
              <div class="px-6 py-4">
                <div class="mb-3 font-mono text-[10px] tracking-[0.1em] text-muted uppercase">
                  Scoring, out of 100 · tap a row
                </div>
                <div class="divide-y divide-line-soft border-y border-line-soft">
                  {pool.scoring.map((item) => (
                    <details class="group">
                      <summary class="flex cursor-pointer list-none flex-wrap items-center gap-3 py-3 [&::-webkit-details-marker]:hidden">
                        <span class="min-w-0 flex-1 text-sm text-ink">{item.name}</span>
                        <span class="font-mono text-sm font-bold text-yale-dark">{item.value}</span>
                        <span class="h-1.5 w-16 overflow-hidden rounded bg-seasalt">
                          <span
                            class="sled-cs-iv-fill block h-full rounded bg-cyan"
                            style={`--w: ${item.value}%`}
                          />
                        </span>
                      </summary>
                      <p class="pb-3 text-[13px] leading-[1.55] text-muted">{item.desc}</p>
                    </details>
                  ))}
                </div>
              </div>
              <div class="flex items-center gap-2 border-t border-line-soft bg-seasalt px-6 py-3 font-mono text-[11px] text-muted">
                <CaseStudyIcon name="file-text" class="size-3.5" />
                Cover sheet {pool.coverSheet}
              </div>
            </article>
          ))}
        </div>
      )}
      {'note' in awardModel && awardModel.note && (
        <div class="sled-reveal mt-4 flex items-start gap-2.5 text-[13px] leading-[1.55] text-muted" data-sled-reveal>
          <CaseStudyIcon name={awardModel.note.icon} class="mt-0.5 size-4 shrink-0 text-cyan-strong" />
          <span set:html={awardModel.note.html} />
        </div>
      )}
    </SledPageWrap>
  </section>
)}

{'differentiator' in study && study.differentiator && (
  <section class={sectionClass()}>
    <SledPageWrap>
      <div
        class="sled-reveal grid grid-cols-1 items-start gap-4 rounded-[14px] bg-yale-dark px-[26px] py-[30px] text-white sm:grid-cols-[auto_1fr] sm:gap-[26px] sm:px-10 sm:py-[38px]"
        data-sled-reveal
      >
        <span class="grid size-[46px] shrink-0 place-items-center rounded-xl bg-cyan/16 text-cyan">
          {'mark' in study.differentiator && study.differentiator.mark ? (
            <span class="text-2xl leading-none font-serif text-cyan">{study.differentiator.mark}</span>
          ) : 'icon' in study.differentiator ? (
            <CaseStudyIcon name={study.differentiator.icon} class="size-6" />
          ) : (
            <CaseStudyIcon name="git-merge" class="size-6" />
          )}
        </span>
        <div>
          <div class="mb-3.5 font-mono text-[10.5px] tracking-[0.12em] text-cyan uppercase">
            {study.differentiator.tag}
          </div>
          <div class="text-[clamp(1.2rem,2vw,1.5rem)] leading-[1.32] font-semibold tracking-[-0.01em]">
            {study.differentiator.quote}
          </div>
          <p class="mt-3.5 max-w-[660px] text-sm leading-[1.6] text-white/74">
            {study.differentiator.sub}
          </p>
          {'liveNote' in study.differentiator && study.differentiator.liveNote && (
            <div class="sled-cs-live-only mt-4 flex items-start gap-2.5 border-t border-white/14 pt-3.5 text-[13.5px] text-white">
              <CaseStudyIcon name="zap" class="mt-0.5 size-4 shrink-0 text-cyan" />
              <span>{study.differentiator.liveNote}</span>
            </div>
          )}
        </div>
      </div>
    </SledPageWrap>
  </section>
)}

{taskAllocation && taskHead && (
  <section class={sectionClass()}>
    <SledPageWrap>
      <CaseStudyModHead {...taskHead} />
      {'legalBar' in taskAllocation && taskAllocation.legalBar && (
        <div
          class="sled-reveal mb-[22px] flex items-start gap-3.5 rounded-[14px] border border-amber/28 bg-amber/8 px-5 py-4"
          data-sled-reveal
        >
          <CaseStudyIcon name={taskAllocation.legalBar.icon} class="mt-0.5 size-[19px] shrink-0 text-amber" />
          <p class="text-[13.5px] leading-[1.55] text-ink [&_strong]:text-yale-dark" set:html={taskAllocation.legalBar.html} />
        </div>
      )}
      <div class="sled-reveal grid grid-cols-1 gap-4 lg:grid-cols-2" data-sled-reveal>
        <div class="overflow-hidden rounded-[14px] border border-line-soft bg-white">
          <div class="flex items-center gap-3 border-b border-line-soft px-[22px] py-[18px]">
            <span class="grid size-[34px] shrink-0 place-items-center rounded-lg bg-cyan/12 text-cyan-strong">
              <CaseStudyIcon name={taskAllocation.canColumn.icon} class="size-[18px]" />
            </span>
            <div>
              <div class="text-[14.5px] leading-[1.2] font-bold text-yale-dark">
                {taskAllocation.canColumn.title}
              </div>
              <div class="mt-0.5 font-mono text-[10px] tracking-[0.1em] text-muted uppercase">
                {taskAllocation.canColumn.subtitle}
              </div>
            </div>
          </div>
          {taskAllocation.canColumn.items.map((item) => (
            <div class="grid grid-cols-[20px_1fr] gap-3 border-t border-line-soft px-[22px] py-3">
              <CaseStudyIcon name="check" class="mt-0.5 size-[15px] text-cyan-strong" />
              <p class="text-[13px] leading-[1.5] text-ink">{item}</p>
            </div>
          ))}
          {techtizSlot && (
            <div class="sled-cs-live-only flex items-start gap-2.5 border-t border-line-soft bg-seasalt px-[22px] py-3.5 text-[13px] text-ink">
              {typeof techtizSlot === 'object' ? (
                <>
                  <CaseStudyIcon name={techtizSlot.icon} class="mt-0.5 size-4 shrink-0 text-cyan-strong" />
                  <span set:html={techtizSlot.html} />
                </>
              ) : (
                <>
                  <CaseStudyIcon name="zap" class="mt-0.5 size-4 shrink-0 text-cyan-strong" />
                  <span set:html={techtizSlot} />
                </>
              )}
            </div>
          )}
        </div>
        <div class="overflow-hidden rounded-[14px] border border-line-soft bg-white">
          <div class="flex items-center gap-3 border-b border-line-soft px-[22px] py-[18px]">
            <span class="grid size-[34px] shrink-0 place-items-center rounded-lg bg-green/10 text-[#1F7855]">
              <CaseStudyIcon name={taskAllocation.primeColumn.icon} class="size-[18px]" />
            </span>
            <div>
              <div class="text-[14.5px] leading-[1.2] font-bold text-yale-dark">
                {taskAllocation.primeColumn.title}
              </div>
              <div class="mt-0.5 font-mono text-[10px] tracking-[0.1em] text-muted uppercase">
                {taskAllocation.primeColumn.subtitle}
              </div>
            </div>
          </div>
          {taskAllocation.primeColumn.items.map((item) => (
