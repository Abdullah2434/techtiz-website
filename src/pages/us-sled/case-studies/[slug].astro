---
import SledCaseStudyDetail from '../../../components/sled/case-study-detail/SledCaseStudyDetail.astro';
import SledLayout from '../../../layouts/SledLayout.astro';
import { SLED_CASE_STUDIES, getSledCaseStudy, sledCaseStudyPath } from '../../../lib/constants/pages/sled-case-studies';
import { articleJsonLd, absoluteUrl } from '../../../lib/seo/json-ld';
import '../../../styles/sled.css';
import '../../../styles/sled-case-study.css';

export function getStaticPaths() {
  return SLED_CASE_STUDIES.map((study) => ({
    params: { slug: study.slug },
    props: { study },
  }));
}

const { study } = Astro.props;
const { title, description, ogImage } = study.seo;
const canonicalPath = sledCaseStudyPath(study.slug);

const jsonLd = [
  articleJsonLd({
    headline: title,
    description,
    url: absoluteUrl(canonicalPath),
    image: ogImage,
  }),
];
---

<SledLayout {title} {description} {canonicalPath} {ogImage} {jsonLd} currentPage="/us-sled/case-studies/">
  <SledCaseStudyDetail study={study} />
  <script src="/scripts/sled-hub.js" is:inline></script>
  <script src="/scripts/sled-case-study.js" is:inline></script>
</SledLayout>
