---
interface Props {
  title: string;
  description: string;
  showArrows?: boolean;
  arrowsId?: string;
}

const { title, description, showArrows = false, arrowsId = 'cs-carousel-arrows' } = Astro.props;
---

<div class="mb-0 flex flex-col items-start justify-between gap-y-3">
  <h2 class="cs-section-header-title mb-1 text-left">{title}</h2>
  <div class="cs-section-header-rule"></div>
  <div class="mb-3 flex w-full flex-wrap items-center justify-between gap-x-4 gap-y-4">
    <h3 class="cs-section-header-desc">{description}</h3>
    {
      showArrows && (
        <div class="flex items-center gap-2" id={arrowsId} data-cs-arrows>
          <button type="button" class="cs-arrow-btn" data-cs-scroll="left" aria-label="Previous">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path
                d="M13 18L7 12L13 6"
                stroke="#1E1E1E"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </button>
          <button type="button" class="cs-arrow-btn" data-cs-scroll="right" aria-label="Next">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path
                d="M11 18L17 12L11 6"
                stroke="#1E1E1E"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </button>
        </div>
      )
    }
  </div>
</div>
