---
import type { HOME_CAPABILITIES_GRID } from '../../lib/constants/pages/home';
import HomeCapabilityGridIcon from './HomeCapabilityGridIcon.astro';

type Capability = (typeof HOME_CAPABILITIES_GRID)[number];

interface Props {
  capability: Capability;
  index: number;
}

const { capability, index } = Astro.props;
const isFeatured = capability.featured;
const capNum = String(index + 1).padStart(2, '0');
---

<a
  href={capability.href}
  role="listitem"
  class:list={[
    'home-cap-card group relative flex min-h-[218px] flex-col gap-3.5 overflow-hidden rounded-[10px] border p-[26px] transition-[transform,border-color,box-shadow] duration-240 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cyan',
    isFeatured
      ? 'border-yale-dark bg-yale-dark text-white hover:-translate-y-0.5 hover:shadow-[0_18px_36px_-18px_rgba(21,58,95,0.18)]'
      : 'border-line bg-white hover:-translate-y-0.5 hover:border-[#C2CCD9] hover:shadow-[0_18px_36px_-18px_rgba(21,58,95,0.18)]',
  ]}
  style={`--ci: ${index}`}
>
  {
    isFeatured && (
      <div
        class="pointer-events-none absolute -top-5 -right-5 size-[100px]"
        aria-hidden="true"
      >
        <span class="absolute top-[22px] right-9 size-[18px] rotate-15 bg-cyan opacity-55" />
        <span class="absolute top-[50px] right-3.5 size-[30px] rotate-15 bg-cyan opacity-[0.18]" />
        <span class="absolute top-[60px] right-12 size-3 rotate-15 bg-cyan opacity-[0.35]" />
      </div>
    )
  }

  <div class="flex items-start justify-between gap-3.5">
    <div
      class:list={[
        'grid size-11 shrink-0 place-items-center rounded-lg transition-[background,color] duration-240',
        isFeatured
          ? 'bg-cyan/16 text-cyan group-hover:bg-cyan group-hover:text-yale-dark'
          : 'bg-cyan-soft text-cyan-strong group-hover:bg-cyan group-hover:text-yale-dark',
      ]}
    >
      <HomeCapabilityGridIcon name={capability.icon} />
    </div>
    <span
      class:list={[
        'font-mono text-[26px] font-semibold leading-none tracking-[-0.02em] transition-colors duration-240',
        isFeatured
          ? 'text-white/22 group-hover:text-cyan'
          : 'text-line group-hover:text-cyan',
      ]}
    >
      {capNum}
    </span>
  </div>

  <h3
    class:list={[
      'text-[22px] leading-[1.2] font-semibold tracking-[-0.018em]',
      isFeatured ? 'text-white' : 'text-yale',
    ]}
  >
    {capability.title}
  </h3>

  <div class="home-cap-tags mt-auto flex flex-wrap gap-1.5">
    {
      capability.tags.map((tag) => (
        <span
          class:list={[
            'rounded border px-2 py-1 font-mono text-[10.5px] leading-[1.4] tracking-[0.04em] whitespace-nowrap',
            isFeatured
              ? 'border-white/14 bg-white/5 text-cyan'
              : 'border-line bg-seasalt text-yale',
          ]}
        >
          {tag}
        </span>
      ))
    }
  </div>

  <div
    class:list={[
      'home-cap-detail flex flex-col justify-end gap-3.5',
      isFeatured ? 'bg-yale-mid' : 'bg-white',
    ]}
  >
    <p
      class:list={[
        'text-[14px] leading-[1.55]',
        isFeatured ? 'text-white/74' : 'text-muted',
      ]}
    >
      {capability.description}
    </p>

    {
      'stack' in capability && capability.stack ? (
        <div class="border-t border-white/10 pt-4 font-mono text-[10.5px] leading-[1.6] tracking-widest text-cyan uppercase">
          {capability.stack}
        </div>
      ) : null
    }

    <span
      class:list={[
        'home-cap-grid-more mt-auto flex items-center gap-2 border-t pt-4 text-[13.5px] font-bold transition-[gap,color] duration-200 group-hover:gap-3.5',
        isFeatured
          ? 'border-white/14 text-cyan'
          : 'border-line-soft text-yale group-hover:text-cyan-strong',
      ]}
    >
      {capability.moreLabel}
    </span>
  </div>
</a>
