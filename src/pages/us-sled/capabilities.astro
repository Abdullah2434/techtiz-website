---
import SledLayout from '../../layouts/SledLayout.astro';
import PageHero from '../../components/shared/PageHero.astro';
import Eyebrow from '../../components/shared/Eyebrow.astro';
import CtaButton from '../../components/shared/CtaButton.astro';
import {
  CAPABILITIES_SEO, CAPABILITIES_HERO, COMPLIANCE_FRAMEWORKS, CAPABILITY_MATRIX,
  TECH_STACK, BOUNDARIES, ENGAGE_STEPS
} from '../../lib/constants/pages/capabilities';

const { title, description, canonicalPath, ogImage } = CAPABILITIES_SEO;
---

<SledLayout {title} {description} {canonicalPath} {ogImage} currentPage="/us-sled/capabilities/">

<!-- HERO -->
<PageHero eyebrow={CAPABILITIES_HERO.eyebrow} heading={CAPABILITIES_HERO.heading} body={CAPABILITIES_HERO.body}>
  <div class="mt-7 flex flex-wrap gap-3.5">
    {CAPABILITIES_HERO.ctas.map(cta => (
      <CtaButton
        href={cta.href}
        label={cta.label}
        variant={cta.variant === 'cta' ? 'cta' : 'ghost-light'}
      />
    ))}
  </div>
</PageHero>

<!-- PROCUREMENT STRIP -->
<section class="border-b border-line bg-white py-16">
  <div class="mx-auto max-w-[1280px] px-12 max-[1024px]:px-8 max-[900px]:px-6 max-[600px]:px-[18px]">
    <div class="mb-7">
      <Eyebrow text="Procurement &amp; registration" showGlyph />
    </div>
    <div class="grid grid-cols-3 gap-6 max-[900px]:grid-cols-1">
      <div class="rounded-2xl border border-line bg-seasalt p-6">
        <svg class="mb-4 size-5 text-yale-dark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M7 4 V2 M17 4 V2 M3 10 h18"/></svg>
        <div class="font-mono text-[10.5px] font-bold tracking-[0.14em] uppercase text-cyan-strong">NAICS Codes</div>
        <div class="mt-2 text-[16px] font-extrabold text-yale-dark">541511 · 541512 · 541519</div>
        <div class="mt-2 text-[13.5px] leading-[1.55] text-muted">Custom Computer Programming · Computer Systems Design</div>
      </div>
      <div class="rounded-2xl border border-line bg-seasalt p-6">
        <svg class="mb-4 size-5 text-yale-dark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 21 h18"/><path d="M6 21 V8 l6 -4 l6 4 v13"/><path d="M9 12 h6 M9 16 h6"/></svg>
        <div class="font-mono text-[10.5px] font-bold tracking-[0.14em] uppercase text-cyan-strong">NIGP Codes</div>
        <div class="mt-2 text-[16px] font-extrabold text-yale-dark">918-46 · 918-00</div>
        <div class="mt-2 text-[13.5px] leading-[1.55] text-muted">Software Development · Technology</div>
      </div>
      <div class="rounded-2xl border border-line bg-seasalt p-6">
        <svg class="mb-4 size-5 text-yale-dark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2 L4 6 v6 c0 4 3.5 8 8 10 c4.5 -2 8 -6 8 -10 V6 z"/></svg>
        <div class="font-mono text-[10.5px] font-bold tracking-[0.14em] uppercase text-cyan-strong">Insurance</div>
        <div class="mt-2 text-[16px] font-extrabold text-yale-dark">Per engagement</div>
        <div class="mt-2 text-[13.5px] leading-[1.55] text-muted">Routed through prime master agreement</div>
      </div>
    </div>
  </div>
</section>

<!-- COMPLIANCE FRAMEWORKS -->
<section class="bg-seasalt py-20">
  <div class="mx-auto max-w-[1280px] px-12 max-[1024px]:px-8 max-[900px]:px-6 max-[600px]:px-[18px]">
    <div class="mb-10 max-w-[860px]">
      <Eyebrow text="Compliance frameworks" showGlyph />
      <h2 class="mt-4 text-[38px] font-extrabold leading-[1.1] tracking-[-0.02em] text-yale-dark">
        What a prime compliance officer is looking for.
      </h2>
      <p class="mt-3.5 text-[15.5px] leading-relaxed text-muted">
        Specific framework claims with status, scope, and target dates. We don't list controls we can't substantiate. Where a framework is in-progress, the target is on the page.
      </p>
      <a
        href="/us-sled/operating-model/"
        class="mt-4 inline-flex items-center gap-2 text-[13.5px] font-semibold text-yale transition-colors duration-180 ease-out hover:text-yale-dark"
      >
        See the full operating model and architecture <span aria-hidden="true">→</span>
      </a>
    </div>

    <div class="grid grid-cols-3 gap-6 max-[1024px]:grid-cols-2 max-[720px]:grid-cols-1">
      {COMPLIANCE_FRAMEWORKS.map(fw => (
        <div class="rounded-2xl border border-line bg-white p-[22px] shadow-[0_14px_36px_-26px_rgba(14,38,64,0.25)]">
          <div class="flex items-start justify-between gap-4">
            <div class="text-[16px] font-extrabold text-yale-dark">{fw.name}</div>
            <span
              class:list={[
                'inline-flex shrink-0 items-center rounded-full px-3 py-1 text-[12.5px] font-bold',
                {
                  'bg-amber/12 text-amber': fw.statusClass === 'ip',
                  'bg-cyan-soft text-yale-dark': fw.statusClass === 'ap',
                  'bg-yale/8 text-yale': fw.statusClass === 'al',
                  'bg-seasalt text-muted': fw.statusClass !== 'ip' && fw.statusClass !== 'ap' && fw.statusClass !== 'al',
                },
              ]}
            >
              {fw.status}
            </span>
          </div>
          <div class="mt-3 text-[13.5px] leading-[1.55] text-muted" set:html={fw.what} />
          <div class="mt-4 rounded-xl border border-line bg-seasalt p-4">
            <span class="font-mono text-[10.5px] font-bold tracking-[0.14em] uppercase text-cyan-strong">
              {fw.statusClass === 'ip' ? 'Target' : fw.statusClass === 'ap' ? 'Deliverable' : fw.statusClass === 'al' ? 'Scope' : 'Evidence'}
            </span>
            <div class="mt-2 text-[13.5px] font-medium leading-[1.55] text-muted">{fw.target}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- CAPABILITY MATRIX -->
<section class="bg-white py-20">
  <div class="mx-auto max-w-[1280px] px-12 max-[1024px]:px-8 max-[900px]:px-6 max-[600px]:px-[18px]">
    <div class="mb-10 max-w-[860px]">
      <Eyebrow text="Capability matrix" showGlyph />
      <h2 class="mt-4 text-[38px] font-extrabold leading-[1.1] tracking-[-0.02em] text-yale-dark">
        Eight rows. One per Backbone component.
      </h2>
      <p class="mt-3.5 text-[15.5px] leading-relaxed text-muted">
        Mapped by depth, not breadth. Each row is something we've shipped on a real engagement.
      </p>
    </div>

    <div class="overflow-hidden rounded-2xl border border-line bg-white">
      <div class="grid grid-cols-[1.1fr_1.6fr_1.2fr] gap-0 border-b border-line bg-seasalt px-6 py-4 text-[12.5px] font-bold text-muted max-[900px]:hidden">
        <div>Capability</div>
        <div>What we do</div>
        <div>Tools we use</div>
      </div>
      {CAPABILITY_MATRIX.map(row => (
        <div class="grid grid-cols-[1.1fr_1.6fr_1.2fr] gap-0 border-b border-line px-6 py-5 max-[900px]:grid-cols-1 max-[900px]:gap-3">
          <div class="flex items-start gap-3">
            <div class="mt-0.5 grid size-10 shrink-0 place-items-center rounded-xl bg-cyan-soft text-yale-dark">
              <svg viewBox="0 0 24 24" class="size-5" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2 L4 6 v6 c0 4 3.5 8 8 10 c4.5 -2 8 -6 8 -10 V6 z"/></svg>
            </div>
            <div class="text-[15px] font-extrabold leading-tight text-yale-dark">{row.name}</div>
          </div>
          <div class="text-[14px] leading-[1.55] text-muted">
            <span class="mb-1 hidden font-mono text-[10.5px] font-bold tracking-[0.14em] text-cyan-strong uppercase max-[900px]:block">What we do</span>
            {row.what}
          </div>
          <div class="text-[14px] leading-[1.55] text-muted">
            <span class="mb-1 hidden font-mono text-[10.5px] font-bold tracking-[0.14em] text-cyan-strong uppercase max-[900px]:block">Tools</span>
            {row.tools}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- TECH STACK -->
<section class="bg-seasalt py-20">
  <div class="mx-auto max-w-[1280px] px-12 max-[1024px]:px-8 max-[900px]:px-6 max-[600px]:px-[18px]">
    <div class="mb-10 max-w-[860px]">
      <Eyebrow text="Tech stack" showGlyph />
      <h2 class="mt-4 text-[38px] font-extrabold leading-[1.1] tracking-[-0.02em] text-yale-dark">
        Four quadrants of working tools.
      </h2>
    </div>

    <div class="grid grid-cols-2 gap-6 max-[720px]:grid-cols-1">
      {TECH_STACK.map(q => (
        <div class="rounded-2xl border border-line bg-white p-6 shadow-[0_14px_36px_-26px_rgba(14,38,64,0.25)]">
          <h3 class="text-[18px] font-extrabold leading-tight text-yale-dark">{q.heading}</h3>
          <div class="mt-2 text-[13.5px] font-medium text-muted">{q.subLabel}</div>
          <div class="mt-4 flex flex-wrap gap-2">
            {q.tools.map(t => (
              <span class="rounded-full border border-line bg-seasalt px-3 py-1 text-[12.5px] font-medium text-muted">
                {t}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- WHAT WE DON'T DO -->
<section class="bg-white py-20">
  <div class="mx-auto max-w-[1280px] px-12 max-[1024px]:px-8 max-[900px]:px-6 max-[600px]:px-[18px]">
    <div class="mb-10 max-w-[860px]">
      <Eyebrow text="What we don't do" showGlyph class="text-amber" />
      <h2 class="mt-4 text-[38px] font-extrabold leading-[1.1] tracking-[-0.02em] text-yale-dark">
        Honest about the lane.
      </h2>
      <p class="mt-3.5 text-[15.5px] leading-relaxed text-muted">
        Trust comes from knowing where the work ends. These six categories belong to the prime, to a specialist sub, to dedicated capture-consulting firms, or to nobody at all.
      </p>
    </div>

    <div class="space-y-3.5">
      {BOUNDARIES.map(b => (
        <div class="flex gap-3 rounded-2xl border border-line bg-seasalt p-5">
          <div class="mt-0.5 shrink-0 text-[14px] font-extrabold text-amber">✕</div>
          <div>
            <h4 class="text-[16px] font-extrabold leading-tight text-yale-dark">{b.heading}</h4>
            <p class="mt-2 text-[14px] leading-[1.55] text-muted">{b.body}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- HOW WE ENGAGE -->
<section class="bg-seasalt py-20">
  <div class="mx-auto max-w-[1280px] px-12 max-[1024px]:px-8 max-[900px]:px-6 max-[600px]:px-[18px]">
    <div class="mb-10 max-w-[860px]">
      <Eyebrow text="How we engage" showGlyph />
      <h2 class="mt-4 text-[38px] font-extrabold leading-[1.1] tracking-[-0.02em] text-yale-dark">
        Every engagement begins with a structured relationship.
      </h2>
      <p class="mt-3.5 text-[15.5px] leading-relaxed text-muted">
        NDA on first substantive contact. No public materials exchanged before paperwork is signed. We do not solicit RFPs from the open market or analyze RFPs we have not been formally engaged on.
      </p>
    </div>

    <div class="grid grid-cols-3 gap-6 max-[1024px]:grid-cols-2 max-[720px]:grid-cols-1">
      {ENGAGE_STEPS.map(step => (
        <div class="rounded-2xl border border-line bg-white p-6 shadow-[0_14px_36px_-26px_rgba(14,38,64,0.25)]">
          <div class="flex items-center justify-between gap-3">
            <div class="grid size-10 place-items-center rounded-xl bg-cyan-soft text-yale-dark">
              <span class="font-mono text-[14px] font-extrabold">{step.n}</span>
            </div>
            <span class="font-mono text-[10.5px] font-bold tracking-[0.14em] text-cyan-strong uppercase">
              {step.when}
            </span>
          </div>
          <h4 class="mt-4 text-[16px] font-extrabold leading-tight text-yale-dark">{step.heading}</h4>
          <p class="mt-2 text-[14px] leading-[1.55] text-muted">{step.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- FINAL CTA -->
<section class="bg-yale-dark py-20">
  <div class="mx-auto max-w-[920px] px-12 max-[1024px]:px-8 max-[900px]:px-6 max-[600px]:px-[18px] text-center">
    <Eyebrow text="Engage us" onDark showGlyph class="justify-center" />
    <h2 class="mt-4 text-[40px] font-extrabold leading-[1.1] tracking-[-0.02em] text-white">
      Considering a teaming arrangement?
    </h2>
    <p class="mx-auto mt-3.5 mb-8 max-w-[720px] text-[15.5px] leading-relaxed text-white/70">
      Start an NDA conversation. Engagement structure proposed within 5 business days of NDA.
    </p>
    <div class="flex flex-wrap justify-center gap-3.5">
      <CtaButton href="/us-sled/contact/" label="Talk to us about a subcontract role" variant="cta" />
      <CtaButton href="/us-sled/capability-statement/" label="Capability statement →" variant="ghost-dark" />
    </div>
  </div>
</section>

</SledLayout>

