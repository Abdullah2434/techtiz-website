---
import PageWrap from '../home/PageWrap.astro';

interface Props {
  appLogo: string;
  client: string;
  overview: string;
  overview2?: string;
}

const { appLogo, client, overview, overview2 } = Astro.props;
---

<section class="py-10 md:py-16">
  <PageWrap>
    <div class="grid grid-cols-1 items-start gap-14 md:grid-cols-[1.15fr_1.85fr]">
      <div class="flex flex-col gap-4 border-l border-[#9c9c9c]/40 pl-10 md:pl-16">
        <div data-aos="zoom-in" data-aos-delay="300">
          <img
            src={appLogo}
            alt={`${client} logo`}
            width={90}
            height={90}
            class="mb-1 h-auto w-[90px]"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div data-aos="fade-up" data-aos-delay="400">
          <span class="text-base text-[#7d7d7d]">Client</span>
        </div>
        <div data-aos="fade-up" data-aos-delay="500">
          <h3 class="text-xl font-semibold leading-tight text-[#101010]">{client}</h3>
        </div>
      </div>

      <div class="flex flex-col gap-4">
        <div data-aos="fade-up" data-aos-delay="300">
          <h2 class="mb-2 text-[30px] font-normal md:text-[40px]">
            Product <span class="font-bold text-cyan">Overview</span>
          </h2>
        </div>
        <div data-aos="fade-up" data-aos-delay="400">
          <p class="max-w-3xl text-lg leading-relaxed text-[#454545]">{overview}</p>
        </div>
        {
          overview2 && (
            <div class="mt-5" data-aos="fade-up" data-aos-delay="500">
              <p class="max-w-3xl text-lg leading-relaxed text-[#454545]">{overview2}</p>
            </div>
          )
        }
      </div>
    </div>
  </PageWrap>
</section>
