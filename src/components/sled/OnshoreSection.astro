---
import { ONSHORE } from '../../lib/constants/pages/sled-hub';
import Eyebrow from '../shared/Eyebrow.astro';
import SledIcon from './SledIcon.astro';
import SledPageWrap from './SledPageWrap.astro';

const concernCard =
  'grid grid-cols-[44px_1fr] gap-4 rounded-[12px] border border-line bg-white p-6 transition-[transform,border-color,box-shadow] duration-200 ease-out hover:-translate-y-[2px] hover:border-[#C2CCD9] hover:shadow-[0_16px_30px_-18px_rgba(21,58,95,0.16)]';
---

<section class="bg-white py-[110px] max-[900px]:py-16" id="onshore" data-screen-label="03 Onshore PM-led">
  <SledPageWrap>
    <Eyebrow text={ONSHORE.eyebrow} showGlyph class="mb-3.5" />

    <div class="mb-10 grid grid-cols-1 gap-8 lg:grid-cols-[1.05fr_0.95fr] lg:items-end">
      <h2 class="text-[40px] font-extrabold tracking-[-0.022em] text-yale-dark max-[900px]:text-[30px]">
        {ONSHORE.heading}
      </h2>
      <p class="max-w-[480px] text-[15.5px] leading-[1.6] text-muted">{ONSHORE.sub}</p>
    </div>

    <div class="mb-6 grid grid-cols-1 gap-9 rounded-[14px] border border-line bg-seasalt p-9 pb-[30px] lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
      <div>
        <div class="mb-3 font-mono text-[11px] tracking-[0.14em] uppercase text-cyan-strong">
          {ONSHORE.clock.label}
        </div>
        <h3 class="text-[22px] font-extrabold text-yale-dark">{ONSHORE.clock.heading}</h3>
      </div>
      <div class="flex flex-col gap-2.5">
        <div class="grid grid-cols-9 pb-1.5 font-mono text-[10.5px] text-muted">
          {['12a', '3a', '6a', '9a', '12p', '3p', '6p', '9p', '12a'].map((t) => (
            <span class="text-center tracking-[0.06em]">{t}</span>
          ))}
        </div>
        <div class="relative h-[70px] rounded-lg border border-line bg-white p-1.5">
          <div class="absolute left-[6%] top-[10px] flex h-6 w-[36%] items-center rounded bg-cyan px-3 font-mono text-[11px] font-semibold tracking-[0.06em] text-yale-dark">
            {ONSHORE.clock.pkBar}
          </div>
          <div class="absolute left-[38%] top-[36px] flex h-6 w-[38%] items-center rounded bg-yale-dark px-3 font-mono text-[11px] font-semibold tracking-[0.06em] text-white">
            {ONSHORE.clock.usBar}
          </div>
        </div>
        <div class="mt-1 flex justify-between font-mono text-[10.5px] tracking-[0.04em] text-muted">
          <span>{ONSHORE.clock.leftNote}</span>
          <span class="font-semibold text-cyan-strong">{ONSHORE.clock.overlap}</span>
          <span>{ONSHORE.clock.rightNote}</span>
        </div>
      </div>
    </div>

    <div class="mt-5 grid grid-cols-1 gap-4 lg:grid-cols-2">
      {ONSHORE.concerns.map((c) => (
        <div class={concernCard}>
          <div class="grid size-11 place-items-center rounded-[10px] bg-yale-dark text-cyan">
            <SledIcon name={c.icon} class="size-[22px]" />
          </div>
          <div>
            <div class="mb-1 font-mono text-[10.5px] tracking-[0.14em] uppercase text-muted">{c.num}</div>
            <h4 class="mb-3 text-[17px] font-extrabold text-yale-dark">{c.heading}</h4>
            <div class="mb-2.5 border-l-2 border-line pl-3 text-[13px] text-muted italic">
              <strong class="not-italic font-bold text-yale-dark">Pain:</strong> {c.pain}
            </div>
            <div class="border-l-2 border-cyan pl-3 text-[13px] text-ink">
              <strong class="font-bold text-yale-dark">Our fix:</strong> {c.fix}
            </div>
          </div>
        </div>
      ))}
    </div>
  </SledPageWrap>
</section>
