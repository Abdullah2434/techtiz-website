.inquiry-foot .nda { font-family: 'JetBrains Mono', monospace; font-size: 10.5px; letter-spacing: 0.06em; color: var(--muted); text-transform: uppercase; line-height: 1.5; max-width: 360px; }
.send-btn { display: inline-flex; align-items: center; gap: 10px; background: var(--yale-dark); color: var(--white); font-weight: 700; font-size: 14.5px; padding: 14px 24px; border-radius: 10px; border: 0; font-family: inherit; cursor: pointer; transition: transform 180ms ease, box-shadow 180ms ease; }
