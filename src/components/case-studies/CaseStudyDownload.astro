---
import PageWrap from '../home/PageWrap.astro';
import FormButton from '../shared/FormButton.astro';
import {
  CASE_STUDY_DOWNLOAD_COPY,
  CASE_STUDY_FORM_API,
  caseStudyPdfUrl,
  RECAPTCHA_SITE_KEY,
} from '../../lib/config/case-studies';
import { caseStudyPdfFilename } from '../../lib/case-studies/generate-pdf';

interface Props {
  slug: string;
}

const { slug } = Astro.props;
const pdfUrl = caseStudyPdfUrl(slug);
const pdfFilename = caseStudyPdfFilename(slug);
const copy = CASE_STUDY_DOWNLOAD_COPY;
---

<section class="py-10 md:py-16" id="download-case-study">
  <PageWrap class="px-2">
    <div class="grid gap-10 md:grid-cols-2">
      <div
        class="max-w-[550px] space-y-5"
        data-aos="fade-right"
        data-aos-delay="100"
        data-aos-duration="1000"
      >
        <h2 class="text-[32px] font-normal leading-[1.2] tracking-[-0.02em] md:text-[48px]">
          {copy.titleLine1}
          <br />
          <span class="font-semibold">{copy.titleLine2}</span>
        </h2>
        <p class="text-lg leading-[1.3] tracking-[-0.02em] text-[#101010]">{copy.paragraph1}</p>
        <p class="text-lg leading-[1.3] tracking-[-0.02em] text-[#101010]">{copy.paragraph2}</p>
      </div>

      <form
        class="ml-auto max-w-[652px] space-y-6"
        data-cs-download-form
        novalidate
      >
        <div class="grid grid-cols-2 gap-4">
          <div>
            <input
              type="text"
              name="firstName"
              placeholder="First name"
              autocomplete="given-name"
              class="cs-form-input"
              required
            />
            <p class="cs-form-error mt-1 hidden text-sm text-red-500" data-error="firstName"></p>
          </div>
          <div>
            <input
              type="text"
              name="lastName"
              placeholder="Last name"
              autocomplete="family-name"
              class="cs-form-input"
              required
            />
            <p class="cs-form-error mt-1 hidden text-sm text-red-500" data-error="lastName"></p>
          </div>
        </div>

        <div>
          <input
            type="email"
            name="email"
            placeholder="Enter your email address"
            autocomplete="email"
            class="cs-form-input"
            required
          />
          <p class="cs-form-error mt-1 hidden text-sm text-red-500" data-error="email"></p>
        </div>

        <div>
          <input
            type="text"
            name="phone"
            placeholder="Phone number"
            autocomplete="tel"
            class="cs-form-input"
            required
          />
          <p class="cs-form-error mt-1 hidden text-sm text-red-500" data-error="phone"></p>
        </div>

        <div class="mt-2 flex items-start gap-4">
          <label class="flex cursor-pointer select-none items-start gap-3">
            <span class="relative flex shrink-0 items-center">
              <input
                type="checkbox"
                name="consent"
                class="peer size-6 cursor-pointer appearance-none rounded-sm bg-[#D9D9D9] transition-all checked:border-cyan checked:bg-cyan"
                required
              />
              <svg
                class="pointer-events-none absolute top-[2.5px] left-[2.5px] size-5 text-white opacity-0 peer-checked:opacity-100"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="3"
                stroke="currentColor"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
            </span>
            <span class="text-base leading-[1.5] tracking-[-0.2px] text-[#101010]">
              {copy.consentPrefix}{' '}
              <a href={copy.privacyHref} class="underline">Privacy Policy</a>{' '}
              {copy.consentSuffix}
            </span>
          </label>
        </div>
        <p class="cs-form-error hidden text-sm text-red-500" data-error="consent"></p>

        <div data-aos="zoom-in" data-aos-delay="1000" data-aos-duration="1000">
          <div class="flex flex-col gap-2">
            <div data-cs-recaptcha data-sitekey={RECAPTCHA_SITE_KEY}></div>
            <p class="cs-form-error hidden text-sm text-red-500" data-error="recaptcha"></p>
          </div>
        </div>

        <div
          class="inline-block"
          data-aos="zoom-in"
          data-aos-delay="1000"
          data-aos-duration="1000"
        >
          <FormButton
            label={copy.submitLabel}
            type="submit"
            variant="filled"
            downArrow={true}
            track="case-study"
            class="cs-form-submit"
          />
        </div>

        <p
          class="hidden rounded-md bg-cyan/10 px-4 py-3 text-sm font-medium text-yale"
          data-cs-form-status
          role="status"
        ></p>
      </form>
    </div>
  </PageWrap>
</section>

<script define:vars={{ pdfUrl, pdfFilename, apiUrl: CASE_STUDY_FORM_API, siteKey: RECAPTCHA_SITE_KEY, submitLabel: copy.submitLabel, loadingLabel: copy.submittingLabel }} is:inline>
  window.__CS_DOWNLOAD_FORM__ = { pdfUrl, pdfFilename, apiUrl, siteKey, submitLabel, loadingLabel };
</script>
<script src="/scripts/case-study-form.js" is:inline></script>
