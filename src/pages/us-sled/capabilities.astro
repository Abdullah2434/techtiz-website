---
import SledLayout from '../../layouts/SledLayout.astro';
import {
  CAPABILITIES_SEO, CAPABILITIES_HERO, COMPLIANCE_FRAMEWORKS, CAPABILITY_MATRIX,
  TECH_STACK, BOUNDARIES, ENGAGE_STEPS
} from '../../lib/constants/pages/capabilities';

const { title, description, canonicalPath, ogImage } = CAPABILITIES_SEO;
---

<SledLayout {title} {description} {canonicalPath} {ogImage} currentPage="/us-sled/capabilities/">

<!-- HERO -->
<section class="page-hero">
  <div class="wrap">
    <div class="lead">
      <span class="eyebrow"><span class="gl"></span> {CAPABILITIES_HERO.eyebrow}</span>
      <h1 set:html={CAPABILITIES_HERO.heading} />
      <p class="body">{CAPABILITIES_HERO.body}</p>
      <div style="display:flex; gap:14px; flex-wrap:wrap; margin-top:26px;">
        {CAPABILITIES_HERO.ctas.map(cta => (
          cta.variant === 'cta'
            ? <a href={cta.href} class="cta">{cta.label} <span class="arr"></span></a>
            : <a href={cta.href} class="btn-ghost-light">{cta.label}</a>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- PROCUREMENT STRIP -->
<section class="proc-strip">
  <div class="wrap">
    <div class="h"><span class="eyebrow">Procurement &amp; registration</span></div>
    <div class="proc-grid">
      <div class="proc-item">
        <svg class="pi-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M7 4 V2 M17 4 V2 M3 10 h18"/></svg>
        <div class="pi-l">NAICS Codes</div>
        <div class="pi-v">541511 · 541512 · 541519</div>
        <div class="pi-c">Custom Computer Programming · Computer Systems Design</div>
      </div>
      <div class="proc-item">
        <svg class="pi-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21 h18"/><path d="M6 21 V8 l6 -4 l6 4 v13"/><path d="M9 12 h6 M9 16 h6"/></svg>
        <div class="pi-l">NIGP Codes</div>
        <div class="pi-v">918-46 · 918-00</div>
        <div class="pi-c">Software Development · Technology</div>
      </div>
      <div class="proc-item">
        <svg class="pi-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 L4 6 v6 c0 4 3.5 8 8 10 c4.5 -2 8 -6 8 -10 V6 z"/></svg>
        <div class="pi-l">Insurance</div>
        <div class="pi-v">Per engagement</div>
        <div class="pi-c">Routed through prime master agreement</div>
      </div>
    </div>
  </div>
</section>

<!-- COMPLIANCE FRAMEWORKS -->
<section class="frameworks-section">
  <div class="wrap">
    <div class="head">
      <span class="eyebrow">Compliance frameworks</span>
      <h2>What a prime compliance officer is looking for.</h2>
      <p>Specific framework claims with status, scope, and target dates. We don't list controls we can't substantiate. Where a framework is in-progress, the target is on the page.</p>
      <a class="fw-link" href="/us-sled/operating-model/">See the full operating model and architecture <span>→</span></a>
    </div>
    <div class="fw-grid">
      {COMPLIANCE_FRAMEWORKS.map(fw => (
        <div class="fw-card">
          <div class="fw-h">
            <div class="fw-n">{fw.name}</div>
            <span class:list={['fw-s', fw.statusClass]}>{fw.status}</span>
          </div>
          <div class="fw-w" set:html={fw.what} />
          <div class="fw-target"><span class="lbl">{fw.statusClass === 'ip' ? 'Target' : fw.statusClass === 'ap' ? 'Deliverable' : fw.statusClass === 'al' ? 'Scope' : 'Evidence'}</span> {fw.target}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- CAPABILITY MATRIX -->
<section class="matrix-section">
  <div class="wrap">
    <div class="head">
      <span class="eyebrow">Capability matrix</span>
      <h2>Eight rows. One per Backbone component.</h2>
      <p>Mapped by depth, not breadth. Each row is something we've shipped on a real engagement.</p>
    </div>
    <div class="matrix-table">
      <div class="matrix-row">
        <div class="cell">Capability</div>
        <div class="cell">What we do</div>
        <div class="cell">Tools we use</div>
      </div>
      {CAPABILITY_MATRIX.map(row => (
        <div class="matrix-row">
          <div class="cell cap-name">
            <div class="ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 L4 6 v6 c0 4 3.5 8 8 10 c4.5 -2 8 -6 8 -10 V6 z"/></svg></div>
            <div class="nm">{row.name}</div>
          </div>
          <div class="cell what">{row.what}</div>
          <div class="cell tools">{row.tools}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- TECH STACK -->
<section class="stack-section">
  <div class="wrap">
    <div class="head">
      <span class="eyebrow">Tech stack</span>
      <h2>Four quadrants of working tools.</h2>
    </div>
    <div class="stack-grid">
      {TECH_STACK.map(q => (
        <div class="stack-card">
          <h3>{q.heading}</h3>
          <div class="sub-l">{q.subLabel}</div>
          <div class="tools">
            {q.tools.map(t => <span class="t">{t}</span>)}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- WHAT WE DON'T DO -->
<section class="boundaries">
  <div class="wrap">
    <div class="head">
      <span class="eyebrow" style="color:var(--amber);">What we don't do</span>
      <h2>Honest about the lane.</h2>
      <p>Trust comes from knowing where the work ends. These six categories belong to the prime, to a specialist sub, to dedicated capture-consulting firms, or to nobody at all.</p>
    </div>
    <div class="list">
      {BOUNDARIES.map(b => (
        <div class="boundary">
          <div class="x">✕</div>
          <div>
            <h4>{b.heading}</h4>
            <p>{b.body}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- HOW WE ENGAGE -->
<section class="engage-band">
  <div class="wrap">
    <div class="engage-head">
      <span class="eyebrow">How we engage</span>
      <h2>Every engagement begins with a structured relationship.</h2>
      <p>NDA on first substantive contact. No public materials exchanged before paperwork is signed. We do not solicit RFPs from the open market or analyze RFPs we have not been formally engaged on.</p>
    </div>
    <div class="engage-steps">
      {ENGAGE_STEPS.map(step => (
        <div class="engage-step">
          <div class="engage-n">{step.n}</div>
          <h4>{step.heading}</h4>
          <p>{step.body}</p>
          <span class="engage-when">{step.when}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- FINAL CTA -->
<section class="final">
  <div class="wrap final-inner">
    <span class="eyebrow">Engage us</span>
    <h2>Considering a teaming arrangement?</h2>
    <p style="color: rgba(255,255,255,0.78); font-size: 16px; max-width: 560px; margin: 0 auto 24px; line-height: 1.55;">Start an NDA conversation. Engagement structure proposed within 5 business days of NDA.</p>
    <div style="display:flex; gap:14px; justify-content:center; flex-wrap:wrap;">
      <a href="/us-sled/contact/" class="cta">Talk to us about a subcontract role <span class="arr"></span></a>
      <a href="/us-sled/capability-statement/" class="btn-ghost-dark">Capability statement →</a>
    </div>
  </div>
</section>

</SledLayout>

<style>
.page-hero { background: var(--seasalt); padding: 80px 0 60px; position: relative; overflow: hidden; }
.page-hero::before { content: ""; position: absolute; right: -40px; top: -40px; width: 260px; height: 260px; background: linear-gradient(45deg, transparent 49%, rgba(24,176,230,0.10) 49% 51%, transparent 51%); background-size: 28px 28px; transform: rotate(15deg); }
.page-hero .lead { max-width: 740px; position: relative; z-index: 2; }
.page-hero .lead .eyebrow { margin-bottom: 18px; display: inline-block; }
.page-hero h1 { font-size: 56px; line-height: 1.05; margin-bottom: 22px; }
.page-hero h1 :global(.accent) { color: var(--cyan); }
.page-hero .body { font-size: 17px; color: var(--muted); line-height: 1.55; max-width: 600px; }

.proc-strip { background: var(--white); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); padding: 40px 0; }
.proc-strip .h { text-align: center; margin-bottom: 26px; }
.proc-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0; }
.proc-item { border-left: 1px solid var(--line); padding: 8px 22px; }
.proc-item:first-child { border-left: 0; padding-left: 0; }
.proc-item .pi-icon { width: 28px; height: 28px; color: var(--cyan-strong); margin-bottom: 12px; }
.proc-item .pi-l { font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); margin-bottom: 6px; }
.proc-item .pi-v { font-family: 'JetBrains Mono', monospace; font-size: 13px; color: var(--yale); font-weight: 700; letter-spacing: 0.02em; margin-bottom: 6px; line-height: 1.4; }
.proc-item .pi-c { font-size: 11.5px; color: var(--muted); line-height: 1.4; }

.frameworks-section { background: var(--seasalt); padding: 90px 0 80px; border-top: 1px solid var(--line); }
.frameworks-section .head { margin-bottom: 40px; max-width: 720px; }
.frameworks-section .head .eyebrow { margin-bottom: 14px; display: inline-block; }
.frameworks-section .head h2 { font-size: 36px; line-height: 1.1; }
.frameworks-section .head p { font-size: 15.5px; color: var(--muted); margin-top: 14px; max-width: 640px; line-height: 1.6; }
.fw-link { margin-top: 18px; display: inline-flex; align-items: center; gap: 10px; font-weight: 700; font-size: 14px; color: var(--yale); border-bottom: 2px solid var(--cyan); padding-bottom: 2px; transition: gap 200ms ease; }
.fw-link:hover { gap: 16px; }
.fw-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
.fw-card { background: var(--white); border: 1px solid var(--line); border-radius: 12px; padding: 24px 24px 22px; display: flex; flex-direction: column; gap: 12px; transition: transform 220ms ease, border-color 220ms ease, box-shadow 220ms ease; }
.fw-card:hover { transform: translateY(-2px); border-color: #C2CCD9; box-shadow: 0 18px 36px -18px rgba(21,58,95,0.16); }
.fw-card .fw-h { display: flex; justify-content: space-between; align-items: flex-start; gap: 12px; }
.fw-card .fw-n { font-size: 16.5px; color: var(--yale-dark); font-weight: 800; line-height: 1.25; }
.fw-card .fw-s { font-family: 'JetBrains Mono', monospace; font-size: 9.5px; letter-spacing: 0.14em; text-transform: uppercase; padding: 4px 8px; border-radius: 4px; white-space: nowrap; flex-shrink: 0; }
.fw-card .fw-s.ip { color: var(--amber); background: rgba(216,144,23,0.10); }
.fw-card .fw-s.ap { color: var(--green); background: rgba(43,165,114,0.12); }
.fw-card .fw-s.al { color: var(--cyan-strong); background: var(--cyan-soft); }
.fw-card .fw-s.po { color: var(--yale); background: var(--seasalt); }
.fw-card .fw-w { font-size: 13px; color: var(--muted); line-height: 1.55; }
.fw-card .fw-target { margin-top: auto; padding-top: 12px; border-top: 1px solid var(--line-soft); display: flex; gap: 10px; align-items: center; font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--yale-dark); letter-spacing: 0.04em; }
.fw-card .fw-target .lbl { color: var(--muted); letter-spacing: 0.10em; text-transform: uppercase; font-size: 9.5px; }

.matrix-section { padding: 100px 0 80px; }
.matrix-section .head { margin-bottom: 48px; max-width: 720px; }
.matrix-section .head .eyebrow { margin-bottom: 14px; display: inline-block; }
.matrix-section .head h2 { font-size: 40px; line-height: 1.1; }
.matrix-section .head p { font-size: 15.5px; color: var(--muted); margin-top: 14px; max-width: 620px; }
.matrix-table { background: var(--white); border: 1px solid var(--line); border-radius: 12px; overflow: hidden; }
.matrix-row { display: grid; grid-template-columns: 280px 1.4fr 1fr; border-top: 1px solid var(--line); align-items: stretch; }
.matrix-row:first-child { border-top: 0; background: var(--yale); color: var(--white); }
.matrix-row .cell { padding: 22px 26px; font-size: 14px; line-height: 1.55; border-left: 1px solid var(--line); }
.matrix-row .cell:first-child { border-left: 0; }
.matrix-row:first-child .cell { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--cyan); font-weight: 700; border-color: rgba(255,255,255,0.10); padding: 18px 26px; }
.matrix-row .cap-name { display: flex; align-items: flex-start; gap: 14px; }
.matrix-row .cap-name .ico { width: 36px; height: 36px; border-radius: 6px; background: var(--cyan-soft); color: var(--cyan-strong); display: grid; place-items: center; flex-shrink: 0; }
.matrix-row .cap-name .ico svg { width: 18px; height: 18px; }
.matrix-row .cap-name .nm { font-weight: 700; font-size: 15px; color: var(--yale); line-height: 1.3; }
.matrix-row .what { color: var(--ink); }
.matrix-row .tools { font-family: 'JetBrains Mono', monospace; font-size: 11.5px; color: var(--cyan-strong); letter-spacing: 0.02em; line-height: 1.55; }
.matrix-row:hover:not(:first-child) { background: var(--seasalt); }

.stack-section { background: var(--seasalt); padding: 100px 0; border-top: 1px solid var(--line); }
.stack-section .head { margin-bottom: 48px; }
.stack-section .head .eyebrow { margin-bottom: 14px; display: inline-block; }
.stack-section .head h2 { font-size: 40px; }
.stack-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.stack-card { background: var(--white); border: 1px solid var(--line); border-radius: 10px; padding: 32px 30px; }
.stack-card h3 { font-size: 17px; color: var(--yale); margin-bottom: 6px; }
.stack-card .sub-l { font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--cyan-strong); margin-bottom: 20px; }
.stack-card .tools { display: flex; flex-wrap: wrap; gap: 8px; }
.stack-card .tools .t { font-family: 'JetBrains Mono', monospace; font-size: 11.5px; color: var(--yale); background: var(--seasalt); border: 1px solid var(--line); padding: 6px 10px; border-radius: 4px; letter-spacing: 0.02em; }

.boundaries { padding: 100px 0; background: var(--white); }
.boundaries .head { margin-bottom: 40px; max-width: 720px; }
.boundaries .head .eyebrow { margin-bottom: 14px; display: inline-block; color: var(--amber); }
.boundaries .head h2 { font-size: 40px; }
.boundaries .head p { font-size: 15.5px; color: var(--muted); margin-top: 14px; max-width: 620px; }
.boundaries .list { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.boundary { border: 1px solid var(--line); border-radius: 10px; padding: 26px 28px; display: grid; grid-template-columns: 36px 1fr; gap: 16px; align-items: start; }
.boundary .x { width: 36px; height: 36px; border-radius: 50%; background: rgba(216,144,23,0.10); color: var(--amber); display: grid; place-items: center; font-size: 18px; font-weight: 700; }
.boundary h4 { font-size: 16px; color: var(--yale); margin-bottom: 6px; line-height: 1.3; }
.boundary p { font-size: 13.5px; color: var(--muted); line-height: 1.55; }

.engage-band { background: var(--seasalt); border-top: 1px solid var(--line); padding: 100px 0; }
.engage-head { max-width: 720px; margin-bottom: 48px; }
.engage-head .eyebrow { margin-bottom: 14px; display: inline-block; }
.engage-head h2 { font-size: 40px; line-height: 1.1; }
.engage-head p { font-size: 15.5px; color: var(--muted); margin-top: 14px; max-width: 620px; line-height: 1.6; }
.engage-steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
.engage-step { background: var(--white); border: 1px solid var(--line); border-radius: 12px; padding: 30px 28px 26px; position: relative; display: flex; flex-direction: column; gap: 14px; }
.engage-step .engage-n { width: 44px; height: 44px; background: var(--yale-dark); color: var(--cyan); border-radius: 10px; display: grid; place-items: center; font-family: 'JetBrains Mono', monospace; font-weight: 700; font-size: 14px; letter-spacing: 0.04em; }
.engage-step h4 { font-size: 18px; color: var(--yale); line-height: 1.25; }
.engage-step p { font-size: 14px; color: var(--muted); line-height: 1.55; }
.engage-step .engage-when { margin-top: auto; padding-top: 14px; border-top: 1px solid var(--line-soft); font-family: 'JetBrains Mono', monospace; font-size: 10.5px; letter-spacing: 0.14em; color: var(--cyan-strong); text-transform: uppercase; }

.final { background: var(--yale-dark); color: var(--white); position: relative; overflow: hidden; }
.final::before { content: ""; position: absolute; right: -60px; top: -60px; width: 320px; height: 320px; background: linear-gradient(45deg, transparent 48%, rgba(24,176,230,0.16) 48% 52%, transparent 52%); background-size: 30px 30px; transform: rotate(15deg); }
.final-inner { padding: 90px 0; text-align: center; position: relative; z-index: 2; }
.final .eyebrow { color: var(--cyan); margin-bottom: 14px; display: inline-block; }
.final h2 { color: var(--white); font-size: 38px; margin-bottom: 28px; max-width: 640px; margin-left: auto; margin-right: auto; line-height: 1.15; }
</style>
