---
import PageWrap from './PageWrap.astro';
import Eyebrow from '../shared/Eyebrow.astro';
---

<section class="relative overflow-hidden bg-white py-[72px] pb-24 max-[900px]:py-12">
  <div
    class="pointer-events-none absolute inset-0 opacity-50 before:absolute before:-right-20 before:-top-[60px] before:size-[360px] before:rotate-[15deg] before:bg-[linear-gradient(45deg,transparent_49%,rgba(24,176,230,0.10)_49%_51%,transparent_51%),linear-gradient(-45deg,transparent_49%,rgba(21,58,95,0.04)_49%_51%,transparent_51%)] before:bg-size-[36px_36px] after:absolute after:-bottom-10 after:-left-20 after:size-[280px] after:rotate-[15deg] after:opacity-60 after:bg-[linear-gradient(45deg,transparent_49%,rgba(24,176,230,0.10)_49%_51%,transparent_51%),linear-gradient(-45deg,transparent_49%,rgba(21,58,95,0.04)_49%_51%,transparent_51%)] after:bg-size-[36px_36px]"
    aria-hidden="true"
  ></div>

  <PageWrap class="relative z-[2]">
    <div class="grid grid-cols-[1.05fr_1fr] items-center gap-16 max-[900px]:grid-cols-1 max-[900px]:gap-10">
      <div>
        <div class="home-sector-on mb-[22px] inline-flex gap-0.5 rounded-full border border-line bg-white p-[5px] shadow-[0_4px_12px_-6px_rgba(14,38,64,0.08)]">
          <span class="inline-flex items-center gap-2 rounded-full bg-yale px-4 py-2 text-[13px] font-semibold text-white">
            <span class="home-sector-dot inline-block size-2 rotate-[15deg] bg-cyan"></span>
            International teams
          </span>
          <a
            href="/us-sled/"
            class="group inline-flex items-center gap-2 rounded-full px-4 py-2 text-[13px] font-semibold text-yale transition-[background,color] duration-200 hover:bg-cyan-soft hover:text-cyan-strong"
            aria-label="View SLED Partnerships hub"
          >
            <span class="inline-block size-2 rotate-[15deg] bg-cyan"></span>
            U.S. SLED primes
            <span class="text-[13px] transition-transform duration-220 group-hover:translate-x-1" aria-hidden="true">→</span>
          </a>
        </div>

        <Eyebrow text="Techtiz · AI-native engineering" showGlyph class="mb-[22px]" />

        <h1 class="mb-[22px] text-[64px] font-extrabold leading-[1.02] tracking-[-0.03em] text-yale max-[1024px]:text-[56px] max-[900px]:text-[clamp(30px,7vw,52px)]">
          Reinvent your business with <span class="inline-block text-cyan">AI systems</span> that adapt and improve.
        </h1>

        <p class="mb-8 max-w-[520px] text-lg leading-[1.55] text-muted">
          An AI-native engineering studio for ambitious product teams worldwide, and a technical subcontractor to U.S. SLED prime contractors for back-office engineering delivery.
        </p>

        <div class="mb-7 flex flex-wrap gap-3">
          <a
            href="/us-sled/contact/"
            class="inline-flex items-center gap-2.5 rounded-lg bg-yale px-[22px] py-[13px] text-[14.5px] font-bold text-white transition-[background,transform] duration-[180ms] hover:-translate-y-px hover:bg-yale-dark"
          >
            Talk to an Expert
            <span class="relative inline-block size-3.5" aria-hidden="true">
              <span class="absolute right-0 top-0 size-[7px] rotate-45 border-t-[1.6px] border-r-[1.6px] border-current"></span>
              <span class="absolute left-0 right-[3px] top-1/2 h-[1.6px] -translate-y-1/2 bg-current"></span>
            </span>
          </a>
          <a
            href="/#intro"
            class="inline-flex items-center gap-2.5 rounded-lg border border-line bg-white px-5 py-3 text-[14.5px] font-bold text-yale transition-[border-color,background] duration-[180ms] hover:border-yale hover:bg-seasalt"
          >
            <span class="inline-block size-0 border-y-[5px] border-l-8 border-y-transparent border-l-cyan" aria-hidden="true"></span>
            Watch 90-sec intro
          </a>
        </div>

        <div class="flex flex-wrap gap-x-[22px] gap-y-2 font-mono text-[11.5px] font-medium tracking-[0.04em] text-muted">
          {['Security-controlled delivery', 'Teams in 3 timezones', 'AI-native by default'].map((item) => (
            <span class="inline-flex items-center gap-2 before:inline-block before:size-1.5 before:rotate-[15deg] before:bg-cyan before:content-['']">
              {item}
            </span>
          ))}
        </div>
      </div>

      <div class="relative" aria-hidden="true">
        <span class="home-float-a absolute -left-[18px] -top-3.5 size-[22px] rotate-[15deg] bg-cyan opacity-[0.22]"></span>
        <span class="home-float-b absolute bottom-[-18px] right-[30%] size-3.5 rotate-[15deg] bg-cyan opacity-40"></span>
        <span class="home-float-c absolute top-[30%] -right-7 size-[30px] rotate-[15deg] bg-cyan opacity-[0.15]"></span>

        <div
          class="home-mockup overflow-hidden rounded-[14px] border border-line bg-white shadow-[0_30px_60px_-30px_rgba(14,38,64,0.20),0_8px_24px_-16px_rgba(14,38,64,0.10)]"
          role="img"
          aria-label="Production AI agent dashboard mockup"
        >
          <div class="flex items-center gap-2.5 border-b border-line-soft bg-seasalt px-4 py-3">
            <div class="flex gap-1.5">
              <span class="size-2.5 rounded-full bg-line"></span>
              <span class="size-2.5 rounded-full bg-line"></span>
              <span class="size-2.5 rounded-full bg-line"></span>
            </div>
            <div class="mx-3 flex-1 rounded border border-line bg-white px-3 py-1 font-mono text-[11px] text-muted">
              agents.techtiz.io / <span class="text-cyan">triage-v3</span>
            </div>
            <div class="inline-flex items-center gap-1.5 font-mono text-[10.5px] font-semibold uppercase tracking-[0.08em] text-green">
              <span class="home-health-blink size-[7px] rounded-full bg-green"></span>
              Healthy
            </div>
          </div>

          <div class="flex items-start justify-between gap-4 px-[22px] pt-[22px] pb-4">
            <div class="flex items-center gap-3">
              <div class="relative grid size-[38px] place-items-center rounded-lg bg-yale-dark before:size-4 before:rotate-[15deg] before:bg-cyan before:content-[''] after:absolute after:left-[11px] after:top-[11px] after:size-1 after:bg-white after:content-['']"></div>
              <div>
                <div class="text-[14.5px] font-bold leading-[1.2] text-yale-dark">Customer triage agent</div>
                <div class="mt-1 font-mono text-[10.5px] tracking-[0.05em] text-muted">v3.2 · prod · region us-east</div>
              </div>
            </div>
            <div class="flex gap-3.5 pt-3 font-mono text-[10.5px] text-muted">
              <span class="home-menu-on relative text-yale after:absolute after:-bottom-3.5 after:left-0 after:right-0 after:h-0.5 after:bg-cyan after:content-['']">Overview</span>
              <span>Eval</span>
              <span>Cost</span>
              <span>Logs</span>
            </div>
          </div>

          <div class="grid grid-cols-3 border-y border-line-soft max-[600px]:grid-cols-3">
            <div class="border-r border-line-soft px-5 py-4 last:border-r-0">
              <div class="mb-1.5 font-mono text-[9.5px] uppercase tracking-[0.10em] text-muted">Resolved</div>
              <div class="home-kpi-v text-[22px] font-extrabold leading-none tracking-[-0.02em] text-yale-dark">
                94<span class="ml-1 text-xs font-semibold text-muted">%</span>
              </div>
              <div class="mt-1 font-mono text-[10.5px] text-green">▲ 2.1 this week</div>
            </div>
            <div class="border-r border-line-soft px-5 py-4 last:border-r-0">
              <div class="mb-1.5 font-mono text-[9.5px] uppercase tracking-[0.10em] text-muted">p95 latency</div>
              <div class="home-kpi-v home-kpi-v-2 text-[22px] font-extrabold leading-none tracking-[-0.02em] text-yale-dark">
                312<span class="ml-1 text-xs font-semibold text-muted">ms</span>
              </div>
              <div class="mt-1 font-mono text-[10.5px] text-green">▼ 48 vs v3.1</div>
            </div>
            <div class="px-5 py-4">
              <div class="mb-1.5 font-mono text-[9.5px] uppercase tracking-[0.10em] text-muted">Cost / run</div>
              <div class="home-kpi-v home-kpi-v-3 text-[22px] font-extrabold leading-none tracking-[-0.02em] text-yale-dark">$0.018</div>
              <div class="mt-1 font-mono text-[10.5px] text-muted">stable</div>
            </div>
          </div>

          <div class="px-[22px] pt-5 pb-[18px]">
            <div class="mb-3 flex items-center justify-between">
              <div class="text-xs font-bold text-yale-dark">Resolution rate · last 14 days</div>
              <div class="flex gap-3.5 font-mono text-[10px] text-muted">
                <span class="inline-flex items-center gap-1.5 before:inline-block before:size-2 before:rotate-[15deg] before:bg-cyan before:content-['']">Auto-resolved</span>
                <span class="inline-flex items-center gap-1.5 before:inline-block before:size-2 before:rotate-[15deg] before:bg-yale before:content-['']">Escalated</span>
              </div>
            </div>
            <div class="h-[90px]">
              <svg viewBox="0 0 320 90" preserveAspectRatio="none" class="size-full">
                <g class="[&_line]:stroke-line-soft">
                  <line x1="0" y1="22" x2="320" y2="22" />
                  <line x1="0" y1="45" x2="320" y2="45" />
                  <line x1="0" y1="68" x2="320" y2="68" />
                </g>
                <path d="M0,70 L23,68 L46,65 L69,66 L92,63 L115,60 L138,58 L161,56 L184,52 L207,50 L230,46 L253,42 L276,38 L299,34 L320,30 L320,90 L0,90 Z" fill="#153A5F" opacity="0.10" />
                <path class="home-chart-line-yale" d="M0,70 L23,68 L46,65 L69,66 L92,63 L115,60 L138,58 L161,56 L184,52 L207,50 L230,46 L253,42 L276,38 L299,34 L320,30" fill="none" stroke="#153A5F" stroke-width="1.5" />
                <path d="M0,55 L23,52 L46,46 L69,48 L92,40 L115,38 L138,30 L161,32 L184,24 L207,22 L230,18 L253,16 L276,12 L299,14 L320,8 L320,90 L0,90 Z" fill="#18B0E6" opacity="0.13" />
                <path class="home-chart-line-cyan" d="M0,55 L23,52 L46,46 L69,48 L92,40 L115,38 L138,30 L161,32 L184,24 L207,22 L230,18 L253,16 L276,12 L299,14 L320,8" fill="none" stroke="#18B0E6" stroke-width="2" />
                <circle class="home-chart-dot" cx="299" cy="14" r="3" fill="#18B0E6" />
                <circle class="home-chart-dot home-chart-dot-delay" cx="320" cy="8" r="3" fill="#18B0E6" />
              </svg>
            </div>
          </div>

          <div class="flex items-center justify-between border-t border-line-soft bg-seasalt px-[22px] py-3.5 font-mono text-[10.5px] text-muted">
            <div class="home-badge-twist inline-flex items-center gap-2 font-semibold uppercase tracking-[0.06em] text-cyan-strong before:inline-block before:size-2 before:rotate-[15deg] before:bg-cyan before:content-['']">
              Self-improving
            </div>
            <div>3 evals running · 87 traces / hr</div>
          </div>
        </div>
      </div>
    </div>
  </PageWrap>
</section>
