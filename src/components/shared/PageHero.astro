---
interface Props {
  eyebrow: string;
  heading: string;
  body?: string;
}

const { eyebrow, heading, body } = Astro.props;
---

<section class="border-b border-line bg-white">
  <div class="mx-auto max-w-[1280px] px-12 max-[1024px]:px-8 max-[900px]:px-6 max-[600px]:px-[18px]">
    <div class="py-20">
      <span class="inline-flex items-center font-mono text-[11px] font-bold tracking-[0.18em] uppercase text-cyan-strong mb-5">
        <span
          class="relative mr-2 inline-block size-[11px] -translate-y-px rotate-15 bg-cyan align-middle"
          aria-hidden="true"
        >
          <span class="absolute left-[1.5px] top-[1.5px] size-[3.5px] bg-white"></span>
        </span>
        {eyebrow}
      </span>
      <h1 class="mb-5 text-[52px] leading-[1.04] tracking-[-0.022em] text-yale font-extrabold" set:html={heading} />
      {body && <p class="max-w-[720px] text-[17px] leading-[1.55] text-muted">{body}</p>}
      <slot />
    </div>
  </div>
</section>
