---
import { INDUSTRIES_DATA, INDUSTRY_TABS } from '../../lib/constants/pages/home';
import BlockHead from '../shared/BlockHead.astro';
import IndustryIcon from './IndustryIcon.astro';
import PageWrap from './PageWrap.astro';

const initial = INDUSTRIES_DATA.healthcare;
---

<section class="relative overflow-hidden bg-yale-dark py-[110px] text-white max-[900px]:py-14">
  <div
    class="pointer-events-none absolute -bottom-[60px] -right-[60px] size-[320px] rotate-[15deg] opacity-70 bg-[linear-gradient(45deg,transparent_48%,rgba(24,176,230,0.12)_48%_52%,transparent_52%)] bg-size-[28px_28px]"
    aria-hidden="true"
  ></div>

  <PageWrap class="relative z-[2]">
    <div class="mb-14 flex items-end justify-between gap-12 max-[900px]:mb-9 max-[900px]:flex-col max-[900px]:items-start max-[900px]:gap-4">
      <div class="max-w-[700px]">
        <span class="mb-3.5 inline-flex font-mono text-[11px] font-bold tracking-[0.18em] uppercase text-cyan-strong">Industries</span>
        <h2 class="text-[44px] font-extrabold leading-[1.05] tracking-[-0.022em] text-white max-[900px]:text-[30px]">
          Empowering diverse <span class="text-cyan">business ecosystems.</span>
        </h2>
        <p class="mt-3.5 max-w-[540px] text-[15px] text-white/72">Intelligent solutions tailored for specific industry challenges.</p>
      </div>
      <a
        href="/#industries"
        class="inline-flex items-center gap-2 border-b-2 border-cyan pb-1 text-sm font-bold text-cyan transition-[gap] duration-200 hover:gap-3.5"
      >
        Explore all →
      </a>
    </div>

    <div class="mb-[22px] flex flex-wrap gap-2" role="tablist" data-ind-tabs>
      {INDUSTRY_TABS.map((tab, i) => (
        <button
          type="button"
          class:list={[
            'cursor-pointer rounded-[10px] border px-6 py-3 text-sm font-semibold leading-none whitespace-nowrap transition-[background,color,border-color] duration-200',
            i === 0
              ? 'border-cyan bg-cyan text-yale-dark'
              : 'border-white/10 bg-white/4 text-white/72 hover:border-cyan/30 hover:bg-white/8 hover:text-white',
          ]}
          role="tab"
          data-ind={tab.id}
          aria-selected={i === 0 ? 'true' : 'false'}
        >
          {tab.label}
        </button>
      ))}
    </div>

    <div class="grid grid-cols-[1.1fr_1fr_0.9fr] gap-4 max-[900px]:grid-cols-1" data-ind-panel>
      <div class="home-ind-card flex flex-col rounded-[14px] border border-white/10 bg-white/4 p-8 max-[600px]:p-6" data-ind-card>
        <div class="mb-[18px] flex items-center gap-3" data-ind-icon-wrap>
          <div class="grid size-11 shrink-0 place-items-center rounded-[10px] bg-cyan/12 text-cyan">
            <IndustryIcon name={initial.icon} />
          </div>
        </div>
        <h3 class="mb-3 text-2xl font-extrabold leading-[1.2] text-white" data-ind-title>{initial.title}</h3>
        <p class="mb-[22px] text-[14.5px] leading-[1.6] text-white/72" data-ind-desc>{initial.desc}</p>
        <div class="mt-auto flex flex-col gap-2.5" data-ind-badges>
          {initial.badges.map((b) => (
            <span class="inline-flex w-fit max-w-full items-center gap-2.5 rounded-full border border-cyan/30 bg-cyan/8 px-4 py-2 font-mono text-xs tracking-[0.04em] text-cyan before:inline-block before:size-[7px] before:shrink-0 before:rotate-[15deg] before:bg-cyan before:content-['']">
              <strong class="font-bold text-white">{b.strong}</strong>
              {b.rest}
            </span>
          ))}
        </div>
      </div>

      <div class="home-ind-card flex flex-col rounded-[14px] border border-white/10 bg-white/4 p-8 max-[600px]:p-6" data-ind-card>
        <div class="mb-1 font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-cyan">Pain points we solve</div>
        <h4 class="mb-[18px] text-base font-bold leading-[1.3] text-white" data-ind-ch-head>{initial.chHead}</h4>
        <div data-ind-challenges>
          {initial.challenges.map((c) => (
            <div class="border-t border-white/8 py-4 first:border-t-0 first:pt-0 last:pb-0">
              <div class="mb-1.5 flex items-start gap-2.5 text-[14.5px] font-bold leading-[1.3] text-white before:mt-1.5 before:inline-block before:size-2 before:shrink-0 before:rotate-[15deg] before:bg-cyan before:content-['']">
                {c.title}
              </div>
              <p class="pl-[18px] text-[13px] font-extrabold text-white/62">{c.pain}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="home-ind-card relative overflow-hidden rounded-[14px] border border-yale-mid bg-yale p-8 max-[600px]:p-6" data-ind-card>
        <div
          class="pointer-events-none absolute -bottom-[30px] -right-[30px] size-[200px] rotate-[15deg] bg-[linear-gradient(45deg,transparent_48%,rgba(24,176,230,0.20)_48%_52%,transparent_52%)] bg-size-[22px_22px]"
          aria-hidden="true"
        ></div>
        <div class="relative z-[2] flex h-full flex-col">
          <div class="mb-7 grid size-11 place-items-center rounded-[10px] bg-white/10 text-cyan">
            <IndustryIcon name="sparkle" />
          </div>
          <h3 class="mb-3.5 max-w-[260px] text-[26px] font-extrabold leading-[1.15] text-white" data-ind-cta-title>{initial.cta}</h3>
          <p class="mb-7 text-[13.5px] leading-[1.55] text-white/72" data-ind-cta-sub>{initial.ctaSub}</p>
          <a
            href="/us-sled/contact/"
            class="mt-auto inline-flex w-full items-center justify-between rounded-lg border border-white/32 px-[22px] py-3.5 text-[14.5px] font-bold text-white transition-[background,border-color,color] duration-220 hover:border-cyan hover:bg-cyan hover:text-yale-dark"
          >
            Book intro call
            <span class="relative inline-block size-3.5" aria-hidden="true">
              <span class="absolute right-0 top-1/2 size-2 -translate-y-1/2 rotate-45 border-t-[1.8px] border-r-[1.8px] border-current"></span>
              <span class="absolute left-0 right-1 top-1/2 h-[1.8px] -translate-y-1/2 bg-current"></span>
            </span>
          </a>
        </div>
      </div>
    </div>
  </PageWrap>
</section>

<script define:vars={{ industriesData: INDUSTRIES_DATA }}>
  const panel = document.querySelector('[data-ind-panel]');
  const tabs = document.querySelectorAll('[data-ind-tabs] [data-ind]');
  if (!panel || !tabs.length) return;

  const iconEl = panel.querySelector('[data-ind-icon-wrap]');
  const titleEl = panel.querySelector('[data-ind-title]');
  const descEl = panel.querySelector('[data-ind-desc]');
  const badgesEl = panel.querySelector('[data-ind-badges]');
  const chHeadEl = panel.querySelector('[data-ind-ch-head]');
  const chEl = panel.querySelector('[data-ind-challenges]');
  const ctaTitleEl = panel.querySelector('[data-ind-cta-title]');
  const ctaSubEl = panel.querySelector('[data-ind-cta-sub]');
  const cards = panel.querySelectorAll('[data-ind-card]');

  const icons = {
    heart: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" class="size-[22px]"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>',
    growth: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" class="size-[22px]"><path d="M3 3v18h18"/><path d="M7 14l4-4 4 4 5-5"/></svg>',
    house: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" class="size-[22px]"><path d="M3 9l9-6 9 6v12H3z"/><path d="M9 21V12h6v9"/></svg>',
    cart: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" class="size-[22px]"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.7 13.4a2 2 0 0 0 2 1.6h9.7a2 2 0 0 0 2-1.6L23 6H6"/></svg>',
    truck: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" class="size-[22px]"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>',
    grad: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" class="size-[22px]"><path d="M2 3h20v14H2z"/><path d="M8 21h8M12 17v4"/></svg>',
  };

  function render(key) {
    const d = industriesData[key];
    if (!d) return;
    cards.forEach((c) => c.classList.add('home-ind-card-fade'));
    setTimeout(() => {
      if (iconEl) iconEl.innerHTML = `<div class="grid size-11 shrink-0 place-items-center rounded-[10px] bg-cyan/12 text-cyan">${icons[d.icon] || ''}</div>`;
      if (titleEl) titleEl.textContent = d.title;
      if (descEl) descEl.textContent = d.desc;
      if (badgesEl) {
        badgesEl.innerHTML = d.badges
          .map(
            (b) =>
              `<span class="inline-flex w-fit max-w-full items-center gap-2.5 rounded-full border border-cyan/30 bg-cyan/8 px-4 py-2 font-mono text-xs tracking-[0.04em] text-cyan before:inline-block before:size-[7px] before:shrink-0 before:rotate-[15deg] before:bg-cyan before:content-['']"><strong class="font-bold text-white">${b.strong}</strong>${b.rest}</span>`,
          )
          .join('');
      }
      if (chHeadEl) chHeadEl.textContent = d.chHead;
      if (chEl) {
        chEl.innerHTML = d.challenges
          .map(
            (c) =>
              `<div class="border-t border-white/8 py-4 first:border-t-0 first:pt-0 last:pb-0"><div class="mb-1.5 flex items-start gap-2.5 text-[14.5px] font-bold leading-[1.3] text-white before:mt-1.5 before:inline-block before:size-2 before:shrink-0 before:rotate-[15deg] before:bg-cyan before:content-['']">${c.title}</div><p class="pl-[18px] text-[13px] font-extrabold text-white/62">${c.pain}</p></div>`,
          )
          .join('');
      }
      if (ctaTitleEl) ctaTitleEl.textContent = d.cta;
      if (ctaSubEl) ctaSubEl.textContent = d.ctaSub;
      cards.forEach((c) => c.classList.remove('home-ind-card-fade'));
    }, 180);
  }

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      tabs.forEach((t) => {
        const on = t === tab;
        t.setAttribute('aria-selected', on ? 'true' : 'false');
        t.classList.toggle('border-cyan', on);
        t.classList.toggle('bg-cyan', on);
        t.classList.toggle('text-yale-dark', on);
        t.classList.toggle('border-white/10', !on);
        t.classList.toggle('bg-white/4', !on);
        t.classList.toggle('text-white/72', !on);
      });
      render(tab.getAttribute('data-ind'));
    });
  });
</script>
