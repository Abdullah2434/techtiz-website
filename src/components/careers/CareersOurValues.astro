---
import type { CareersValueItem } from '../../lib/types/careers';

interface Props {
  values: CareersValueItem[];
}

const { values } = Astro.props;
---

<section class="mx-auto w-full max-w-[1400px] px-2 py-10 md:py-16">
  <div class="flex flex-col lg:flex-row">
    <div class="mb-12 w-full text-center lg:mb-16 lg:w-[30.5%] lg:text-left" data-aos="fade-up" data-aos-delay="100">
      <h2 class="mb-3 text-[32px] font-semibold text-[#101010] md:text-[40px]">Our values</h2>
      <p class="text-[16px] leading-[130%] font-normal text-[#101010] md:text-[18px] lg:max-w-md">
        We strive to redefine the
        <br />
        standard of excellence.
      </p>
    </div>

    <div class="grid w-full grid-cols-1 gap-x-14 gap-y-14 md:grid-cols-2 lg:w-[64%] lg:gap-x-0">
      {
        values.map((value) => (
          <div class="w-fit space-y-4">
            <div
              class="mx-auto mb-6 flex h-[64px] w-[64px] items-center justify-center rounded-[16px] bg-[#18B0E6]/10 p-2 lg:mx-0"
              data-aos="fade-up"
              data-aos-delay="100"
            >
              <span class="inline-flex [&>svg]:h-10 [&>svg]:w-10" set:html={value.icon} />
            </div>
            <h3
              class="mb-3 text-center text-[28px] font-semibold text-[#153A5F] lg:text-left"
              data-aos="fade-up"
              data-aos-delay="100"
            >
              {value.title}
            </h3>
            <p
              class="text-center text-[18px] leading-[130%] font-normal text-[#101010] lg:max-w-[350px] lg:text-left"
              data-aos="fade-up"
              data-aos-delay="100"
            >
              {value.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
