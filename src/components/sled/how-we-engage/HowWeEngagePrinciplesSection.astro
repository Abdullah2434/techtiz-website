---
import FileCheck from '@lucide/astro/icons/file-check';
import { NON_NEGOTIABLES, NON_NEGOTIABLES_SECTION } from '../../../lib/constants/pages/how-we-engage';
import Eyebrow from '../../shared/Eyebrow.astro';
import SledPageWrap from '../shared/SledPageWrap.astro';
import SledSpecAccordion from '../shared/SledSpecAccordion.astro';
---

<section class="sled-section relative overflow-hidden bg-yale-dark text-white" id="principles" data-screen-label="03 Non-negotiables">
  <div
    class="pointer-events-none absolute -right-[60px] -top-[60px] size-[340px] [background:linear-gradient(45deg,transparent_48%,rgba(24,176,230,0.14)_48%_52%,transparent_52%)] [background-size:30px_30px] rotate-[15deg]"
    aria-hidden="true"
  />

  <SledPageWrap class="relative z-2">
    <div class="grid grid-cols-1 items-start gap-9 lg:grid-cols-[0.9fr_1.3fr] lg:gap-14">
      <div class="sled-reveal" data-sled-reveal>
        <Eyebrow text={NON_NEGOTIABLES_SECTION.eyebrow} onDark showGlyph class="mb-4" />
        <h2 class="sled-h2 mb-[18px] leading-[1.1] text-white max-w-[450px] ">{NON_NEGOTIABLES_SECTION.heading}</h2>
        <p class="max-w-[400px] text-[15px] leading-[1.6] text-white/74">{NON_NEGOTIABLES_SECTION.body}</p>
        <span class="mt-6 inline-flex items-center gap-2.5 rounded-full border border-cyan/40 bg-cyan/6 px-4 py-2.5 font-mono text-[11px] tracking-[0.12em] uppercase text-cyan">
          <FileCheck class="size-3.5" aria-hidden="true" />
          {NON_NEGOTIABLES_SECTION.stamp}
        </span>
      </div>

      <div class="sled-reveal" data-sled-reveal>
        <SledSpecAccordion items={NON_NEGOTIABLES} variant="dark" defaultOpen={0} />
      </div>
    </div>
  </SledPageWrap>
</section>
