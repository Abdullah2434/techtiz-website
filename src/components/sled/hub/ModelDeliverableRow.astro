---
import Award from '@lucide/astro/icons/award';
import Calculator from '@lucide/astro/icons/calculator';
import FileText from '@lucide/astro/icons/file-text';
import IdCard from '@lucide/astro/icons/id-card';
import ListChecks from '@lucide/astro/icons/list-checks';
import MonitorPlay from '@lucide/astro/icons/monitor-play';
import ShieldCheck from '@lucide/astro/icons/shield-check';
import Tag from '@lucide/astro/icons/tag';
import UsersRound from '@lucide/astro/icons/users-round';
import type { SledModelDeliverable } from '../../../lib/constants/pages/sled-hub';

interface Props {
  item: SledModelDeliverable;
  isLast?: boolean;
}

const { item, isLast = false } = Astro.props;

const deliverableIcons = {
  'file-text': FileText,
  'list-checks': ListChecks,
  'monitor-play': MonitorPlay,
  calculator: Calculator,
  award: Award,
  'id-card': IdCard,
  'users-round': UsersRound,
  tag: Tag,
  'shield-check': ShieldCheck,
} as const;

const Icon = deliverableIcons[item.icon];
---

<div
  class:list={[
    'grid grid-cols-[46px_1fr_auto] items-center gap-4 py-4.5',
    !isLast && 'border-b border-line-soft',
  ]}
>
  <span class="grid size-[46px] place-items-center rounded-xl bg-cyan-soft text-cyan-strong">
    <Icon class="size-5" stroke-width="1.75" aria-hidden="true" />
  </span>
  <div class="min-w-0">
    <h4 class="m-0 mb-0.75 text-[1.08rem] font-extrabold text-yale-dark">{item.heading}</h4>
    <p class="m-0 text-[13.5px] leading-[1.45] text-muted">{item.body}</p>
  </div>
  <span class="self-start pt-1 font-mono text-xs font-semibold text-line">{item.num}</span>
</div>
