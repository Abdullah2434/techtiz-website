---
import { SLED_OUTCOMES } from '../../../lib/constants/pages/sled-hub';
import Eyebrow from '../../shared/Eyebrow.astro';
import SledPageWrap from '../shared/SledPageWrap.astro';
---

<section
  class="sled-section-tight bg-seasalt"
  id="outcomes"
  data-screen-label="Outcomes"
>
  <SledPageWrap>
    <div class="sled-reveal mb-[30px] max-w-[680px]" data-sled-reveal>
      <Eyebrow text={SLED_OUTCOMES.eyebrow} showGlyph class="mb-4" />
      <h2 class="text-[clamp(1.7rem,2.5vw,2.3rem)] font-semibold leading-[1.12] tracking-[-0.02em] text-yale-dark">
        {SLED_OUTCOMES.heading}
      </h2>
    </div>

    <div
      class="sled-reveal grid grid-cols-2 gap-5 md:grid-cols-3 lg:grid-cols-5 lg:gap-7"
      data-sled-reveal
    >
      {
        SLED_OUTCOMES.stats.map((stat) => (
          <div class="min-w-0">
            <div class="font-mono text-[clamp(2.1rem,3.2vw,2.8rem)] font-semibold leading-[0.95] tracking-[-0.02em] text-yale tabular-nums">
              {
                stat.tickerTo !== undefined ? (
                  <>
                    <span data-sled-ticker data-to={stat.tickerTo}>0</span>
                    {stat.suffix && (
                      <span class="text-[0.46em] text-cyan-strong">{stat.suffix}</span>
                    )}
                  </>
                ) : (
                  stat.value
                )
              }
            </div>
            <p class="mt-3 max-w-[21ch] text-[12.5px] leading-[1.45] text-muted">
              {stat.label}
            </p>
          </div>
        ))
      }
    </div>
  </SledPageWrap>
</section>
