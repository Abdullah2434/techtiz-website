---
import PageWrap from '../home/PageWrap.astro';
import { CASE_STUDIES_LISTING_HEADER } from '../../lib/config/case-studies';

const { title, description1, description2 } = CASE_STUDIES_LISTING_HEADER;
const [beforeSolutions, afterSolutions] = title.includes('Solutions for')
  ? [title.split('Solutions for')[0], `Solutions for${title.split('Solutions for')[1]}`]
  : [title, ''];
---

<section class="py-10 pb-16 md:py-10">
  <PageWrap>
    <div class="grid items-start gap-10 md:grid-cols-2 lg:gap-20">
      <div class="space-y-6 md:max-w-[550px]">
        <div data-aos="fade-up" data-aos-delay="100">
          <h2 class="text-left text-[28px] leading-[1.2] font-normal text-[#101010] md:mb-12 md:text-[34px] lg:text-[48px]">
            {
              afterSolutions ? (
                <>
                  {beforeSolutions}
                  <span class="font-bold text-cyan">{afterSolutions}</span>
                </>
              ) : (
                <>
                  {title}{' '}
                  <span class="font-bold text-cyan">Case Studies</span>
                </>
              )
            }
          </h2>
        </div>
      </div>
      <div class="space-y-6 md:mt-3 md:space-y-7">
        <div data-aos="fade-up" data-aos-delay="100">
          <p class="text-left text-base font-normal leading-[1.3] text-[#101010] md:text-right md:text-lg">
            {description1}
          </p>
        </div>
        <div data-aos="fade-up" data-aos-delay="100">
          <p class="text-left text-base font-normal leading-[1.3] text-[#101010] md:text-right md:text-lg">
            {description2}
          </p>
        </div>
      </div>
    </div>
  </PageWrap>
</section>
