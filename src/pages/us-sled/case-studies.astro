---
import SledLayout from '../../layouts/SledLayout.astro';
import {
  CASE_STUDIES_SEO, CASE_STUDIES_HERO, TRUST_ITEMS, ENGAGEMENT_CARDS, CONFIDENTIALITY_ROWS
} from '../../lib/constants/pages/case-studies';

const { title, description, canonicalPath, ogImage } = CASE_STUDIES_SEO;
---

<SledLayout {title} {description} {canonicalPath} {ogImage} currentPage="/us-sled/case-studies/">

<!-- HERO -->
<section class="page-hero">
  <div class="wrap">
    <div class="lead">
      <span class="eyebrow"><span class="gl"></span> {CASE_STUDIES_HERO.eyebrow}</span>
      <h1 set:html={CASE_STUDIES_HERO.heading} />
      <p class="body">{CASE_STUDIES_HERO.body}</p>
    </div>
  </div>
</section>

<!-- TRUST STRIP -->
<section class="trust">
  <div class="wrap trust-inner">
    <span class="trust-label">Operating boundaries</span>
    {TRUST_ITEMS.map(item => (
      <span class="trust-item"><span class="tsq"></span> <span class="v">{item}</span></span>
    ))}
  </div>
</section>

<!-- ENGAGEMENT EXAMPLES -->
<section class="examples-section">
  <div class="wrap">
    <div class="head">
      <span class="eyebrow">Delivered engagements</span>
      <h2>What we shipped, under whose roof, on what vehicle.</h2>
      <p>Each card describes a delivered subcontract engagement: the technical surface area, the prime relationship type, the deliverables that shipped, and the procurement vehicle the work moved through. References available with NDA.</p>
    </div>
    <div class="ex-grid">
      {ENGAGEMENT_CARDS.map(card => (
        <article class="ex-card">
          <div class="ex-head">
            <span class="badge">{card.badge}</span>
            <span class="anon">{card.anon}</span>
          </div>
          <h3>{card.heading}</h3>
          <div class="ex-meta">
            {card.meta.map(m => <span>{m}</span>)}
          </div>
          {card.rows.map(row => (
            <div class="ex-row">
              <span class="lbl">{row.lbl}</span>
              <span class="val" set:html={row.val} />
            </div>
          ))}
          <div class="ex-foot">Vehicle · {card.vehicle}</div>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- CONFIDENTIALITY -->
<section class="confid">
  <div class="wrap confid-inner">
    <div class="left">
      <span class="eyebrow" style="color:var(--amber);">What we cannot show publicly</span>
      <h2>Most of our SLED work stays under NDA.</h2>
      <p>The engagements above are summarized at the technical-deliverable level. Specifics live on a separate call, behind a mutual NDA, with the prime in the room.</p>
    </div>
    <div class="right">
      {CONFIDENTIALITY_ROWS.map(row => (
        <div class="row">
          <div class="ic">✕</div>
          <p><strong>{row.heading}</strong> {row.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- CTA BAND -->
<section class="cta-band">
  <div class="wrap cta-band-inner">
    <span class="eyebrow">Capture manager or BD lead at a U.S. prime?</span>
    <h2>Request a reference conversation.</h2>
    <p>NDA-first introduction. We'll route you to the right named reference for the engagement type closest to your pursuit.</p>
    <a href="/us-sled/contact/" class="cta">Start an NDA conversation <span class="arr"></span></a>
  </div>
</section>

</SledLayout>

<style>
.page-hero { background: var(--seasalt); padding: 80px 0 56px; position: relative; overflow: hidden; }
.page-hero::before { content: ""; position: absolute; right: -40px; top: -40px; width: 280px; height: 280px; background: linear-gradient(45deg, transparent 49%, rgba(24,176,230,0.10) 49% 51%, transparent 51%); background-size: 28px 28px; transform: rotate(15deg); }
.page-hero .lead { max-width: 760px; position: relative; z-index: 2; }
.page-hero .lead .eyebrow { margin-bottom: 18px; display: inline-block; }
.page-hero h1 { font-size: 56px; line-height: 1.05; margin-bottom: 22px; }
.page-hero h1 :global(.accent) { color: var(--cyan); }
.page-hero .body { font-size: 17px; color: var(--muted); line-height: 1.55; max-width: 640px; }

.trust { background: var(--white); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); padding: 28px 0; }
.trust-inner { display: grid; grid-template-columns: 200px 1fr 1fr 1fr; align-items: center; }
.trust-label { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); }
.trust-item { display: flex; align-items: center; gap: 12px; padding: 0 24px; border-left: 1px solid var(--line); }
.trust-item .tsq { width: 10px; height: 10px; background: var(--cyan); transform: rotate(15deg); flex-shrink: 0; }
.trust-item .v { font-size: 13.5px; color: var(--yale); font-weight: 600; }

.examples-section { padding: 80px 0 60px; }
.examples-section .head { margin-bottom: 48px; max-width: 720px; }
.examples-section .head .eyebrow { margin-bottom: 14px; display: inline-block; }
.examples-section .head h2 { font-size: 40px; line-height: 1.1; }
.examples-section .head p { font-size: 15.5px; color: var(--muted); margin-top: 14px; max-width: 620px; }
.ex-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
.ex-card { background: var(--white); border: 1px solid var(--line); border-radius: 14px; padding: 32px 32px 28px; display: flex; flex-direction: column; position: relative; transition: border-color 220ms ease, box-shadow 220ms ease, transform 220ms ease; }
.ex-card:hover { border-color: #C2CCD9; transform: translateY(-2px); box-shadow: 0 18px 36px -20px rgba(21,58,95,0.16); }
.ex-card .ex-head { display: flex; align-items: center; gap: 14px; margin-bottom: 20px; padding-bottom: 20px; border-bottom: 1px solid var(--line-soft); }
.ex-card .ex-head .badge { font-family: 'JetBrains Mono', monospace; font-size: 10.5px; letter-spacing: 0.14em; text-transform: uppercase; color: #1F7855; background: rgba(31,120,85,0.10); padding: 6px 12px; border-radius: 100px; font-weight: 700; }
.ex-card .ex-head .anon { font-family: 'JetBrains Mono', monospace; font-size: 10.5px; letter-spacing: 0.10em; text-transform: uppercase; color: var(--muted); margin-left: auto; }
.ex-card h3 { font-size: 21px; line-height: 1.25; color: var(--yale-dark); margin-bottom: 16px; }
.ex-card .ex-meta { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 22px; }
.ex-card .ex-meta span { font-family: 'JetBrains Mono', monospace; font-size: 10.5px; letter-spacing: 0.04em; color: var(--muted); background: var(--seasalt); border: 1px solid var(--line); padding: 4px 9px; border-radius: 4px; }
.ex-card .ex-row { display: grid; grid-template-columns: 92px 1fr; gap: 14px; padding: 12px 0; border-top: 1px solid var(--line-soft); }
.ex-card .ex-row:last-of-type { border-bottom: 1px solid var(--line-soft); margin-bottom: 18px; }
.ex-card .ex-row .lbl { font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--cyan-strong); padding-top: 2px; }
.ex-card .ex-row .val { font-size: 13.5px; color: var(--ink); line-height: 1.55; }
.ex-card .ex-foot { margin-top: auto; font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.06em; color: var(--muted); text-transform: uppercase; display: flex; align-items: center; gap: 8px; }
.ex-card .ex-foot::before { content: ""; width: 6px; height: 6px; background: var(--cyan); transform: rotate(15deg); }

.confid { background: var(--seasalt); padding: 80px 0; border-top: 1px solid var(--line); }
.confid-inner { display: grid; grid-template-columns: 0.85fr 1.15fr; gap: 56px; align-items: start; }
.confid .left .eyebrow { display: inline-block; margin-bottom: 16px; }
.confid .left h2 { font-size: 36px; line-height: 1.1; margin-bottom: 18px; }
.confid .left p { font-size: 15px; color: var(--muted); line-height: 1.6; max-width: 380px; }
.confid .right { background: var(--white); border: 1px solid var(--line); border-radius: 12px; padding: 32px 36px; }
.confid .right .row { display: grid; grid-template-columns: 28px 1fr; gap: 14px; padding: 14px 0; border-bottom: 1px solid var(--line-soft); }
.confid .right .row:last-child { border-bottom: 0; }
.confid .right .row .ic { width: 22px; height: 22px; color: var(--amber); display: grid; place-items: center; font-weight: 800; background: rgba(216,144,23,0.10); border-radius: 50%; font-size: 14px; }
.confid .right .row p { font-size: 14px; color: var(--ink); line-height: 1.55; }

.cta-band { background: var(--yale-dark); color: var(--white); position: relative; overflow: hidden; }
.cta-band::before { content: ""; position: absolute; right: -60px; top: -60px; width: 320px; height: 320px; background: linear-gradient(45deg, transparent 48%, rgba(24,176,230,0.16) 48% 52%, transparent 52%); background-size: 30px 30px; transform: rotate(15deg); }
.cta-band-inner { padding: 80px 0; text-align: center; position: relative; z-index: 2; }
.cta-band .eyebrow { color: var(--cyan); margin-bottom: 16px; display: inline-block; }
.cta-band h2 { color: var(--white); font-size: 38px; line-height: 1.1; margin-bottom: 18px; max-width: 700px; margin-left: auto; margin-right: auto; }
.cta-band p { color: rgba(255,255,255,0.78); font-size: 16px; max-width: 560px; margin: 0 auto 28px; }
</style>
