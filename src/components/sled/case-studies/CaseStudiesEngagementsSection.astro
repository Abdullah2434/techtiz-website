---

<section class="sled-section bg-seasalt" id="engagements" aria-labelledby="engagements-heading">
  <SledPageWrap>
    <div class="sled-reveal mb-[clamp(2rem,4vw,3.25rem)] max-w-[720px]" data-sled-reveal>
      <Eyebrow text={ENGAGEMENTS_SECTION.eyebrow} showGlyph class="mb-3.5" />
      <h2 id="engagements-heading" class="sled-h2 leading-[1.12] text-yale-dark">
        {ENGAGEMENTS_SECTION.heading}
      </h2>
      <p class="mt-3.5 max-w-[640px] text-[15.5px] leading-[1.6] text-muted">{ENGAGEMENTS_SECTION.body}</p>
    </div>

    <div class="sled-reveal-stagger grid grid-cols-1 gap-[18px] lg:grid-cols-2" data-sled-reveal>
      {FEATURE_CARDS.map((card) => (
        <a
          href={card.href}
          class="sled-engagement-card group relative flex flex-col overflow-hidden rounded-2xl border border-line-soft bg-white text-inherit no-underline shadow-[0_1px_2px_rgba(14,38,64,0.1),0_1px_3px_1px_rgba(14,38,64,0.05)] transition-[transform,box-shadow,border-color] duration-300 hover:-translate-y-[3px] hover:border-cyan hover:shadow-[0_4px_8px_3px_rgba(14,38,64,0.08),0_1px_3px_rgba(14,38,64,0.12)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cyan"
        >
          <div class="flex flex-col bg-yale-dark p-4 sm:p-[18px]">
            <div class="flex h-[138px] items-center justify-center rounded-[9px] border border-white/[0.08] bg-white p-[18px] shadow-[0_14px_30px_rgba(0,0,0,0.3)]">
              <img
                src={card.logo}
                alt={card.logoAlt}
                class="h-auto max-h-full w-auto max-w-[172px] object-contain"
                loading="lazy"
                decoding="async"
              />
            </div>
            <p class="mt-2.5 font-mono text-[11px] leading-[1.5] text-white/70">{card.cap}</p>
          </div>

          <div class="flex flex-1 flex-col px-[22px] py-5">
            <div class="mb-3 flex items-start gap-3.5">
              <div class="min-w-0 flex-1">
                <h3 class="mb-1 text-[1.3rem] leading-[1.16] font-extrabold tracking-[-0.01em] text-yale-dark">
                  {card.heading}
                </h3>
                <p class="font-mono text-xs text-muted">{card.sub}</p>
              </div>
              <div class="flex shrink-0 gap-2">
                <span class="inline-flex items-center gap-[7px] rounded-[7px] bg-cyan/12 px-3 py-1.5 font-mono text-[11px] font-semibold tracking-[0.06em] text-cyan-strong">
                  <span
                    class="relative inline-block size-[9px] -translate-y-px rotate-[15deg] bg-cyan"
                    aria-hidden="true"
                  >
                    <span class="absolute left-[1px] top-[1px] size-[3px] bg-white" />
                  </span>
                  {card.state}
                </span>
                <span class="inline-flex items-center gap-1.5 rounded-[7px] bg-amber/12 px-3 py-1.5 font-mono text-[11px] font-semibold tracking-[0.06em] text-amber">
                  <FileClock class="size-3.5" aria-hidden="true" />
                  {card.tag}
                </span>
              </div>
            </div>

            <div class="grid grid-cols-2 gap-x-5 gap-y-[11px] border-y border-line-soft py-[13px]">
              {card.stats.map((stat) => (
                <div>
                  <div class="text-[1.4rem] leading-none font-bold tracking-[-0.02em] text-yale-dark">{stat.n}</div>
                  <div class="mt-[5px] text-[11.5px] text-muted">{stat.l}</div>
                </div>
              ))}
            </div>

            <div class="mt-[11px] flex flex-wrap items-center gap-3.5">
              <div class="flex flex-wrap gap-1.5">
                {card.chips.map((chip) => (
                  <span class="rounded-[6px] border border-line bg-seasalt px-[9px] py-1 font-mono text-[10.5px] text-muted">
                    {chip}
                  </span>
                ))}
              </div>
              <span class="ml-auto inline-flex shrink-0 items-center gap-2 whitespace-nowrap text-[13px] font-bold text-cyan-strong">
                Read the full case study
                <ArrowRight class="size-4 transition-transform duration-300 group-hover:translate-x-1" aria-hidden="true" />
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </SledPageWrap>
</section>
