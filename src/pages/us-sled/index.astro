---
import '../../styles/sled.css';
import SledLayout from '../../layouts/SledLayout.astro';
import SledHubHero from '../../components/sled/SledHubHero.astro';
import SledTrustStrip from '../../components/sled/SledTrustStrip.astro';
import WhoWeAreNotStripe from '../../components/sled/WhoWeAreNotStripe.astro';
import TwoStagesSection from '../../components/sled/TwoStagesSection.astro';
import OnshoreSection from '../../components/sled/OnshoreSection.astro';
import OperatingPrinciplesSection from '../../components/sled/OperatingPrinciplesSection.astro';
import OutcomesSection from '../../components/sled/OutcomesSection.astro';
import BackboneSection from '../../components/sled/BackboneSection.astro';
import SpecializationsSection from '../../components/sled/SpecializationsSection.astro';
import VehiclesSection from '../../components/sled/VehiclesSection.astro';
import WhyTechtizSection from '../../components/sled/WhyTechtizSection.astro';
import HubInquirySection from '../../components/sled/HubInquirySection.astro';
import { SLED_HUB_SEO } from '../../lib/constants/pages/sled-hub';

const { title, description, canonicalPath, ogImage } = SLED_HUB_SEO;
---

<SledLayout {title} {description} {canonicalPath} {ogImage} currentPage="/us-sled/">
  <SledHubHero />
  <SledTrustStrip />
  <WhoWeAreNotStripe />
  <TwoStagesSection />
  <OnshoreSection />
  <OperatingPrinciplesSection />
  <OutcomesSection />
  <BackboneSection />
  <SpecializationsSection />
  <VehiclesSection />
  <WhyTechtizSection />
  <HubInquirySection />
  <script src="/scripts/sled-hub.js" is:inline></script>
</SledLayout>
