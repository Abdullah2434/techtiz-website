        <div
          class="mega pointer-events-none invisible relative absolute top-[calc(100%+14px)] left-1/2 z-60 w-[760px] -translate-x-1/2 -translate-y-1 rounded-2xl border border-line bg-white p-[22px] opacity-0 shadow-[0_30px_60px_-20px_rgba(14,38,64,0.22),0_6px_18px_-8px_rgba(14,38,64,0.10)] transition-[opacity,transform,visibility] duration-[180ms] ease-out before:content-[''] before:absolute before:-top-2 before:left-1/2 before:size-3.5 before:-translate-x-1/2 before:rotate-45 before:rounded-tl before:border-t before:border-l before:border-line before:bg-white group-data-[open=true]:pointer-events-auto group-data-[open=true]:visible group-data-[open=true]:translate-x-[-50%] group-data-[open=true]:translate-y-0 group-data-[open=true]:opacity-100"
          role="menu"
        >
          <div class="mega-inner relative grid grid-cols-[250px_1fr] gap-[22px]">
            <div class="mega-left">
              <div class="mega-eyebrow mb-3.5 px-1.5 text-[17px] font-extrabold tracking-[-0.01em] text-yale-dark">Industries</div>
              <div class="mega-list flex flex-col gap-0.5" data-list="industries">
                <a class="mega-item group flex cursor-pointer items-center justify-between rounded-lg px-3.5 py-[11px] text-sm font-semibold text-ink transition-[background,color] duration-[180ms] ease-out hover:bg-cyan-soft hover:text-yale-dark [&.active]:bg-cyan-soft [&.active]:text-yale-dark" data-key="healthcare" href="/" aria-current="page">
                  Healthcare
                  <span class="arr-r size-2 rotate-[-45deg] border-r-[1.6px] border-b-[1.6px] border-current opacity-0 transition-opacity duration-[180ms] ease-out group-data-[active=true]:opacity-60"></span>
                </a>
                <a class="mega-item group flex cursor-pointer items-center justify-between rounded-lg px-3.5 py-[11px] text-sm font-semibold text-ink transition-[background,color] duration-[180ms] ease-out hover:bg-cyan-soft hover:text-yale-dark [&.active]:bg-cyan-soft [&.active]:text-yale-dark" data-key="marketing" href="/">
                  Digital Marketing
                  <span class="arr-r size-2 rotate-[-45deg] border-r-[1.6px] border-b-[1.6px] border-current opacity-0 transition-opacity duration-[180ms] ease-out group-data-[active=true]:opacity-60"></span>
                </a>
                <a class="mega-item group flex cursor-pointer items-center justify-between rounded-lg px-3.5 py-[11px] text-sm font-semibold text-ink transition-[background,color] duration-[180ms] ease-out hover:bg-cyan-soft hover:text-yale-dark [&.active]:bg-cyan-soft [&.active]:text-yale-dark" data-key="realestate" href="/">
                  Real Estate
                  <span class="arr-r size-2 rotate-[-45deg] border-r-[1.6px] border-b-[1.6px] border-current opacity-0 transition-opacity duration-[180ms] ease-out group-data-[active=true]:opacity-60"></span>
                </a>
                <a class="mega-item group flex cursor-pointer items-center justify-between rounded-lg px-3.5 py-[11px] text-sm font-semibold text-ink transition-[background,color] duration-[180ms] ease-out hover:bg-cyan-soft hover:text-yale-dark [&.active]:bg-cyan-soft [&.active]:text-yale-dark" data-key="ecommerce" href="/">
                  E-commerce
                  <span class="arr-r size-2 rotate-[-45deg] border-r-[1.6px] border-b-[1.6px] border-current opacity-0 transition-opacity duration-[180ms] ease-out group-data-[active=true]:opacity-60"></span>
                </a>
                <a class="mega-item group flex cursor-pointer items-center justify-between rounded-lg px-3.5 py-[11px] text-sm font-semibold text-ink transition-[background,color] duration-[180ms] ease-out hover:bg-cyan-soft hover:text-yale-dark [&.active]:bg-cyan-soft [&.active]:text-yale-dark" data-key="logistics" href="/">
                  Logistics &amp; Supply Chain
                  <span class="arr-r size-2 rotate-[-45deg] border-r-[1.6px] border-b-[1.6px] border-current opacity-0 transition-opacity duration-[180ms] ease-out group-data-[active=true]:opacity-60"></span>
                </a>
                <a class="mega-item group flex cursor-pointer items-center justify-between rounded-lg px-3.5 py-[11px] text-sm font-semibold text-ink transition-[background,color] duration-[180ms] ease-out hover:bg-cyan-soft hover:text-yale-dark [&.active]:bg-cyan-soft [&.active]:text-yale-dark" data-key="education" href="/">
                  Education
                  <span class="arr-r size-2 rotate-[-45deg] border-r-[1.6px] border-b-[1.6px] border-current opacity-0 transition-opacity duration-[180ms] ease-out group-data-[active=true]:opacity-60"></span>
                </a>
              </div>
            </div>
            <div class="mega-right flex flex-col border-l border-line-soft pl-[22px]">
              <div class="mega-feature mb-3.5 flex items-start gap-3.5 rounded-[10px] bg-cyan-soft p-4 px-[18px]" data-feature="industries">
                <div class="feat-icon grid size-[38px] shrink-0 place-items-center text-yale-dark">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 12h-4l-3 9L9 3l-3 9H2"></path>
                  </svg>
                </div>
                <div>
                  <h4 data-feat-title class="mb-1 text-[17px] leading-[1.2] text-yale-dark">Healthcare</h4>
                  <p data-feat-desc class="m-0 max-w-[360px] text-xs leading-[1.45] text-muted">Techtiz streamlines admin tasks for healthcare teams, enhancing efficiency and safety.</p>
                </div>
              </div>
              <div class="mega-sublinks grid grid-cols-2 gap-x-2 gap-y-0.5 py-1" data-sublinks="industries">
                <a href="/" class="rounded-md px-3 py-2 text-[13.5px] font-medium text-muted transition-[background,color] duration-[180ms] ease-out hover:bg-seasalt hover:text-yale">AI Appointment Management</a>
                <a href="/" class="rounded-md px-3 py-2 text-[13.5px] font-medium text-muted transition-[background,color] duration-[180ms] ease-out hover:bg-seasalt hover:text-yale">AI-Powered Communication</a>
                <a href="/" class="rounded-md px-3 py-2 text-[13.5px] font-medium text-muted transition-[background,color] duration-[180ms] ease-out hover:bg-seasalt hover:text-yale">Reporting Optimization</a>
                <a href="/" class="rounded-md px-3 py-2 text-[13.5px] font-medium text-muted transition-[background,color] duration-[180ms] ease-out hover:bg-seasalt hover:text-yale">Patient Records</a>
              </div>
              <div class="mega-footer mt-3.5 flex items-center justify-between border-t border-line-soft pt-3.5">
                <span class="mega-tag font-mono text-[10.5px] tracking-[0.14em] text-cyan-strong uppercase">U.S. SLED prime contractor?</span>
