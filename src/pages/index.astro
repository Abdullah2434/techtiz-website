---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/shared/Header.astro';
import Footer from '../components/shared/Footer.astro';
import CtaButton from '../components/shared/CtaButton.astro';

const seo = {
  title: 'Techtiz | AI-native engineering studio',
  description: 'Techtiz is an AI-native engineering studio building adaptive systems for ambitious teams. Specialized technical subcontractor for U.S. SLED prime contractors.',
  canonicalPath: '/',
  ogImage: '/assets/logo.svg',
};
---

<BaseLayout {...seo}>
  <Header currentPage="/" />
  <main>
    <section class="bg-white">
      <div class="mx-auto max-w-[1280px] px-12 max-[1024px]:px-8 max-[900px]:px-6 max-[600px]:px-[18px] py-[72px] max-[900px]:py-12">
        <div class="mb-10 flex justify-center">
          <div class="inline-flex items-center gap-2 rounded-full border border-line bg-white p-1 shadow-[0_8px_24px_-18px_rgba(14,38,64,0.20)]">
            <span class="inline-flex items-center rounded-full bg-yale-dark px-4 py-2 text-sm font-bold text-white">International teams</span>
            <a href="/us-sled/" class="inline-flex items-center gap-2 rounded-full px-4 py-2 text-sm font-bold text-yale hover:bg-seasalt">
              U.S. SLED primes <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>

        <div class="grid grid-cols-[1.1fr_0.9fr] items-center gap-14 max-[900px]:grid-cols-1 max-[900px]:gap-10">
          <div>
            <span class="mb-5 inline-flex items-center font-mono text-[11px] font-bold tracking-[0.18em] uppercase text-cyan-strong">
              <span class="relative mr-2 inline-block size-[11px] -translate-y-px rotate-15 bg-cyan align-middle" aria-hidden="true">
                <span class="absolute left-[1.5px] top-[1.5px] size-[3.5px] bg-white"></span>
              </span>
              Techtiz · AI-native engineering
            </span>
            <h1 class="text-[64px] leading-[1.02] tracking-[-0.03em] text-yale font-extrabold max-[1024px]:text-[56px] max-[600px]:text-[44px]">
              Reinvent your business with <span class="text-cyan">AI systems</span> that adapt and improve.
            </h1>
            <p class="mt-5 max-w-[680px] text-[18px] leading-[1.6] text-muted">
              An AI-native engineering studio for ambitious product teams worldwide, and a technical subcontractor to U.S. SLED prime contractors for back-office engineering delivery.
            </p>
            <div class="mt-8 flex flex-wrap gap-3.5">
              <CtaButton href="/us-sled/contact/" label="Talk to an Expert" variant="cta" />
              <CtaButton href="/#intro" label="Watch 90-sec intro" variant="ghost-light" />
            </div>
            <div class="mt-10 flex flex-wrap gap-x-10 gap-y-3 text-sm font-semibold text-muted">
              <span class="inline-flex items-center gap-2"><span class="inline-block size-2 rotate-15 bg-cyan" aria-hidden="true"></span> ISO-aligned delivery</span>
              <span class="inline-flex items-center gap-2"><span class="inline-block size-2 rotate-15 bg-cyan" aria-hidden="true"></span> Teams in 3 timezones</span>
              <span class="inline-flex items-center gap-2"><span class="inline-block size-2 rotate-15 bg-cyan" aria-hidden="true"></span> AI-native by default</span>
            </div>
          </div>

          <div class="relative overflow-hidden">
            <div class="absolute -left-8 -top-8 size-16 rotate-12 bg-cyan/10"></div>
            <div class="absolute -right-10 top-10 size-20 rotate-12 bg-yale/5"></div>
            <div class="overflow-hidden rounded-[18px] border border-line bg-white shadow-[0_30px_70px_-30px_rgba(14,38,64,0.30)]">
              <div class="border-b border-line bg-white px-5 py-3">
                <div class="flex items-center gap-2">
                  <span class="inline-flex gap-1.5" aria-hidden="true">
                    <span class="size-2 rounded-full bg-line"></span>
                    <span class="size-2 rounded-full bg-line"></span>
                    <span class="size-2 rounded-full bg-line"></span>
                  </span>
                  <div class="ml-2 flex-1 rounded-full border border-line-soft bg-seasalt px-4 py-2 font-mono text-[11px] font-bold text-muted">
                    agents.techtiz.io / <span class="text-cyan-strong">triage-v3</span>
                  </div>
                </div>
              </div>
              <div class="p-6 max-[600px]:p-5">
                <div class="flex items-start gap-4">
                  <div class="grid size-11 shrink-0 place-items-center rounded-xl bg-yale-dark text-white">
                    <span class="grid size-7 place-items-center rotate-12 rounded-[6px] bg-cyan" aria-hidden="true">
                      <span class="size-[10px] rotate-12 rounded-[2px] bg-white"></span>
                    </span>
                  </div>
                  <div class="min-w-0">
                    <div class="text-[15px] font-extrabold text-yale">Customer triage agent</div>
                    <div class="mt-1 flex flex-wrap gap-x-3 gap-y-1 font-mono text-[11px] font-bold text-muted">
                      <span>v3.2</span>
                      <span>·</span>
                      <span>prod</span>
                      <span>·</span>
                      <span>region us-east</span>
                    </div>
                  </div>
                </div>

                <div class="mt-6 grid grid-cols-2 gap-3">
                  <div class="rounded-xl border border-line-soft bg-seasalt p-4">
                    <div class="font-mono text-[10px] font-bold tracking-[0.14em] uppercase text-muted">Resolved</div>
                    <div class="mt-2 text-[26px] font-extrabold text-yale">94<span class="text-sm font-bold text-muted">%</span></div>
                    <div class="mt-1 text-[12px] font-semibold text-green">▲ 2.1 this week</div>
                  </div>
                  <div class="rounded-xl border border-line-soft bg-seasalt p-4">
                    <div class="font-mono text-[10px] font-bold tracking-[0.14em] uppercase text-muted">P95 latency</div>
                    <div class="mt-2 text-[26px] font-extrabold text-yale">312<span class="text-sm font-bold text-muted">ms</span></div>
                    <div class="mt-1 text-[12px] font-semibold text-muted">▼ 48 vs v3.1</div>
                  </div>
                </div>

                <div class="mt-6 rounded-xl border border-line-soft bg-white p-4">
                  <div class="text-[12px] font-bold text-yale">Resolution rate · last 14 days</div>
                  <div class="mt-3 h-24 w-full rounded-lg bg-seasalt">
                    <div class="h-full w-full bg-[linear-gradient(to_top,rgba(24,176,230,0.10),transparent_55%),linear-gradient(to_right,transparent_0%,rgba(21,58,95,0.08)_50%,transparent_100%)]"></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="mt-[54px] border-t border-line-soft pt-10">
          <div class="mb-5 text-center font-mono text-[11px] font-bold tracking-[0.18em] uppercase text-cyan-strong">
            Trusted by teams shipping at the edge
          </div>
          <div class="mx-auto grid max-w-[980px] grid-cols-3 gap-4 text-center text-[13px] font-semibold text-muted max-[600px]:grid-cols-2">
            {['LinkedGolf', 'Dashboard.Earth', 'Capsule Lab', 'Northstar Health', 'Meridian Logix', 'Orbital Studio'].map(name => (
              <div class="rounded-xl border border-line-soft bg-seasalt px-4 py-3">{name}</div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="border-t border-line bg-white py-[96px] max-[900px]:py-14">
      <div class="mx-auto max-w-[1280px] px-12 max-[1024px]:px-8 max-[900px]:px-6 max-[600px]:px-[18px]">
        <div class="mb-12 flex items-end justify-between gap-10 max-[900px]:flex-col max-[900px]:items-start max-[900px]:gap-4">
          <div class="max-w-[760px]">
            <span class="inline-flex items-center font-mono text-[11px] font-bold tracking-[0.18em] uppercase text-cyan-strong mb-3.5">
              Capabilities
            </span>
            <h2 class="text-[44px] leading-[1.05] tracking-[-0.022em] text-yale font-extrabold max-[900px]:text-[30px] max-[600px]:text-[26px]">
              A full engineering and design surface, wired for AI.
            </h2>
            <p class="mt-3.5 max-w-[620px] text-[15.5px] text-muted">
              Five interlocking practices. Engage one, or hand us the whole problem.
            </p>
          </div>
          <a href="/#capability-matrix" class="inline-flex items-center gap-2 border-b-2 border-cyan pb-1 text-sm font-bold text-yale hover:gap-3 transition-[gap] duration-200">
            See full capability matrix →
          </a>
        </div>

        <div class="grid grid-cols-3 gap-4 max-lg:grid-cols-2 max-sm:grid-cols-1">
          {[
            { title: 'Development', desc: 'Production-grade web, mobile, and platform engineering. Sketch to scale, with the same team across the whole arc.', cta: 'Explore development', href: '/#development' },
            { title: 'AI & Intelligence', desc: 'LLM systems, RAG, agents, and ML pipelines that ship and stay in production. Instrumented, evaluated, cost-controlled.', cta: 'Explore AI & intelligence', href: '/#ai' },
            { title: 'Automation & AI', desc: 'Internal tools and workflows that pay for themselves. Lead-gen, ops, support, billing, every flow that drains a Tuesday.', cta: 'Explore automation', href: '/#automation' },
            { title: 'Digital Transformation', desc: 'Modernize legacy stacks without halting the business. Strategy, migrations, data, operations, change management.', cta: 'Explore transformation', href: '/#transformation' },
            { title: 'UX Design', desc: 'Research-backed interfaces that feel inevitable. Systems, prototyping, brand, and the unglamorous edge cases.', cta: 'Explore UX design', href: '/#ux' },
            { title: 'Data & Platform', desc: 'Warehouses, lakehouses, and the pipelines that feed AI in production. Observability built in, not bolted on.', cta: 'Explore data', href: '/#data' },
          ].map(card => (
            <a
              href={card.href}
              class="group flex min-h-[220px] flex-col gap-3 rounded-[12px] border border-line bg-white px-[26px] py-7 transition-[transform,border-color,box-shadow] duration-220 ease-out hover:-translate-y-0.5 hover:border-[#C2CCD9] hover:shadow-[0_18px_36px_-18px_rgba(21,58,95,0.16)]"
            >
              <h3 class="text-[19px] leading-[1.2] font-extrabold text-yale">{card.title}</h3>
              <p class="text-sm leading-[1.55] text-muted">{card.desc}</p>
              <span class="mt-auto inline-flex items-center gap-2 border-b-2 border-transparent pb-1 text-sm font-bold text-yale group-hover:border-cyan transition-[gap,border-color] duration-200 group-hover:gap-3">
                {card.cta} →
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="border-t border-line bg-seasalt py-[96px] max-[900px]:py-14">
      <div class="mx-auto max-w-[1280px] px-12 max-[1024px]:px-8 max-[900px]:px-6 max-[600px]:px-[18px]">
        <div class="mb-10 flex items-end justify-between gap-10 max-[900px]:flex-col max-[900px]:items-start max-[900px]:gap-4">
          <div class="max-w-[760px]">
            <span class="inline-flex items-center font-mono text-[11px] font-bold tracking-[0.18em] uppercase text-cyan-strong mb-3.5">
              Industries
            </span>
            <h2 class="text-[44px] leading-[1.05] tracking-[-0.022em] text-yale font-extrabold max-[900px]:text-[30px] max-[600px]:text-[26px]">
              Empowering diverse business ecosystems.
            </h2>
            <p class="mt-3.5 max-w-[620px] text-[15.5px] text-muted">
              Intelligent solutions tailored for specific industry challenges.
            </p>
          </div>
          <a href="/#industries" class="inline-flex items-center gap-2 border-b-2 border-cyan pb-1 text-sm font-bold text-yale hover:gap-3 transition-[gap] duration-200">
            Explore all →
          </a>
        </div>

        <div class="grid grid-cols-6 gap-3 max-[1024px]:grid-cols-3 max-[600px]:grid-cols-2">
          {['Healthcare', 'Digital Marketing', 'Real Estate', 'E-commerce', 'Logistics', 'Education'].map(item => (
            <a href="/#industries" class="rounded-xl border border-line bg-white px-4 py-3 text-center text-[13.5px] font-semibold text-yale hover:bg-seasalt">
              {item}
            </a>
          ))}
        </div>

        <div class="mt-10 grid grid-cols-[1.2fr_0.8fr] gap-6 max-[900px]:grid-cols-1">
          <div class="rounded-2xl border border-line bg-white p-8 max-[600px]:p-6">
            <h3 class="text-[18px] font-extrabold text-yale">Healthcare insights</h3>
            <p class="mt-2 text-sm text-muted">Pain points we solve</p>
            <div class="mt-6 rounded-xl border border-line-soft bg-seasalt p-5">
              <div class="text-xs font-bold tracking-[0.14em] uppercase text-cyan-strong">What slows teams down today.</div>
              <ul class="mt-3 space-y-2.5 text-sm text-ink">
                {[
                  'Manual intake and triage across too many systems',
                  'Backlogs in authorizations, scheduling, and follow-ups',
                  'Low visibility into ops bottlenecks and outcomes',
                ].map(li => (
                  <li class="flex gap-2.5">
                    <span class="mt-2 inline-block size-2 rotate-15 bg-cyan" aria-hidden="true"></span>
                    <span>{li}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>

          <div class="rounded-2xl border border-line bg-white p-8 max-[600px]:p-6">
            <h3 class="text-[18px] font-extrabold text-yale">Talk to a healthcare specialist.</h3>
            <p class="mt-2 text-sm leading-[1.55] text-muted">A 30-minute scoping call, NDA-first, with the engineer who'd lead delivery.</p>
            <div class="mt-6">
              <CtaButton href="/us-sled/contact/" label="Book intro call" variant="primary" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="border-t border-line bg-white py-[96px] max-[900px]:py-14">
      <div class="mx-auto max-w-[1280px] px-12 max-[1024px]:px-8 max-[900px]:px-6 max-[600px]:px-[18px]">
        <div class="mb-10 max-w-[820px]">
          <span class="inline-flex items-center font-mono text-[11px] font-bold tracking-[0.18em] uppercase text-cyan-strong mb-3.5">
            Why teams choose us
          </span>
          <h2 class="text-[44px] leading-[1.05] tracking-[-0.022em] text-yale font-extrabold max-[900px]:text-[30px] max-[600px]:text-[26px]">
            Four reasons the engagement keeps compounding.
          </h2>
          <p class="mt-3.5 max-w-[620px] text-[15.5px] text-muted">
            Pick a pillar to see the shape of how we work.
          </p>
        </div>

        <div class="grid grid-cols-4 gap-4 max-[1024px]:grid-cols-2 max-[600px]:grid-cols-1">
          {[
            {
              k: '01',
              title: 'Expert Team.',
              desc: "Our team isn't junior devs learning on your dime. Every project is led by senior engineers and designers with 8+ years across fintech, SaaS, healthcare, and e-commerce.",
            },
            {
              k: '02',
              title: 'On-Time Delivery',
              desc: 'Clear scope. Fast feedback. No surprises. Transparent milestones with quality gates before every release.',
            },
            {
              k: '03',
              title: 'Scalable Solutions',
              desc: 'Architected for longevity: observability, maintainability, and performance are built-in, not bolted on.',
            },
            {
              k: '04',
              title: 'Ongoing Support',
              desc: "We don't disappear after launch. We iterate, harden, and extend the system as your needs evolve.",
            },
          ].map(p => (
            <div class="rounded-2xl border border-line bg-white p-7">
              <div class="mb-4 font-mono text-[11px] font-bold tracking-[0.18em] uppercase text-cyan-strong">{p.k}</div>
              <h3 class="text-[18px] font-extrabold text-yale">{p.title}</h3>
              <p class="mt-2 text-sm leading-[1.6] text-muted">{p.desc}</p>
            </div>
          ))}
        </div>

        <div class="mt-8 flex flex-wrap items-center gap-3">
          <div class="rounded-xl border border-line-soft bg-seasalt px-4 py-3 text-sm font-semibold text-yale">8+ Avg. years experience</div>
          <div class="rounded-xl border border-line-soft bg-seasalt px-4 py-3 text-sm font-semibold text-yale">5+ Years shipping</div>
          <div class="rounded-xl border border-line-soft bg-seasalt px-4 py-3 text-sm font-semibold text-yale">98% Client satisfaction</div>
          <div class="rounded-xl border border-line-soft bg-seasalt px-4 py-3 text-sm font-semibold text-yale">180+ Projects delivered</div>
          <div class="rounded-xl border border-line-soft bg-seasalt px-4 py-3 text-sm font-semibold text-yale">200+ Clients served</div>
          <div class="ml-auto max-[900px]:ml-0">
            <CtaButton href="/us-sled/contact/" label="Get started" variant="primary" />
          </div>
        </div>
      </div>
    </section>

    <section class="border-t border-line bg-seasalt py-[96px] max-[900px]:py-14">
      <div class="mx-auto max-w-[1280px] px-12 max-[1024px]:px-8 max-[900px]:px-6 max-[600px]:px-[18px]">
        <div class="mb-10 flex items-end justify-between gap-10 max-[900px]:flex-col max-[900px]:items-start max-[900px]:gap-4">
          <div class="max-w-[780px]">
            <span class="inline-flex items-center font-mono text-[11px] font-bold tracking-[0.18em] uppercase text-cyan-strong mb-3.5">
              Selected work
            </span>
            <h2 class="text-[44px] leading-[1.05] tracking-[-0.022em] text-yale font-extrabold max-[900px]:text-[30px] max-[600px]:text-[26px]">
              Outcomes, not artifacts.
            </h2>
            <p class="mt-3.5 max-w-[620px] text-[15.5px] text-muted">
              A few of the products we've taken from sketch to scale.
            </p>
          </div>
          <a href="/us-sled/case-studies/" class="inline-flex items-center gap-2 border-b-2 border-cyan pb-1 text-sm font-bold text-yale hover:gap-3 transition-[gap] duration-200">
            All case studies →
          </a>
        </div>

        <div class="grid grid-cols-3 gap-4 max-lg:grid-cols-2 max-sm:grid-cols-1">
          {[
            {
              tag: 'Climate Analytics',
              title: 'LinkedGolf',
              challenge: 'Tee-time inventory fragmented across 1,200+ operators.',
              solution: 'Unified marketplace plus a booking SDK with realtime supply sync.',
              outcome: '+312% bookings · 4.8★ App Store · 11s avg checkout',
            },
            {
              tag: 'Climate Analytics',
              title: 'Dashboard.Earth',
              challenge: 'Climate teams stitching 40+ data sources by hand.',
              solution: 'Lakehouse plus an LLM-driven exploration UI on top of curated sets.',
              outcome: '-87% time-to-insight · adopted by 14 NGOs',
            },
            {
              tag: 'Healthtech Web',
              title: 'Capsule Lab',
              challenge: 'Lab results delivered as static PDFs, low patient engagement.',
              solution: 'Interactive longitudinal viewer with AI explanations.',
              outcome: '4.2× weekly active · NPS +38',
            },
          ].map(cs => (
            <div class="rounded-2xl border border-line bg-white p-7">
              <div class="text-xs font-bold tracking-[0.14em] uppercase text-cyan-strong">{cs.tag}</div>
              <h3 class="mt-3 text-[18px] font-extrabold text-yale">{cs.title}</h3>
              <div class="mt-4 space-y-2 text-sm text-muted">
                <div><span class="font-bold text-yale">Challenge</span> {cs.challenge}</div>
                <div><span class="font-bold text-yale">Solution</span> {cs.solution}</div>
                <div><span class="font-bold text-yale">Outcome</span> {cs.outcome}</div>
              </div>
              <a href="/us-sled/case-studies/" class="mt-6 inline-flex items-center gap-2 border-b-2 border-cyan pb-1 text-sm font-bold text-yale hover:gap-3 transition-[gap] duration-200">
                Read the case study →
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="border-t border-line bg-white py-[96px] max-[900px]:py-14">
      <div class="mx-auto max-w-[1280px] px-12 max-[1024px]:px-8 max-[900px]:px-6 max-[600px]:px-[18px]">
        <div class="mb-10 max-w-[820px]">
          <span class="inline-flex items-center font-mono text-[11px] font-bold tracking-[0.18em] uppercase text-cyan-strong mb-3.5">
            How we work
          </span>
          <h2 class="text-[44px] leading-[1.05] tracking-[-0.022em] text-yale font-extrabold max-[900px]:text-[30px] max-[600px]:text-[26px]">
            Three ways to engage. One bar for quality.
          </h2>
        </div>

        <div class="grid grid-cols-3 gap-4 max-lg:grid-cols-2 max-sm:grid-cols-1">
          {[
            { k: '01 · Fixed scope', title: 'Fixed Scope', desc: 'Defined deliverables, milestone billing. Predictable from day one.', best: 'Well-scoped MVPs and rebuilds with clear acceptance criteria.' },
            { k: 'Most popular 02 · Time & materials', title: 'Time & Materials', desc: 'Weekly sprints, billed against effort. Steerable as scope evolves.', best: 'Evolving scope, R&D, and most AI work where the spec is a moving target.' },
            { k: '03 · Retainer', title: 'Retainer', desc: 'Embedded squad, predictable monthly spend. Roadmap-owning team.', best: 'Long-term roadmap ownership across multiple workstreams.' },
          ].map(m => (
            <div class="rounded-2xl border border-line bg-white p-7">
              <div class="text-xs font-bold tracking-[0.14em] uppercase text-cyan-strong">{m.k}</div>
              <h3 class="mt-3 text-[18px] font-extrabold text-yale">{m.title}</h3>
              <p class="mt-2 text-sm leading-[1.6] text-muted">{m.desc}</p>
              <div class="mt-4 text-sm text-muted">
                <span class="font-bold text-yale">Best for</span> {m.best}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="border-t border-line bg-yale-dark py-[96px] text-white max-[900px]:py-14">
      <div class="mx-auto max-w-[1280px] px-12 max-[1024px]:px-8 max-[900px]:px-6 max-[600px]:px-[18px] grid grid-cols-[1.1fr_0.9fr] items-center gap-12 max-[900px]:grid-cols-1">
        <div>
          <h2 class="text-[44px] leading-[1.05] tracking-[-0.022em] font-extrabold max-[900px]:text-[30px] max-[600px]:text-[26px]">
            Have an idea worth building? Let's pressure-test it.
          </h2>
          <p class="mt-4 max-w-[640px] text-[15.5px] leading-[1.6] text-white/75">
            A 30-minute call with a senior engineer. No deck, no pitch. We'll sketch the system on the call.
          </p>
          <div class="mt-7">
            <CtaButton href="/us-sled/contact/" label="Book a Consultation →" variant="cta" />
          </div>
        </div>
        <div class="rounded-2xl border border-white/12 bg-white/6 p-8 max-[600px]:p-6">
          <div class="font-mono text-[11px] font-bold tracking-[0.18em] uppercase text-cyan">Start the conversation</div>
          <p class="mt-3 text-sm leading-[1.6] text-white/75">Prefer email? Reach us at <a class="font-bold text-white underline decoration-white/25 hover:decoration-white" href="mailto:hello@techtiz.co">hello@techtiz.co</a>.</p>
          <p class="mt-4 text-xs text-white/60">NDA-first when needed. Senior-led delivery. Clear milestones.</p>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
