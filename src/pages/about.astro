---
import '../styles/about.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/shared/Header.astro';
import Footer from '../components/shared/Footer.astro';
import AboutHero from '../components/about/AboutHero.astro';
import AboutValuesSection from '../components/about/AboutValuesSection.astro';
import AboutStatsSection from '../components/about/AboutStatsSection.astro';
import AboutLeadershipSection from '../components/about/AboutLeadershipSection.astro';
import IndustryCta from '../components/industries/IndustryCta.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import { ABOUT_SEO } from '../lib/config/about';
import {
  ABOUT_CTA,
  ABOUT_HERO,
  ABOUT_LEADERS,
  ABOUT_STATS,
  ABOUT_VALUES,
} from '../lib/constants/pages/about';
import { ROUTES } from '../lib/constants/routes';
import { SITE } from '../lib/constants/site';
import { aboutPageJsonLd } from '../lib/seo/json-ld';

const { title, description, canonicalPath } = ABOUT_SEO;
const pageUrl = `${SITE.url}${canonicalPath}`;
const aboutJsonLd = aboutPageJsonLd({ title, description, url: pageUrl });
---

<BaseLayout {title} {description} {canonicalPath} jsonLd={[aboutJsonLd]}>
  <Header currentPage={ROUTES.about} />
  <main id="main-content" class="bg-white">
    <div class="mx-auto max-w-[1400px] px-2 pt-4">
      <Breadcrumbs {canonicalPath} />
    </div>
    <AboutHero {...ABOUT_HERO} />
    <AboutValuesSection values={ABOUT_VALUES} />
    <AboutStatsSection stats={ABOUT_STATS} />
    <AboutLeadershipSection leaders={ABOUT_LEADERS} />
    <IndustryCta {...ABOUT_CTA} />
  </main>
  <Footer />
  <script src="/scripts/nav.js" is:inline></script>
  <script src="/scripts/mobile-nav.js" is:inline></script>
  <script src="/scripts/about-values.js" is:inline></script>
  <script src="/scripts/about-stats.js" is:inline></script>
</BaseLayout>
