---
import { SEQUENCE_SECTION, SEQUENCE_STEPS } from '../../../lib/constants/pages/how-we-engage';
import Eyebrow from '../../shared/Eyebrow.astro';
import SledPageWrap from '../shared/SledPageWrap.astro';
import SledSpecAccordion from '../shared/SledSpecAccordion.astro';
---

<section class="sled-section border-b border-line/60 bg-white" id="sequence" data-screen-label="02 Sequence">
  <SledPageWrap>
    <div class="sled-reveal mb-[clamp(2rem,4vw,3.25rem)] max-w-[720px]" data-sled-reveal>
      <Eyebrow text={SEQUENCE_SECTION.eyebrow} showGlyph class="mb-3.5" />
      <h2 class="sled-h2 leading-[1.12] text-yale-dark max-w-[25ch]">{SEQUENCE_SECTION.heading}</h2>
      <p class="mt-3.5 max-w-[600px] text-[15.5px] leading-[1.6] text-muted">{SEQUENCE_SECTION.body}</p>
    </div>

    <div class="sled-reveal" data-sled-reveal>
      <SledSpecAccordion items={SEQUENCE_STEPS} defaultOpen={0} />
    </div>
  </SledPageWrap>
</section>
