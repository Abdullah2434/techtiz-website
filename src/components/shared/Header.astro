---
interface Props {
  currentPage?: string;
}

const { currentPage = '' } = Astro.props;
const isSled = currentPage.startsWith('/us-sled') || Astro.url?.pathname?.startsWith('/us-sled');
---

<header class="top sticky top-0 z-50 border-b border-line bg-white/94 backdrop-blur-[10px]">
  <div class="nav mx-auto max-w-[1280px] px-12 max-[1024px]:px-8 max-[900px]:px-6 max-[600px]:px-[18px] grid h-[76px] grid-cols-[1fr_auto_1fr] items-center max-[900px]:h-[64px]">
    <a
      href="/"
      class="brand-mark inline-flex items-center gap-2.5"
      aria-label="Techtiz home"
    >
      <img src="/assets/logo.svg" alt="Techtiz" class="brand-logo block h-[26px] w-auto" />
    </a>

    <nav class="primary-nav inline-flex items-center gap-0.5 max-[900px]:hidden" aria-label="Primary">
      <a href="/" class="nav-link relative inline-flex cursor-pointer items-center gap-1.5 whitespace-nowrap rounded-lg border border-transparent bg-transparent px-4 py-2.5 font-sans text-[14.5px] font-semibold leading-none text-ink transition-[color,background,border-color] duration-[180ms] ease-out hover:bg-yale/4 hover:text-yale">
        About Us
      </a>

      <div class="nav-item relative group" data-mega="services">
        <button
          class="nav-link nav-link relative inline-flex cursor-pointer items-center gap-1.5 whitespace-nowrap rounded-lg border border-transparent bg-transparent px-4 py-2.5 font-sans text-[14.5px] font-semibold leading-none text-ink transition-[color,background,border-color] duration-[180ms] ease-out hover:bg-yale/4 hover:text-yale group-data-[open=true]:border-line group-data-[open=true]:bg-white group-data-[open=true]:text-yale group-data-[open=true]:shadow-[0_1px_2px_rgba(14,38,64,0.04)]"
          type="button"
          aria-expanded="false"
        >
          Services <span class="chev size-[7px] -translate-x-px -translate-y-px rotate-45 border-r-[1.6px] border-b-[1.6px] border-current opacity-55 transition-transform duration-220 ease-out group-data-[open=true]:-translate-x-px group-data-[open=true]:-translate-y-px group-data-[open=true]:-rotate-[135deg]"></span>
        </button>
        <div
          class="mega pointer-events-none invisible relative absolute top-[calc(100%+14px)] left-1/2 z-60 w-[760px] -translate-x-1/2 -translate-y-1 rounded-2xl border border-line bg-white p-[22px] opacity-0 shadow-[0_30px_60px_-20px_rgba(14,38,64,0.22),0_6px_18px_-8px_rgba(14,38,64,0.10)] transition-[opacity,transform,visibility] duration-[180ms] ease-out before:content-[''] before:absolute before:-top-2 before:left-1/2 before:size-3.5 before:-translate-x-1/2 before:rotate-45 before:rounded-tl before:border-t before:border-l before:border-line before:bg-white group-data-[open=true]:pointer-events-auto group-data-[open=true]:visible group-data-[open=true]:translate-x-[-50%] group-data-[open=true]:translate-y-0 group-data-[open=true]:opacity-100"
          role="menu"
        >
          <div class="mega-inner relative grid grid-cols-[250px_1fr] gap-[22px]">
            <div class="mega-left">
              <div class="mega-eyebrow mb-3.5 px-1.5 text-[17px] font-extrabold tracking-[-0.01em] text-yale-dark">We Offer</div>
              <div class="mega-list flex flex-col gap-0.5" data-list="services">
                <a class="mega-item group flex cursor-pointer items-center justify-between rounded-lg px-3.5 py-[11px] text-sm font-semibold text-ink transition-[background,color] duration-[180ms] ease-out hover:bg-cyan-soft hover:text-yale-dark [&.active]:bg-cyan-soft [&.active]:text-yale-dark" data-key="development" href="/" aria-current="page">
                  Development
                  <span class="arr-r size-2 rotate-[-45deg] border-r-[1.6px] border-b-[1.6px] border-current opacity-0 transition-opacity duration-[180ms] ease-out group-data-[active=true]:opacity-60"></span>
                </a>
                <a class="mega-item group flex cursor-pointer items-center justify-between rounded-lg px-3.5 py-[11px] text-sm font-semibold text-ink transition-[background,color] duration-[180ms] ease-out hover:bg-cyan-soft hover:text-yale-dark [&.active]:bg-cyan-soft [&.active]:text-yale-dark" data-key="ai" href="/">
                  AI &amp; Intelligence
                  <span class="arr-r size-2 rotate-[-45deg] border-r-[1.6px] border-b-[1.6px] border-current opacity-0 transition-opacity duration-[180ms] ease-out group-data-[active=true]:opacity-60"></span>
                </a>
                <a class="mega-item group flex cursor-pointer items-center justify-between rounded-lg px-3.5 py-[11px] text-sm font-semibold text-ink transition-[background,color] duration-[180ms] ease-out hover:bg-cyan-soft hover:text-yale-dark [&.active]:bg-cyan-soft [&.active]:text-yale-dark" data-key="automation" href="/">
