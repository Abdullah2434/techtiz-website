---
import { INDUSTRIES_DATA, INDUSTRY_TABS } from "../../lib/constants/pages/home";
import IndustryIcon from "./IndustryIcon.astro";
import PageWrap from "./PageWrap.astro";

const initial = INDUSTRIES_DATA.healthcare;
const IND_ICON_KEYS = [
  "heart",
  "growth",
  "house",
  "cart",
  "truck",
  "grad",
] as const;

const challengeItems = initial.challenges
  .map(
    (c) =>
      `<div class="home-ind-challenge"><div class="home-ind-ch-title">${c.title}</div><div class="home-ind-ch-pain">${c.pain}</div></div>`,
  )
  .join("");
---

<section
  id="industries"
  class="home-industries relative overflow-hidden bg-yale-dark py-[70px] text-white max-[900px]:py-14"
>
  <div
    class="pointer-events-none absolute -right-[60px] -bottom-[60px] size-[320px] rotate-[15deg] opacity-70 bg-[linear-gradient(45deg,transparent_48%,rgba(24,176,230,0.12)_48%_52%,transparent_52%)] bg-size-[28px_28px]"
    aria-hidden="true"
  >
  </div>

  <PageWrap class="relative z-[2]">
    <div
      class="relative z-[2] mb-14 flex items-end justify-between gap-12 max-[900px]:mb-9 max-[900px]:flex-col max-[900px]:items-start max-[900px]:gap-4"
    >
      <div class="max-w-[700px]">
        <span
          class="mb-3 inline-flex font-mono text-[11px] font-bold tracking-[0.18em] text-cyan-strong uppercase"
        >
          Industries
        </span>
        <h2
          class="text-[34px] leading-[1.1] font-semibold tracking-[-0.022em] text-white max-[900px]:text-[30px] max-[640px]:text-[24px]"
        >
          Empowering diverse <span class="text-cyan">business ecosystems.</span>
        </h2>
        <p class="mt-3.5 max-w-[540px] text-[15px] text-white/72">
          Intelligent solutions tailored for specific industry challenges.
        </p>
      </div>
      <a
        href="/industries/"
        class="inline-flex shrink-0 items-center gap-2 border-b-2 border-cyan pb-1 text-sm font-bold text-cyan transition-[gap] duration-200 hover:gap-3.5"
      >
        Explore all →
      </a>
    </div>

    <div
      class="home-ind-tabs relative z-[2] mb-[22px] flex flex-wrap gap-2"
      role="tablist"
      data-ind-tabs
    >
      {
        INDUSTRY_TABS.map((tab, i) => (
          <button
            type="button"
            class:list={["home-ind-tab", i === 0 && "is-active"]}
            role="tab"
            data-ind={tab.id}
            aria-selected={i === 0 ? "true" : "false"}
          >
            {tab.label}
          </button>
        ))
      }
    </div>

    <div
      class="home-ind-panel relative z-[2] grid grid-cols-[1.1fr_1fr_0.9fr] items-stretch gap-4 max-[900px]:grid-cols-1 max-[900px]:gap-7"
      data-ind-panel
    >
      <div
        class="home-ind-card home-ind-insights flex flex-col rounded-[14px] border border-white/10 bg-white/4 px-[30px] py-8 max-[600px]:px-6 max-[600px]:py-6"
      >
        <div class="mb-[18px] flex items-center gap-3">
          <div
            class="home-ind-icon grid size-11 shrink-0 place-items-center rounded-[10px] bg-cyan/12 text-cyan [&_svg]:size-[22px]"
            data-ind-icon
          >
            <IndustryIcon name={initial.icon} />
          </div>
        </div>
        <h3
          class="mb-3 text-2xl leading-[1.2] font-semibold text-white"
          data-ind-title
        >
          {initial.title}
        </h3>
        <p
          class="mb-[22px] text-[14.5px] leading-[1.6] text-white/72"
          data-ind-desc
        >
          {initial.desc}
        </p>
        <div class="mt-auto flex flex-col gap-2.5" data-ind-badges>
          {
            initial.badges.map((b) => (
              <span class="home-ind-badge">
                <strong>{b.strong}</strong>
                {b.rest}
              </span>
            ))
          }
        </div>
      </div>

      <div
        class="home-ind-card home-ind-challenges flex flex-col rounded-[14px] border border-white/10 bg-white/4 px-[30px] py-8 max-[600px]:px-6 max-[600px]:py-6"
      >
        <div
          class="mb-1 font-mono text-[11px] font-semibold tracking-[0.14em] text-cyan uppercase"
        >
          Pain points we solve
        </div>
        <h4
          class="mb-[18px] text-base leading-[1.3] font-bold text-white"
          data-ind-ch-head
        >
          {initial.chHead}
        </h4>
        <div class="home-ind-ch-reel" data-ind-challenges>
          <div class="home-ind-ch-track">
            <div class="home-ind-ch-set" set:html={challengeItems} />
            <div class="home-ind-ch-set" aria-hidden="true" set:html={challengeItems} />
          </div>
        </div>
      </div>

      <div
        class="home-ind-card home-ind-cta relative flex flex-col overflow-hidden rounded-[14px] border border-yale-mid bg-yale px-[30px] py-8 max-[600px]:px-6 max-[600px]:py-6"
      >
        <div
          class="home-ind-icon relative z-[2] mb-7 grid size-11 place-items-center rounded-[10px] bg-white/10 text-cyan [&_svg]:size-[22px]"
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.7"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            class="size-[22px]"
          >
            <circle cx="12" cy="12" r="3"></circle>
            <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"></path>
          </svg>
        </div>
        <h3
          class="relative z-[2] mb-3.5 max-w-[260px] text-[26px] leading-[1.15] font-semibold text-white"
          data-ind-cta-title
        >
          {initial.cta}
        </h3>
        <p
          class="relative z-[2] mb-7 text-[13.5px] leading-[1.55] text-white/72"
          data-ind-cta-sub
        >
          {initial.ctaSub}
        </p>
        <a href="/contact/" class="home-ind-cta-btn relative z-[2]">
          Book intro call
          <span class="home-ind-cta-arr" aria-hidden="true"></span>
        </a>
      </div>
    </div>

    <div class="hidden" aria-hidden="true" id="home-ind-icon-templates">
      {
        IND_ICON_KEYS.map((key) => (
          <template data-ind-icon={key}>
            <IndustryIcon name={key} />
          </template>
        ))
      }
    </div>
  </PageWrap>
</section>

<script define:vars={{ industriesData: INDUSTRIES_DATA }}>
  const panel = document.querySelector("[data-ind-panel]");
  const tabs = document.querySelectorAll("[data-ind-tabs] [data-ind]");
  if (!panel || !tabs.length) return;

  const iconEl = panel.querySelector("[data-ind-icon]");
  const titleEl = panel.querySelector("[data-ind-title]");
  const descEl = panel.querySelector("[data-ind-desc]");
  const badgesEl = panel.querySelector("[data-ind-badges]");
  const chHeadEl = panel.querySelector("[data-ind-ch-head]");
  const chEl = panel.querySelector("[data-ind-challenges]");
  const ctaTitleEl = panel.querySelector("[data-ind-cta-title]");
  const ctaSubEl = panel.querySelector("[data-ind-cta-sub]");
  const cards = panel.querySelectorAll(".home-ind-card");

  const iconTemplates = document.getElementById("home-ind-icon-templates");

  const getIconMarkup = (key) => {
    const template = iconTemplates?.querySelector(`template[data-ind-icon="${key}"]`);
    return template?.innerHTML ?? "";
  };

  const buildChallengeItems = (challenges) =>
    challenges
      .map(
        (c) =>
          `<div class="home-ind-challenge"><div class="home-ind-ch-title">${c.title}</div><div class="home-ind-ch-pain">${c.pain}</div></div>`,
      )
      .join("");

  const buildChallengesHtml = (challenges) => {
    const items = buildChallengeItems(challenges);
    return `<div class="home-ind-ch-track"><div class="home-ind-ch-set">${items}</div><div class="home-ind-ch-set" aria-hidden="true">${items}</div></div>`;
  };

  const setTabState = (tab, on) => {
    tab.setAttribute("aria-selected", on ? "true" : "false");
    tab.classList.toggle("is-active", on);
  };

  const render = (key) => {
    const d = industriesData[key];
    if (!d) return;

    cards.forEach((card) => card.classList.add("is-fade"));

    setTimeout(() => {
      if (iconEl) {
        const markup = getIconMarkup(d.icon);
        if (markup) iconEl.innerHTML = markup;
      }
      if (titleEl) titleEl.textContent = d.title;
      if (descEl) descEl.textContent = d.desc;
      if (badgesEl) {
        badgesEl.innerHTML = d.badges
          .map(
            (b) =>
              `<span class="home-ind-badge"><strong>${b.strong}</strong>${b.rest}</span>`,
          )
          .join("");
      }
      if (chHeadEl) chHeadEl.textContent = d.chHead;
      if (chEl) chEl.innerHTML = buildChallengesHtml(d.challenges);
      if (ctaTitleEl) ctaTitleEl.textContent = d.cta;
      if (ctaSubEl) ctaSubEl.textContent = d.ctaSub;
      cards.forEach((card) => card.classList.remove("is-fade"));
    }, 180);

    setTimeout(() => {
      cards.forEach((card) => {
        card.style.transition = "none";
        card.style.opacity = "1";
        card.style.transform = "none";
        requestAnimationFrame(() => {
          card.style.transition = "";
          card.style.opacity = "";
          card.style.transform = "";
          card.classList.remove("is-fade");
        });
      });
    }, 700);
  };

  tabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      if (tab.classList.contains("is-active")) return;
      tabs.forEach((t) => setTabState(t, t === tab));
      render(tab.getAttribute("data-ind"));
    });
  });
</script>
