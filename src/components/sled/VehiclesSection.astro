---
import { VEHICLES, VEHICLES_SECTION } from '../../lib/constants/pages/sled-hub';
import { SITE } from '../../lib/constants/site';
import Eyebrow from '../shared/Eyebrow.astro';
import SledIcon from './SledIcon.astro';
import SledPageWrap from './SledPageWrap.astro';
---

<section class="bg-seasalt py-[110px] max-[900px]:py-16" id="vehicles" data-screen-label="08 Vehicles">
  <SledPageWrap>
    <Eyebrow text={VEHICLES_SECTION.eyebrow} showGlyph class="mb-3.5" />

    <div class="mb-10 grid grid-cols-1 gap-8 lg:grid-cols-[1.05fr_0.95fr] lg:items-end">
      <h2 class="text-[40px] font-extrabold tracking-[-0.022em] text-yale-dark max-[900px]:text-[30px]">
        {VEHICLES_SECTION.heading}
      </h2>
      <div class="flex flex-col gap-3 lg:items-end">
        <p class="max-w-[460px] text-[15.5px] leading-[1.6] text-muted lg:text-right">{VEHICLES_SECTION.sub}</p>
        <div class="font-mono text-[11px] tracking-[0.10em] uppercase text-muted lg:text-right">
          {VEHICLES_SECTION.emailPrompt}<br />
          Email <a class="border-b border-cyan pb-px text-yale" href={`mailto:${SITE.email.sled}`}>{SITE.email.sled}</a>
        </div>
      </div>
    </div>

    <div class="overflow-hidden rounded-[14px] border border-line bg-white">
      <div class="grid grid-cols-1 lg:grid-cols-3">
        {VEHICLES.map((v, idx) => (
          <div
            class:list={[
              'grid grid-cols-[44px_1fr] gap-4 p-[30px] pb-[26px]',
              idx % 3 !== 2 && 'lg:border-r lg:border-line',
              idx < 3 && 'border-b border-line lg:border-b',
              idx >= 3 && 'border-b border-line lg:border-b-0',
            ]}
          >
            <div class="grid size-11 place-items-center rounded-[10px] bg-cyan-soft text-cyan-strong">
              <SledIcon name="award" class="size-[22px]" />
            </div>
            <div>
              <h4 class="mb-1 text-[17px] font-extrabold text-yale-dark">{v.heading}</h4>
              <div class="mb-[14px] text-[13.5px] leading-[1.45] text-muted">{v.sub}</div>
              <div class="inline-flex items-center gap-2 font-mono text-[11.5px] tracking-[0.04em] text-cyan-strong">
                <span class="size-1.5 rotate-[15deg] bg-cyan" aria-hidden="true"></span>
                {v.note}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </SledPageWrap>
</section>
