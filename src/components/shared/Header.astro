  <style>
    @keyframes usPillDotPulse {
      0% {
        box-shadow: 0 0 0 0 rgba(24,176,230,0.55);
      }
      70% {
        box-shadow: 0 0 0 6px rgba(24,176,230,0);
      }
      100% {
        box-shadow: 0 0 0 0 rgba(24,176,230,0);
      }
    }
  </style>
</header>
