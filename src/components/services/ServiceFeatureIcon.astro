---
/** Legacy FeatureIcons.tsx — cycled by feature index % 6 */
export const SERVICE_FEATURE_ICON_COUNT = 6;

interface Props {
  index: number;
  class?: string;
}

const { index, class: className = 'size-12' } = Astro.props;
const variant = index % SERVICE_FEATURE_ICON_COUNT;
---

<span class:list={['inline-flex shrink-0', className]} aria-hidden="true">
  {
    variant === 0 && (
      <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" class="size-full">
        <path
          d="M8 16L24 8L40 16V32L24 40L8 32V16Z"
          stroke="#1E1E1E"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
        <path d="M24 8V24" stroke="#1E1E1E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
        ></path>
        <path d="M8 16L24 24L40 16" stroke="#1E1E1E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
        ></path>
        <path d="M8 32L24 24L40 32" stroke="#1E1E1E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
        ></path>
      </svg>
    )
  }
  {
    variant === 1 && (
      <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" class="size-full">
        <rect
          x="6"
          y="12"
          width="16"
          height="24"
          rx="2"
          stroke="#1E1E1E"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"></rect>
        <rect
          x="26"
          y="12"
          width="16"
          height="24"
          rx="2"
          stroke="#1E1E1E"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"></rect>
        <path d="M18 24L30 24" stroke="#1E1E1E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
        ></path>
        <path d="M14 20L34 20" stroke="#1E1E1E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
        ></path>
      </svg>
    )
  }
  {
    variant === 2 && (
      <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" class="size-full">
        <rect
          x="12"
          y="32"
          width="24"
          height="8"
          rx="1"
          stroke="#1E1E1E"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"></rect>
        <rect
          x="16"
          y="20"
          width="16"
          height="8"
          rx="1"
          stroke="#1E1E1E"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"></rect>
        <rect
          x="20"
          y="8"
          width="8"
          height="8"
          rx="1"
          stroke="#1E1E1E"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"></rect>
        <path d="M24 16V20" stroke="#1E1E1E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        <path d="M24 28V32" stroke="#1E1E1E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
    )
  }
  {
    variant === 3 && (
      <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" class="size-full">
        <path
          d="M24 4L8 10V22C8 32 24 44 24 44C24 44 40 32 40 22V10L24 4Z"
          stroke="#1E1E1E"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
        <path d="M18 24L22 28L30 20" stroke="#1E1E1E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
        ></path>
      </svg>
    )
  }
  {
    variant === 4 && (
      <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" class="size-full">
        <circle cx="24" cy="24" r="16" stroke="#1E1E1E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
        ></circle>
        <circle cx="24" cy="24" r="8" stroke="#1E1E1E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
        ></circle>
        <path d="M24 8V16" stroke="#1E1E1E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        <path d="M24 32V40" stroke="#1E1E1E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        <path d="M8 24H16" stroke="#1E1E1E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        <path d="M32 24H40" stroke="#1E1E1E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
    )
  }
  {
    variant === 5 && (
      <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" class="size-full">
        <circle cx="24" cy="24" r="16" stroke="#1E1E1E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
        ></circle>
        <path d="M18 24L22 28L30 20" stroke="#1E1E1E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
        ></path>
        <path d="M24 8V12" stroke="#1E1E1E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        <path d="M24 36V40" stroke="#1E1E1E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
    )
  }
</span>
