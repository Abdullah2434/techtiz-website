---
import 'aos/dist/aos.css';
import '../styles/globals.css';
import GoogleAnalytics from '../components/seo/GoogleAnalytics.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import Seo from '../components/seo/Seo.astro';
import { siteGraphJsonLd } from '../lib/seo/json-ld';
import type { JsonLdNode } from '../lib/seo/types';

interface Props {
  title: string;
  description: string;
  canonicalPath: string;
  ogImage?: string;
  ogTitle?: string;
  ogDescription?: string;
  noindex?: boolean;
  /** Page-specific JSON-LD graphs (merged with Organization + WebSite). */
  jsonLd?: JsonLdNode[];
  /** Set false to omit global Organization/WebSite graphs (rare). */
  includeSiteGraph?: boolean;
}

const {
  title,
  description,
  canonicalPath,
  ogImage,
  ogTitle,
  ogDescription,
  noindex,
  jsonLd = [],
  includeSiteGraph = true,
} = Astro.props;

const graphs = includeSiteGraph ? siteGraphJsonLd(jsonLd) : jsonLd;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <Seo
    {title}
    {description}
    {canonicalPath}
    {ogImage}
    {ogTitle}
    {ogDescription}
    {noindex}
  />
  <JsonLd data={graphs} />
  <GoogleAnalytics />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Poppins:wght@400;600&family=JetBrains+Mono:wght@400;500;600&display=swap"
    rel="stylesheet"
    media="print"
    onload="this.media='all'"
  />
  <noscript>
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Poppins:wght@400;600&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </noscript>

  <slot name="head" />
</head>
<body class="min-h-screen min-w-0 bg-seasalt text-ink font-sans antialiased">
  <slot />
</body>
</html>

<script>
  import AOS from 'aos';

  (globalThis as typeof globalThis & { AOS: typeof AOS }).AOS = AOS;

  const initAos = () => {
    AOS.init({
      duration: 1000,
      once: true,
      mirror: false,
      offset: 100,
      disable: false,
      debounceDelay: 50,
      throttleDelay: 99,
    });
    window.setTimeout(() => AOS.refresh(), 100);
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAos, { once: true });
  } else {
    initAos();
  }
  document.addEventListener('astro:page-load', initAos);
</script>
