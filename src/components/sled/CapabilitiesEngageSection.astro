---
import Eyebrow from '../shared/Eyebrow.astro';
import SledPageWrap from './SledPageWrap.astro';
import { ENGAGE_STEPS } from '../../lib/constants/pages/capabilities';

interface Props {
  eyebrow?: string;
  heading?: string;
  body?: string;
}

const {
  eyebrow = 'How we engage',
  heading = 'Every engagement begins with a structured relationship.',
  body = 'NDA on first substantive contact. No public materials exchanged before paperwork is signed. We do not solicit RFPs from the open market or analyze RFPs we have not been formally engaged on.',
} = Astro.props;
---

<section class="border-t border-line bg-seasalt py-[100px]">
  <SledPageWrap>
    <div class="mb-12 max-w-[720px]">
      <Eyebrow text={eyebrow} showGlyph class="mb-3.5" />
      <h2 class="text-[40px] leading-[1.1] font-extrabold text-yale-dark">{heading}</h2>
      <p class="mt-3.5 max-w-[620px] text-[15.5px] leading-[1.6] text-muted">{body}</p>
    </div>

    <div class="grid grid-cols-3 gap-4 max-[1024px]:grid-cols-2 max-[720px]:grid-cols-1">
      {ENGAGE_STEPS.map((step) => (
        <div class="flex flex-col gap-3.5 rounded-xl border border-line bg-white px-7 py-[30px] pb-[26px]">
          <div class="grid size-11 place-items-center rounded-[10px] bg-yale-dark font-mono text-sm font-bold tracking-[0.04em] text-cyan">
            {step.n}
          </div>
          <h4 class="text-lg leading-[1.25] font-extrabold text-yale">{step.heading}</h4>
          <p class="text-[14px] leading-[1.55] text-muted">{step.body}</p>
          <span class="mt-auto border-t border-line-soft pt-3.5 font-mono text-[10.5px] tracking-[0.14em] uppercase text-cyan-strong">
            {step.when}
          </span>
        </div>
      ))}
    </div>
  </SledPageWrap>
</section>
