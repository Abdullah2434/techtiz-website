---
import SledPageWrap from './SledPageWrap.astro';
import { WHO_WE_ARE_NOT } from '../../lib/constants/pages/sled-hub';
---

<div class="border-b border-line bg-white py-[18px]">
  <SledPageWrap class="flex flex-wrap items-center gap-4">
    <span class="shrink-0 font-mono text-[10.5px] tracking-[0.14em] text-cyan-strong uppercase">
      {WHO_WE_ARE_NOT.label}
    </span>
    <p class="m-0 min-w-[280px] flex-1 text-[13.5px] leading-[1.55] text-muted">
      {WHO_WE_ARE_NOT.body}
    </p>
  </SledPageWrap>
</div>
