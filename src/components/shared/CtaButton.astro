---
import ArrowRight from '@lucide/astro/icons/arrow-right';

type ButtonVariant =
  | 'filled'
  | 'outlined'
  | 'yale'
  | 'ghost-dark'
  | 'ghost-light'
  | 'cta'
  | 'primary';

interface Props {
  label?: string;
  href?: string;
  type?: 'button' | 'submit';
  variant?: ButtonVariant;
  showArrow?: boolean;
  /** Animated cyan border trace (redesign beam). */
  beam?: boolean;
  id?: string;
  class?: string;
}

const {
  label,
  href,
  type = 'button',
  variant = 'cta',
  showArrow = true,
  beam = false,
  id,
  class: className = '',
} = Astro.props;

function resolveVariant(v: ButtonVariant): string {
  if (v === 'cta') return 'filled';
  if (v === 'primary') return 'yale';
  return v;
}

const styleVariant = resolveVariant(variant);
const btnClass = ['btn', `btn--${styleVariant}`, beam && 'btn--beam', className];
const Tag = href ? 'a' : 'button';
---

<Tag
  {id}
  href={href}
  type={href ? undefined : type}
  class:list={btnClass}
>
  <span class="btn__inner">
    <slot />
    {label}
    {showArrow && <ArrowRight class="btn__arrow size-4 shrink-0" aria-hidden="true" />}
  </span>
</Tag>
