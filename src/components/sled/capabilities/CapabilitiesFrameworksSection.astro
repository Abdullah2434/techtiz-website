---
import Eyebrow from '../../shared/Eyebrow.astro';
import SledPageWrap from '../shared/SledPageWrap.astro';
import { COMPLIANCE_FRAMEWORKS, FRAMEWORKS_SECTION } from '../../../lib/constants/pages/capabilities';

const statusClasses: Record<string, string> = {
  ip: 'bg-amber/10 text-amber',
  po: 'bg-seasalt text-yale',
  al: 'bg-cyan-soft text-cyan-strong',
  ap: 'bg-green/12 text-green',
};
---

<section class="border-t border-line bg-seasalt py-[90px] pb-20">
  <SledPageWrap>
    <div class="mb-10 max-w-[720px]">
      <Eyebrow text={FRAMEWORKS_SECTION.eyebrow} showGlyph class="mb-3.5" />
      <h2 class="sled-h2 text-yale-dark">{FRAMEWORKS_SECTION.heading}</h2>
      <p class="mt-3.5 max-w-[640px] text-[15.5px] leading-[1.6] text-muted">{FRAMEWORKS_SECTION.body}</p>
      <a
        href={FRAMEWORKS_SECTION.linkHref}
        class="mt-[18px] inline-flex items-center gap-2.5 border-b-2 border-cyan pb-0.5 text-sm font-bold text-yale transition-[gap] duration-200 ease-out hover:gap-4"
      >
        {FRAMEWORKS_SECTION.linkLabel} <span aria-hidden="true">→</span>
      </a>
    </div>

    <div class="grid grid-cols-3 gap-3.5 max-[1024px]:grid-cols-2 max-[600px]:grid-cols-1">
      {COMPLIANCE_FRAMEWORKS.map((fw) => (
        <div class="flex flex-col gap-3 rounded-xl border border-line bg-white p-6 transition-[transform,border-color,box-shadow] duration-200 ease-out hover:-translate-y-0.5 hover:border-[#C2CCD9] hover:shadow-[0_18px_36px_-18px_rgba(21,58,95,0.16)]">
          <div class="flex items-start justify-between gap-3">
            <div class="text-[16.5px] font-extrabold leading-[1.25] text-yale-dark">{fw.name}</div>
            <span class:list={['shrink-0 rounded px-2 py-1 font-mono text-[9.5px] font-bold tracking-[0.14em] uppercase', statusClasses[fw.statusClass]]}>
              {fw.status}
            </span>
          </div>
          <div class="text-[13px] leading-[1.55] text-muted" set:html={fw.what} />
          <div class="mt-auto flex items-center gap-2.5 border-t border-line-soft pt-3 font-mono text-[11px] tracking-[0.04em] text-yale-dark">
            <span class="text-[9.5px] tracking-[0.10em] uppercase text-muted">{fw.targetLabel}</span>
            {fw.target}
          </div>
        </div>
      ))}
    </div>
  </SledPageWrap>
</section>
