                class="sled-spec-head"
                aria-expanded={idx === 0 ? 'true' : 'false'}
              >
                <span class="sled-spec-num">{item.num}</span>
                <span class="sled-spec-title">
                  <CaseStudyIcon name={item.icon} class="size-[19px] shrink-0" />
                  {item.title}
                </span>
                <span class="sled-spec-head-right">
                  <span class="sled-spec-chev" aria-hidden="true">
                    <ChevronDown class="size-5" />
                  </span>
                </span>
              </button>
              <div class="sled-spec-body">
                <div class="sled-spec-body-in">
                  <div class="sled-spec-body-pad">
                    <p>{item.body}</p>
                    {'tools' in item && item.tools && (
                      <div class="sled-spec-tools">
                        {item.tools.map((tool) => (
                          <span>{tool}</span>
                        ))}
                      </div>
                    )}
                  </div>
                </div>
              </div>
            </article>
          ))}
        </div>
      )}
      {'lockedNote' in response && response.lockedNote && (
        <div class="sled-reveal mt-[22px] flex items-center gap-2.5 py-2.5 text-[13px] text-muted" data-sled-reveal>
          <Lock class="size-[15px] shrink-0" aria-hidden="true" />
          {response.lockedNote}
        </div>
      )}
    </SledPageWrap>
  </section>
)}

{'insurance' in study && study.insurance && (
  <section class={sectionClass()}>
    <SledPageWrap>
      <div class="sled-reveal flex items-start gap-2.5 rounded-[14px] border border-line bg-seasalt px-5 py-4" data-sled-reveal>
        <CaseStudyIcon name={study.insurance.icon} class="mt-0.5 size-[18px] shrink-0 text-yale" />
        <p class="text-[13px] leading-[1.55] text-ink [&_strong]:text-yale-dark" set:html={study.insurance.html} />
      </div>
    </SledPageWrap>
  </section>
)}

{strategicQuestions && stratHead && (
  <section class:list={[sectionClass(), stratLiveOnly && 'sled-cs-live-only']}>
    <SledPageWrap>
      <CaseStudyModHead {...stratHead} />
      <div class="sled-reveal-stagger grid grid-cols-1 gap-3.5 md:grid-cols-2" data-sled-reveal>
        {strategicQuestions.questions.map((q) => (
          <article class="rounded-[14px] border border-line-soft border-l-[3px] border-l-cyan bg-white px-[26px] py-6">
            <div class="mb-2.5 font-mono text-[11px] font-bold tracking-[0.08em] text-cyan-strong">
              {q.num}
            </div>
            <h4 class="mb-2 text-[1.02rem] font-bold text-yale-dark">{q.title}</h4>
            <p class="text-[13px] leading-[1.55] text-muted">
              {'body' in q ? q.body : 'desc' in q ? q.desc : ''}
            </p>
          </article>
        ))}
      </div>
    </SledPageWrap>
  </section>
)}

{techtizApproach && approachHead && (
  <section class:list={[sectionClass(), approachLiveOnly && 'sled-cs-live-only']}>
    <SledPageWrap>
      <CaseStudyModHead {...approachHead} />
      <div class="sled-reveal-stagger grid grid-cols-1 gap-3.5 sm:grid-cols-2 lg:grid-cols-4" data-sled-reveal>
        {techtizApproach.cards.map((card) => (
          <article class="rounded-[14px] border border-line-soft bg-white px-[22px] py-[22px] shadow-[0_8px_24px_-16px_rgba(21,58,95,0.1)] transition-[transform,box-shadow,border-color] duration-300 ease-out hover:-translate-y-1 hover:border-cyan/30 hover:shadow-[0_16px_36px_-18px_rgba(21,58,95,0.16)] motion-reduce:transition-none motion-reduce:hover:translate-y-0">
            <h4 class="mb-1.5 text-base font-bold text-yale-dark">{card.title}</h4>
            <p class="text-[12.5px] leading-[1.55] text-muted">
              {'body' in card ? card.body : 'desc' in card ? card.desc : ''}
            </p>
          </article>
        ))}
      </div>
      {'lockedNote' in techtizApproach && techtizApproach.lockedNote && (
        <div class="sled-reveal mt-[22px] flex items-center gap-2.5 py-2.5 text-[13px] text-muted" data-sled-reveal>
          <Lock class="size-[15px] shrink-0" aria-hidden="true" />
          {techtizApproach.lockedNote}
        </div>
      )}
    </SledPageWrap>
  </section>
)}

{ctaResolved && (
  <section class="sled-final-cta relative overflow-hidden bg-yale-dark">
    <div
      class="pointer-events-none absolute right-[-60px] top-[-60px] size-[340px] rotate-[15deg] bg-[linear-gradient(45deg,transparent_48%,rgba(24,176,230,0.16)_48%_52%,transparent_52%)] bg-[length:30px_30px] motion-reduce:hidden"
      aria-hidden="true"
    />
    <SledPageWrap class="relative z-2 py-[clamp(3.75rem,7vw,5.625rem)]">
      <div class="sled-reveal mx-auto max-w-[700px] text-center" data-sled-reveal>
        <Eyebrow text={ctaResolved.eyebrowLive} onDark showGlyph class="sled-cs-live-only mb-4 justify-center" />
        <Eyebrow
          text={ctaResolved.eyebrowPast}
          onDark
          showGlyph
          class="sled-cs-past-only mb-4 hidden justify-center"
        />
        <h2 class="sled-h2 mx-auto mb-4 max-w-[680px] text-white">
          <span class="sled-cs-live-only">{ctaResolved.headingLive}</span>
          <span class="sled-cs-past-only hidden">{ctaResolved.headingPast}</span>
        </h2>
        <p class="mx-auto mb-7 max-w-[580px] text-base leading-[1.6] text-white/78">
          {ctaResolved.dualBody ? (
            <>
              <span class="sled-cs-live-only">{ctaResolved.bodyLive}</span>
              <span class="sled-cs-past-only hidden">{ctaResolved.bodyPast}</span>
            </>
          ) : (
            ctaResolved.bodyLive
          )}
        </p>
        <div class="flex flex-wrap justify-center gap-3.5 max-[600px]:[&_a]:w-full max-[600px]:[&_a]:justify-center">
          {ctaResolved.buttons.map((btn) => (
            <CtaButton
              href={btn.href}
              label={btn.label}
              variant={btn.variant === 'cyan' ? 'cta' : ctaVariant(btn.variant)}
              showArrow={false}
            />
          ))}
        </div>
      </div>
    </SledPageWrap>
  </section>
)}
