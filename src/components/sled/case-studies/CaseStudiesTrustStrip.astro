---
import EyeOff from '@lucide/astro/icons/eye-off';
import FileLock from '@lucide/astro/icons/file-lock';
import Handshake from '@lucide/astro/icons/handshake';
import { TRUST_ITEMS } from '../../../lib/constants/pages/case-studies';
import SledPageWrap from '../shared/SledPageWrap.astro';
const trustIcons = [Handshake, FileLock, EyeOff] as const;
---

<section class="border-b border-line/80 bg-white py-6" aria-label="Operating boundaries">
  <SledPageWrap>
    <div class="sled-reveal sled-glass rounded-2xl border border-line/90 px-5 py-4 sm:px-6" data-sled-reveal>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-[minmax(0,200px)_1fr] sm:items-center lg:grid-cols-[200px_repeat(3,1fr)]">
        <span class="font-mono text-[11px] font-bold tracking-[0.14em] uppercase text-muted">
          Operating boundaries
        </span>
        <div class="grid min-w-0 grid-cols-1 gap-3 sm:grid-cols-3 lg:col-span-3 lg:grid-cols-3 lg:gap-4">
          {TRUST_ITEMS.map((item, idx) => {
            const Icon = trustIcons[idx];
            return (
              <span class="group flex min-w-0 items-center gap-3 rounded-xl px-2 py-1.5 text-[13.5px] font-semibold leading-snug text-yale transition-colors hover:bg-white/70 sm:border-l sm:border-line sm:pl-5 first:sm:border-l-0 first:sm:pl-0 max-sm:border-t max-sm:border-line max-sm:pt-3 first:max-sm:border-t-0 first:max-sm:pt-0">
                <span class="grid size-9 shrink-0 place-items-center rounded-lg bg-cyan-soft text-cyan-strong transition-transform duration-300 group-hover:scale-105">
                  <Icon class="size-4" stroke-width="1.75" aria-hidden="true" />
                </span>
                <span class="min-w-0">{item}</span>
              </span>
            );
          })}
        </div>
      </div>
    </div>
  </SledPageWrap>
</section>
