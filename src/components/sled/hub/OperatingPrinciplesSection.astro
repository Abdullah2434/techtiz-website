---
import { SLED_OPERATING_PRINCIPLES } from '../../../lib/constants/pages/sled-hub';
import Eyebrow from '../../shared/Eyebrow.astro';
import SledPageWrap from '../shared/SledPageWrap.astro';

const staggerDelays = [0, 90, 180, 270];
---

<section class="sled-section bg-seasalt" data-screen-label="Operating principles">
  <SledPageWrap>
    <div class="sled-reveal mb-[30px] max-w-[640px]" data-sled-reveal>
      <Eyebrow text={SLED_OPERATING_PRINCIPLES.eyebrow} showGlyph class="mb-4" />
      <h2 class="text-[clamp(1.7rem,2.5vw,2.3rem)] font-semibold leading-[1.12] tracking-[-0.02em] text-yale-dark">
        {SLED_OPERATING_PRINCIPLES.heading}
      </h2>
    </div>

    <div
      class="sled-reveal-stagger grid grid-cols-1 gap-[18px] sm:grid-cols-2 lg:grid-cols-4"
      data-sled-reveal
    >
      {
        SLED_OPERATING_PRINCIPLES.items.map((item, idx) => (
          <article
            class="rounded-xl border border-line-soft border-t-[3px] border-t-cyan bg-white p-[30px] transition-[transform,box-shadow] duration-300 motion-safe:hover:-translate-y-0.75 motion-safe:hover:shadow-[0_18px_40px_-22px_rgba(21,58,95,0.22)]"
            style={staggerDelays[idx] ? `--d:${staggerDelays[idx]}ms` : undefined}
          >           
            <h4 class="mb-2.25 text-[1.12rem] font-semibold leading-[1.25] text-yale-dark">
              {item.heading}
            </h4>
            <p class="m-0 text-[14.5px] leading-normal text-muted">{item.body}</p>
          </article>
        ))
      }
    </div>
  </SledPageWrap>
</section>
