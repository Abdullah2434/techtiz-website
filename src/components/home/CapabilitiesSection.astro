---
import { HOME_CAPABILITIES } from '../../lib/constants/pages/home';
import PageWrap from './PageWrap.astro';
import CapabilityCard from './CapabilityCard.astro';
---

<section class="bg-white py-10 md:py-16" aria-labelledby="capabilities-heading">
  <PageWrap>
    <header
      class="mb-0 flex flex-col items-start justify-between gap-y-3"
      data-aos="fade-up"
      data-aos-delay="100"
    >
      <h2
        id="capabilities-heading"
        class="mb-1 text-left text-[24px] font-normal leading-[110%] text-[#1E1E1E]/80"
      >
        Tailored Services
      </h2>
      <div class="h-0.5 w-full bg-[#D0D0D0]"></div>
      <div
        class="mb-3 flex w-full flex-wrap items-center justify-between gap-x-4 gap-y-4"
        data-aos="fade-up"
        data-aos-delay="200"
      >
        <p class="mb-1 max-w-[79%] text-left text-[32px] font-normal leading-[120%] tracking-[-0.02em] text-[#1E1E1E] md:text-[40px]">
          Accelerate Your Growth
        </p>
        <a
          href="/contact-us"
          class="home-cap-btn-outline hidden min-h-[42px] min-w-[116px] items-center justify-center rounded-[2px] border border-[#4D4D4D] bg-transparent px-6 py-[11px] text-base font-normal text-[#4D4D4D] transition-all duration-300 hover:-translate-y-0.5 hover:border-cyan hover:bg-cyan hover:text-white hover:shadow-md md:inline-flex"
        >
          Book a Consultation
        </a>
      </div>
    </header>

    <div
      class="home-cap-scroll -mr-2 mt-8 overflow-x-auto overflow-y-hidden pb-6 pr-2"
      data-aos="fade-up"
      data-aos-delay="300"
    >
      <div class="flex w-max min-w-full gap-6 py-4">
        {
          HOME_CAPABILITIES.map((cap) => (
            <CapabilityCard
              subtitle={cap.subtitle}
              mainText={cap.mainText}
              image={cap.image}
              serviceLinks={cap.serviceLinks}
            />
          ))
        }
      </div>
    </div>

    <div
      class="mt-5 flex justify-center md:hidden"
      data-aos="fade-up"
      data-aos-delay="200"
    >
      <a
        href="/capabilities/ai-consultation"
        class="home-cap-btn-outline mx-auto inline-flex min-h-[42px] min-w-[116px] items-center justify-center rounded-[2px] border border-[#4D4D4D] bg-transparent px-6 py-[11px] text-base font-normal text-[#4D4D4D] transition-all duration-300 hover:border-cyan hover:bg-cyan hover:text-white"
      >
        Book a Consultation
      </a>
    </div>
  </PageWrap>
</section>

<script>
  const cards = document.querySelectorAll<HTMLElement>('[data-cap-card]');
  const mq = window.matchMedia('(hover: none)');

  cards.forEach((card) => {
    card.querySelectorAll('a[href]').forEach((link) => {
      link.addEventListener('click', (e) => e.stopPropagation());
    });

    card.addEventListener('click', () => {
      if (!mq.matches) return;
      const isActive = card.classList.contains('is-active');
      cards.forEach((c) => c.classList.remove('is-active'));
      if (!isActive) card.classList.add('is-active');
    });
  });
</script>
