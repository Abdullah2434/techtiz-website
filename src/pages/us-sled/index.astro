---
import BackboneSection from '../../components/sled/hub/BackboneSection.astro';
import DeliveryModelSection from '../../components/sled/hub/DeliveryModelSection.astro';
import HubInquirySection from '../../components/sled/hub/HubInquirySection.astro';
import ModelSection from '../../components/sled/hub/ModelSection.astro';
import OperatingPrinciplesSection from '../../components/sled/hub/OperatingPrinciplesSection.astro';
import OutcomesSection from '../../components/sled/hub/OutcomesSection.astro';
import ProofSection from '../../components/sled/hub/ProofSection.astro';
import SledHubHero from '../../components/sled/hub/SledHubHero.astro';
import SledTrustStrip from '../../components/sled/hub/SledTrustStrip.astro';
import SpecializationsSection from '../../components/sled/hub/SpecializationsSection.astro';
import WhyTechtizSection from '../../components/sled/hub/WhyTechtizSection.astro';
import SledLayout from '../../layouts/SledLayout.astro';
import { SLED_HUB_SEO } from '../../lib/constants/pages/sled-hub';
import '../../styles/sled.css';

const { title, description, canonicalPath, ogImage } = SLED_HUB_SEO;
---

<SledLayout {title} {description} {canonicalPath} {ogImage} currentPage="/us-sled/">
  <div class="sled-hub-page">
  <SledHubHero />
  <SledTrustStrip />
  <ModelSection />
  <DeliveryModelSection />
  <BackboneSection />
  <SpecializationsSection />
  <OperatingPrinciplesSection />
  <OutcomesSection />
  <ProofSection />
  <HubInquirySection />
  <WhyTechtizSection />
  </div>
  <script src="/scripts/sled-hub.js" is:inline></script>
</SledLayout>
