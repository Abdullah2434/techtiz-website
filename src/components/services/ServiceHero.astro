---
import type { ServiceHeroData } from '../../lib/types/service';
import CtaButton from '../shared/CtaButton.astro';
import { ROUTES } from '../../lib/constants/routes';

interface Props extends ServiceHeroData {}

const {
  title,
  titleLine2,
  subtitle,
  description,
  ctaText,
  ctaDescription,
  ctaUrl,
  techStack,
} = Astro.props;

const stack = techStack?.length ? techStack : [];
const doubled = [...stack, ...stack];
const ctaBody =
  ctaDescription ||
  'From custom systems to enterprise-grade applications, we engineer solutions that move your business forward.';
---

<section class="mx-auto w-full max-w-[1400px] px-2 py-10 md:py-16">
  <div class="flex flex-col gap-8 lg:gap-12">
    <div class="flex flex-col items-start gap-6 lg:flex-row lg:gap-12">
      <div class="w-full lg:w-[60%]">
        <h1 class="mb-4 text-[32px] leading-tight font-medium text-[#101010] md:text-[40px] lg:text-[56px]">
          {title}
          {titleLine2 && (
            <>
              <br />
              {titleLine2}
            </>
          )}
        </h1>
      </div>
      <div class="w-full lg:w-[40%]">
        <p class="mt-3 text-center text-[16px] leading-[130%] font-normal text-[#101010] md:text-left md:text-[18px]">
          {description}
        </p>
      </div>
    </div>

    <div class="flex flex-col items-center gap-8 lg:flex-row lg:gap-20">
      <div class="w-full lg:w-[55%]">
        <p class="mb-4 text-[16px] font-normal text-[#101010] md:text-[18px]">{subtitle}</p>
        {
          stack.length > 0 && (
            <div class="relative overflow-hidden">
              <div
                class="pointer-events-none absolute top-0 bottom-0 left-0 z-10 w-20 bg-linear-to-r from-white to-transparent"
                aria-hidden="true"
              />
              <div
                class="pointer-events-none absolute top-0 right-0 bottom-0 z-10 w-20 bg-linear-to-l from-white to-transparent"
                aria-hidden="true"
              />
              <div class="service-tech-marquee overflow-hidden">
                <div class="service-tech-track">
                  {doubled.map((tech) => (
                    <div class="mx-2 flex shrink-0 items-center gap-2 transition-transform duration-300 hover:scale-105 md:mx-4 md:gap-3 lg:gap-4">
                      <div class="flex h-10 w-10 shrink-0 items-center justify-center md:h-[60px] md:w-[60px] lg:h-20 lg:w-20">
                        <img
                          src={tech.icon}
                          alt={tech.name}
                          width={80}
                          height={80}
                          loading="lazy"
                          class="max-h-10 max-w-10 object-contain md:max-h-[60px] md:max-w-[60px] lg:max-h-20 lg:max-w-20"
                        />
                      </div>
                      <span class="text-[12px] font-medium whitespace-nowrap text-[#101010] md:text-[14px] lg:text-[16px]">
                        {tech.name}
                      </span>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          )
        }
      </div>

      <div class="w-full lg:w-[37%]">
        <div class="relative overflow-hidden rounded-lg border border-white bg-yale p-6 md:p-8">
          <img
            src="/svgs/transparent-bg.svg"
            alt=""
            class="pointer-events-none absolute inset-0 h-full w-full object-cover object-top-right opacity-70"
            loading="lazy"
            aria-hidden="true"
          />
          <div class="relative z-10 flex flex-col gap-6">
            <p class="text-[16px] leading-[130%] font-normal text-white md:text-[18px]">{ctaBody}</p>
            <CtaButton
              label={ctaText}
              href={ctaUrl || ROUTES.sledContact}
              variant="cta"
              showArrow={true}
              class="text-base md:text-lg"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
