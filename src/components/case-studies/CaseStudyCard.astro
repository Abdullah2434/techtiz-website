---
import ArrowRight from '@lucide/astro/icons/arrow-right';
import Play from '@lucide/astro/icons/play';
import type { CaseStudy } from '../../lib/types/case-study';
import { isVideoMedia, truncateOverview } from '../../lib/utils/case-study';

interface Props {
  study: CaseStudy;
}

const { study } = Astro.props;
const overview = truncateOverview(study.overview);
const isVideo = isVideoMedia(study.image);
const detailHref = `/case-studies/${study.slug}/`;
const videoId =
  study.videoId ?? study.reviewVideoUrl?.match(/embed\/([^?&/]+)/)?.[1];
---

<article class="cs-card group flex flex-col">
  <a href={detailHref} class="block flex-1">
    <div class="min-h-[220px] max-w-[700px]" data-aos="fade-up" data-aos-delay="100">
      {
        isVideo ? (
          <video
            src={study.image}
            autoplay
            muted
            loop
            playsinline
            class="h-[220px] w-full rounded-lg object-cover"
          />
        ) : (
          <img
            src={study.image}
            alt={`${study.title} — ${study.client} case study preview`}
            width={700}
            height={220}
            class="h-[220px] w-full rounded-lg object-cover"
            loading="lazy"
            decoding="async"
          />
        )
      }
    </div>

    <div class="flex max-w-[700px] flex-col gap-10 p-6" data-aos="fade-up" data-aos-delay="100">
      <div class="max-w-[620px] gap-2">
        <h3 class="mb-3 line-clamp-2 text-[30px] font-medium leading-[1.2] tracking-[-0.64px] text-[#1E1E1E] md:text-[32px]">
          {study.title}
        </h3>
        <p class="text-left text-base font-normal leading-[1.2] tracking-[-0.32px] text-[#1E1E1E]/60">
          {overview}
        </p>
      </div>
    </div>
  </a>

  <div class="mt-auto flex max-w-[700px] flex-wrap items-center justify-between gap-4 px-6 pb-6">
    {
      study.founder ? (
        <div class="flex items-center gap-3">
          <img
            src={study.founder.image}
            alt={study.founder.name}
            width={40}
            height={40}
            class="size-10 rounded-full object-cover"
            loading="lazy"
          />
          <div>
            <p class="mb-1 text-[11px] font-semibold leading-[1.2] tracking-[-0.02em] text-[#0E0E0E]">
              {study.founder.name}
            </p>
            <p class="text-[8px] font-normal leading-[1.2] tracking-[-0.02em] text-[#0E0E0E]">
              {study.founder.role}
            </p>
          </div>
          {
            videoId && (
              <button
                type="button"
                class="ml-1 flex size-8 shrink-0 cursor-pointer items-center justify-center rounded-full bg-[#0E0E0E]/20 transition-colors hover:bg-[#0E0E0E]/40"
                data-video-open={videoId}
                aria-label={`Play ${study.client} video`}
              >
                <Play class="size-3.5 fill-[#0E0E0E] stroke-[#0E0E0E]" aria-hidden="true" />
              </button>
            )
          }
        </div>
      ) : (
        <div />
      )
    }
    <a
      href={detailHref}
      class="inline-flex items-center gap-3 text-base font-semibold uppercase leading-[1.2] tracking-[-0.02em] text-[#1E1E1E] transition-all group-hover:gap-4"
    >
      SEE DETAILS
      <ArrowRight class="size-4 shrink-0" aria-hidden="true" />
    </a>
  </div>
</article>
