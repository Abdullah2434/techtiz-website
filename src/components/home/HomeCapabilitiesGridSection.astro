---
import {
  HOME_CAPABILITIES_GRID,
  HOME_CAPABILITIES_GRID_SECTION,
} from '../../lib/constants/pages/home';
import HomeCapabilityGridCard from './HomeCapabilityGridCard.astro';
import PageWrap from './PageWrap.astro';

const sectionId = 'capabilities-grid';
const { eyebrow, heading, sub, rightLink } = HOME_CAPABILITIES_GRID_SECTION;
---

<section
  id={sectionId}
  class="scroll-mt-24 bg-seasalt py-[110px] max-[900px]:py-14"
  aria-labelledby={`${sectionId}-heading`}
>
  <PageWrap>
    <div
      class="mb-14 flex items-end justify-between gap-12 max-[900px]:mb-9 max-[900px]:flex-col max-[900px]:items-start max-[900px]:gap-4"
    >
      <div class="max-w-[640px]">
        <span
          class="mb-3 inline-flex font-mono text-[11px] font-bold tracking-[0.18em] text-cyan-strong uppercase"
        >
          {eyebrow}
        </span>
        <h2
          id={`${sectionId}-heading`}
          class="text-[34px] leading-[1.1] font-semibold tracking-[-0.022em] text-yale max-[900px]:text-[30px] max-[640px]:text-[24px]"
        >
          {heading}
        </h2>
        <p class="mt-3.5 max-w-[580px] text-[15px] text-muted italic">
          {sub}
        </p>
      </div>
      <a
        href={rightLink.href}
        class="inline-flex shrink-0 items-center gap-2 border-b-2 border-cyan pb-1 text-sm font-bold text-yale transition-[gap] duration-200 hover:gap-3.5"
      >
        {rightLink.label}
      </a>
    </div>

    <div
      class="home-cap-grid grid grid-cols-1 gap-4 min-[601px]:grid-cols-2 lg:grid-cols-3"
      role="list"
    >
      {
        HOME_CAPABILITIES_GRID.map((capability, i) => (
          <HomeCapabilityGridCard capability={capability} index={i} />
        ))
      }
    </div>
  </PageWrap>
</section>

<script>
  (function () {
    const grid = document.querySelector<HTMLElement>('#capabilities-grid .home-cap-grid');
    if (!(grid instanceof HTMLElement)) return;

    const capGrid = grid;

    function check() {
      const rect = capGrid.getBoundingClientRect();
      const vh = window.innerHeight || document.documentElement.clientHeight;
      if (rect.top < vh * 0.9 && rect.bottom > 0) {
        capGrid.classList.add('is-in');
        document.removeEventListener('scroll', check);
        window.removeEventListener('resize', check);
        window.removeEventListener('load', check);
      }
    }

    document.addEventListener('scroll', check, { passive: true });
    window.addEventListener('resize', check);
    window.addEventListener('load', check);
    check();
    setTimeout(check, 200);
  })();
</script>
