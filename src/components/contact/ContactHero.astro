---
import { CONTACT_HERO } from '../../lib/constants/pages/commercial-contact';

const { heading, headingAccent, body } = CONTACT_HERO;
---

<section class="mx-auto w-full max-w-[1280px] px-3 py-10 md:py-16">
  <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
    <div class="flex-1">
      <h1
        class="mb-2 text-center text-[40px] leading-[120%] font-normal md:text-left md:text-[56px]"
        data-aos="fade-up"
        data-aos-delay="100"
      >
        {heading}
        <br />
        <span class="font-bold text-cyan">{headingAccent}</span>
      </h1>
    </div>
    <div class="mb-3 flex-1">
      <p
        class="text-center text-[18px] leading-[130%] font-normal text-[#101010] md:text-right"
        data-aos="fade-up"
        data-aos-delay="100"
      >
        {body}
      </p>
    </div>
  </div>
</section>
