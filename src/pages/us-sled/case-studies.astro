---
import SledLayout from '../../layouts/SledLayout.astro';
import PageHero from '../../components/shared/PageHero.astro';
import Eyebrow from '../../components/shared/Eyebrow.astro';
import CtaButton from '../../components/shared/CtaButton.astro';
import {
  CASE_STUDIES_SEO, CASE_STUDIES_HERO, TRUST_ITEMS, ENGAGEMENT_CARDS, CONFIDENTIALITY_ROWS
} from '../../lib/constants/pages/case-studies';

const { title, description, canonicalPath, ogImage } = CASE_STUDIES_SEO;
---

<SledLayout {title} {description} {canonicalPath} {ogImage} currentPage="/us-sled/case-studies/">

<!-- HERO -->
<PageHero eyebrow={CASE_STUDIES_HERO.eyebrow} heading={CASE_STUDIES_HERO.heading} body={CASE_STUDIES_HERO.body} />

<!-- TRUST STRIP -->
<section class="border-b border-line bg-white py-4">
  <div class="mx-auto max-w-[1280px] px-12 max-[1024px]:px-8 max-[900px]:px-6 max-[600px]:px-[18px] flex flex-wrap items-center gap-x-5 gap-y-2">
    <span class="shrink-0 font-mono text-[10.5px] font-bold tracking-[0.18em] uppercase text-cyan-strong">
      Operating boundaries
    </span>
    {TRUST_ITEMS.map(item => (
      <span class="inline-flex items-center gap-2 text-[13.5px] leading-[1.55] text-muted">
        <span class="inline-block size-2 rotate-15 bg-cyan" aria-hidden="true"></span>
        <span class="text-muted">{item}</span>
      </span>
    ))}
  </div>
</section>

<!-- ENGAGEMENT EXAMPLES -->
<section class="bg-seasalt py-20">
  <div class="mx-auto max-w-[1280px] px-12 max-[1024px]:px-8 max-[900px]:px-6 max-[600px]:px-[18px]">
    <div class="mb-10 max-w-[760px]">
      <Eyebrow text="Delivered engagements" showGlyph />
      <h2 class="mt-4 text-[38px] font-extrabold leading-[1.1] tracking-[-0.02em] text-yale-dark">
        What we shipped, under whose roof, on what vehicle.
      </h2>
      <p class="mt-3.5 text-[15.5px] leading-relaxed text-muted">
        Each card describes a delivered subcontract engagement: the technical surface area, the prime relationship type, the deliverables that shipped, and the procurement vehicle the work moved through. References available with NDA.
      </p>
    </div>

    <div class="grid grid-cols-3 gap-6 max-[1024px]:grid-cols-2 max-[720px]:grid-cols-1">
      {ENGAGEMENT_CARDS.map(card => (
        <article class="rounded-2xl border border-line bg-white p-[22px] shadow-[0_14px_36px_-26px_rgba(14,38,64,0.25)]">
          <div class="mb-4 flex items-center justify-between gap-3">
            <span class="inline-flex items-center rounded-full border border-line bg-white px-3 py-1 font-mono text-[10.5px] font-bold tracking-[0.14em] text-yale uppercase">
              {card.badge}
            </span>
            <span class="text-[12.5px] font-medium text-muted">{card.anon}</span>
          </div>
          <h3 class="text-[18px] font-extrabold leading-tight text-yale-dark">{card.heading}</h3>
          <div class="mt-3 flex flex-wrap gap-2">
            {card.meta.map(m => (
              <span class="rounded-full bg-seasalt px-3 py-1 text-[12.5px] font-medium text-muted">{m}</span>
            ))}
          </div>

          <div class="mt-5 space-y-2.5">
            {card.rows.map(row => (
              <div class="grid grid-cols-[120px_1fr] gap-3 max-[420px]:grid-cols-1">
                <span class="font-mono text-[10.5px] font-bold tracking-[0.14em] text-cyan-strong uppercase">{row.lbl}</span>
                <span class="text-[13.5px] leading-[1.55] text-muted" set:html={row.val} />
              </div>
            ))}
          </div>

          <div class="mt-6 border-t border-line pt-4 text-[12.5px] font-medium text-muted">
            Vehicle · {card.vehicle}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- CONFIDENTIALITY -->
<section class="bg-white py-20">
  <div class="mx-auto max-w-[1280px] px-12 max-[1024px]:px-8 max-[900px]:px-6 max-[600px]:px-[18px] grid grid-cols-[1fr_1.15fr] gap-12 items-start max-[900px]:grid-cols-1">
    <div>
      <Eyebrow text="What we cannot show publicly" showGlyph class="text-amber" />
      <h2 class="mt-4 text-[34px] font-extrabold leading-[1.12] tracking-[-0.02em] text-yale-dark">
        Most of our SLED work stays under NDA.
      </h2>
      <p class="mt-3.5 text-[15.5px] leading-relaxed text-muted">
        The engagements above are summarized at the technical-deliverable level. Specifics live on a separate call, behind a mutual NDA, with the prime in the room.
      </p>
    </div>
    <div class="space-y-3.5">
      {CONFIDENTIALITY_ROWS.map(row => (
        <div class="flex gap-3 rounded-xl border border-line bg-seasalt p-4">
          <div class="mt-0.5 shrink-0 text-[14px] font-extrabold text-amber">✕</div>
          <p class="m-0 text-[14px] leading-[1.55] text-muted">
            <strong class="text-yale-dark">{row.heading}</strong> {row.body}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- CTA BAND -->
<section class="bg-yale-dark py-20">
  <div class="mx-auto max-w-[920px] px-12 max-[1024px]:px-8 max-[900px]:px-6 max-[600px]:px-[18px] text-center">
    <Eyebrow text="Capture manager or BD lead at a U.S. prime?" onDark showGlyph class="justify-center" />
    <h2 class="mt-4 text-[40px] font-extrabold leading-[1.1] tracking-[-0.02em] text-white">
      Request a reference conversation.
    </h2>
    <p class="mx-auto mt-3.5 max-w-[720px] text-[15.5px] leading-relaxed text-white/70">
      NDA-first introduction. We'll route you to the right named reference for the engagement type closest to your pursuit.
    </p>
    <div class="mt-8 flex justify-center">
      <CtaButton href="/us-sled/contact/" label="Start an NDA conversation" variant="cta" />
    </div>
  </div>
</section>

</SledLayout>

