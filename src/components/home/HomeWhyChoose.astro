---
import { WHY_DATA, WHY_TABS } from '../../lib/constants/pages/home';
import CtaButton from '../shared/CtaButton.astro';
import IndustryIcon from './IndustryIcon.astro';
import PageWrap from './PageWrap.astro';
import WhyHighlightItem from './WhyHighlightItem.astro';
import WhyIcon from './WhyIcon.astro';

const initial = WHY_DATA.expert;
const WHY_TRANSITION_MS = 400;
const WHY_KEYS = ['expert', 'ontime', 'scalable', 'ongoing'] as const;
---

<section class="relative bg-white py-[110px] max-[900px]:py-14">
  <PageWrap>
    <div
      class="mb-9 max-w-[700px] max-[640px]:mb-7"
      data-aos="fade-up"
      data-aos-delay="100"
    >
      <span class="mb-3.5 inline-flex font-mono text-[11px] font-bold tracking-[0.18em] uppercase text-cyan-strong max-[640px]:text-[10px]">Why teams choose us</span>
      <h2 class="text-[44px] font-extrabold leading-[1.05] tracking-[-0.022em] text-yale max-[900px]:text-[30px] max-[640px]:text-[24px] max-[640px]:leading-[1.1] max-[480px]:text-[22px]">
        Four reasons the engagement keeps compounding.
      </h2>
      <p class="mt-3.5 max-w-[620px] text-[15px] text-muted max-[640px]:mt-3 max-[640px]:text-[14px]">Pick a pillar to see the shape of how we work.</p>
    </div>

    <div
      class="relative mb-6 grid grid-cols-4 gap-2.5 border-b border-line pb-6 max-[1024px]:grid-cols-2 max-[600px]:grid-cols-1 max-[640px]:mb-5 max-[640px]:gap-2 max-[640px]:pb-5"
      role="tablist"
      data-why-tabs
      data-aos="fade-up"
      data-aos-delay="100"
    >
      {
        WHY_TABS.map((tab, i) => (
          <button
            type="button"
            class:list={[
              'home-why-tab relative flex cursor-pointer items-start gap-[18px] rounded-[14px] border border-transparent bg-white px-[22px] py-[18px] text-left font-inherit hover:bg-seasalt max-[640px]:gap-3 max-[640px]:px-4 max-[640px]:py-3.5',
              i === 0 && 'is-active',
            ]}
            role="tab"
            data-why={tab.id}
            aria-selected={i === 0 ? 'true' : 'false'}
          >
            <span class="home-why-tab-num mt-1 font-mono text-[28px] font-extrabold leading-none tracking-[-0.04em] text-line max-[900px]:text-[22px] max-[640px]:mt-0.5 max-[640px]:text-[18px] max-[480px]:text-[16px]">
              {tab.num}
            </span>
            <span class="flex min-w-0 flex-col gap-1.5">
              <span class="home-why-tab-title text-[16.5px] font-bold leading-[1.15] tracking-[-0.005em] text-muted max-[640px]:text-[15px] max-[480px]:text-[14px]">
                {tab.title}
              </span>
              <span class="home-why-tab-tag line-clamp-1 text-[12.5px] leading-[1.4] text-muted max-[640px]:text-[12px]">{tab.tag}</span>
            </span>
          </button>
        ))
      }
    </div>

    <div
      class="home-why-panel grid grid-cols-[1.35fr_0.85fr] gap-4 max-[900px]:grid-cols-1"
      data-why-panel
      data-aos="fade-up"
      data-aos-delay="200"
    >
      <div
        class="home-why-pane rounded-2xl border border-line bg-seasalt p-8 max-[600px]:p-6"
      >
        <div class="home-why-stagger">
          <div class="mb-5 flex items-center gap-3">
            <div class="grid size-10 place-items-center rounded-lg bg-cyan-soft text-cyan-strong" data-why-icon>
              <WhyIcon name="expert" />
            </div>
            <div class="font-mono text-xs font-bold uppercase tracking-[0.16em] text-yale-dark" data-why-eyebrow>
              {initial.eyebrow}
            </div>
          </div>
          <h3 class="text-[32px] font-extrabold leading-[1.1] text-yale max-[900px]:text-[26px] max-[640px]:text-[22px] max-[480px]:text-[20px]" data-why-title>
            {initial.title}<span class="text-cyan">.</span>
          </h3>
          <p class="mt-4 text-[15px] leading-[1.6] text-muted max-[640px]:mt-3 max-[640px]:text-[14px]" data-why-desc>{initial.desc}</p>
          <div class="my-7 h-px bg-line"></div>
          <div class="flex flex-wrap items-end justify-between gap-4">
            <div>
              <div class="text-[48px] font-extrabold leading-none tracking-[-0.04em] text-yale max-[900px]:text-[36px] max-[640px]:text-[30px] max-[480px]:text-[26px]" data-why-stat-n>
                {initial.statN}
              </div>
              <div class="mt-2 font-mono text-[11px] uppercase tracking-[0.14em] text-muted" data-why-stat-l>
                {initial.statL}
              </div>
            </div>
            <CtaButton href="/us-sled/contact/" label="Get started" variant="primary" />
          </div>
        </div>
      </div>

      <div
        class="home-why-pane flex flex-col rounded-2xl border border-line bg-white p-[30px] max-[640px]:p-5"
      >
        <div class="home-why-stagger flex flex-1 flex-col">
          <h4 class="mb-5 font-mono text-xs font-bold uppercase tracking-[0.16em] text-yale-dark">Key Highlights</h4>
          <ul class="mb-6 flex flex-col gap-3.5" data-why-highlights>
            {initial.highlights.map((h) => (
              <WhyHighlightItem text={h} />
            ))}
          </ul>
          <div class="mt-auto border-t border-line pt-[22px]">
            <div class="mb-3 inline-flex items-center gap-2">
              <IndustryIcon name="sparkle" class="size-4 text-cyan-strong" />
              <span class="font-mono text-[11.5px] font-bold uppercase tracking-[0.16em] text-yale-dark">Our Pledge</span>
            </div>
            <p class="text-[13.5px] leading-[1.6] text-muted">
              Clear scope. Fast feedback. No surprises. Transparent milestones with quality gates before every release.
            </p>
          </div>
        </div>
      </div>
    </div>

    <div class="hidden" aria-hidden="true" id="home-why-icon-templates">
      {
        WHY_KEYS.map((key) => (
          <div data-why-icon={key}>
            <WhyIcon name={key} />
          </div>
        ))
      }
    </div>

    <div class="hidden" aria-hidden="true" id="home-why-highlight-templates">
      {
        WHY_KEYS.map((key) => (
          <ul data-why-highlights={key} class="mb-6 flex flex-col gap-3.5">
            {WHY_DATA[key].highlights.map((h) => (
              <WhyHighlightItem text={h} />
            ))}
          </ul>
        ))
      }
    </div>
  </PageWrap>
</section>

<script define:vars={{ whyData: WHY_DATA, whyTransitionMs: WHY_TRANSITION_MS }}>
  const panel = document.querySelector('[data-why-panel]');
  const tabs = document.querySelectorAll('[data-why-tabs] [data-why]');
  if (!panel || !tabs.length) return;

  const panes = panel.querySelectorAll('.home-why-pane');
  const iconEl = panel.querySelector('[data-why-icon]');
  const ebEl = panel.querySelector('[data-why-eyebrow]');
  const titleEl = panel.querySelector('[data-why-title]');
  const descEl = panel.querySelector('[data-why-desc]');
  const statN = panel.querySelector('[data-why-stat-n]');
  const statL = panel.querySelector('[data-why-stat-l]');
  const hlEl = panel.querySelector('[data-why-highlights]');
  const iconTemplates = document.getElementById('home-why-icon-templates');
  const highlightTemplates = document.getElementById('home-why-highlight-templates');

  let activeKey = 'expert';
  let animating = false;

  const wait = (ms) => new Promise((resolve) => setTimeout(resolve, ms));

  const getIconMarkup = (key) => {
    const template = iconTemplates?.querySelector(`[data-why-icon="${key}"]`);
    return template?.innerHTML ?? '';
  };

  const getHighlightsMarkup = (key) => {
    const template = highlightTemplates?.querySelector(`[data-why-highlights="${key}"]`);
    return template?.innerHTML ?? '';
  };

  const setTabState = (tab, on) => {
    tab.setAttribute('aria-selected', on ? 'true' : 'false');
    tab.classList.toggle('is-active', on);
  };

  const updateContent = (key) => {
    const d = whyData[key];
    if (!d) return;

    const iconMarkup = getIconMarkup(key);
    if (iconEl && iconMarkup) iconEl.innerHTML = iconMarkup;
    if (ebEl) ebEl.textContent = d.eyebrow;
    if (titleEl) titleEl.innerHTML = `${d.title}<span class="text-cyan">.</span>`;
    if (descEl) descEl.textContent = d.desc;
    if (statN) statN.textContent = d.statN;
    if (statL) statL.textContent = d.statL;
    if (hlEl) {
      const highlightsMarkup = getHighlightsMarkup(key);
      if (highlightsMarkup) hlEl.innerHTML = highlightsMarkup;
    }
  };

  const runPanelTransition = async (key) => {
    if (animating || key === activeKey) return;
    animating = true;

    panes.forEach((pane) => {
      pane.classList.remove('home-why-enter');
      pane.classList.add('home-why-exit');
    });

    await wait(whyTransitionMs);

    panel.classList.remove('home-why-panel-ready');
    panel.classList.add('home-why-revealing');
    updateContent(key);
    activeKey = key;

    panes.forEach((pane) => {
      pane.classList.remove('home-why-exit');
      pane.classList.add('home-why-enter');
    });

    await wait(20);

    panes.forEach((pane) => pane.classList.remove('home-why-enter'));
    panel.classList.add('home-why-panel-ready');

    await wait(whyTransitionMs);

    panel.classList.remove('home-why-revealing');
    animating = false;
  };

  panel.classList.add('home-why-panel-ready');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const key = tab.getAttribute('data-why');
      if (!key || key === activeKey) return;

      tabs.forEach((t) => setTabState(t, t === tab));
      runPanelTransition(key);
    });
  });
</script>
