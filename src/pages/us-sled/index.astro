.need-card.on .check { background: var(--cyan); border-color: var(--cyan); }
.need-card.on .check::after { content: ""; position: absolute; left: 4px; top: 1px; width: 5px; height: 9px; border-right: 2px solid var(--yale-dark); border-bottom: 2px solid var(--yale-dark); transform: rotate(45deg); }
