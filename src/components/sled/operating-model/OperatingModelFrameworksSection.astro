---
import Accessibility from '@lucide/astro/icons/accessibility';
import Cloud from '@lucide/astro/icons/cloud';
import HeartPulse from '@lucide/astro/icons/heart-pulse';
import Lock from '@lucide/astro/icons/lock';
import Shield from '@lucide/astro/icons/shield';
import ShieldCheck from '@lucide/astro/icons/shield-check';
import Eyebrow from '../../shared/Eyebrow.astro';
import SledPageWrap from '../shared/SledPageWrap.astro';

const FRAMEWORKS = [
  { name: 'SOC 2 Type II', status: 'In progress', statusClass: 'in-progress', what: '<strong>Operational cybersecurity controls.</strong> Independent audit of access, change management, monitoring, and incident response over a 6 to 12 month observation window.', detail: { Scope: 'Engineering platform, ticketing, code repos, identity provider, production deploy pipeline.', Target: 'Type II report Q4 2026 · Bridge letter on request', Auditor: 'CPA firm engaged; readiness assessment complete' } },
  { name: 'CJIS Security Policy', status: 'Posture', statusClass: 'posture', what: '<strong>Required for law-enforcement, court, and dispatch work.</strong> Personnel fingerprinting, background checks, U.S.-citizen on U.S. soil, encryption to FIPS 140-2/3 standards.', detail: { Onshore: 'Fingerprinted, background-checked U.S. personnel for any CJIS-touching engagement.', Offshore: 'Never touches CJI. Sanitized-fixture work only, gated behind onshore review.', Evidence: "Personnel attestations and workstation hardening report provided to the prime's CJIS coordinator." } },
  { name: 'StateRAMP / TX-RAMP', status: 'Aligned', statusClass: 'aligned', what: "<strong>Cloud architectures we design are StateRAMP-aware.</strong> We do not hold an authorization ourselves; we build inside the prime's authorization boundary using controls that map to StateRAMP and TX-RAMP categorization.", detail: { 'What we do': 'Architecture, control mapping, SSP narrative drafts, control evidence collection, and 3PAO response support.', Boundary: "All work performed inside the prime's authorization boundary on prime-managed cloud accounts." } },
  { name: 'Section 508 / VPAT', status: 'Applied', statusClass: 'applied', what: '<strong>Required for all government digital interfaces.</strong> WCAG 2.2 AA validation, screen-reader regression, PDF/UA conversion, plain-language editing pipelines. VPAT 2.5 ITI authored per delivered surface.', detail: { Methodology: 'axe DevTools automated · NVDA & VoiceOver manual · keyboard-only walkthroughs · PDF/UA validation.', Deliverable: 'A signed VPAT ships with every accessibility-scoped engagement. Prior VPATs reviewable under NDA.' } },
  { name: 'NIST 800-171 / CMMC', status: 'Aligned', statusClass: 'aligned', what: '<strong>Standard hygiene for any prime serving federal customers.</strong> 110-control baseline implemented across access management, audit, configuration, incident response, and media protection.', detail: { Posture: 'Self-assessment complete · SSP & POAM maintained · gap remediation tracked quarterly.', CMMC: 'Level 2 alignment for engagements requiring it; assessment via prime-led joint scope.' } },
  { name: 'HIPAA · IRS Pub 1075', status: 'Posture', statusClass: 'posture', what: '<strong>Required for healthcare, eligibility, and tax-data engagements.</strong> BAA execution as subcontractor under prime BAA. Pub 1075 onshore handling for FTI; offshore plane never touches FTI or PHI.', detail: { BAA: 'Mutual or prime-flow-down BAA executed before any PHI exposure.', FTI: 'Handled exclusively by U.S. personnel on U.S. soil per IRS Pub 1075 §9.3.' } },
] as const;

const frameworkIcons = [ShieldCheck, Shield, Cloud, Accessibility, Lock, HeartPulse] as const;

const statusStyles = {
  'in-progress': 'bg-amber/12 text-amber',
  aligned: 'bg-yale/8 text-yale',
  applied: 'bg-cyan-soft text-yale-dark',
  posture: 'bg-seasalt text-muted',
} as const;
---

<section class="sled-section-tight bg-seasalt" id="frameworks">
  <SledPageWrap>
    <div class="sled-reveal mb-12 max-w-[720px]" data-sled-reveal>
      <Eyebrow text="Compliance frameworks" showGlyph class="mb-4" />
      <h2 class="sled-h2 text-yale-dark">
        The frameworks a prime compliance officer is looking for.
      </h2>
      <p class="mt-3.5 text-[15.5px] leading-[1.65] text-muted">
        Specific claims with status, scope, and target dates. Where a framework is in-progress, a target date is on the page. Where a framework applies on a per-engagement basis, the posture statement explains how.
      </p>
    </div>

    <div class="sled-reveal-stagger grid grid-cols-1 gap-4 lg:grid-cols-2" data-sled-reveal>
      {FRAMEWORKS.map((fw, idx) => {
        const Icon = frameworkIcons[idx];
        return (
          <article class="sled-card group flex flex-col rounded-2xl p-6 sm:p-7">
            <div class="mb-4 flex items-start justify-between gap-4">
              <div class="flex items-start gap-3">
                <div class="text-[16px] font-extrabold leading-tight text-yale-dark">{fw.name}</div>
              </div>
              <span
                class:list={[
                  'inline-flex shrink-0 items-center rounded-full px-3 py-1 text-[12.5px] font-bold',
                  statusStyles[fw.statusClass],
                ]}
              >
                {fw.status}
              </span>
            </div>
            <div class="text-[13.5px] leading-[1.55] text-muted" set:html={fw.what} />
            <div class="mt-5 grid grid-cols-1 gap-x-4 gap-y-2 rounded-xl border border-line bg-seasalt/80 p-4 sm:grid-cols-[minmax(120px,140px)_1fr]">
              {Object.entries(fw.detail).map(([k, v]) => (
                <>
                  <div class="font-mono text-[10.5px] font-bold tracking-[0.14em] text-cyan-strong uppercase">{k}</div>
                  <div class:list={['text-[13.5px] leading-[1.55] text-muted', { 'font-semibold text-yale-dark': k === 'Target' }]}>{v}</div>
                </>
              ))}
            </div>
          </article>
        );
      })}
    </div>
  </SledPageWrap>
</section>
