---
import { COVERAGE_CHIPS, COVERAGE_SECTION } from '../../../lib/constants/pages/how-we-engage';
import Eyebrow from '../../shared/Eyebrow.astro';
import SledPageWrap from '../shared/SledPageWrap.astro';
---

<section class="sled-section bg-white" id="coverage" data-screen-label="04 Coverage">
  <SledPageWrap>
    <div class="sled-reveal mb-[clamp(2rem,4vw,3.25rem)] max-w-[720px]" data-sled-reveal>
      <Eyebrow text={COVERAGE_SECTION.eyebrow} showGlyph class="mb-3.5" />
      <h2 class="sled-h2 leading-[1.12] text-yale-dark">{COVERAGE_SECTION.heading}</h2>
      <p class="mt-3.5 max-w-[640px] text-[15.5px] leading-[1.6] text-muted">{COVERAGE_SECTION.body}</p>
    </div>

    <div class="sled-reveal grid grid-cols-1 items-stretch gap-9 lg:grid-cols-[1.3fr_0.9fr] lg:gap-12" data-sled-reveal>
      <div class="sled-map-wrap rounded-2xl border border-line bg-white p-[30px] shadow-[0_24px_48px_-28px_rgba(21,58,95,0.18)]">
        <svg
          id="sledDotmap"
          class="block h-auto w-full"
          viewBox="0 0 460 280"
          role="img"
          aria-label="Dotted map of the United States showing state and local coverage via primes"
        />
        <div class="mt-[18px] flex flex-wrap items-center gap-[18px] font-mono text-xs tracking-[0.04em] text-muted">
          {COVERAGE_SECTION.mapLegend.map((item) => (
            <span class="inline-flex items-center gap-[7px]">
              <i
                class:list={[
                  'block size-[9px] rounded-full',
                  item.tone === 'served' ? 'bg-cyan' : 'bg-line',
                ]}
                aria-hidden="true"
              />
              {item.label}
            </span>
          ))}
        </div>
      </div>

      <div class="flex flex-col gap-3">
        {COVERAGE_CHIPS.map((chip) => (
          <div class="sled-veh-chip group flex items-center justify-between gap-4 rounded-[14px] border border-line bg-white px-5 py-4 transition-[transform,border-color,box-shadow] duration-300 hover:translate-x-[3px] hover:border-cyan hover:shadow-[0_8px_24px_-16px_rgba(21,58,95,0.18)]">
            <span class="text-[15px] font-bold text-yale">{chip.name}</span>
            <span class="font-mono text-[11.5px] tracking-[0.02em] text-muted">{chip.meta}</span>
          </div>
        ))}
      </div>
    </div>
  </SledPageWrap>
</section>
