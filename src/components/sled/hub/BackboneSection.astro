---
import ArrowRight from '@lucide/astro/icons/arrow-right';
import { SLED_BACKBONE } from '../../../lib/constants/pages/sled-hub';
import Eyebrow from '../../shared/Eyebrow.astro';
import BackboneBentoCard from './BackboneBentoCard.astro';
import SledPageWrap from '../shared/SledPageWrap.astro';

const staggerDelays = [0, 60, 120, 180, 240, 300];
---

<section
  class="sled-section border-y border-line-soft bg-seasalt"
  id="backbone"
  data-screen-label="The backbone"
>
  <SledPageWrap>
    <div class="sled-reveal mb-[30px] max-w-[640px]" data-sled-reveal>
      <Eyebrow text={SLED_BACKBONE.eyebrow} showGlyph class="mb-4" />
      <h2 class="text-[clamp(1.7rem,2.5vw,2.3rem)] font-semibold leading-[1.12] tracking-[-0.02em] text-yale-dark">
        {SLED_BACKBONE.heading}
      </h2>
      <a
        class="mt-[18px] inline-flex items-center gap-2 text-sm font-bold text-yale-dark transition-colors duration-200 hover:text-cyan-strong"
        href={SLED_BACKBONE.linkHref}
      >
        {SLED_BACKBONE.linkLabel}
        <ArrowRight class="size-4" aria-hidden="true" />
      </a>
    </div>

    <div class="sled-reveal-stagger grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3" data-sled-reveal>
      {
        SLED_BACKBONE.cards.map((card, idx) => (
          <BackboneBentoCard card={card} delayMs={staggerDelays[idx]} />
        ))
      }
    </div>
  </SledPageWrap>
</section>
