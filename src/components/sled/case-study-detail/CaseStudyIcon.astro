  package: Package,
  'phone-call': PhoneCall,
  'phone-off': PhoneOff,
  plug: Plug,
  radar: Radar,
  receipt: Receipt,
  'receipt-text': ReceiptText,
  route: Route,
  scale: Scale,
  'scroll-text': ScrollText,
  'search-check': SearchCheck,
  send: Send,
  server: Server,
  'server-crash': ServerCrash,
