---
import { Plus } from '@lucide/astro';
import Building2 from '@lucide/astro/icons/building-2';
import FileSearch from '@lucide/astro/icons/file-search';
import Handshake from '@lucide/astro/icons/handshake';
import Network from '@lucide/astro/icons/network';
import Signature from '@lucide/astro/icons/signature';
import UsersRound from '@lucide/astro/icons/users-round';
import { VEHICLES_BENTO, VEHICLES_BENTO_SECTION } from '../../../lib/constants/pages/how-we-engage';
import Eyebrow from '../../shared/Eyebrow.astro';
import SledPageWrap from '../shared/SledPageWrap.astro';

const iconMap = {
  network: Network,
  'building-2': Building2,
  signature: Signature,
  handshake: Handshake,
  'users-round': UsersRound,
  'file-search': FileSearch,
} as const;
---

<section class="sled-section border-t border-line/60 bg-seasalt" id="vehicles" data-screen-label="05 Vehicles">
  <SledPageWrap>
    <div class="sled-reveal mb-[clamp(2rem,4vw,3.25rem)] max-w-[720px]" data-sled-reveal>
      <Eyebrow text={VEHICLES_BENTO_SECTION.eyebrow} showGlyph class="mb-3.5" />
      <h2 class="sled-h2 leading-[1.12] text-yale-dark max-w-[20ch]">{VEHICLES_BENTO_SECTION.heading}</h2>
      <p class="mt-3.5 max-w-[640px] text-[15.5px] leading-[1.6] text-muted">{VEHICLES_BENTO_SECTION.body}</p>
    </div>

    <div class="sled-reveal-stagger sled-bento grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3" data-sled-reveal data-sled-bento>
      {VEHICLES_BENTO.map((card, idx) => {
        const CardIcon = iconMap[card.icon as keyof typeof iconMap];
        const isDark = 'dark' in card && false;
        return (
          <article
            class:list={[
              'sled-bento-card group relative flex min-h-[158px] cursor-pointer flex-col overflow-hidden rounded-[14px] border p-6 transition-[transform,box-shadow,border-color] duration-300 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cyan',
              isDark
                ? 'border-transparent bg-yale-dark text-white'
                : 'border-line bg-white hover:translate-y-[-3px] hover:border-line hover:shadow-[0_16px_40px_-20px_rgba(21,58,95,0.22)]',
            ]}
            tabindex="0"
            style={`--d:${idx * 60}ms`}
          >
            <span
              class:list={[
                'mb-[18px] grid size-[46px] place-items-center rounded-xl',
                isDark ? 'bg-cyan/16 text-cyan' : 'bg-cyan-soft text-cyan-strong',
              ]}
            >
              {CardIcon && <CardIcon class="size-[22px]" aria-hidden="true" />}
            </span>
            <div class="mb-[7px] font-mono text-[11px] font-semibold tracking-[0.1em] uppercase text-cyan-strong">
              {card.meta}
            </div>
            <h3 class:list={['text-[1.2rem] leading-[1.2] font-semibold', isDark ? 'text-white' : 'text-yale-dark']}>
              {card.heading}
            </h3>
            <span
              class:list={[
                'absolute right-[22px] top-[22px] grid size-[26px] place-items-center rounded-full border transition-[transform,border-color,color] duration-300 group-[.is-open]:rotate-45',
                isDark
                  ? 'border-white/28 text-white/70 group-hover:border-cyan group-hover:text-cyan'
                  : 'border-line text-muted group-hover:border-cyan group-hover:text-cyan-strong',
              ]}
              aria-hidden="true"
            >
              <Plus class="size-[15px]" />
            </span>
            <div
              class:list={[
                'sled-bento-detail absolute inset-0 flex flex-col justify-end gap-3 rounded-[inherit] p-6 opacity-0 invisible translate-y-2.5 transition-[opacity,transform,visibility] duration-300 group-hover:opacity-100 group-hover:visible group-hover:translate-y-0 group-focus-within:opacity-100 group-focus-within:visible group-focus-within:translate-y-0 group-[.is-open]:opacity-100 group-[.is-open]:visible group-[.is-open]:translate-y-0',
                isDark ? 'bg-yale-mid' : 'bg-white',
              ]}
            >
              <p class:list={['m-0 text-[13.5px] leading-normal', isDark ? 'text-white/80' : 'text-muted']}>
                {card.body}
              </p>
              <div
                class:list={[
                  'border-t pt-3.5 font-mono text-[11.5px] leading-[1.7] tracking-[0.01em]',
                  isDark ? 'border-white/16 text-white/62' : 'border-line text-muted',
                ]}
              >
                {'stackPrefix' in card && card.stackPrefix ? (
                  <>
                    {card.stackPrefix}{' '}
                    <b class:list={[isDark ? 'text-white' : 'text-yale']}>{card.stack}</b>
                  </>
                ) : 'stackSuffix' in card && card.stackSuffix ? (
                  <>
                    <b class:list={[isDark ? 'text-white' : 'text-yale']}>{card.stack}</b>
                    {card.stackSuffix}
                  </>
                ) : 'stackBold' in card && card.stackBold ? (
                  <b class:list={[isDark ? 'text-white' : 'text-yale']}>{card.stack}</b>
                ) : (
                  card.stack
                )}
              </div>
            </div>
          </article>
        );
      })}
    </div>
  </SledPageWrap>
</section>
