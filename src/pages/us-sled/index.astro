          <div>
            <label class="field-label">Your role</label>
            <input type="text" id="iq-role" name="role" placeholder="e.g. Capture Manager, Delivery Lead" />
          </div>
        </div>
        <div class="form-row">
          <div>
            <label class="field-label">Contract vehicle</label>
            <select id="iq-vehicle" name="vehicle">
              <option value="">Select…</option>
              <option>NASPO ValuePoint</option><option>GSA MAS / IT-70</option>
              <option>State Master Agreement</option><option>Direct Subcontract</option>
              <option>Local Co-op</option><option>Open RFP / RFQ</option><option>Other</option>
            </select>
          </div>
          <div>
            <label class="field-label">Agency / end customer</label>
