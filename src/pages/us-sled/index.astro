---
import SledLayout from '../../layouts/SledLayout.astro';
import {
  SLED_HUB_SEO, SLED_HERO, TRUST_ITEMS, OUTCOMES_STATS, BACKBONE_CARDS, VEHICLES, WHY_CARDS
} from '../../lib/constants/pages/sled-hub';
import { SITE } from '../../lib/constants/site';

const { title, description, canonicalPath, ogImage } = SLED_HUB_SEO;
---

<SledLayout {title} {description} {canonicalPath} {ogImage} currentPage="/us-sled/">

<!-- HERO -->
<section
  class="relative isolate overflow-hidden bg-yale-dark text-white min-h-[640px]"
  id="top"
  data-screen-label="01 Hero"
>
  <div class="absolute inset-0 z-0 overflow-hidden" aria-hidden="true">
    <div
      class="absolute inset-0 bg-[url('/assets/capitol.png')] bg-cover bg-[position:right_35%] opacity-[0.48] [filter:saturate(0.5)_contrast(1.05)_brightness(0.9)] [will-change:transform] animate-[capitolDrift_32s_ease-in-out_infinite_alternate]"
    ></div>
  </div>
  <div
    class="absolute inset-0 z-[1] bg-[linear-gradient(90deg,rgba(14,38,64,0.98)_0%,rgba(14,38,64,0.88)_38%,rgba(14,38,64,0.55)_72%,rgba(14,38,64,0.30)_100%),linear-gradient(180deg,rgba(14,38,64,0.20)_0%,rgba(14,38,64,0.55)_100%)]"
    aria-hidden="true"
  ></div>
  <div class="hidden" aria-hidden="true"></div>
  <div class="hidden" aria-hidden="true">
    <span></span><span></span><span></span><span></span><span></span><span></span>
  </div>
  <div class="hidden" aria-hidden="true">
    <span class="a"></span><span class="b"></span><span class="c"></span>
    <span class="d"></span><span class="e"></span><span class="f"></span>
    <span class="g"></span><span class="h"></span>
  </div>

  <div class="relative z-[5] mx-auto w-full max-w-[1120px] px-5 py-[120px] pb-[110px] lg:px-8">
    <div class="max-w-[760px]">
      <span class="mb-[22px] inline-flex items-center gap-2 text-cyan font-mono text-[10.5px] tracking-[0.14em] uppercase">
        <span class="inline-block size-2 bg-cyan [transform:rotate(15deg)]" aria-hidden="true"></span>
        {SLED_HERO.eyebrow}
      </span>
      <h1 class="mb-6 text-[60px] leading-[1.04] tracking-[-0.022em] font-extrabold text-white [&_.accent]:text-cyan" set:html={SLED_HERO.heading} />
      <p class="mb-9 max-w-[640px] text-[18px] leading-[1.55] text-white/80">{SLED_HERO.body}</p>

      <div class="flex flex-wrap gap-[14px]">
        {SLED_HERO.ctas.map(cta => (
          cta.variant === 'cta'
            ? (
              <a
                href={cta.href}
                class="inline-flex items-center justify-center gap-2 rounded-[10px] bg-cyan px-6 py-[14px] text-[14.5px] font-bold text-yale-dark transition-[transform,box-shadow] duration-200 ease-out hover:-translate-y-[1px] hover:shadow-[0_14px_28px_-10px_rgba(14,38,64,0.40)]"
              >
                {cta.label}
                <span class="inline-block text-[16px]" aria-hidden="true">→</span>
              </a>
            )
            : (
              <a
                href={cta.href}
                class="inline-flex items-center justify-center rounded-[10px] border border-white/20 bg-white/5 px-6 py-[14px] text-[14.5px] font-bold text-white transition-[background,transform] duration-200 ease-out hover:bg-white/10 hover:-translate-y-[1px]"
              >
                {cta.label}
              </a>
            )
        ))}
      </div>

      <div class="mt-14 flex max-w-[760px] gap-9 border-t border-white/15 pt-7">
        {SLED_HERO.stats.map(s => (
          <div class="flex flex-col [&+&]:border-l [&+&]:border-white/15 [&+&]:pl-9">
            <div class="text-[26px] font-extrabold leading-none tracking-[-0.02em] text-cyan">{s.n}</div>
            <div class="mt-2 font-mono text-[10.5px] tracking-[0.10em] uppercase text-white/70">{s.l}</div>
          </div>
        ))}
      </div>

      <div class="mt-9 inline-flex items-center gap-[10px] rounded border border-cyan/40 px-[14px] py-2 font-mono text-[11px] tracking-[0.10em] uppercase text-cyan/85">
        <span class="size-2 bg-cyan [transform:rotate(15deg)]" aria-hidden="true"></span>
        <span>{SLED_HERO.disclaimer}</span>
      </div>
    </div>
  </div>
</section>

<!-- TRUST STRIP -->
<div class="border-b border-line bg-white">
  <div class="mx-auto w-full max-w-[1120px] px-5 py-3 lg:px-8">
    <div class="grid grid-cols-2 gap-0 md:grid-cols-4 lg:grid-cols-8">
      <div class="flex items-center gap-3 py-2">
        <div class="grid size-9 place-items-center rounded-[10px] bg-cyan-soft text-cyan-strong">
          <svg class="size-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 3 6v6c0 5 3.8 8.3 9 10 5.2-1.7 9-5 9-10V6z"></path><path d="M9 12l2 2 4-4"></path></svg>
        </div>
        <div class="flex flex-col">
          <span class="font-mono text-[10px] tracking-[0.12em] uppercase text-muted">SAM.gov UEI</span>
          <span class="text-[12.5px] font-semibold text-muted">Add UEI</span>
        </div>
      </div>
      <div class="flex items-center gap-3 py-2">
        <div class="grid size-9 place-items-center rounded-[10px] bg-cyan-soft text-cyan-strong">
          <svg class="size-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2"></rect><path d="M3 9h18M8 14h3"></path></svg>
        </div>
        <div class="flex flex-col">
          <span class="font-mono text-[10px] tracking-[0.12em] uppercase text-muted">CAGE Code</span>
          <span class="text-[12.5px] font-semibold text-muted">Add CAGE</span>
        </div>
      </div>
      <div class="flex items-center gap-3 py-2">
        <div class="grid size-9 place-items-center rounded-[10px] bg-cyan-soft text-cyan-strong">
          <svg class="size-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l8 4.5v9L12 21l-8-4.5v-9z"></path><circle cx="12" cy="11" r="2.5"></circle><path d="M8.5 16c.6-1.8 2-2.6 3.5-2.6s2.9.8 3.5 2.6"></path></svg>
        </div>
        <div class="flex flex-col">
          <span class="font-mono text-[10px] tracking-[0.12em] uppercase text-muted">Business size</span>
          <span class="text-[12.5px] font-semibold text-muted">Small Business?</span>
        </div>
      </div>
      <div class="flex items-center gap-3 py-2">
        <div class="grid size-9 place-items-center rounded-[10px] bg-cyan-soft text-cyan-strong">
          <svg class="size-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2"></rect><path d="M7 4 V2 M17 4 V2 M3 10 h18"></path></svg>
        </div>
        <div class="flex flex-col">
          <span class="font-mono text-[10px] tracking-[0.12em] uppercase text-muted">Federal classification</span>
          <span class="text-[12.5px] font-semibold text-muted">NAICS 541511 · 541512 · 541519</span>
        </div>
      </div>
      <div class="flex items-center gap-3 py-2">
        <div class="grid size-9 place-items-center rounded-[10px] bg-cyan-soft text-cyan-strong">
          <svg class="size-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21 h18"></path><path d="M6 21 V8 l6 -4 l6 4 v13"></path></svg>
        </div>
        <div class="flex flex-col">
          <span class="font-mono text-[10px] tracking-[0.12em] uppercase text-muted">State procurement</span>
          <span class="text-[12.5px] font-semibold text-muted">NIGP 918-46 · 918-00</span>
        </div>
      </div>
      <div class="flex items-center gap-3 py-2">
        <div class="grid size-9 place-items-center rounded-[10px] bg-cyan-soft text-cyan-strong">
          <svg class="size-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><path d="M9 12 l2 2 l4 -4"></path></svg>
        </div>
        <div class="flex flex-col">
          <span class="font-mono text-[10px] tracking-[0.12em] uppercase text-muted">Insurance</span>
          <span class="text-[12.5px] font-semibold text-muted">Prime-routed</span>
        </div>
      </div>
      <div class="flex items-center gap-3 py-2">
        <div class="grid size-9 place-items-center rounded-[10px] bg-cyan-soft text-cyan-strong">
          <svg class="size-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><path d="M12 7 v5 l3 2"></path></svg>
        </div>
        <div class="flex flex-col">
          <span class="font-mono text-[10px] tracking-[0.12em] uppercase text-muted">Response SLA</span>
          <span class="text-[12.5px] font-semibold text-muted">1 business day</span>
        </div>
      </div>
      <a class="flex items-center gap-3 py-2" href="/us-sled/operating-model/">
        <div class="grid size-9 place-items-center rounded-[10px] bg-cyan-soft text-cyan-strong">
          <svg class="size-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 3 6v6c0 5 3.8 8.3 9 10 5.2-1.7 9-5 9-10V6z"></path><path d="M9 12l2 2 4-4"></path></svg>
        </div>
        <div class="flex flex-col">
          <span class="font-mono text-[10px] tracking-[0.12em] uppercase text-muted">Compliance posture</span>
          <span class="text-[12.5px] font-semibold text-muted">SOC 2 Type II in progress · NIST 800-171 aligned</span>
        </div>
      </a>
    </div>
  </div>
</div>

<!-- WHO WE ARE NOT -->
<div class="who-we-arent border-b border-line bg-white py-[18px]">
  <div class="mx-auto max-w-[1280px] px-12 max-[1024px]:px-8 max-[900px]:px-6 max-[600px]:px-[18px] flex flex-wrap items-center gap-4">
    <span class="shrink-0 font-mono text-[10.5px] tracking-[0.14em] text-cyan-strong uppercase">Who we are not</span>
    <p class="m-0 min-w-[280px] flex-1 text-[13.5px] leading-[1.55] text-muted">Techtiz is not a procurement intelligence firm. We are a technical implementation subcontractor for U.S. SLED primes. For RFP intelligence, our partners use Deltek GovWin and Bloomberg Government.</p>
  </div>
</div>

<!-- TWO STAGES -->
<section class="bg-seasalt py-24" id="two-stages" data-screen-label="02 Two stages">
  <div class="mx-auto w-full max-w-[1120px] px-5 lg:px-8">
    <span class="mb-3.5 inline-flex items-center gap-2 font-mono text-[10.5px] tracking-[0.14em] uppercase text-cyan-strong">
      <span class="inline-block size-2 bg-cyan [transform:rotate(15deg)]" aria-hidden="true"></span>
      Two engagement modes. One contract structure.
    </span>
    <div class="mb-12 grid grid-cols-1 gap-8 lg:grid-cols-[1.05fr_0.95fr] lg:items-end">
      <h2 class="text-[44px] leading-[1.05] tracking-[-0.022em] text-yale-dark">Engage us pre-award, post-award, or both, the prime always stays the face to the agency.</h2>
      <p class="max-w-[540px] text-[16px] leading-[1.6] text-muted">Under teaming letter and NDA. Pre-award, we draft proposal volumes and build demo systems for your evaluation panel. Post-award, we deliver the technical workstream. Either way, white-labeled.</p>
    </div>

    <div class="toggle-pill inline-flex items-center justify-center gap-[4px] rounded-full border border-line bg-white p-[6px] mb-[40px]" role="tablist">
      <button class="on inline-flex items-center gap-[10px] px-[22px] py-[12px] rounded-full text-[14px] font-bold text-muted transition-[background,color] duration-[200ms] ease-out hover:text-yale [&.on]:bg-yale-dark [&.on]:text-white" data-stage="pre" role="tab" aria-selected="true">
        <svg class="ic size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M9 9 l6 6 M15 9 l-6 6"></path></svg>
        Pre-Award Proposal Support
      </button>
      <button class="inline-flex items-center gap-[10px] px-[22px] py-[12px] rounded-full text-[14px] font-bold text-muted transition-[background,color] duration-[200ms] ease-out hover:text-yale [&.on]:bg-yale-dark [&.on]:text-white" data-stage="post" role="tab" aria-selected="false">
        <svg class="ic size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 17 9 11 13 15 21 7"></polyline><polyline points="14 7 21 7 21 14"></polyline></svg>
        Post-Award Delivery
      </button>
    </div>

    <!-- PRE-BID PANEL -->
    <div class="stage-panel show grid grid-cols-1 gap-6 lg:grid-cols-[1fr_1.55fr] lg:gap-12" data-panel="pre">
      <div>
        <div class="mb-[18px] inline-flex items-center gap-[10px] font-mono text-[11px] tracking-[0.14em] uppercase text-cyan-strong">Phase 01 · Pre-Award (under teaming letter + NDA)</div>
        <h3 class="mb-7 text-[30px] leading-[1.15] text-yale-dark">Load the technical volume. Build the demo. Package past performance.</h3>
        <div class="rounded-[12px] border border-line bg-white p-[22px] pb-5">
          <div class="mb-3 inline-flex items-center gap-2 font-mono text-[10.5px] tracking-[0.16em] uppercase text-amber">The Pain Point</div>
          <p class="text-[14px] leading-[1.55] text-ink italic">"17 days to submission. Your architect is on another pursuit. Technical volume, compliance matrix, and orals demo all need owners."</p>
        </div>
        <div class="mt-[22px] inline-flex items-center gap-2 font-mono text-[12px] text-muted">↳ Our role: <strong class="font-semibold tracking-[0.02em] text-yale-dark">Proposal-support services under teaming letter</strong></div>
      </div>
      <div class="grid grid-cols-1 gap-[14px] lg:grid-cols-2">
        <div class="relative flex gap-[14px] rounded-[12px] border border-line bg-white p-[22px] pb-5 transition-[transform,border-color,box-shadow] duration-200 ease-out hover:-translate-y-[2px] hover:border-[#C2CCD9] hover:shadow-[0_16px_30px_-18px_rgba(21,58,95,0.18)]"><span class="absolute right-[22px] top-[18px] font-mono text-[10.5px] tracking-[0.14em] text-muted">01</span><div class="shrink-0 text-cyan-strong"><svg class="size-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4z"></path></svg></div><div class="flex flex-col gap-1.5"><h4 class="text-[15.5px] leading-[1.25] text-yale-dark">Technical volume writing</h4><p class="text-[13.5px] leading-[1.5] text-muted">Solution architecture, approach, and methodology sections drafted to your outline and style guide.</p></div></div>
        <div class="relative flex gap-[14px] rounded-[12px] border border-line bg-white p-[22px] pb-5 transition-[transform,border-color,box-shadow] duration-200 ease-out hover:-translate-y-[2px] hover:border-[#C2CCD9] hover:shadow-[0_16px_30px_-18px_rgba(21,58,95,0.18)]"><span class="absolute right-[22px] top-[18px] font-mono text-[10.5px] tracking-[0.14em] text-muted">02</span><div class="shrink-0 text-cyan-strong"><svg class="size-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"></polyline><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path></svg></div><div class="flex flex-col gap-1.5"><h4 class="text-[15.5px] leading-[1.25] text-yale-dark">Compliance matrix preparation</h4><p class="text-[13.5px] leading-[1.5] text-muted">Line-by-line traceability against the SOW, every statutory requirement mapped to a proposal section, owner, and evidence.</p></div></div>
        <div class="relative flex gap-[14px] rounded-[12px] border border-line bg-white p-[22px] pb-5 transition-[transform,border-color,box-shadow] duration-200 ease-out hover:-translate-y-[2px] hover:border-[#C2CCD9] hover:shadow-[0_16px_30px_-18px_rgba(21,58,95,0.18)]"><span class="absolute right-[22px] top-[18px] font-mono text-[10.5px] tracking-[0.14em] text-muted">03</span><div class="shrink-0 text-cyan-strong"><svg class="size-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 17 9 11 13 15 21 7"></polyline><polyline points="14 7 21 7 21 14"></polyline></svg></div><div class="flex flex-col gap-1.5"><h4 class="text-[15.5px] leading-[1.25] text-yale-dark">LOE &amp; pricing input</h4><p class="text-[13.5px] leading-[1.5] text-muted">Bottom-up labor estimates with optimistic/likely/pessimistic ranges. Direct-to-pricing model handoff.</p></div></div>
        <div class="relative flex gap-[14px] rounded-[12px] border border-line bg-white p-[22px] pb-5 transition-[transform,border-color,box-shadow] duration-200 ease-out hover:-translate-y-[2px] hover:border-[#C2CCD9] hover:shadow-[0_16px_30px_-18px_rgba(21,58,95,0.18)]"><span class="absolute right-[22px] top-[18px] font-mono text-[10.5px] tracking-[0.14em] text-muted">04</span><div class="shrink-0 text-cyan-strong"><svg class="size-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"></rect><path d="M8 21h8M12 17v4"></path></svg></div><div class="flex flex-col gap-1.5"><h4 class="text-[15.5px] leading-[1.25] text-yale-dark">Demo &amp; POC builds for orals</h4><p class="text-[13.5px] leading-[1.5] text-muted">Working prototypes the evaluation panel can click, not slideware. Built in 2-3 weeks, ready for orals.</p></div></div>
        <div class="relative flex gap-[14px] rounded-[12px] border border-line bg-white p-[22px] pb-5 transition-[transform,border-color,box-shadow] duration-200 ease-out hover:-translate-y-[2px] hover:border-[#C2CCD9] hover:shadow-[0_16px_30px_-18px_rgba(21,58,95,0.18)]"><span class="absolute right-[22px] top-[18px] font-mono text-[10.5px] tracking-[0.14em] text-muted">05</span><div class="shrink-0 text-cyan-strong"><svg class="size-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg></div><div class="flex flex-col gap-1.5"><h4 class="text-[15.5px] leading-[1.25] text-yale-dark">Past-performance packaging</h4><p class="text-[13.5px] leading-[1.5] text-muted">Citation writeups, CPARS-equivalent narratives, and reference letters, in your prime-branded templates.</p></div></div>
        <div class="relative flex gap-[14px] rounded-[12px] border border-line bg-white p-[22px] pb-5 transition-[transform,border-color,box-shadow] duration-200 ease-out hover:-translate-y-[2px] hover:border-[#C2CCD9] hover:shadow-[0_16px_30px_-18px_rgba(21,58,95,0.18)]"><span class="absolute right-[22px] top-[18px] font-mono text-[10.5px] tracking-[0.14em] text-muted">06</span><div class="shrink-0 text-cyan-strong"><svg class="size-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="8" r="4"></circle><path d="M19 8l2 2 3-3"></path></svg></div><div class="flex flex-col gap-1.5"><h4 class="text-[15.5px] leading-[1.25] text-yale-dark">Key personnel resume tailoring</h4><p class="text-[13.5px] leading-[1.5] text-muted">Resume edits, role mapping, and LCAT alignment for proposed staff (yours or ours, named on your roster).</p></div></div>
      </div>
    </div>

    <!-- POST-BID PANEL -->
    <div class="stage-panel grid grid-cols-1 gap-6 lg:grid-cols-[1fr_1.55fr] lg:gap-12" data-panel="post">
      <div>
        <div class="mb-[18px] inline-flex items-center gap-[10px] font-mono text-[11px] tracking-[0.14em] uppercase text-cyan-strong">Phase 02 · Post-Award</div>
        <h3 class="mb-7 text-[30px] leading-[1.15] text-yale-dark">Deliver the technical workstream, under your name.</h3>
        <div class="rounded-[12px] border border-line bg-white p-[22px] pb-5">
          <div class="mb-3 inline-flex items-center gap-2 font-mono text-[10.5px] tracking-[0.16em] uppercase text-amber">The Pain Point</div>
          <p class="text-[14px] leading-[1.55] text-ink italic">"Kickoff Monday. You need senior engineers in seats, a sprint cadence the agency PM trusts, and zero compliance findings. Bench is thin, ramp-up is tight."</p>
        </div>
        <div class="mt-[22px] inline-flex items-center gap-2 font-mono text-[12px] text-muted">↳ Our role: <strong class="font-semibold tracking-[0.02em] text-yale-dark">Back-office delivery · white-label</strong></div>
      </div>
      <div class="grid grid-cols-1 gap-[14px] lg:grid-cols-2">
        <div class="relative flex gap-[14px] rounded-[12px] border border-line bg-white p-[22px] pb-5 transition-[transform,border-color,box-shadow] duration-200 ease-out hover:-translate-y-[2px] hover:border-[#C2CCD9] hover:shadow-[0_16px_30px_-18px_rgba(21,58,95,0.18)]"><span class="absolute right-[22px] top-[18px] font-mono text-[10.5px] tracking-[0.14em] text-muted">01</span><div class="shrink-0 text-cyan-strong"><svg class="size-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg></div><div class="flex flex-col gap-1.5"><h4 class="text-[15.5px] leading-[1.25] text-yale-dark">Senior engineering surge</h4><p class="text-[13.5px] leading-[1.5] text-muted">Named, vetted engineers, not generic resumes. Cleared resources available; team scaling 2-20 FTEs.</p></div></div>
