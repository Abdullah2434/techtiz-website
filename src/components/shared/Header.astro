        class="grid size-[42px] place-items-center rounded-lg border border-line bg-white text-yale transition-[border-color,background,color] duration-[180ms] ease-out hover:border-yale hover:bg-seasalt"
      >
        <svg aria-hidden="true" viewBox="0 0 20 20" class="size-4">
          <path
            d="M7 4.5 12.5 10 7 15.5"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
      </a>
    </div>
