---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/shared/Header.astro';
import Footer from '../components/shared/Footer.astro';
import Subnav from '../components/shared/Subnav.astro';
import type { JsonLdNode } from '../lib/seo/types';

interface Props {
  title: string;
  description: string;
  canonicalPath: string;
  ogImage?: string;
  currentPage?: string;
  showSubnav?: boolean;
  jsonLd?: JsonLdNode[];
}

const {
  title,
  description,
  canonicalPath,
  ogImage,
  currentPage = '',
  showSubnav = true,
  jsonLd,
} = Astro.props;
---

<BaseLayout {title} {description} {canonicalPath} {ogImage} {jsonLd}>
  <Header currentPage={currentPage} />
  {showSubnav && <Subnav currentPath={canonicalPath} />}
  <main id="main-content">
    <slot />
  </main>
  <Footer />
  <script src="/scripts/nav.js" is:inline></script>
  <script src="/scripts/mobile-nav.js" is:inline></script>
</BaseLayout>
