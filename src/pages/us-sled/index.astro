</SledLayout>

<style>
  @keyframes capitolDrift {
    0% { transform: scale(1.02) translate3d(0, 0, 0); }
    100% { transform: scale(1.05) translate3d(-6px, -4px, 0); }
  }
  /* JS-toggled hooks: keep behavior stable without external CSS */
  .stage-panel { display: none; }
  .stage-panel.show { display: grid; }
  #inquirySuccess { display: none; }
  #inquirySuccess.is-visible { display: flex; }
  .need-card.on .check { background: var(--cyan); border-color: var(--cyan); }
  .need-card.on .check::after {
    content: "";
    position: absolute;
    left: 4px;
    top: 1px;
    width: 5px;
    height: 9px;
    border-right: 2px solid var(--yale-dark);
    border-bottom: 2px solid var(--yale-dark);
    transform: rotate(45deg);
  }
</style>


<script>
  // Stage tabs (Pre-Bid / Post-Bid)
  (function(){
    const buttons = document.querySelectorAll('.toggle-pill button[data-stage]');
    const panels = document.querySelectorAll('.stage-panel');
    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const target = (btn as HTMLButtonElement).dataset.stage;
        buttons.forEach(b => {
          b.classList.toggle('on', b === btn);
          b.setAttribute('aria-selected', b === btn ? 'true' : 'false');
        });
        panels.forEach(p => (p as HTMLElement).classList.toggle('show', (p as HTMLElement).dataset.panel === target));
      });
    });
  })();

  // Pre/Post inquiry checkboxes
  (function(){
    const cards = document.querySelectorAll('.need-card');
    cards.forEach(card => {
      card.addEventListener('click', () => card.classList.toggle('on'));
    });
  })();

  // Hub inquiry form: validate → mailto → success
  (function(){
    const form = document.getElementById('inquiryForm') as HTMLFormElement;
    const success = document.getElementById('inquirySuccess');
    if(!form) return;
    function v(id: string){ const el = document.getElementById(id) as HTMLInputElement; return el ? el.value.trim() : ''; }
    form.addEventListener('submit', e => {
      e.preventDefault();
      let ok = true;
      ['iq-company','iq-email'].forEach(id => {
        const el = document.getElementById(id) as HTMLInputElement;
        if(el && !el.value.trim()){ el.style.borderColor = 'var(--amber)'; ok = false; }
        else if(el){ el.style.borderColor = ''; }
      });
      if(!ok) return;
      const needs = [...document.querySelectorAll('.need-card.on .body h5')].map(h => h.textContent?.trim());
      const lines = [
        'U.S. SLED engagement inquiry (hub)', '',
        'Needs:       ' + (needs.join(', ') || '—'),
        'Company:     ' + v('iq-company'),
        'Role:        ' + v('iq-role'),
        'Vehicle:     ' + v('iq-vehicle'),
        'Agency:      ' + v('iq-agency'),
        'Email:       ' + v('iq-email'),
        'Phone:       ' + v('iq-phone'),
        '', 'Description:', (v('iq-desc') || '(none provided)')
      ];
      const subject = 'SLED engagement inquiry — ' + (v('iq-company') || 'prime contractor');
      window.location.href = 'mailto:sled@techtiz.co?subject=' + encodeURIComponent(subject) + '&body=' + encodeURIComponent(lines.join('\n'));
      form.classList.add('hidden');
      success?.classList.add('is-visible');
    });
    const reset = document.getElementById('inquiryReset');
    if(reset) reset.addEventListener('click', e => {
      e.preventDefault();
      success?.classList.remove('is-visible');
      form.reset();
      form.classList.remove('hidden');
    });
  })();
</script>
