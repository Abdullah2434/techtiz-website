                </a>
                <a class="mega-item group flex cursor-pointer items-center justify-between rounded-lg px-3.5 py-[11px] text-sm font-semibold text-ink transition-[background,color] duration-[180ms] ease-out hover:bg-cyan-soft hover:text-yale-dark [&.active]:bg-cyan-soft [&.active]:text-yale-dark" data-key="transformation" href="/">
                  Digital Transformation
                  <span class="arr-r size-2 rotate-[-45deg] border-r-[1.6px] border-b-[1.6px] border-current opacity-0 transition-opacity duration-[180ms] ease-out group-data-[active=true]:opacity-60"></span>
                </a>
                <a class="mega-item group flex cursor-pointer items-center justify-between rounded-lg px-3.5 py-[11px] text-sm font-semibold text-ink transition-[background,color] duration-[180ms] ease-out hover:bg-cyan-soft hover:text-yale-dark [&.active]:bg-cyan-soft [&.active]:text-yale-dark" data-key="ux" href="/">
                  UX Design / Enablement
                  <span class="arr-r size-2 rotate-[-45deg] border-r-[1.6px] border-b-[1.6px] border-current opacity-0 transition-opacity duration-[180ms] ease-out group-data-[active=true]:opacity-60"></span>
                </a>
              </div>
            </div>
            <div class="mega-right flex flex-col border-l border-line-soft pl-[22px]">
              <div class="mega-feature mb-3.5 flex items-start gap-3.5 rounded-[10px] bg-cyan-soft p-4 px-[18px]" data-feature="services">
                <div class="feat-icon grid size-[38px] shrink-0 place-items-center text-yale-dark">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="3" width="20" height="14" rx="2"></rect>
                    <path d="M8 21h8M12 17v4"></path>
                  </svg>
                </div>
                <div>
                  <h4 data-feat-title class="mb-1 text-[17px] leading-[1.2] text-yale-dark">Development</h4>
                  <p data-feat-desc class="m-0 max-w-[360px] text-xs leading-[1.45] text-muted">Build robust, scalable digital products designed to grow with your business.</p>
                </div>
              </div>
              <div class="mega-sublinks grid grid-cols-2 gap-x-2 gap-y-0.5 py-1" data-sublinks="services">
                <a href="/" class="rounded-md px-3 py-2 text-[13.5px] font-medium text-muted transition-[background,color] duration-[180ms] ease-out hover:bg-seasalt hover:text-yale">Custom Software</a>
                <a href="/" class="rounded-md px-3 py-2 text-[13.5px] font-medium text-muted transition-[background,color] duration-[180ms] ease-out hover:bg-seasalt hover:text-yale">Mobile Apps</a>
                <a href="/" class="rounded-md px-3 py-2 text-[13.5px] font-medium text-muted transition-[background,color] duration-[180ms] ease-out hover:bg-seasalt hover:text-yale">Low code / No-code Dev</a>
