---
import PageWrap from './PageWrap.astro';
import { SITE, mailtoGeneral } from '../../lib/constants/site';
---

<section class="relative overflow-hidden bg-yale text-white">
  <div
    class="pointer-events-none absolute -right-[60px] -top-[60px] size-[360px] rotate-[15deg] bg-[linear-gradient(45deg,transparent_48%,rgba(24,176,230,0.16)_48%_52%,transparent_52%),linear-gradient(-45deg,transparent_49%,rgba(255,255,255,0.05)_49%_51%,transparent_51%)] bg-size-[32px_32px]"
    aria-hidden="true"
  ></div>
  <div
    class="pointer-events-none absolute -bottom-10 -left-10 size-[220px] rotate-[15deg] opacity-60 bg-[linear-gradient(45deg,transparent_49%,rgba(24,176,230,0.10)_49%_51%,transparent_51%)] bg-size-[24px_24px]"
    aria-hidden="true"
  ></div>

  <PageWrap class="relative z-[2] py-[110px] text-center max-[900px]:py-14">
    <span
      class="mb-[18px] inline-block font-mono text-[11px] font-bold tracking-[0.18em] uppercase text-cyan"
      data-aos="fade-up"
      data-aos-delay="100"
    >Start the conversation</span>
    <h2
      class="mx-auto mb-[22px] max-w-[760px] text-[52px] font-extrabold leading-[1.05] tracking-[-0.022em] max-[900px]:text-[30px]"
      data-aos="fade-up"
      data-aos-delay="200"
    >
      Have an idea worth building?<br />
      <span class="text-cyan">Let's pressure-test it.</span>
    </h2>
    <p
      class="mx-auto mb-9 max-w-[540px] text-[16.5px] leading-[1.55] text-white/78"
      data-aos="fade-up"
      data-aos-delay="300"
    >
      A 30-minute call with a senior engineer. No deck, no pitch. We'll sketch the system on the call.
    </p>
    <form
      class="mx-auto flex max-w-[520px] gap-2 rounded-[10px] bg-white p-1.5"
      action="/us-sled/contact/"
      method="get"
      data-aos="fade-up"
      data-aos-delay="400"
    >
      <input
        type="email"
        name="email"
        placeholder="you@company.com"
        aria-label="Your email"
        required
        class="min-w-0 flex-1 border-0 bg-transparent px-3.5 py-2.5 font-sans text-[14.5px] text-ink outline-none placeholder:text-muted"
      />
      <button
        type="submit"
        class="inline-flex shrink-0 items-center gap-2 rounded-md bg-cyan px-[22px] py-3 text-sm font-bold whitespace-nowrap text-yale-dark transition-[background,color] duration-[180ms] hover:bg-cyan-strong hover:text-white"
      >
        Book a Consultation →
      </button>
    </form>
    <p
      class="mt-[22px] text-[13.5px] text-white/60"
      data-aos="fade-up"
      data-aos-delay="500"
    >
      Or email <a class="border-b border-cyan/40 text-cyan hover:border-cyan" href={mailtoGeneral()}>{SITE.email.general}</a>
    </p>
  </PageWrap>
</section>
