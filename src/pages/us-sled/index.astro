            <select class="w-full cursor-pointer rounded-lg border border-line bg-white px-[14px] py-3 text-[14.5px] text-ink outline-none transition-[border-color,box-shadow] duration-200 ease-out focus:border-cyan focus:shadow-[0_0_0_3px_rgba(24,176,230,0.18)]" id="iq-vehicle" name="vehicle">
              <option value="">Select…</option>
              <option>NASPO ValuePoint</option><option>GSA MAS / IT-70</option>
              <option>State Master Agreement</option><option>Direct Subcontract</option>
              <option>Local Co-op</option><option>Open RFP / RFQ</option><option>Other</option>
            </select>
          </div>
          <div>
            <label class="mb-2 block font-mono text-[10.5px] tracking-[0.14em] uppercase text-muted">Agency / end customer</label>
            <input class="w-full rounded-lg border border-line bg-white px-[14px] py-3 text-[14.5px] text-ink outline-none transition-[border-color,box-shadow] duration-200 ease-out placeholder:text-[#9AA4B2] focus:border-cyan focus:shadow-[0_0_0_3px_rgba(24,176,230,0.18)]" type="text" id="iq-agency" name="agency" placeholder="e.g. NC DHHS, we never contact directly" />
