              <div class="mega-footer mt-3.5 flex items-center justify-between border-t border-line-soft pt-3.5">
                <span class="mega-tag font-mono text-[10.5px] tracking-[0.14em] text-cyan-strong uppercase">U.S. SLED prime contractor?</span>
                <a class="mega-cta inline-flex items-center gap-2 border-b-2 border-cyan pb-0.5 text-[13px] font-bold text-yale" href="/us-sled/">See SLED Partnerships →</a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="nav-item relative group" data-mega="industries">
        <button
          class="nav-link relative inline-flex cursor-pointer items-center gap-1.5 whitespace-nowrap rounded-lg border border-transparent bg-transparent px-4 py-2.5 font-sans text-[14.5px] font-semibold leading-none text-ink transition-[color,background,border-color] duration-[180ms] ease-out hover:bg-yale/4 hover:text-yale group-data-[open=true]:border-line group-data-[open=true]:bg-white group-data-[open=true]:text-yale group-data-[open=true]:shadow-[0_1px_2px_rgba(14,38,64,0.04)]"
          type="button"
          aria-expanded="false"
        >
          Industries <span class="chev size-[7px] -translate-x-px -translate-y-px rotate-45 border-r-[1.6px] border-b-[1.6px] border-current opacity-55 transition-transform duration-220 ease-out group-data-[open=true]:-translate-x-px group-data-[open=true]:-translate-y-px group-data-[open=true]:-rotate-[135deg]"></span>
