---
import ChevronDown from '@lucide/astro/icons/chevron-down';
import type { SledFaqContent } from '../../../lib/constants/pages/sled-faq';
import { absoluteUrl, faqPageJsonLd } from '../../../lib/seo/json-ld';
import JsonLd from '../../seo/JsonLd.astro';
import Eyebrow from '../../shared/Eyebrow.astro';
import SledPageWrap from './SledPageWrap.astro';

interface Props extends SledFaqContent {
  /** Canonical path for FAQPage JSON-LD (e.g. `/us-sled/contact/`). */
  canonicalPath: string;
  sectionId?: string;
  screenLabel?: string;
}

const {
  eyebrow,
  heading,
  intro,
  items,
  canonicalPath,
  sectionId = 'faq',
  screenLabel,
} = Astro.props;

const pageUrl = absoluteUrl(canonicalPath);
const faqJsonLd = faqPageJsonLd(items, pageUrl);
const headingId = `${sectionId}-heading`;
---

<section
  class="sled-section border-t border-line-soft bg-seasalt"
  id={sectionId}
  aria-labelledby={headingId}
  {...screenLabel && { 'data-screen-label': screenLabel }}
>
  <SledPageWrap>
    <div class="sled-reveal mb-[30px] max-w-[720px]" data-sled-reveal>
      <Eyebrow text={eyebrow} showGlyph class="mb-4" />
      <h2
        id={headingId}
        class="text-[clamp(1.7rem,2.5vw,2.3rem)] font-semibold leading-[1.12] tracking-[-0.02em] text-yale-dark"
      >
        {heading}
      </h2>
      {intro && (
        <p class="mt-3.5 max-w-[640px] text-[15.5px] leading-[1.6] text-muted">{intro}</p>
      )}
    </div>

    <div class="sled-reveal border-t border-line" data-sled-spec-accordion data-sled-reveal>
      {
        items.map((item, idx) => {
          const num = String(idx + 1).padStart(2, '0');
          const isOpen = idx === 0;

          return (
            <div
              class:list={['sled-spec-item border-b border-line-soft', isOpen && 'is-open']}
              data-sled-spec-item
            >
              <button
                type="button"
                class="sled-spec-head group grid w-full grid-cols-[64px_1fr_auto] items-center gap-[22px] bg-transparent px-2 py-5 text-left max-[620px]:grid-cols-[44px_1fr_auto] max-[620px]:gap-x-3.5"
                aria-expanded={isOpen ? 'true' : 'false'}
              >
                <span class="font-mono text-[1.9rem] font-semibold leading-none tracking-[-0.02em] text-line transition-colors duration-200 group-hover:text-cyan-strong [.sled-spec-item.is-open_&]:text-cyan">
                  {num}
                </span>
                <span class="text-[1.05rem] font-semibold leading-[1.3] text-yale transition-colors duration-200 group-hover:text-cyan-strong [.sled-spec-item.is-open_&]:text-yale-dark">
                  {item.question}
                </span>
                <span class="text-muted transition-[transform,color] duration-300 [.sled-spec-item.is-open_&]:rotate-180 [.sled-spec-item.is-open_&]:text-cyan-strong">
                  <ChevronDown class="size-5" aria-hidden="true" />
                </span>
              </button>
              <div class="sled-spec-body">
                <div class="sled-spec-body-inner">
                  <div class="pb-6 pl-[86px] pr-2 max-[620px]:pl-2">
                    <p class="m-0 max-w-[64ch] text-sm leading-[1.55] text-muted">{item.answer}</p>
                  </div>
                </div>
              </div>
            </div>
          );
        })
      }
    </div>
  </SledPageWrap>

  <JsonLd data={faqJsonLd} />
</section>
