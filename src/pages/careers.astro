---
import CareersContactForm from '../components/careers/CareersContactForm.astro';
import CareersContactHero from '../components/careers/CareersContactHero.astro';
import CareersFacilitate from '../components/careers/CareersFacilitate.astro';
import CareersHiringProcess from '../components/careers/CareersHiringProcess.astro';
import CareersOurValues from '../components/careers/CareersOurValues.astro';
import IndustryHero from '../components/industries/IndustryHero.astro';
import Footer from '../components/shared/Footer.astro';
import Header from '../components/shared/Header.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { CAREERS_SEO } from '../lib/config/careers';
import {
CAREERS_BENEFITS,
CAREERS_CONTACT_HERO,
CAREERS_HERO,
CAREERS_HIRING_STEPS,
CAREERS_VALUES,
} from '../lib/constants/pages/careers';
import { ROUTES } from '../lib/constants/routes';
import { SITE } from '../lib/constants/site';
import { jobPostingJsonLd } from '../lib/seo/json-ld';
import '../styles/careers.css';
import '../styles/industries.css';

const { title, description, canonicalPath, ogImage } = CAREERS_SEO;
const pageUrl = `${SITE.url}${canonicalPath}`;
const careersJsonLd = jobPostingJsonLd({
  title: 'Software Development Careers at Techtiz',
  description,
  url: pageUrl,
});
---

<BaseLayout {title} {description} {canonicalPath} {ogImage} jsonLd={[careersJsonLd]}>
  <Header currentPage={ROUTES.careers} />
  <main id="main-content" class="bg-white">
    <div class="mx-auto max-w-[1400px] px-2 pt-4">
      <Breadcrumbs {canonicalPath} />
    </div>
    <IndustryHero {...CAREERS_HERO} title={CAREERS_HERO.title ?? ''} />
    <CareersOurValues values={CAREERS_VALUES} />
    <CareersHiringProcess steps={CAREERS_HIRING_STEPS} />
    <CareersFacilitate benefits={CAREERS_BENEFITS} />
    <CareersContactHero {...CAREERS_CONTACT_HERO} />
    <CareersContactForm />
  </main>
  <Footer />
  <script src="/scripts/nav.js" is:inline></script>
  <script src="/scripts/mobile-nav.js" is:inline></script>
  <script src="/scripts/industry-hero.js" is:inline></script>
  <script src="/scripts/recaptcha.js" is:inline></script>
  <script src="/scripts/careers-form.js" is:inline></script>
</BaseLayout>
