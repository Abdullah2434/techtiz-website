---
/** Legacy `Button` variant="outlined" — used on case studies and marketing CTAs. */
interface Props {
  href: string;
  label: string;
  class?: string;
  minWidth?: string;
}

const { href, label, class: className = '', minWidth = '' } = Astro.props;
---

<a
  href={href}
  class:list={[
    'group relative inline-flex min-h-[42px] min-w-[116px] transform-gpu cursor-pointer items-center justify-center overflow-hidden rounded-[2px] border border-[#4D4D4D] bg-transparent px-6 py-[11px] text-base font-normal text-[#4D4D4D] transition-all duration-300 ease-in-out hover:-translate-y-0.5 hover:scale-[1.02] hover:border-cyan hover:bg-cyan hover:text-white hover:shadow-md',
    minWidth,
    className,
  ]}
>
  <span
    class="relative z-10 flex items-center transition-all duration-300 group-hover:drop-shadow-sm"
  >
    {label}
    <span class="ml-4 flex items-center">
      <svg
        width="18"
        height="14"
        viewBox="0 0 18 14"
        fill="none"
        class="stroke-[#101010] transition-all duration-300 ease-in-out group-hover:translate-x-1 group-hover:scale-110 group-hover:stroke-white"
        aria-hidden="true"
      >
        <path
          d="M1 7.01097L16.8124 6.99999M11.5858 13L17 6.99999L11.5858 1"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    </span>
  </span>
</a>
