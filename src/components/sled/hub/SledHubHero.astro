---
import { SLED_HERO } from '../../../lib/constants/pages/sled-hub';
import CtaButton from '../../shared/CtaButton.astro';
import Eyebrow from '../../shared/Eyebrow.astro';
import SledPageWrap from '../shared/SledPageWrap.astro';
---

<section
  class="sled-hub-hero relative isolate overflow-hidden bg-yale-dark text-white"
  id="top"
  data-screen-label="01 Hero"
>
  <div class="absolute inset-0 z-0 overflow-hidden" aria-hidden="true">
    <div
      class="sled-hero-capitol absolute inset-0 bg-[url('/assets/hero-capitol.png')] bg-cover bg-center opacity-[0.85] [will-change:transform]"
    ></div>
    <div
      class="sled-hero-glow-a pointer-events-none absolute top-[-6%] right-[4%] size-[min(44vw,540px)] rounded-full bg-[radial-gradient(circle,rgba(24,176,230,0.28)_0%,transparent_68%)] blur-[80px] motion-reduce:hidden"
    ></div>
    <div
      class="sled-hero-glow-b pointer-events-none absolute bottom-[-10%] left-[-6%] size-[min(38vw,420px)] rounded-full bg-[radial-gradient(circle,rgba(21,58,95,0.35)_0%,transparent_70%)] blur-[72px] motion-reduce:hidden"
    ></div>
  </div>
  <div
    class="absolute inset-0 z-[1] bg-[linear-gradient(90deg,rgba(14,38,64,0.82)_0%,rgba(14,38,64,0.55)_32%,rgba(14,38,64,0.12)_58%,transparent_78%)]"
    aria-hidden="true"
  ></div>

  <SledPageWrap class="relative z-[5] py-[clamp(4.5rem,8vw,6.5rem)] pb-[clamp(4rem,7vw,5.75rem)]">
    <div class="max-w-[62ch] sled-reveal is-visible">
      <Eyebrow text={SLED_HERO.eyebrow} onDark showGlyph class="mb-[18px]" />

      <h1
        class="sled-h1 mb-6 text-[clamp(2.7rem,4.6vw,4rem)] font-semibold leading-[1.05] tracking-[-0.022em] text-white [&_.accent]:text-cyan"
        set:html={SLED_HERO.heading}
      />

      <p class="mb-[34px] max-w-[30ch] text-[clamp(1.1rem,1.5vw,1.35rem)] font-medium leading-normal text-white/82">
        {SLED_HERO.body}
      </p>

      <div class="flex flex-wrap gap-3.5 max-[600px]:flex-col max-[600px]:items-stretch">
        {SLED_HERO.ctas.map((cta) => (
          <CtaButton
            href={cta.href}
            label={cta.label}
            variant={cta.variant}
            showArrow={cta.showArrow}
            beam={'beam' in cta ? cta.beam : false}
          />
        ))}
      </div>
    </div>
  </SledPageWrap>
</section>
