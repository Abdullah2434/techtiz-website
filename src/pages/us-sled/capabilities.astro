---
import '../../styles/sled.css';
import SledLayout from '../../layouts/SledLayout.astro';
import SledInnerHero from '../../components/sled/SledInnerHero.astro';
import CapabilitiesProcStrip from '../../components/sled/CapabilitiesProcStrip.astro';
import CapabilitiesFrameworksSection from '../../components/sled/CapabilitiesFrameworksSection.astro';
import CapabilitiesMatrixSection from '../../components/sled/CapabilitiesMatrixSection.astro';
import CapabilitiesTechStackSection from '../../components/sled/CapabilitiesTechStackSection.astro';
import CapabilitiesEngageSection from '../../components/sled/CapabilitiesEngageSection.astro';
import CapabilitiesBoundariesSection from '../../components/sled/CapabilitiesBoundariesSection.astro';
import SledFinalCta from '../../components/sled/SledFinalCta.astro';
import { CAPABILITIES_SEO, CAPABILITIES_HERO } from '../../lib/constants/pages/capabilities';

const { title, description, canonicalPath, ogImage } = CAPABILITIES_SEO;
---

<SledLayout {title} {description} {canonicalPath} {ogImage} currentPage="/us-sled/capabilities/">
  <SledInnerHero
    eyebrow={CAPABILITIES_HERO.eyebrow}
    heading={CAPABILITIES_HERO.heading}
    body={CAPABILITIES_HERO.body}
    ctas={CAPABILITIES_HERO.ctas}
  />
  <CapabilitiesProcStrip />
  <CapabilitiesFrameworksSection />
  <CapabilitiesMatrixSection />
  <CapabilitiesTechStackSection />
  <CapabilitiesEngageSection />
  <CapabilitiesBoundariesSection />
  <SledFinalCta />
</SledLayout>
