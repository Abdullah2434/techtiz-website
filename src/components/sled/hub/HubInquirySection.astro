---
import Check from '@lucide/astro/icons/check';
import { SLED_HUB_INQUIRY } from '../../../lib/constants/pages/sled-hub';
import { highlightSledEmailHtml, SITE } from '../../../lib/constants/site';
import CtaButton from '../../shared/CtaButton.astro';
import Eyebrow from '../../shared/Eyebrow.astro';
import SledPageWrap from '../shared/SledPageWrap.astro';

const fieldClass =
  'w-full rounded-[10px] border border-line bg-seasalt px-3.5 py-3 text-sm text-ink outline-none transition-[border-color,box-shadow] placeholder:text-muted focus:border-cyan focus:shadow-[0_0_0_3px_rgba(24,176,230,0.16)]';
const labelClass = 'mb-[7px] block text-[12.5px] font-semibold text-yale';
---

<section
  class="sled-section bg-yale-dark text-white"
  id="inquiry"
  data-screen-label="Inquiry form"
>
  <SledPageWrap>
    <div
      class="sled-reveal grid grid-cols-1 items-start gap-8 lg:grid-cols-[0.82fr_1.18fr] lg:gap-12"
      data-sled-reveal
    >
      <aside>
        <Eyebrow text={SLED_HUB_INQUIRY.aside.eyebrow} onDark showGlyph class="mb-4" />
        <h2 class="mb-4 text-[clamp(1.8rem,2.8vw,2.5rem)] leading-[1.1] font-semibold text-white">
          {SLED_HUB_INQUIRY.aside.heading}
          <span class="sled-hl-u">{SLED_HUB_INQUIRY.aside.headingAccent}</span>
        </h2>
        <p class="mb-6 max-w-[42ch] text-[14.5px] leading-normal text-white/72">
          {SLED_HUB_INQUIRY.aside.body}
        </p>
        <ul class="m-0 flex list-none flex-col gap-3 p-0">
          {
            SLED_HUB_INQUIRY.aside.bullets.map((bullet) => (
              <li class="flex items-start gap-3 text-sm text-white/85">
                <Check class="mt-0.5 size-[18px] shrink-0 text-cyan" aria-hidden="true" />
                {bullet}
              </li>
            ))
          }
        </ul>
        <!-- <img
          src={SLED_HUB_INQUIRY.aside.imageSrc}
          alt={SLED_HUB_INQUIRY.aside.imageAlt}
          class="mt-[26px] block aspect-[16/10] w-full rounded-[14px] border border-white/14 bg-white/[0.04] object-cover shadow-md"
          loading="lazy"
          decoding="async"
        /> -->
      </aside>

      <div class="relative">
        <form
          class="flex flex-col rounded-2xl bg-white p-[30px] text-ink shadow-lg"
          id="sledInquiryForm"
          novalidate
        >
          <div class="mb-4">
            <label class={labelClass}>
              What do you need help with? <span class="text-cyan-strong">*</span>
            </label>
            <div class="flex flex-wrap gap-2" data-sled-inquiry-needs>
              {
                SLED_HUB_INQUIRY.needOptions.map((opt) => (
                  <label
                    class:list={[
                      'inline-flex cursor-pointer items-center gap-2 rounded-full border border-line bg-seasalt px-3.5 py-2.25 text-[13px] font-semibold text-muted transition-[background,border-color,color] duration-200',
                      opt.defaultOn && 'is-on border-cyan bg-cyan-soft text-yale',
                    ]}
                    data-sled-inquiry-need
                  >
                    <input
                      type="checkbox"
                      name="need"
                      value={opt.value}
                      class="sr-only"
                      checked={opt.defaultOn}
                    />
                    {opt.label}
                  </label>
                ))
              }
            </div>
          </div>

          <div class="mb-4 grid grid-cols-1 gap-4 sm:grid-cols-2">
            <div>
              <label class={labelClass} for="sled-iq-company">
                Company <span class="text-cyan-strong">*</span>
              </label>
              <input
                class={fieldClass}
                type="text"
                id="sled-iq-company"
                name="company"
                placeholder="Prime contractor name"
                required
              />
            </div>
            <div>
              <label class={labelClass} for="sled-iq-role">Your role</label>
              <input
                class={fieldClass}
                type="text"
                id="sled-iq-role"
                name="role"
                placeholder="e.g. Capture Manager"
              />
            </div>
          </div>

          <div class="mb-4 grid grid-cols-1 gap-4 sm:grid-cols-2">
            <div>
              <label class={labelClass} for="sled-iq-vehicle">Contract vehicle</label>
              <select class={fieldClass} id="sled-iq-vehicle" name="vehicle">
                <option value="">Select…</option>
                {SLED_HUB_INQUIRY.vehicleOptions.map((v) => <option>{v}</option>)}
              </select>
            </div>
            <div>
              <label class={labelClass} for="sled-iq-agency">Agency / end customer</label>
              <input
                class={fieldClass}
                type="text"
                id="sled-iq-agency"
                name="agency"
                placeholder="We never contact directly"
              />
            </div>
          </div>

          <div class="mb-4">
            <label class={labelClass} for="sled-iq-desc">{SLED_HUB_INQUIRY.descLabel}</label>
            <textarea
              class={`${fieldClass} min-h-[92px] resize-y`}
              id="sled-iq-desc"
              name="desc"
              placeholder={SLED_HUB_INQUIRY.descPlaceholder}
            ></textarea>
          </div>

          <div class="mb-4 grid grid-cols-1 gap-4 sm:grid-cols-2">
            <div>
              <label class={labelClass} for="sled-iq-email">
                Email <span class="text-cyan-strong">*</span>
              </label>
              <input
                class={fieldClass}
                type="email"
                id="sled-iq-email"
                name="email"
                placeholder="you@prime.com"
                required
              />
            </div>
            <div>
              <label class={labelClass} for="sled-iq-phone">Phone</label>
              <input
                class={fieldClass}
                type="tel"
                id="sled-iq-phone"
                name="phone"
                placeholder={SITE.phone.display}
              />
            </div>
          </div>

          <input
            type="text"
            name="website"
            tabindex="-1"
            autocomplete="off"
            class="hidden"
            aria-hidden="true"
          />

          <CtaButton
            type="submit"
            label={SLED_HUB_INQUIRY.submitLabel}
            variant="cta"
            class="mt-1.5 w-full justify-center"
          />
          <p class="mt-3.5 text-center text-xs leading-normal text-muted">
            {SLED_HUB_INQUIRY.reassure}
          </p>
        </form>

        <div
          class="sled-inquiry-success absolute inset-0 min-h-full flex-col items-center justify-center rounded-2xl bg-white px-8 py-12 text-center shadow-lg"
          id="sledInquirySuccess"
          role="status"
        >
          <div class="mx-auto mb-6 grid size-16 place-items-center rounded-full bg-cyan-soft shadow-[0_12px_28px_-12px_rgba(24,176,230,0.45)]">
            <svg
              viewBox="0 0 24 24"
              width="28"
              height="28"
              fill="none"
              stroke="var(--color-cyan-strong)"
              stroke-width="2.2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M5 13l4 4L19 7"></path>
            </svg>
          </div>
          <h3 class="mb-3 text-2xl font-semibold text-yale-dark">
            {SLED_HUB_INQUIRY.success.heading}
          </h3>
          <p
            class="mx-auto mb-7 max-w-[420px] text-[15px] leading-[1.58] text-muted"
            set:html={highlightSledEmailHtml(SLED_HUB_INQUIRY.success.body)}
          />
          <CtaButton
            id="sledInquiryReset"
            href="#top"
            label={SLED_HUB_INQUIRY.success.resetLabel}
            variant="ghost-light"
            showArrow={false}
          />
        </div>
      </div>
    </div>
  </SledPageWrap>
</section>
