---
import { SLED_CAPABILITIES } from '../../../lib/constants/pages/capabilities';
import Eyebrow from '../../shared/Eyebrow.astro';
import SledPageWrap from '../shared/SledPageWrap.astro';

const { boundaries } = SLED_CAPABILITIES;

const staggerDelays = [0, 90, 180, 270];
---

<section
  class="sled-section border-t border-line-soft bg-white"
  data-screen-label="06 Boundaries"
>
  <SledPageWrap>
    <div class="sled-reveal mb-[30px] max-w-[620px]" data-sled-reveal>
      <Eyebrow
        text={boundaries.eyebrow}
        showGlyph
        class="mb-4 text-amber [&>span:first-child]:bg-amber"
      />
      <h2 class="text-[clamp(1.7rem,2.5vw,2.3rem)] font-semibold leading-[1.12] tracking-[-0.02em] text-yale-dark">
        {boundaries.heading}
      </h2>
      <p class="mt-3.5 text-[15.5px] leading-[1.6] text-muted">
        {boundaries.body}
      </p>
    </div>

    <div
      class="sled-reveal-stagger grid grid-cols-1 gap-[18px] sm:grid-cols-2 lg:grid-cols-4"
      data-sled-reveal
    >
      {
        boundaries.items.map((item, idx) => (
          <article
            class="rounded-xl border border-line-soft border-t-[3px] border-t-amber bg-white p-[30px] transition-[transform,box-shadow] duration-300 motion-safe:hover:-translate-y-0.75 motion-safe:hover:shadow-[0_18px_40px_-22px_rgba(21,58,95,0.22)]"
            style={staggerDelays[idx] ? `--d:${staggerDelays[idx]}ms` : undefined}
          >
            
            <h4 class="mb-2.25 text-[1.12rem] font-semibold leading-[1.25] text-yale-dark">
              {item.heading}
            </h4>
            <p class="m-0 text-[14.5px] leading-normal text-muted">{item.body}</p>
          </article>
        ))
      }
    </div>
  </SledPageWrap>
</section>
