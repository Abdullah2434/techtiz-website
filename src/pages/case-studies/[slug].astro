---
import "../../styles/case-studies.css";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/shared/Header.astro";
import Footer from "../../components/shared/Footer.astro";
import DetailHero from "../../components/case-studies/DetailHero.astro";
import ClientOverview from "../../components/case-studies/ClientOverview.astro";
import MetricsSection from "../../components/case-studies/MetricsSection.astro";
import CaseStudyDownload from "../../components/case-studies/CaseStudyDownload.astro";
import SuccessStoriesSection from "../../components/home/SuccessStoriesSection.astro";
import { CASE_STUDIES_PORTFOLIO } from "../../lib/constants/case-studies-portfolio";

export function getStaticPaths() {
  return CASE_STUDIES_PORTFOLIO.map((study) => ({
    params: { slug: study.slug },
    props: { study },
  }));
}

const { study } = Astro.props;
const title = `${study.title} Case Study - Software Development Success | Techtiz`;
const description = `${study.overview.slice(0, 155)}...`;
const canonicalPath = `/case-studies/${study.slug}/`;
const ogImage = study.image.endsWith(".mp4") ? study.appLogo : study.image;
---

<BaseLayout {title} {description} {canonicalPath} {ogImage}>
  <Header currentPage="/case-studies/" />
  <main>
    <DetailHero title={study.title} media={study.image} />
    <ClientOverview
      appLogo={study.appLogo}
      client={study.client}
      overview={study.overview}
      overview2={study.overview2}
    />
    {
      study.metrics && study.metrics.length > 0 && (
        <MetricsSection metrics={study.metrics} />
      )
    }
    <CaseStudyDownload pdfUrl={study.pdfUrl} />
    <SuccessStoriesSection />
  </main>
  <Footer />
  <script src="/scripts/nav.js" is:inline></script>
  <script src="/scripts/mobile-nav.js" is:inline></script>
  <script src="/scripts/video-modal.js" is:inline></script>
</BaseLayout>
