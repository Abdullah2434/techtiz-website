---
import { STATE_ROWS } from '../../../lib/constants/pages/operating-model';
import Eyebrow from '../../shared/Eyebrow.astro';
import SledPageWrap from '../shared/SledPageWrap.astro';

const postureDot = {
  serve: 'bg-green',
  disclose: 'bg-amber',
  waiver: 'bg-yale',
} as const;

const badgeStyles = {
  serve: 'bg-green/12 text-green',
  disclose: 'bg-amber/12 text-amber',
  waiver: 'bg-yale/8 text-yale',
} as const;
---

<section class="sled-section bg-white" id="states">
  <SledPageWrap>
    <div class="sled-reveal mb-10 max-w-[820px]" data-sled-reveal>
      <Eyebrow text="State-by-state offshore restrictions" showGlyph class="mb-4" />
      <h2 class="text-[clamp(1.75rem,3.5vw,2.375rem)] font-extrabold leading-[1.1] tracking-[-0.02em] text-yale-dark">
        Where we can serve directly. Where the prime needs to disclose. Where a waiver is required.
      </h2>
      <p class="mt-3.5 text-[15.5px] leading-[1.65] text-muted">
        The U.S. state landscape on offshore subcontracting is fragmented; an offshore-shy compliance officer needs a prepared answer, not a research project. This is ours, kept current. Always confirm against the live solicitation language before bid.
      </p>
    </div>

    <div class="sled-reveal mb-6 flex flex-wrap gap-x-5 gap-y-2.5 text-[13.5px] text-muted" data-sled-reveal>
      <span class="inline-flex items-center gap-2"><span class="inline-block size-2 rounded-sm bg-green" aria-hidden="true"></span>Serve directly under standard subcontract</span>
      <span class="inline-flex items-center gap-2"><span class="inline-block size-2 rounded-sm bg-amber" aria-hidden="true"></span>Standard subcontract + offshore-handling disclosure</span>
      <span class="inline-flex items-center gap-2"><span class="inline-block size-2 rounded-sm bg-yale" aria-hidden="true"></span>Restructuring or written waiver required</span>
    </div>

    <div class="sled-reveal overflow-hidden rounded-2xl border border-line bg-white shadow-[0_20px_44px_-28px_rgba(21,58,95,0.16)]" data-sled-reveal>
      <div class="hidden grid-cols-[140px_260px_1fr_240px] border-b border-line bg-seasalt px-6 py-4 text-[12.5px] font-bold text-muted lg:grid">
        <div>Posture</div>
        <div>State / framework</div>
        <div>Restriction in plain English</div>
        <div>Our handling</div>
      </div>

      <div class="divide-y divide-line">
        {STATE_ROWS.map((row) => (
          <div class="grid grid-cols-1 gap-3 px-5 py-5 sm:px-6 lg:grid-cols-[140px_260px_1fr_240px] lg:items-center lg:gap-4 lg:py-5">
            <div class="flex items-center gap-2 text-[13.5px] font-semibold text-yale-dark">
              <span class:list={['inline-block size-2 rounded-sm', postureDot[row.posture]]} aria-hidden="true" />
              <span class="lg:hidden font-mono text-[10px] tracking-[0.12em] uppercase text-muted">Posture · </span>
              {row.code}
            </div>
            <div>
              <span class="mb-1 block font-mono text-[10px] tracking-[0.12em] uppercase text-muted lg:hidden">State / framework</span>
              <div class="text-[14px] font-semibold text-yale-dark">{row.name}</div>
            </div>
            <div>
              <span class="mb-1 block font-mono text-[10px] tracking-[0.12em] uppercase text-muted lg:hidden">Restriction</span>
              <div class="text-[14px] leading-[1.55] text-muted">{row.what}</div>
            </div>
            <div>
              <span class="mb-1.5 block font-mono text-[10px] tracking-[0.12em] uppercase text-muted lg:hidden">Our handling</span>
              <span
                class:list={[
                  'inline-flex items-center rounded-full px-3 py-1 text-[12.5px] font-bold',
                  badgeStyles[row.badgeClass],
                ]}
              >
                {row.badge}
              </span>
            </div>
          </div>
        ))}
      </div>
    </div>

    <p class="sled-reveal mt-4 font-mono text-[10.5px] tracking-[0.14em] text-muted uppercase" data-sled-reveal>
      // State-level disclosure pack maintained on request · Updated quarterly · Confirm against live solicitation language
    </p>
  </SledPageWrap>
</section>
