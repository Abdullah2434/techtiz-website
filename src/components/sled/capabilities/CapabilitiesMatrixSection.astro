---
import Accessibility from '@lucide/astro/icons/accessibility';
import AppWindow from '@lucide/astro/icons/app-window';
import Bot from '@lucide/astro/icons/bot';
import ChartColumn from '@lucide/astro/icons/chart-column';
import GitMerge from '@lucide/astro/icons/git-merge';
import MapPin from '@lucide/astro/icons/map-pin';
import { SLED_CAPABILITIES_MATRIX } from '../../../lib/constants/pages/capabilities';
import Eyebrow from '../../shared/Eyebrow.astro';
import SledPageWrap from '../shared/SledPageWrap.astro';

const icons = {
  'app-window': AppWindow,
  'git-merge': GitMerge,
  bot: Bot,
  'map-pin': MapPin,
  'chart-column': ChartColumn,
  accessibility: Accessibility,
} as const;
---

<section class="sled-section bg-white" data-screen-label="02 Capability matrix">
  <SledPageWrap>
    <div class="sled-reveal is-visible mb-12 max-w-[720px]" data-sled-reveal>
      <Eyebrow text={SLED_CAPABILITIES_MATRIX.eyebrow} showGlyph class="mb-4" />
      <h2 class="text-[clamp(1.7rem,2.5vw,2.3rem)] font-semibold leading-[1.12] tracking-[-0.02em] text-yale-dark">
        {SLED_CAPABILITIES_MATRIX.heading}
      </h2>
      <p class="mt-3.5 max-w-[620px] text-[15.5px] leading-[1.6] text-muted">
        {SLED_CAPABILITIES_MATRIX.body}
      </p>
    </div>

    <div
      class="sled-reveal is-visible overflow-hidden rounded-xl border border-line-soft bg-white shadow-[0_8px_24px_-12px_rgba(21,58,95,0.14)]"
      data-sled-reveal
    >
      <div class="grid grid-cols-[300px_1.4fr_1fr] bg-yale-dark max-[900px]:hidden">
        {SLED_CAPABILITIES_MATRIX.columns.map((column, idx) => (
          <div
            class:list={[
              'px-[26px] py-[18px] font-mono text-[11px] font-semibold tracking-[0.14em] uppercase text-cyan',
              idx < SLED_CAPABILITIES_MATRIX.columns.length - 1 && 'border-r border-white/10',
            ]}
          >
            {column}
          </div>
        ))}
      </div>

      {SLED_CAPABILITIES_MATRIX.rows.map((row) => {
        const Icon = icons[row.icon];
        return (
          <div class="sled-matrix-row grid grid-cols-[300px_1.4fr_1fr] border-t border-line-soft max-[900px]:grid-cols-1 max-[900px]:gap-3 max-[900px]:p-5">
            <div class="flex items-start gap-3.5 border-r border-line-soft px-[26px] py-[22px] max-[900px]:border-r-0 max-[900px]:px-0 max-[900px]:py-0">
              <div class="flex items-start gap-3.5">
                <span
                  class="grid size-[38px] shrink-0 place-items-center rounded-[9px] bg-cyan-soft text-cyan-strong"
                  aria-hidden="true"
                >
                  <Icon class="size-[19px]" />
                </span>
                <div class="text-[15px] font-bold leading-[1.3] text-yale">{row.name}</div>
              </div>
            </div>
            <div class="border-r border-line-soft px-[26px] py-[22px] text-[14px] leading-[1.55] text-ink max-[900px]:border-r-0 max-[900px]:px-0 max-[900px]:py-0">
              <span class="mb-1 hidden font-mono text-[10.5px] font-bold tracking-[0.14em] uppercase text-cyan-strong max-[900px]:block">
                What we do
              </span>
              {row.what}
            </div>
            <div class="px-[26px] py-[22px] font-mono text-[11.5px] leading-[1.6] tracking-[0.02em] text-cyan-strong max-[900px]:px-0 max-[900px]:py-0">
              <span class="mb-1 hidden font-mono text-[10.5px] font-bold tracking-[0.14em] uppercase text-cyan-strong max-[900px]:block">
                NAICS / NIGP
              </span>
              {row.codes}
            </div>
          </div>
        );
      })}
    </div>
  </SledPageWrap>
</section>
