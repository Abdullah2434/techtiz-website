      </div>

      <a href="/us-sled/case-studies/" class="nav-link relative inline-flex cursor-pointer items-center gap-1.5 whitespace-nowrap rounded-lg border border-transparent bg-transparent px-4 py-2.5 font-sans text-[14.5px] font-semibold leading-none text-ink transition-[color,background,border-color] duration-[180ms] ease-out hover:bg-yale/4 hover:text-yale">Case Studies</a>
      <a href="/" class="nav-link relative inline-flex cursor-pointer items-center gap-1.5 whitespace-nowrap rounded-lg border border-transparent bg-transparent px-4 py-2.5 font-sans text-[14.5px] font-semibold leading-none text-ink transition-[color,background,border-color] duration-[180ms] ease-out hover:bg-yale/4 hover:text-yale">Careers</a>
    </nav>

    <div class="right-cta flex items-center justify-self-end gap-3 max-[900px]:hidden">
      <a
        href="/us-sled/"
        class="us-pill group inline-flex items-center gap-2 rounded-lg border border-line bg-white px-3.5 py-2 font-mono text-[13px] font-bold tracking-[0.04em] text-yale transition-[border-color,background] duration-[180ms] ease-out hover:border-yale hover:bg-seasalt"
        aria-current={isSled ? 'page' : undefined}
        data-current={isSled ? 'page' : undefined}
      >
        <span class="grid size-4 place-items-center rotate-12 rounded-[4px] bg-cyan text-white shadow-[0_8px_18px_-10px_rgba(24,176,230,0.60)] group-data-[current=page]:animate-[usPillDotPulse_2.4s_ease-out_infinite]" aria-hidden="true">
