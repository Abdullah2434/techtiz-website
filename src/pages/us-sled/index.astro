            <label class="field-label">Email <span class="req">*</span></label>
            <input type="email" id="iq-email" name="email" placeholder="you@prime.com" required />
          </div>
          <div>
            <label class="field-label">Phone</label>
            <input type="tel" id="iq-phone" name="phone" placeholder="+1 (XXX) XXX-XXXX" />
          </div>
        </div>
        <div class="inquiry-foot">
          <div class="nda">By submitting, you agree to a mutual NDA on first substantive contact.</div>
          <button type="submit" class="send-btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
            Send Inquiry
          </button>
        </div>
      </form>

      <div class="inquiry-right" id="inquirySuccess" role="status" style="display:none; text-align:center; justify-content:center; align-items:center; min-height:420px;">
        <div style="width:56px; height:56px; margin:0 auto 22px; border-radius:50%; background:var(--cyan-soft); display:grid; place-items:center;">
          <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="var(--cyan-strong)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7"></path></svg>
        </div>
        <h3 style="font-size:24px; margin-bottom:10px;">Your inquiry is ready to send.</h3>
        <p style="font-size:15px; color:var(--muted); line-height:1.55; max-width:420px; margin:0 auto 24px;">Your email client should have opened a pre-filled message to <strong style="color:var(--yale);">sled@techtiz.co</strong>. If it didn't, email that address directly — we reply within one business day with a mutual NDA template.</p>
        <a class="btn-ghost-light" id="inquiryReset" href="#top">Start another inquiry</a>
      </div>
    </div>
  </div>
</section>

