---
import {
INDUSTRIES_MEGA_NAV_DATA,
INDUSTRY_CATEGORIES,
} from '../../lib/constants/nav/industries';
import {
SERVICE_CATEGORIES_NAV,
SERVICES_MEGA_NAV_DATA,
} from '../../lib/constants/nav/services';
import { ROUTES } from '../../lib/constants/routes';
import { SITE } from '../../lib/constants/site';

const firstServicesCategory = SERVICE_CATEGORIES_NAV[0];
const firstIndustryCategory = INDUSTRY_CATEGORIES[0];
const servicesMegaJson = JSON.stringify(SERVICES_MEGA_NAV_DATA);
const industriesMegaJson = JSON.stringify(INDUSTRIES_MEGA_NAV_DATA);

interface Props {
  currentPage?: string;
}

const { currentPage = '' } = Astro.props;

const wrap =
  'mx-auto w-full max-w-[1400px] px-2 max-[600px]:px-[18px]';

const navLinkBase =
  'nav-link inline-flex cursor-pointer items-center gap-1.5 whitespace-nowrap rounded-lg border border-transparent bg-transparent px-4 py-2.5 font-sans text-[14.5px] font-semibold leading-none text-ink transition-[color,background,border-color] duration-[180ms] ease-out hover:bg-yale/4 hover:text-yale';

const navLinkClass = (href: string) =>
  [navLinkBase, currentPage === href && 'bg-yale/8 text-yale'].filter(Boolean);

/** Position + layout only; open/close animation lives in chrome.css (.mega transform) */
const megaPanelBase =
  'mega absolute top-[calc(100%+14px)] z-60 w-[min(900px,calc(100vw-32px))] rounded-2xl border border-line bg-white p-[22px] shadow-[0_30px_60px_-20px_rgba(14,38,64,0.22),0_6px_18px_-8px_rgba(14,38,64,0.10)] before:absolute before:-top-2 before:size-3.5 before:rotate-45 before:rounded-tl before:border-t before:border-l before:border-line before:bg-white before:content-[\'\']';
const megaPanelServices = `${megaPanelBase} before:left-1/2 before:-translate-x-1/2 max-[1180px]:before:left-10`;
const megaPanelIndustries = `${megaPanelBase} before:left-1/2 before:-translate-x-1/2 max-[1180px]:before:left-auto max-[1180px]:before:right-10`;
---


<header class="top sticky top-0 z-50 border-b border-line bg-white/94 backdrop-blur-[10px]">
  <div class:list={[wrap, 'nav grid h-[76px] grid-cols-[1fr_auto_1fr] items-center max-[900px]:flex max-[900px]:h-16 max-[900px]:justify-between']}>
    <a href="/" class="brand" aria-label={`${SITE.name} home`}>
      <img src={SITE.logo.dark} alt={SITE.name} class="brand-logo block h-[26px] w-auto" />
    </a>

    <nav class="primary-nav inline-flex items-center gap-0.5 max-[900px]:hidden" aria-label="Primary">
      <a
        href={ROUTES.about}
        class:list={navLinkClass(ROUTES.about)}
        aria-current={currentPage === ROUTES.about ? 'page' : undefined}
      >
        About Us
      </a>

      <div class="nav-item relative" data-mega="services">
        <button
          class="nav-link inline-flex cursor-pointer items-center gap-1.5 whitespace-nowrap rounded-lg border border-transparent bg-transparent px-4 py-2.5 font-sans text-[14.5px] font-semibold leading-none text-ink transition-[color,background,border-color] duration-[180ms] ease-out hover:bg-yale/4 hover:text-yale"
          type="button"
          aria-expanded="false"
        >
          Services <span class="chev size-[7px] -translate-x-px -translate-y-px rotate-45 border-r-[1.6px] border-b-[1.6px] border-current opacity-55 transition-transform duration-300 ease-out"></span>
        </button>
        <div class={megaPanelServices} role="menu">
          <div class="mega-inner grid grid-cols-[minmax(240px,280px)_1fr] gap-[22px]">
            <div class="mega-left border-r border-[#EAEAEA] pr-4">
              <div class="mega-eyebrow mb-2 px-1 text-xl font-semibold text-[#141414]">We Offer</div>
              <div class="mega-list flex flex-col gap-0.5" data-list="services">
                {
                  SERVICE_CATEGORIES_NAV.map((cat, index) => (
                    <button
                      type="button"
                      class:list={[
                        'mega-item group flex w-full cursor-pointer items-center justify-between rounded-[2px] border-0 bg-transparent px-4 py-3 text-left text-base font-normal leading-none text-[#1E1E1E] transition-[background,color] duration-[400ms] ease-out hover:bg-[#EAEAEA]',
                        index === 0 && 'active',
                      ]}
                      data-key={cat.megaKey}
                    >
                      {cat.title}
                      <svg
                        class="ml-2 size-4 shrink-0 opacity-0 transition-opacity duration-200 group-hover:opacity-100 [.mega-item.active_&]:opacity-100"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        viewBox="0 0 24 24"
                        aria-hidden="true"
                      >
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                      </svg>
                    </button>
                  ))
                }
              </div>
            </div>
            <div class="mega-right flex min-w-0 flex-col pl-[22px]" data-mega-panel="services">
              <div data-feature="services" class="mega-panel-body flex flex-col gap-4">
                <div class="mega-feature rounded-[7.3px] bg-[#18B0E633] px-4 py-[15.4px]">
                  <div class="flex items-start gap-4">
                    <div class="feat-icon shrink-0" data-feat-icon>
                      <img
                        src={firstServicesCategory.icon}
                        alt=""
                        width={40}
                        height={40}
                        class="size-10 object-contain"
                        data-feat-icon-img
                      />
                    </div>
                    <div class="flex min-w-0 flex-col gap-2">
                      <h3 data-feat-title class="mega-feat-title">
                        {firstServicesCategory.title}
                      </h3>
                      <p data-feat-desc class="mega-feat-desc">
                        {firstServicesCategory.description}
                      </p>
                    </div>
                  </div>
                </div>
                <div class="mega-sublinks flex flex-col gap-2" data-sublinks="services">
                  {
                    firstServicesCategory.subs.map((sub) => (
                      <a href={sub.href} class="mega-service-link">
                        {sub.name}
                      </a>
                    ))
                  }
                </div>
              </div>
              <div class="mega-footer mt-3.5 flex items-center justify-between border-t border-line-soft pt-3.5">
                <span class="mega-tag font-mono text-[10.5px] tracking-[0.14em] text-cyan-strong uppercase">U.S. SLED prime contractor?</span>
                <a class="mega-cta inline-flex items-center gap-2 border-b-2 border-cyan pb-0.5 text-[13px] font-bold text-yale" href="/us-sled/">See SLED Partnerships →</a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="nav-item relative" data-mega="industries">
        <button
          class="nav-link inline-flex cursor-pointer items-center gap-1.5 whitespace-nowrap rounded-lg border border-transparent bg-transparent px-4 py-2.5 font-sans text-[14.5px] font-semibold leading-none text-ink transition-[color,background,border-color] duration-[180ms] ease-out hover:bg-yale/4 hover:text-yale"
          type="button"
          aria-expanded="false"
        >
          Industries <span class="chev size-[7px] -translate-x-px -translate-y-px rotate-45 border-r-[1.6px] border-b-[1.6px] border-current opacity-55 transition-transform duration-300 ease-out"></span>
        </button>
        <div class={megaPanelIndustries} role="menu">
          <div class="mega-inner grid grid-cols-[minmax(240px,280px)_1fr] gap-[22px]">
            <div class="mega-left border-r border-[#EAEAEA] pr-4">
              <div class="mega-eyebrow mb-2 px-1 text-xl font-semibold text-[#141414]">Industries</div>
              <div class="mega-list flex flex-col gap-0.5" data-list="industries">
                {
                  INDUSTRY_CATEGORIES.map((cat, index) => (
                    <button
                      type="button"
                      class:list={[
                        'mega-item group flex w-full cursor-pointer items-center justify-between rounded-[2px] border-0 bg-transparent px-4 py-3 text-left text-base font-normal leading-none text-[#1E1E1E] transition-[background,color] duration-[400ms] ease-out hover:bg-[#EAEAEA]',
                        index === 0 && 'active',
                      ]}
                      data-key={cat.megaKey}
                    >
                      {cat.title}
                      <svg
                        class="ml-2 size-4 shrink-0 opacity-0 transition-opacity duration-200 group-hover:opacity-100 [.mega-item.active_&]:opacity-100"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        viewBox="0 0 24 24"
                        aria-hidden="true"
                      >
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                      </svg>
                    </button>
                  ))
                }
              </div>
            </div>
            <div class="mega-right flex min-w-0 flex-col pl-[22px]">
              <div data-feature="industries" class="mega-panel-body flex flex-col gap-3">
                <a
                  href={firstIndustryCategory.landingHref}
                  data-industry-panel
                  class="mega-industry-panel group -m-2 flex flex-col gap-3 rounded-[8px] border-2 border-transparent p-2 transition-all duration-300 hover:border-[#18B0E6] hover:bg-[#18B0E610]"
                >
                  <div class="mega-feature rounded-[7.3px] bg-[#F6F6F6] px-4 py-[15.4px] transition-colors group-hover:bg-[#18B0E615]">
                    <div class="flex items-start gap-4">
                      <div class="feat-icon shrink-0" data-feat-icon>
                        <img
                          src={firstIndustryCategory.icon}
                          alt=""
                          width={40}
                          height={40}
                          class="size-10 object-contain"
                        />
                      </div>
                      <div class="flex min-w-0 flex-col gap-2">
                        <h3
                          data-feat-title
                          class="mega-feat-title transition-colors group-hover:text-[#18B0E6]"
                        >
                          {firstIndustryCategory.title}
                        </h3>
                        <p data-feat-desc class="mega-feat-desc">
                          {firstIndustryCategory.description}
                        </p>
                      </div>
                    </div>
                  </div>
                  <div class="h-[2px] bg-[#EAEAEA] transition-colors group-hover:bg-[#18B0E6]" aria-hidden="true"></div>
                  <div class="mega-sublinks flex flex-col gap-3" data-sublinks="industries">
                    {
                      firstIndustryCategory.subs.map((sub) => (
                        <div class="flex flex-col gap-2 px-4 py-3">
                          <h3 class="mega-industry-sub-title">{sub.name}</h3>
                          <p class="mega-industry-sub-desc">{sub.desc}</p>
                        </div>
                      ))
                    }
                  </div>
                </a>
              </div>
              <div class="mega-footer mt-3.5 flex items-center justify-between border-t border-line-soft pt-3.5">
                <span class="mega-tag font-mono text-[10.5px] tracking-[0.14em] text-cyan-strong uppercase">U.S. SLED prime contractor?</span>
                <a class="mega-cta inline-flex items-center gap-2 border-b-2 border-cyan pb-0.5 text-[13px] font-bold text-yale" href="/us-sled/">See SLED Partnerships →</a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <a
        href={ROUTES.caseStudies}
        class:list={navLinkClass(ROUTES.caseStudies)}
        aria-current={currentPage === ROUTES.caseStudies ? 'page' : undefined}
      >
        Case Studies
      </a>
      <a
        href={ROUTES.careers}
        class:list={navLinkClass(ROUTES.careers)}
        aria-current={currentPage === ROUTES.careers ? 'page' : undefined}
      >
        Careers
      </a>
    </nav>

    <div class="right-cta flex items-center justify-self-end max-[900px]:hidden">
      <a
        href="/us-sled/"
        class="us-pill inline-flex items-center gap-2 rounded-lg border border-line bg-white px-4 py-2.5 font-mono text-[13px] font-bold tracking-[0.04em] text-yale transition-[border-color,background] duration-[180ms] ease-out hover:border-yale hover:bg-seasalt"
      >
        <span class="sled-dot inline-block size-2 shrink-0 rotate-[15deg] bg-cyan" aria-hidden="true"></span>
        SLED Partnerships
      </a>
    </div>
  </div>
  <script id="services-mega-nav" type="application/json" set:html={servicesMegaJson} />
  <script id="industries-mega-nav" type="application/json" set:html={industriesMegaJson} />
</header>
