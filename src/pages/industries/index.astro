---
import '../../styles/industries.css';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/shared/Header.astro';
import Footer from '../../components/shared/Footer.astro';
import CtaButton from '../../components/shared/CtaButton.astro';
import { INDUSTRIES_HUB_SEO } from '../../lib/config/industries';
import { INDUSTRY_CATEGORIES } from '../../lib/constants/nav/industries';
import { ROUTES } from '../../lib/constants/routes';

const { title, description, canonicalPath } = INDUSTRIES_HUB_SEO;
const wrap = 'mx-auto w-full max-w-[1400px] px-2';
---

<BaseLayout {title} {description} {canonicalPath}>
  <Header currentPage={ROUTES.industries} />
  <main class="bg-white">
    <section class:list={[wrap, 'py-10 md:py-16']}>
      <div class="flex flex-col gap-4 md:gap-6">
        <h1 class="text-[32px] leading-tight font-medium text-[#101010] md:text-[44px] lg:text-[56px]">
          Industries
        </h1>
        <p class="max-w-3xl text-[16px] leading-[140%] font-normal text-[#4D4D4D] md:text-[18px]">
          Intelligent solutions tailored for specific industry challenges—from healthcare and
          logistics to e-commerce and education.
        </p>
      </div>
    </section>

    <section class:list={[wrap, 'pb-12 md:pb-16']}>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 md:gap-8">
        {
          INDUSTRY_CATEGORIES.map((cat) => (
            <article class="flex w-full flex-col rounded-lg bg-[#F3F7FB] p-6 transition-shadow duration-300 hover:shadow-md md:p-8">
              <img
                src={cat.icon}
                alt=""
                width={48}
                height={48}
                class="mb-4 object-contain"
                loading="lazy"
              />
              <h2 class="text-[20px] leading-[120%] font-semibold tracking-[-0.02em] text-[#141414] md:text-[24px]">
                {cat.title}
              </h2>
              <p class="mt-3 text-[14px] leading-[140%] font-normal text-[#101010]/70 md:text-[16px]">
                {cat.description}
              </p>
              <ul class="mt-4 flex list-disc flex-col gap-2 pl-5">
                {cat.subs.map((sub) => <li class="text-sm text-[#101010]/80">{sub.name}</li>)}
              </ul>
              <div class="mt-6">
                <CtaButton
                  label="View industry"
                  href={cat.landingHref}
                  variant="primary"
                  showArrow={true}
                />
              </div>
            </article>
          ))
        }
      </div>
    </section>
  </main>
  <Footer />
  <script src="/scripts/nav.js" is:inline></script>
  <script src="/scripts/mobile-nav.js" is:inline></script>
</BaseLayout>
