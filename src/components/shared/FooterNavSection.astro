---
import type { FooterNavLink } from "../../lib/constants/footer-nav";
import FooterLink from "./FooterLink.astro";

interface Props {
  title: string;
  links: FooterNavLink[];
}

const { title, links } = Astro.props;

/** Split links into two balanced columns (4+4, 4+3, 3+3, etc.). */
const splitAt = Math.ceil(links.length / 2);
const linkColumns = [links.slice(0, splitAt), links.slice(splitAt)];

const listClass = "m-0 flex list-none flex-col gap-y-2.5 p-0";
---

<div class="flex h-full min-w-0 flex-col">
  <h3
    class="mb-5 flex min-h-[2.75rem] items-end text-[20px] font-medium leading-[130%] tracking-[-0.02em] text-white md:mb-6 md:min-h-[3rem] md:text-[22px] lg:min-h-[3.25rem] lg:text-[24px]"
  >
    {title}
  </h3>
  <div
    class="grid flex-1 grid-cols-1 gap-y-2 sm:grid-cols-2 sm:items-start sm:gap-x-8 sm:gap-y-0 lg:gap-x-10"
  >
    {
      linkColumns.map(
        (column) =>
          column.length > 0 && (
            <ul class={listClass}>
              {column.map((link) => (
                <li class="min-w-0">
                  <FooterLink {...link} />
                </li>
              ))}
            </ul>
          ),
      )
    }
  </div>
</div>
