---
import { PROCUREMENT_BOUNDARY } from '../../../lib/constants/pages/procurement-vehicles';
import Eyebrow from '../../shared/Eyebrow.astro';
import SledPageWrap from '../shared/SledPageWrap.astro';
---

<section class="sled-section-tight border-t border-line/60 bg-seasalt">
  <SledPageWrap>
    <div class="sled-reveal max-w-[800px]" data-sled-reveal>
      <Eyebrow text={PROCUREMENT_BOUNDARY.eyebrow} showGlyph class="mb-4" />
      <h2 class="text-[clamp(1.375rem,2.5vw,1.625rem)] font-extrabold text-yale-dark">{PROCUREMENT_BOUNDARY.heading}</h2>
      <p class="mt-4 text-[15px] leading-[1.65] text-muted">{PROCUREMENT_BOUNDARY.body}</p>
      <a
        href={PROCUREMENT_BOUNDARY.linkHref}
        class="mt-6 inline-flex items-center gap-2 border-b-2 border-cyan pb-0.5 text-[14px] font-bold text-yale transition-colors hover:text-yale-dark"
      >
        {PROCUREMENT_BOUNDARY.linkLabel} →
      </a>
    </div>
  </SledPageWrap>
</section>
