---
import { VEHICLES, VEHICLES_SECTION } from '../../../lib/constants/pages/sled-hub';
import { SITE } from '../../../lib/constants/site';
import Eyebrow from '../../shared/Eyebrow.astro';
import SledIcon from '../shared/SledIcon.astro';
import SledPageWrap from '../shared/SledPageWrap.astro';
---

<section class="sled-section bg-seasalt" id="vehicles" data-screen-label="08 Vehicles">
  <SledPageWrap>
    <div class="sled-reveal" data-sled-reveal>
      <Eyebrow text={VEHICLES_SECTION.eyebrow} showGlyph class="mb-4" />

      <div class="mb-12 grid grid-cols-1 gap-8 lg:grid-cols-[1.08fr_0.92fr] lg:items-end">
        <h2 class="text-[clamp(1.75rem,3.5vw,2.5rem)] font-extrabold tracking-[-0.022em] text-yale-dark">
          {VEHICLES_SECTION.heading}
        </h2>
        <div class="flex flex-col gap-4 lg:items-end">
          <p class="max-w-[460px] text-[15.5px] leading-[1.65] text-muted lg:text-right">{VEHICLES_SECTION.sub}</p>
          <div class="font-mono text-[11px] tracking-[0.10em] uppercase text-muted lg:text-right">
            {VEHICLES_SECTION.emailPrompt}<br />
            Email <a class="border-b border-cyan pb-px text-yale transition-colors hover:text-yale-dark" href={`mailto:${SITE.email.sled}`}>{SITE.email.sled}</a>
          </div>
        </div>
      </div>
    </div>

    <div class="sled-reveal overflow-hidden rounded-2xl border border-line bg-white shadow-[0_24px_48px_-28px_rgba(21,58,95,0.18)]" data-sled-reveal>
      <div class="grid grid-cols-1 lg:grid-cols-3">
        {VEHICLES.map((v, idx) => (
          <div
            class:list={[
              'group grid grid-cols-[48px_1fr] gap-4 p-8 transition-colors duration-300 hover:bg-seasalt/80',
              idx % 3 !== 2 && 'lg:border-r lg:border-line',
              idx < 3 && 'border-b border-line',
              idx >= 3 && 'border-b border-line lg:border-b-0',
            ]}
          >
            <div class="grid size-12 place-items-center rounded-xl bg-cyan-soft text-cyan-strong transition-transform duration-300 group-hover:scale-105">
              <SledIcon name="award" class="size-[22px]" />
            </div>
            <div>
              <h4 class="mb-1.5 text-[17px] font-extrabold text-yale-dark">{v.heading}</h4>
              <div class="mb-4 text-[13.5px] leading-[1.5] text-muted">{v.sub}</div>
              <div class="inline-flex items-center gap-2 font-mono text-[11.5px] tracking-[0.04em] text-cyan-strong">
                <span class="size-1.5 rotate-[15deg] bg-cyan" aria-hidden="true"></span>
                {v.note}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </SledPageWrap>
</section>
