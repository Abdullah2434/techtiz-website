---
import { formatLiveEyebrowHtml } from '../../../lib/sled-case-studies/live-eyebrow';

interface Props {
  text: string;
  class?: string;
}

const { text, class: extraClass = '' } = Astro.props;
---

<span
  class:list={[
    'inline-flex items-center font-mono text-[11px] font-bold tracking-[0.18em] uppercase text-cyan',
    extraClass,
  ]}
>
  <span
    class="relative mr-2 inline-block size-[11px] -translate-y-px rotate-[15deg] bg-cyan align-middle"
    aria-hidden="true"
  >
    <span class="absolute left-[1.5px] top-[1.5px] size-[3.5px] bg-white" />
  </span>
  <span set:html={formatLiveEyebrowHtml(text)} />
</span>
