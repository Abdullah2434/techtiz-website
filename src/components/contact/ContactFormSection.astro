---
import FormButton from '../shared/FormButton.astro';
import { RECAPTCHA_SITE_KEY } from '../../lib/config/recaptcha';
import { CONTACT_FORM } from '../../lib/constants/pages/commercial-contact';
import { ROUTES } from '../../lib/constants/routes';
import { SITE } from '../../lib/constants/site';

const contactEmail = SITE.email.contact;
const {
  messagePlaceholder,
  subscribeLabel,
  legalPrefix,
  legalConnector,
  submitLabel,
  successTitle,
  successMessage,
} = CONTACT_FORM;
---

<section class="mx-auto w-full max-w-[1280px] px-3 py-8 md:py-14" id="contact-form">
  <div class="flex flex-col gap-12 md:flex-row">
    <div class="contact-form-panel w-full md:w-1/2" data-contact-form-panel>
      <form class="flex flex-col gap-12" data-contact-form novalidate>
        <div class="flex flex-col gap-12 sm:flex-row">
          <div class="w-full sm:w-1/2">
            <input
              type="text"
              name="firstName"
              placeholder="First name"
              autocomplete="given-name"
              class="contact-field"
              data-aos="fade-up"
              data-aos-delay="100"
            />
            <p class="contact-field-error hidden" data-error-for="firstName"></p>
          </div>
          <div class="w-full sm:w-1/2">
            <input
              type="text"
              name="lastName"
              placeholder="Last name"
              autocomplete="family-name"
              class="contact-field"
              data-aos="fade-up"
              data-aos-delay="100"
            />
            <p class="contact-field-error hidden" data-error-for="lastName"></p>
          </div>
        </div>

        <div>
          <input
            type="email"
            name="email"
            placeholder="Enter your email address"
            autocomplete="email"
            class="contact-field"
            data-aos="fade-up"
            data-aos-delay="100"
          />
          <p class="contact-field-error hidden" data-error-for="email"></p>
        </div>

        <div>
          <input
            type="tel"
            name="phone"
            placeholder="Phone number"
            autocomplete="tel"
            class="contact-field"
            data-aos="fade-up"
            data-aos-delay="100"
          />
          <p class="contact-field-error hidden" data-error-for="phone"></p>
        </div>

        <div>
          <textarea
            name="message"
            placeholder={messagePlaceholder}
            rows={4}
            class="contact-field resize-none"
            data-aos="fade-up"
            data-aos-delay="100"></textarea>
          <p class="contact-field-error hidden" data-error-for="message"></p>
        </div>

        <div class="flex items-start gap-3" data-aos="fade-up" data-aos-delay="100">
          <input
            type="checkbox"
            name="subscribe"
            id="contact-subscribe"
            class="mt-[5px] h-5 w-5 min-w-5 cursor-pointer accent-[#49685E]"
          />
          <label
            for="contact-subscribe"
            class="cursor-pointer text-[18px] leading-[130%] font-normal text-[#101010]"
          >
            {subscribeLabel}
          </label>
        </div>

        <input
          type="text"
          name="company"
          tabindex="-1"
          autocomplete="off"
          class="hidden"
          aria-hidden="true"
        />

        <p
          class="text-[18px] leading-[130%] font-normal text-[#101010]"
          data-aos="fade-up"
          data-aos-delay="100"
        >
          {legalPrefix}
          <a href={ROUTES.termsOfService} class="text-yale underline hover:text-cyan">
            terms of use
          </a>
          {legalConnector}
          <a href={ROUTES.privacyPolicy} class="text-yale underline hover:text-cyan">
            privacy policy
          </a>.
        </p>

        <div data-aos="fade-up" data-aos-delay="100">
          <div data-contact-recaptcha></div>
          <p class="contact-field-error hidden" data-error-for="recaptcha"></p>
        </div>

        <div data-aos="fade-up" data-aos-delay="100">
          <FormButton
            type="submit"
            label={submitLabel}
            track="contact"
            class="w-full md:w-[145px]!"
          />
        </div>
      </form>
    </div>

    <div
      class="contact-form-success w-full rounded-[8px] border border-line bg-seasalt p-8 md:w-1/2"
      data-contact-form-success
      hidden
    >
      <h3 class="mb-3 text-[24px] font-semibold text-[#153A5F]">{successTitle}</h3>
      <p class="mb-6 text-[16px] leading-[140%] text-[#101010]">{successMessage}</p>
      <a
        href={`mailto:${contactEmail}`}
        class="inline-flex items-center gap-2 border-b-2 border-cyan pb-0.5 text-[15px] font-bold text-yale"
      >
        Email {contactEmail}
      </a>
    </div>

    <div class="block w-full md:w-1/2" data-contact-form-image>
      <div class="h-full w-full overflow-hidden rounded-[8px]">
        <img
          src="/images/contact/contact-img.png"
          alt="Contact Techtiz"
          width={577}
          height={687}
          class="h-full w-full object-cover"
          loading="lazy"
          decoding="async"
          data-aos="fade-up"
          data-aos-delay="100"
        />
      </div>
    </div>
  </div>
</section>

<script define:vars={{ contactEmail, siteKey: RECAPTCHA_SITE_KEY }}>
  window.__CONTACT_EMAIL__ = contactEmail;
  window.__CONTACT_FORM_CONFIG__ = { siteKey, apiUrl: '/api/contact/' };
</script>
