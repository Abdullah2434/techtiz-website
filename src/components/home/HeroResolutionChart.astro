    class="home-chart-line-cyan"
    d="M0,55 L23,52 L46,46 L69,48 L92,40 L115,38 L138,30 L161,32 L184,24 L207,22 L230,18 L253,16 L276,12 L299,14 L320,8"
    fill="none"
    stroke="#18B0E6"
    stroke-width="2"></path>
  <circle class="home-chart-dot" cx="299" cy="14" r="3" fill="#18B0E6"></circle>
  <circle class="home-chart-dot home-chart-dot-delay" cx="320" cy="8" r="3" fill="#18B0E6"></circle>
</svg>
