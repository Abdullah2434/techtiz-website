---
interface Props {
  eyebrow: string;
  heading: string;
  sub?: string;
  rightLinkLabel?: string;
  rightLinkHref?: string;
  light?: boolean;
}

const { eyebrow, heading, sub, rightLinkLabel, rightLinkHref, light = false } = Astro.props;
---

<div class="home-section-header-row">
  <div class="max-w-[700px]">
    <span class:list={['home-section-eyebrow', light && 'home-section-eyebrow--light']}>{eyebrow}</span>
    <h2 class:list={['home-section-title', light && 'home-section-title--light']} set:html={heading} />
    {sub && <p class:list={['home-section-lead', light && 'home-section-lead--light']}>{sub}</p>}
  </div>
  {
    rightLinkLabel && rightLinkHref && (
      <div class="pb-1">
        <a
          href={rightLinkHref}
          class:list={[
            'inline-flex items-center gap-2 border-b-2 border-cyan pb-1 text-sm font-bold transition-[gap] duration-200 ease-out hover:gap-3.5',
            light ? 'text-cyan' : 'text-yale',
          ]}
        >
          {rightLinkLabel}
        </a>
      </div>
    )
  }
</div>
