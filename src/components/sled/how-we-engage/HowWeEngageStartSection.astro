---
import { FIRST_EMAIL_CHECKLIST, START_SECTION } from '../../../lib/constants/pages/how-we-engage';
import CtaButton from '../../shared/CtaButton.astro';
import Eyebrow from '../../shared/Eyebrow.astro';
import SledPageWrap from '../shared/SledPageWrap.astro';
---

<section class="sled-section-tight border-t border-line/60 bg-seasalt" id="start" data-screen-label="07 CTA">
  <SledPageWrap>
    <div class="grid grid-cols-1 items-center gap-9 lg:grid-cols-[1.1fr_0.9fr] lg:gap-14">
      <div class="sled-reveal" data-sled-reveal>
        <Eyebrow text={START_SECTION.eyebrow} showGlyph class="mb-4" />
        <h2 class="sled-h2 mb-[18px] leading-[1.1] text-yale-dark">{START_SECTION.heading}</h2>
        <p class="mb-7 max-w-[500px] text-[15.5px] leading-[1.6] text-muted">{START_SECTION.body}</p>
        <CtaButton href={START_SECTION.ctaHref} label={START_SECTION.ctaLabel} variant="ghost-light" showArrow={false} />
      </div>

      <div
        class="sled-reveal rounded-[14px] border border-line bg-seasalt p-8 shadow-[0_8px_24px_-16px_rgba(21,58,95,0.14)]"
        data-sled-reveal
      >
        <h4 class="mb-3.5 text-base font-bold text-yale">{START_SECTION.checklistHeading}</h4>
        <ul class="m-0 flex list-none flex-col gap-2.5 p-0">
          {FIRST_EMAIL_CHECKLIST.map((item) => (
            <li class="flex items-start gap-2.5 text-[13.5px] leading-[1.5] text-ink">
              <span class="mt-[5px] size-2 shrink-0 rotate-[15deg] rounded-[1.5px] bg-cyan" aria-hidden="true" />
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </SledPageWrap>
</section>
