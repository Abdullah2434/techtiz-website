              <div class="grid size-9 place-items-center rounded-lg bg-seasalt text-yale-dark"><svg class="size-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5 L3 21 l4.5 -1.5 M14 6 l4 4 -8 8 -4 0 0 -4 z"></path></svg></div>
              <div class="body">
                <h5 class="mb-0.5 text-[14.5px] font-bold text-yale-dark">Post-Award Delivery</h5>
                <p class="m-0 font-mono text-[10.5px] tracking-[0.10em] uppercase text-muted">Engineers, sprints, KT</p>
              </div>
              <div class="check relative size-[18px] rounded border-[1.5px] border-line transition-[border-color,background] duration-200 ease-out"></div>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 gap-4 lg:grid-cols-2">
          <div>
            <label class="mb-2 block font-mono text-[10.5px] tracking-[0.14em] uppercase text-muted">Company <span class="text-cyan-strong">*</span></label>
            <input class="w-full rounded-lg border border-line bg-white px-[14px] py-3 text-[14.5px] text-ink outline-none transition-[border-color,box-shadow] duration-200 ease-out placeholder:text-[#9AA4B2] focus:border-cyan focus:shadow-[0_0_0_3px_rgba(24,176,230,0.18)]" type="text" id="iq-company" name="company" placeholder="Prime contractor name" required />
          </div>
          <div>
            <label class="mb-2 block font-mono text-[10.5px] tracking-[0.14em] uppercase text-muted">Your role</label>
            <input class="w-full rounded-lg border border-line bg-white px-[14px] py-3 text-[14.5px] text-ink outline-none transition-[border-color,box-shadow] duration-200 ease-out placeholder:text-[#9AA4B2] focus:border-cyan focus:shadow-[0_0_0_3px_rgba(24,176,230,0.18)]" type="text" id="iq-role" name="role" placeholder="e.g. Capture Manager, Delivery Lead" />
          </div>
        </div>
        <div class="grid grid-cols-1 gap-4 lg:grid-cols-2">
          <div>
