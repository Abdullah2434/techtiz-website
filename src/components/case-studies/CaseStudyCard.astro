---
import type { CaseStudy } from '../../lib/types/case-study';
import { isVideoMedia, truncateOverview } from '../../lib/utils/case-study';

interface Props {
  study: CaseStudy;
}

const { study } = Astro.props;
const overview = truncateOverview(study.overview);
const isVideo = isVideoMedia(study.image);
const detailHref = `/case-studies/${study.slug}/`;
---

<a href={detailHref} class="cs-card group block">
  <div class="flex flex-col">
    <div class="min-h-[220px] max-w-[700px]" data-aos="fade-up" data-aos-delay="100">
      {
        isVideo ? (
          <video
            src={study.image}
            autoplay
            muted
            loop
            playsinline
            class="h-[220px] w-full rounded-lg object-cover"
          />
        ) : (
          <img
            src={study.image}
            alt={`Case study image for ${study.title}`}
            width={700}
            height={220}
            class="h-[220px] w-full rounded-lg object-cover"
            loading="lazy"
            decoding="async"
          />
        )
      }
    </div>

    <div class="flex min-h-[229px] max-w-[700px] flex-col gap-10 p-6" data-aos="fade-up" data-aos-delay="100">
      <div class="max-w-[620px] gap-2">
        <h3 class="mb-3 line-clamp-2 text-[30px] font-medium leading-[1.2] tracking-[-0.64px] text-[#1E1E1E] md:text-[32px]">
          {study.title}
        </h3>
        <p class="text-left text-base font-normal leading-[1.2] tracking-[-0.32px] text-[#1E1E1E]/60">
          {overview}
        </p>
      </div>

      {
        study.founder && (
          <div class="mt-auto flex max-w-[620px] flex-wrap justify-between">
            <div class="flex items-center gap-3">
              <img
                src={study.founder.image}
                alt={study.founder.name}
                width={40}
                height={40}
                class="size-10 rounded-full object-cover"
                loading="lazy"
              />
              <div>
                <p class="mb-1 text-[11px] font-semibold leading-[1.2] tracking-[-0.02em] text-[#0E0E0E]">
                  {study.founder.name}
                </p>
                <p class="text-[8px] font-normal leading-[1.2] tracking-[-0.02em] text-[#0E0E0E]">
                  {study.founder.role}
                </p>
              </div>
              {
                study.videoId && (
                  <button
                    type="button"
                    class="ml-3 flex size-8 cursor-pointer items-center justify-center rounded-full bg-[#0E0E0E33] hover:bg-[#0E0E0E66]"
                    data-video-open={study.videoId}
                    onclick="event.preventDefault(); event.stopPropagation();"
                    aria-label="Play video"
                  >
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="ml-0.5 p-0.5" aria-hidden="true">
                      <path
                        d="M13.9268 5.88247C14.311 6.08679 14.6324 6.39181 14.8565 6.76483C15.0806 7.13786 15.199 7.56483 15.199 8.00001C15.199 8.43518 15.0806 8.86216 14.8565 9.23518C14.6324 9.60821 14.311 9.91322 13.9268 10.1175L3.67749 15.691C2.02714 16.5894 0 15.4214 0 13.5742V2.42657C0 0.578629 2.02714 -0.588537 3.67749 0.308237L13.9268 5.88247Z"
                        fill="#0E0E0E"
                      />
                    </svg>
                  </button>
                )
              }
            </div>
            <span class="mt-4 inline-flex items-center gap-4 text-base font-semibold uppercase leading-[1.2] tracking-[-0.02em] text-[#1E1E1E] transition-all group-hover:gap-5 lg:mt-0">
              SEE DETAILS
              <svg width="14" height="12" viewBox="0 0 14 12" fill="none" aria-hidden="true">
                <path
                  d="M0.803762 10.599L12.1295 0.809738M12.0694 7.22556L12.2639 0.693694L4.69787 0.861589"
                  stroke="#1E1E1E"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </span>
          </div>
        )
      }
    </div>
  </div>
</a>
