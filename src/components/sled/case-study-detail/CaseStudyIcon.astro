  unplug: Unplug,
  'upload-cloud': CloudUpload,
  'user-round': UserRound,
  'user-x': UserX,
  users: Users,
  'volume-x': VolumeX,
  wind: Wind,
  zap: Zap,
};

const Icon = iconMap[name];
---

{Icon ? <Icon class={className} aria-hidden="true" /> : null}
