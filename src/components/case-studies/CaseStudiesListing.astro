---
import "../../styles/case-studies.css";
import CaseStudyCard from "./CaseStudyCard.astro";
import PageWrap from "../home/PageWrap.astro";
import { CASE_STUDIES_PORTFOLIO } from "../../lib/constants/case-studies-portfolio";
import {
  CASE_STUDY_TABS,
  CASE_STUDIES_ITEMS_PER_PAGE,
  CASE_STUDIES_MAX_VISIBLE_PAGES,
} from "../../lib/config/case-studies";
import { getCaseStudiesByCategory } from "../../lib/constants/case-studies-portfolio";

const urlTab = Astro.url.searchParams.get("tab") ?? "All";
const activeTab = CASE_STUDY_TABS.some((t) => t.name === urlTab)
  ? urlTab
  : "All";
const pageParam = Number(Astro.url.searchParams.get("page") ?? "1");
const currentPage = Number.isFinite(pageParam) && pageParam > 0 ? pageParam : 1;

const filtered = getCaseStudiesByCategory(activeTab);
const totalPages = Math.max(
  1,
  Math.ceil(filtered.length / CASE_STUDIES_ITEMS_PER_PAGE),
);
const safePage = Math.min(currentPage, totalPages);
const startIndex = (safePage - 1) * CASE_STUDIES_ITEMS_PER_PAGE;
const pageItems = filtered.slice(
  startIndex,
  startIndex + CASE_STUDIES_ITEMS_PER_PAGE,
);
const endIndex = Math.min(
  startIndex + CASE_STUDIES_ITEMS_PER_PAGE,
  filtered.length,
);

const portfolioLite = CASE_STUDIES_PORTFOLIO.map((s) => ({
  slug: s.slug,
  title: s.title,
  overview: s.overview,
  image: s.image,
  category: s.category,
  website: s.website ?? "",
  founder: s.founder,
  videoId: s.videoId,
  reviewVideoUrl: s.reviewVideoUrl,
}));
---

<div class="relative z-20 w-full py-10 md:px-2 md:py-10" data-cs-listing>
  <PageWrap class="px-2">
    <div
      id="case-studies-tabs"
      class="flex flex-col overflow-hidden rounded-[2px] md:flex-row md:flex-wrap md:justify-center md:gap-6 md:rounded-none xl:justify-start"
      role="tablist"
      aria-label="Case studies categories"
      data-cs-tabs
    >
      {
        CASE_STUDY_TABS.map((tab, index) => (
          <div data-aos="fade-up" data-aos-delay="100">
            <button
              type="button"
              role="tab"
              data-cs-tab={tab.name}
              aria-selected={activeTab === tab.name}
              class:list={[
                tab.minWidth,
                "cursor-pointer border-b-2 py-4 text-base font-normal transition-all duration-300 ease-in-out focus:outline-none focus:ring-2 focus:ring-inset focus:ring-cyan/20 md:rounded-[2px] md:border-none md:px-5",
                index !== CASE_STUDY_TABS.length - 1
                  ? "border-cyan/20 md:border-b-0"
                  : "border-b-0",
                activeTab === tab.name ? "cs-tab-active" : "cs-tab-inactive",
              ]}
            >
              {tab.name}
            </button>
          </div>
        ))
      }
    </div>

    <div
      class="mt-8 md:mt-14"
      role="tabpanel"
      id={`tabpanel-${activeTab.toLowerCase().replace(/\s+/g, "-")}`}
      data-cs-panel
    >
      <div class="cs-listing-panel cs-panel-enter" data-cs-panel-inner>
        <div data-aos="fade-up" data-aos-delay="100">
          <h2
            id="case-studies-heading"
            class="mb-6 text-2xl font-semibold text-[#1E1E1E]"
          >
            Case Studies
          </h2>
        </div>
        <div data-aos="fade-up" data-aos-delay="200" aria-hidden="true">
          <div class="mb-10 h-0.5 w-full bg-[#D0D0D0]"></div>
        </div>
        <div
          class="grid grid-cols-1 gap-10 md:grid-cols-2 md:gap-10"
          data-cs-grid
        >
          {pageItems.map((study) => <CaseStudyCard study={study} />)}
        </div>
      </div>
    </div>

    <div
      class="mt-12 flex flex-col items-center gap-4"
      data-cs-pagination
      hidden={totalPages <= 1}
    >
      <div data-aos="fade-up" data-aos-delay="100">
        <p class="text-sm text-gray-600" data-cs-range>
          Showing {filtered.length === 0 ? 0 : startIndex + 1} to {endIndex} of {
            filtered.length
          } case studies
        </p>
      </div>
      <div data-aos="fade-up" data-aos-delay="100">
        <nav
          class="flex items-center justify-center gap-2"
          aria-label="Pagination Navigation"
          data-cs-pagination-nav
        >
        </nav>
      </div>
    </div>
  </PageWrap>
</div>

<script
  define:vars={{
    portfolioLite,
    itemsPerPage: CASE_STUDIES_ITEMS_PER_PAGE,
    maxVisiblePages: CASE_STUDIES_MAX_VISIBLE_PAGES,
    initialTab: activeTab,
    initialPage: safePage,
  }}
  is:inline
>
  window.__CS_LISTING__ = {
    portfolioLite,
    itemsPerPage,
    maxVisiblePages,
    initialTab,
    initialPage,
  };
</script>
<script src="/scripts/case-studies-listing.js" is:inline></script>
