---
import type { AboutHeroData } from '../../lib/types/about';

interface Props extends AboutHeroData {}

const {
  titleHighlight,
  subtitle,
  headline,
  headlineHighlight,
  body,
  quoteHighlight,
  quoteRest,
} = Astro.props;
---

<section class="mx-auto w-full max-w-[1400px] px-2 py-10 md:py-16">
  <div
    class="flex flex-col gap-y-10 md:flex-row md:items-start md:justify-between md:gap-x-[clamp(2rem,6vw,80px)] md:gap-y-0"
  >
    <div class="min-w-[260px] max-w-[420px] flex-1" data-aos="fade-up" data-aos-delay="300">
      <h2 class="mb-1 text-[30px] leading-[120%] font-normal lg:text-[56px]">
        About <span class="font-semibold text-[#18B0E6]">{titleHighlight}</span>
      </h2>
      <h1 class="text-[20px] font-medium text-[#101010] lg:text-[24px]">{subtitle}</h1>
    </div>

    <div class="mb-3 min-w-[260px] max-w-[640px] flex-1 justify-end" data-aos="fade-up" data-aos-delay="100">
      <h3 class="mb-2 text-[20px] font-medium tracking-[-0.04em] [word-spacing:0px] lg:text-[32px]">
        {headline}{' '}
        <span class="font-semibold text-[#18B0E6]">{headlineHighlight}</span>
      </h3>
      <p class="max-w-[624px] text-[16px] leading-[130%] font-normal text-[#101010] lg:text-[18px]">
        {body}
      </p>
    </div>
  </div>

  <div class="mx-auto mt-[70px] max-w-[1400px] md:mt-[140px]">
    <p
      class="text-[24px] leading-[130%] font-light tracking-[-0.02em] text-[#101010] [word-spacing:0px] lg:text-[40px]"
      data-aos="fade-up"
      data-aos-delay="100"
    >
      Founded on a belief that{' '}
      <span class="font-semibold text-[#18B0E6]">{quoteHighlight}</span>
      <br class="hidden lg:block" />
      {quoteRest}
    </p>
  </div>
</section>
