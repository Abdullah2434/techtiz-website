---
import Calendar from '@lucide/astro/icons/calendar';
import FileSearch from '@lucide/astro/icons/file-search';
import Mail from '@lucide/astro/icons/mail';
import Send from '@lucide/astro/icons/send';
import {
  INTENT_OPTIONS,
  ROLE_OPTIONS,
  TIMING_OPTIONS,
  VEHICLE_OPTIONS,
  WHAT_HAPPENS_NEXT,
} from '../../../lib/constants/pages/contact';
import { SITE, highlightSledEmailHtml } from '../../../lib/constants/site';
import CtaButton from '../../shared/CtaButton.astro';
import FormButton from '../../shared/FormButton.astro';
import SledPageWrap from '../shared/SledPageWrap.astro';

const stepIcons = [Mail, Calendar, FileSearch] as const;

const inputClass =
  'w-full rounded-xl border border-line bg-white px-4 py-3.5 text-[14px] text-ink outline-none transition-[border-color,box-shadow,transform] duration-200 ease-out placeholder:text-muted/70 focus:border-cyan focus:shadow-[0_0_0_3px_rgba(24,176,230,0.18)] focus:-translate-y-px';

const labelClass = 'mb-2 block text-[13.5px] font-semibold text-yale-dark';
const sectionLabelClass = 'font-mono text-[10.5px] font-bold tracking-[0.18em] text-cyan-strong uppercase';
---

<section class="sled-section bg-seasalt" id="intake">
  <SledPageWrap>
    <div class="grid grid-cols-1 items-start gap-10 lg:grid-cols-[1.2fr_0.88fr] lg:gap-12">
      <div class="sled-reveal min-w-0" data-sled-reveal>
        <form
          class="overflow-hidden rounded-2xl border border-line bg-white shadow-[0_24px_56px_-32px_rgba(14,38,64,0.28)]"
          id="intakeForm"
          data-mailto={SITE.email.sled}
          novalidate
        >
          <div class="space-y-5 px-6 py-6 sm:px-8 sm:py-7">
            <div>
              <label class={labelClass}>What would you like from us? <span class="text-cyan-strong">*</span></label>
              <div class="intent-pills mt-2 flex flex-wrap gap-2">
                {INTENT_OPTIONS.map((opt, i) => (
                  <label
                    class:list={[
                      'intent-option inline-flex cursor-pointer items-center gap-2 rounded-full border border-line bg-seasalt px-3.5 py-2.5 transition-[border-color,background] duration-200 hover:border-cyan-strong hover:bg-white [&.on]:border-cyan [&.on]:bg-cyan-soft [&.on_.check]:border-cyan [&.on_.check]:bg-cyan',
                      { on: i === 0 },
                    ]}
                  >
                    <input type="radio" name="intent" value={opt.value} checked={i === 0} class="sr-only" />
                    <span
                      class="check size-2.5 shrink-0 rounded-full border-[1.5px] border-line bg-white"
                      aria-hidden="true"
                    />
                    <span class="l text-[13px] font-semibold text-yale">{opt.label}</span>
                  </label>
                ))}
              </div>
            </div>

            <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
              <div>
                <label for="name" class={labelClass}>Full name <span class="text-amber">*</span></label>
                <input id="name" name="name" type="text" placeholder="Jane Doe" required class={inputClass} />
              </div>
              <div>
                <label for="email" class={labelClass}>Work email <span class="text-amber">*</span></label>
                <input id="email" name="email" type="email" placeholder="jane@prime.com" required class={inputClass} />
              </div>
            </div>

            <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
              <div>
                <label for="firm" class={labelClass}>Prime firm <span class="text-amber">*</span></label>
                <input id="firm" name="firm" type="text" placeholder="Prime contractor name" required class={inputClass} />
              </div>
              <div>
                <label for="role" class={labelClass}>Your role</label>
                <select id="role" name="role" class={inputClass}>
                  {ROLE_OPTIONS.map((opt) => <option>{opt}</option>)}
                </select>
              </div>
            </div>

            <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
              <div>
                <label for="vehicle" class={labelClass}>Contract vehicle</label>
                <select id="vehicle" name="vehicle" class={inputClass}>
                  {VEHICLE_OPTIONS.map((opt) => <option>{opt}</option>)}
                </select>
              </div>
              <div>
                <label for="timing" class={labelClass}>Timing</label>
                <select id="timing" name="timing" class={inputClass}>
                  {TIMING_OPTIONS.map((opt) => <option>{opt}</option>)}
                </select>
              </div>
            </div>

            <div>
              <label for="desc" class={labelClass}>Engagement: phase, scope, timing</label>
              <textarea
                id="desc"
                name="desc"
                placeholder="Subcontract under a master? Teaming letter in place? What technical surface area are you staffing? Add a solicitation number if you have one."
                class:list={[inputClass, 'min-h-[120px] resize-y']}
              />
            </div>
          </div>

          <input
            type="text"
            name="website"
            tabindex="-1"
            autocomplete="off"
            class="hidden"
            aria-hidden="true"
          />

          <div class="flex flex-wrap items-center justify-between gap-4 border-t border-line bg-seasalt/40 px-6 py-5 sm:px-8">
            <div class="text-[13.5px] leading-[1.55] text-muted">All fields are confidential. NDA on request before review.</div>
            <FormButton type="submit" label="Send to Techtiz" variant="yale" showArrow={false}>
              <Send class="size-4" aria-hidden="true" />
            </FormButton>
          </div>
        </form>

        <div
          class="sled-inquiry-success hidden flex-col items-center rounded-2xl border border-line bg-white px-8 py-14 text-center shadow-[0_24px_56px_-32px_rgba(14,38,64,0.28)] sm:px-10"
          id="formSuccess"
          role="status"
        >
          <div class="mb-6 grid size-14 place-items-center rounded-full bg-cyan-soft">
            <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="var(--color-cyan-strong)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 13l4 4L19 7"></path></svg>
          </div>
          <h3 class="mb-2.5 text-2xl font-extrabold text-yale-dark">Inquiry received.</h3>
          <p
            class="mx-auto mb-6 max-w-[420px] text-[15px] leading-[1.55] text-muted"
            set:html={highlightSledEmailHtml(
              `Thank you for reaching out. Our U.S.-based partner manager will reply within one business day from ${SITE.email.sled} with a mutual NDA template and a calendar slot.`,
            )}
          />
          <CtaButton
            id="formReset"
            href="#"
            label="Submit another inquiry"
            variant="ghost-light"
            showArrow={false}
          />
        </div>
      </div>

      <aside class="sled-reveal-stagger space-y-5 lg:sticky lg:top-[120px] lg:self-start" data-sled-reveal>
        <div class="sled-card overflow-hidden rounded-2xl p-0">
          <div class="border-b border-line bg-gradient-to-br from-yale-dark to-yale px-6 py-5 text-white sm:px-7">
            <div class={sectionLabelClass}>What happens next</div>
            <h2 class="mt-2 text-[22px] font-extrabold leading-tight">Three steps. Two of them are ours.</h2>
          </div>
          <div class="space-y-3 p-5 sm:p-6">
            {WHAT_HAPPENS_NEXT.map((step, idx) => {
              const StepIcon = stepIcons[idx];
              return (
                <div class="flex gap-3.5 rounded-xl border border-line bg-seasalt/80 p-4 transition-colors hover:bg-seasalt">
                  <div class="grid size-10 shrink-0 place-items-center rounded-xl bg-white text-yale-dark shadow-[0_4px_12px_-8px_rgba(21,58,95,0.2)]">
                    <StepIcon class="size-[18px]" stroke-width="1.75" aria-hidden="true" />
                  </div>
                  <div class="text-[13.5px] leading-[1.55] text-muted">
                    <span class="mb-0.5 block font-mono text-[11px] font-extrabold text-cyan-strong">{step.n}</span>
                    <em class="block not-italic font-semibold text-yale-dark">{step.timing}</em>
                    {step.text}
                  </div>
                </div>
              );
            })}
          </div>
        </div>

        <div class="sled-card rounded-2xl p-6 sm:p-7">
          <div class={sectionLabelClass}>Or skip the form</div>
          <h3 class="mt-2 text-[18px] font-extrabold leading-tight text-yale-dark">Email the SLED desk directly.</h3>
          <p class="mt-2 text-[13.5px] leading-[1.6] text-muted">
            If you'd rather start with a short email, send a one-line description of the engagement type and your role. Our U.S.-based partner manager routes it from there, usually within one business day.
          </p>
          <CtaButton
            href={`mailto:${SITE.email.sled}`}
            label={SITE.email.sled}
            variant="ghost-light"
            showArrow={false}
            class="mt-5 w-full"
          >
            <Mail class="size-4 text-cyan-strong" stroke-width="1.75" aria-hidden="true" />
          </CtaButton>
        </div>
      </aside>
    </div>
  </SledPageWrap>
</section>

<script>
  import { initContactIntakeForm } from './contact-intake-form';
  initContactIntakeForm();
</script>
