---
import { BACKBONE, BACKBONE_CARDS } from '../../lib/constants/pages/sled-hub';
import Eyebrow from '../shared/Eyebrow.astro';
import SledIcon from './SledIcon.astro';
import SledPageWrap from './SledPageWrap.astro';

const cardClass =
  'rounded-[10px] border border-line bg-white px-[26px] py-[28px] transition-[transform,border-color,box-shadow] duration-200 ease-out hover:-translate-y-[2px] hover:border-[#C2CCD9] hover:shadow-[0_18px_36px_-18px_rgba(21,58,95,0.16)]';
---

<section class="bg-seasalt py-[110px] max-[900px]:py-16" data-screen-label="06 Backbone">
  <SledPageWrap>
    <div class="mb-14 flex flex-col items-start justify-between gap-12 max-[900px]:mb-9 max-[900px]:gap-4 lg:flex-row lg:items-end">
      <div class="max-w-[700px]">
        <Eyebrow text={BACKBONE.eyebrow} showGlyph class="mb-3.5" />
        <h2 class="text-[44px] font-extrabold tracking-[-0.022em] text-yale-dark max-[900px]:text-[30px] max-[600px]:text-[26px]">{BACKBONE.heading}</h2>
        <p class="mt-3.5 max-w-[620px] text-[15.5px] leading-[1.6] text-muted">{BACKBONE.sub}</p>
      </div>
      <a
        class="inline-flex items-center gap-2 border-b-2 border-cyan pb-1 text-sm font-bold text-yale transition-[gap] duration-200 ease-out hover:gap-3.5"
        href={BACKBONE.linkHref}
      >
        {BACKBONE.linkLabel} <span aria-hidden="true">→</span>
      </a>
    </div>

    <div class="grid grid-cols-1 gap-4 lg:grid-cols-3">
      {BACKBONE_CARDS.map((card) => (
        <a class={cardClass} href={card.href}>
          <div class="mb-2 flex items-center gap-2.5">
            <div class="grid size-11 place-items-center rounded-lg bg-cyan-soft text-cyan-strong">
              <SledIcon name="doc" class="size-[22px]" />
            </div>
            <span class="font-mono text-[10px] tracking-[0.14em] uppercase text-cyan-strong">{card.badgeNo}</span>
          </div>
          <h3 class="mb-2 text-[18px] font-extrabold text-yale-dark">{card.heading}</h3>
          <p class="text-[13.5px] leading-[1.55] text-muted">{card.body}</p>
        </a>
      ))}
    </div>
  </SledPageWrap>
</section>
