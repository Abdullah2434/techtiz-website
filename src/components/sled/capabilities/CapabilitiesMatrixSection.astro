---
import { CAPABILITY_MATRIX } from '../../../lib/constants/pages/capabilities';
import Eyebrow from '../../shared/Eyebrow.astro';
import SledPageWrap from '../shared/SledPageWrap.astro';
---

<section class="bg-white py-[100px] pb-20">
  <SledPageWrap>
    <div class="mb-12 max-w-[720px]">
      <Eyebrow text="Capability matrix" showGlyph class="mb-3.5" />
      <h2 class="sled-h2 text-yale-dark">Eight rows. One per Backbone component.</h2>
      <p class="mt-3.5 max-w-[620px] text-[15.5px] leading-[1.6] text-muted">
        Mapped by depth, not breadth. Each row is something we've shipped on a real engagement.
      </p>
    </div>

    <div class="overflow-hidden rounded-xl border border-line bg-white">
      <div class="grid grid-cols-[280px_1.4fr_1fr] bg-yale max-[900px]:hidden">
        <div class="border-r border-white/10 px-[26px] py-[18px] font-mono text-[11px] font-bold tracking-[0.14em] uppercase text-cyan">Capability</div>
        <div class="border-r border-white/10 px-[26px] py-[18px] font-mono text-[11px] font-bold tracking-[0.14em] uppercase text-cyan">What we do</div>
        <div class="px-[26px] py-[18px] font-mono text-[11px] font-bold tracking-[0.14em] uppercase text-cyan">Tools we use</div>
      </div>

      {CAPABILITY_MATRIX.map((row) => (
        <div class="sled-matrix-row grid grid-cols-[280px_1.4fr_1fr] border-t border-line max-[900px]:grid-cols-1 max-[900px]:gap-3 max-[900px]:p-5">
          <div class="flex items-start gap-3.5 border-r border-line px-[26px] py-[22px] max-[900px]:border-r-0 max-[900px]:px-0 max-[900px]:py-0">
            
            <div class="text-[15px] font-bold leading-[1.3] text-yale">{row.name}</div>
          </div>
          <div class="border-r border-line px-[26px] py-[22px] text-[14px] leading-[1.55] text-ink max-[900px]:border-r-0 max-[900px]:px-0 max-[900px]:py-0">
            <span class="mb-1 hidden font-mono text-[10.5px] font-bold tracking-[0.14em] uppercase text-cyan-strong max-[900px]:block">What we do</span>
            {row.what}
          </div>
          <div class="px-[26px] py-[22px] font-mono text-[11.5px] leading-[1.55] tracking-[0.02em] text-cyan-strong max-[900px]:px-0 max-[900px]:py-0">
            <span class="mb-1 hidden font-mono text-[10.5px] font-bold tracking-[0.14em] uppercase text-cyan-strong max-[900px]:block">Tools we use</span>
            {row.tools}
          </div>
        </div>
      ))}
    </div>
  </SledPageWrap>
</section>
