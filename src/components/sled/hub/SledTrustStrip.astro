---
import { TRUST_BADGES } from '../../../lib/constants/pages/sled-hub';
import SledPageWrap from '../shared/SledPageWrap.astro';

const badgeBase =
  'relative inline-flex max-w-full items-center gap-2.25 rounded-full border border-white/16 bg-white/6 px-5 py-2.75 text-[13.5px] font-semibold leading-snug text-white/92';
const badgeDefault = `${badgeBase} shrink-0 whitespace-nowrap`;
const badgeNaics =
  'relative inline-flex basis-full max-w-full items-center rounded-xl border border-white/16 bg-white/6 px-4 py-3 font-mono text-[10.5px] leading-relaxed tracking-wide text-white/78 whitespace-normal sm:basis-auto sm:rounded-full sm:px-5 sm:py-2.75 sm:text-xs sm:leading-snug';
---

<section
  class="bg-yale py-[clamp(30px,3.5vw,46px)] text-white"
  aria-label="Compliance and registration"
>
  <SledPageWrap>
    <div class="flex min-w-0 flex-wrap gap-3 sled-reveal-stagger" data-sled-reveal>
      {TRUST_BADGES.map((badge) => (
        <span
          class:list={[
            badge.naics ? badgeNaics : badgeDefault,
            badge.beam && 'sled-beam',
          ]}
        >
          {!badge.naics && (
            <span class="size-[7px] shrink-0 rounded-full bg-cyan" aria-hidden="true"></span>
          )}
          {badge.label}
        </span>
      ))}
    </div>
  </SledPageWrap>
</section>
