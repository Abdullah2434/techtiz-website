---
import CircleQuestionMark from '@lucide/astro/icons/circle-question-mark';
import { OPERATING_MODEL_HERO } from '../../../lib/constants/pages/operating-model';

const answerHtml = `<strong class="text-yale-dark">"If I subcontract this work to Techtiz, where does the data go and who touches it?"</strong> ${OPERATING_MODEL_HERO.answerCard.text.replace(/^"[^"]*"\s*&nbsp;/, '')}`;
---

<div class="sled-reveal mt-8 max-w-[780px]" data-sled-reveal>
  <div class="sled-card sled-glass overflow-hidden rounded-2xl p-0">
    <div class="grid grid-cols-1 gap-0 sm:grid-cols-[minmax(120px,140px)_1fr]">
      <div class="flex items-center justify-center border-b border-line/80 bg-gradient-to-br from-cyan-soft/80 to-seasalt p-5 sm:border-b-0 sm:border-r">
        <div class="text-center">
          <div class="mx-auto mb-3 grid size-11 place-items-center rounded-xl bg-yale-dark text-cyan">
            <CircleQuestionMark class="size-5" stroke-width="1.75" aria-hidden="true" />
          </div>
          <div class="font-mono text-[10.5px] font-bold leading-tight tracking-[0.14em] uppercase text-cyan-strong">
            Flow-down<br />question
          </div>
        </div>
      </div>
      <div class="p-6 text-[14.5px] leading-[1.65] text-muted sm:p-7" set:html={answerHtml} />
    </div>
  </div>
</div>
