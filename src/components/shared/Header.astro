---
import '../../styles/chrome.css';
import { SITE } from '../../lib/constants/site';

interface Props {
  currentPage?: string;
}

const wrap =
  'mx-auto w-full max-w-[1400px] px-2 max-[600px]:px-[18px]';
---

<header class="top sticky top-0 z-50 border-b border-line bg-white/94 backdrop-blur-[10px]">
  <div class:list={[wrap, 'nav grid h-[76px] grid-cols-[1fr_auto_1fr] items-center max-[900px]:flex max-[900px]:h-16 max-[900px]:justify-between']}>
    <a href="/" class="brand" aria-label={`${SITE.name} home`}>
      <img src={SITE.logo.dark} alt={SITE.name} class="brand-logo block h-[26px] w-auto" />
    </a>

    <nav class="primary-nav inline-flex items-center gap-0.5 max-[900px]:hidden" aria-label="Primary">
      <a
        href="/"
        class="nav-link inline-flex cursor-pointer items-center gap-1.5 whitespace-nowrap rounded-lg border border-transparent bg-transparent px-4 py-2.5 font-sans text-[14.5px] font-semibold leading-none text-ink transition-[color,background,border-color] duration-[180ms] ease-out hover:bg-yale/4 hover:text-yale"
      >
        About Us
      </a>

      <div class="nav-item relative" data-mega="services">
        <button
          class="nav-link inline-flex cursor-pointer items-center gap-1.5 whitespace-nowrap rounded-lg border border-transparent bg-transparent px-4 py-2.5 font-sans text-[14.5px] font-semibold leading-none text-ink transition-[color,background,border-color] duration-[180ms] ease-out hover:bg-yale/4 hover:text-yale"
          type="button"
          aria-expanded="false"
        >
          Services <span class="chev size-[7px] -translate-x-px -translate-y-px rotate-45 border-r-[1.6px] border-b-[1.6px] border-current opacity-55 transition-transform duration-220 ease-out"></span>
        </button>
        <div
          class="mega pointer-events-none invisible absolute top-[calc(100%+14px)] left-1/2 z-60 w-[min(760px,calc(100vw-32px))] -translate-x-1/2 -translate-y-1 rounded-2xl border border-line bg-white p-[22px] opacity-0 shadow-[0_30px_60px_-20px_rgba(14,38,64,0.22),0_6px_18px_-8px_rgba(14,38,64,0.10)] transition-[opacity,transform,visibility] duration-[180ms] ease-out before:absolute before:-top-2 before:left-1/2 before:size-3.5 before:-translate-x-1/2 before:rotate-45 before:rounded-tl before:border-t before:border-l before:border-line before:bg-white before:content-[''] max-[1180px]:left-0 max-[1180px]:translate-x-0 max-[1180px]:before:left-10"
          role="menu"
        >
          <div class="mega-inner grid grid-cols-[250px_1fr] gap-[22px]">
            <div class="mega-left">
              <div class="mega-eyebrow mb-3.5 px-1.5 text-[17px] font-extrabold tracking-[-0.01em] text-yale-dark">We Offer</div>
              <div class="mega-list flex flex-col gap-0.5" data-list="services">
                <a class="mega-item active flex cursor-pointer items-center justify-between rounded-lg px-3.5 py-[11px] text-sm font-semibold text-ink transition-[background,color] duration-[180ms] ease-out hover:bg-cyan-soft hover:text-yale-dark" data-key="development" href="/">
                  Development
                  <span class="arr-r size-2 rotate-[-45deg] border-r-[1.6px] border-b-[1.6px] border-current opacity-0 transition-opacity duration-[180ms] ease-out"></span>
                </a>
                <a class="mega-item flex cursor-pointer items-center justify-between rounded-lg px-3.5 py-[11px] text-sm font-semibold text-ink transition-[background,color] duration-[180ms] ease-out hover:bg-cyan-soft hover:text-yale-dark" data-key="ai" href="/">
                  AI &amp; Intelligence
                  <span class="arr-r size-2 rotate-[-45deg] border-r-[1.6px] border-b-[1.6px] border-current opacity-0 transition-opacity duration-[180ms] ease-out"></span>
                </a>
                <a class="mega-item flex cursor-pointer items-center justify-between rounded-lg px-3.5 py-[11px] text-sm font-semibold text-ink transition-[background,color] duration-[180ms] ease-out hover:bg-cyan-soft hover:text-yale-dark" data-key="automation" href="/">
                  Automation &amp; AI Solutions
                  <span class="arr-r size-2 rotate-[-45deg] border-r-[1.6px] border-b-[1.6px] border-current opacity-0 transition-opacity duration-[180ms] ease-out"></span>
                </a>
                <a class="mega-item flex cursor-pointer items-center justify-between rounded-lg px-3.5 py-[11px] text-sm font-semibold text-ink transition-[background,color] duration-[180ms] ease-out hover:bg-cyan-soft hover:text-yale-dark" data-key="transformation" href="/">
                  Digital Transformation
                  <span class="arr-r size-2 rotate-[-45deg] border-r-[1.6px] border-b-[1.6px] border-current opacity-0 transition-opacity duration-[180ms] ease-out"></span>
                </a>
                <a class="mega-item flex cursor-pointer items-center justify-between rounded-lg px-3.5 py-[11px] text-sm font-semibold text-ink transition-[background,color] duration-[180ms] ease-out hover:bg-cyan-soft hover:text-yale-dark" data-key="ux" href="/">
                  UX Design / Enablement
                  <span class="arr-r size-2 rotate-[-45deg] border-r-[1.6px] border-b-[1.6px] border-current opacity-0 transition-opacity duration-[180ms] ease-out"></span>
                </a>
              </div>
            </div>
            <div class="mega-right flex flex-col border-l border-line-soft pl-[22px]">
              <div class="mega-feature mb-3.5 flex items-start gap-3.5 rounded-[10px] bg-cyan-soft p-4 px-[18px]" data-feature="services">
                <div class="feat-icon grid size-[38px] shrink-0 place-items-center text-yale-dark" data-feat-icon>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" class="size-[30px]">
                    <polyline points="16 18 22 12 16 6"></polyline>
                    <polyline points="8 6 2 12 8 18"></polyline>
                  </svg>
                </div>
                <div>
                  <h4 data-feat-title class="mb-1 text-[17px] leading-[1.2] text-yale-dark">Development</h4>
                  <p data-feat-desc class="m-0 max-w-[360px] text-[12.5px] leading-[1.45] text-muted">Build robust, scalable digital products designed to grow with your business.</p>
                </div>
              </div>
              <div class="mega-sublinks grid grid-cols-2 gap-x-2 gap-y-0.5 py-1" data-sublinks="services">
                <a href="/" class="rounded-md px-3 py-2 text-[13.5px] font-medium text-muted transition-[background,color] duration-[180ms] ease-out hover:bg-seasalt hover:text-yale">Custom Software</a>
                <a href="/" class="rounded-md px-3 py-2 text-[13.5px] font-medium text-muted transition-[background,color] duration-[180ms] ease-out hover:bg-seasalt hover:text-yale">Mobile Apps</a>
                <a href="/" class="rounded-md px-3 py-2 text-[13.5px] font-medium text-muted transition-[background,color] duration-[180ms] ease-out hover:bg-seasalt hover:text-yale">Low code / No-code Dev</a>
                <a href="/" class="rounded-md px-3 py-2 text-[13.5px] font-medium text-muted transition-[background,color] duration-[180ms] ease-out hover:bg-seasalt hover:text-yale">Vibe code Dev</a>
              </div>
              <div class="mega-footer mt-3.5 flex items-center justify-between border-t border-line-soft pt-3.5">
                <span class="mega-tag font-mono text-[10.5px] tracking-[0.14em] text-cyan-strong uppercase">U.S. SLED prime contractor?</span>
                <a class="mega-cta inline-flex items-center gap-2 border-b-2 border-cyan pb-0.5 text-[13px] font-bold text-yale" href="/us-sled/">See SLED Partnerships →</a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="nav-item relative" data-mega="industries">
        <button
          class="nav-link inline-flex cursor-pointer items-center gap-1.5 whitespace-nowrap rounded-lg border border-transparent bg-transparent px-4 py-2.5 font-sans text-[14.5px] font-semibold leading-none text-ink transition-[color,background,border-color] duration-[180ms] ease-out hover:bg-yale/4 hover:text-yale"
          type="button"
          aria-expanded="false"
        >
          Industries <span class="chev size-[7px] -translate-x-px -translate-y-px rotate-45 border-r-[1.6px] border-b-[1.6px] border-current opacity-55 transition-transform duration-220 ease-out"></span>
        </button>
        <div
          class="mega pointer-events-none invisible absolute top-[calc(100%+14px)] left-1/2 z-60 w-[min(760px,calc(100vw-32px))] -translate-x-1/2 -translate-y-1 rounded-2xl border border-line bg-white p-[22px] opacity-0 shadow-[0_30px_60px_-20px_rgba(14,38,64,0.22),0_6px_18px_-8px_rgba(14,38,64,0.10)] transition-[opacity,transform,visibility] duration-[180ms] ease-out before:absolute before:-top-2 before:left-1/2 before:size-3.5 before:-translate-x-1/2 before:rotate-45 before:rounded-tl before:border-t before:border-l before:border-line before:bg-white before:content-[''] max-[1180px]:left-auto max-[1180px]:right-0 max-[1180px]:translate-x-0 max-[1180px]:before:left-auto max-[1180px]:before:right-10"
          role="menu"
        >
          <div class="mega-inner grid grid-cols-[250px_1fr] gap-[22px]">
            <div class="mega-left">
              <div class="mega-eyebrow mb-3.5 px-1.5 text-[17px] font-extrabold tracking-[-0.01em] text-yale-dark">Industries</div>
              <div class="mega-list flex flex-col gap-0.5" data-list="industries">
                <a class="mega-item active flex cursor-pointer items-center justify-between rounded-lg px-3.5 py-[11px] text-sm font-semibold text-ink transition-[background,color] duration-[180ms] ease-out hover:bg-cyan-soft hover:text-yale-dark" data-key="healthcare" href="/">
                  Healthcare
                  <span class="arr-r size-2 rotate-[-45deg] border-r-[1.6px] border-b-[1.6px] border-current opacity-0 transition-opacity duration-[180ms] ease-out"></span>
                </a>
                <a class="mega-item flex cursor-pointer items-center justify-between rounded-lg px-3.5 py-[11px] text-sm font-semibold text-ink transition-[background,color] duration-[180ms] ease-out hover:bg-cyan-soft hover:text-yale-dark" data-key="marketing" href="/">
                  Digital Marketing
                  <span class="arr-r size-2 rotate-[-45deg] border-r-[1.6px] border-b-[1.6px] border-current opacity-0 transition-opacity duration-[180ms] ease-out"></span>
                </a>
                <a class="mega-item flex cursor-pointer items-center justify-between rounded-lg px-3.5 py-[11px] text-sm font-semibold text-ink transition-[background,color] duration-[180ms] ease-out hover:bg-cyan-soft hover:text-yale-dark" data-key="realestate" href="/">
                  Real Estate
                  <span class="arr-r size-2 rotate-[-45deg] border-r-[1.6px] border-b-[1.6px] border-current opacity-0 transition-opacity duration-[180ms] ease-out"></span>
                </a>
                <a class="mega-item flex cursor-pointer items-center justify-between rounded-lg px-3.5 py-[11px] text-sm font-semibold text-ink transition-[background,color] duration-[180ms] ease-out hover:bg-cyan-soft hover:text-yale-dark" data-key="ecommerce" href="/">
                  E-commerce
                  <span class="arr-r size-2 rotate-[-45deg] border-r-[1.6px] border-b-[1.6px] border-current opacity-0 transition-opacity duration-[180ms] ease-out"></span>
                </a>
                <a class="mega-item flex cursor-pointer items-center justify-between rounded-lg px-3.5 py-[11px] text-sm font-semibold text-ink transition-[background,color] duration-[180ms] ease-out hover:bg-cyan-soft hover:text-yale-dark" data-key="logistics" href="/">
                  Logistics &amp; Supply Chain
                  <span class="arr-r size-2 rotate-[-45deg] border-r-[1.6px] border-b-[1.6px] border-current opacity-0 transition-opacity duration-[180ms] ease-out"></span>
                </a>
                <a class="mega-item flex cursor-pointer items-center justify-between rounded-lg px-3.5 py-[11px] text-sm font-semibold text-ink transition-[background,color] duration-[180ms] ease-out hover:bg-cyan-soft hover:text-yale-dark" data-key="education" href="/">
                  Education
                  <span class="arr-r size-2 rotate-[-45deg] border-r-[1.6px] border-b-[1.6px] border-current opacity-0 transition-opacity duration-[180ms] ease-out"></span>
                </a>
              </div>
            </div>
            <div class="mega-right flex flex-col border-l border-line-soft pl-[22px]">
              <div class="mega-feature mb-3.5 flex items-start gap-3.5 rounded-[10px] bg-cyan-soft p-4 px-[18px]" data-feature="industries">
                <div class="feat-icon grid size-[38px] shrink-0 place-items-center text-yale-dark" data-feat-icon>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" class="size-[30px]">
                    <path d="M22 12h-4l-3 9L9 3l-3 9H2"></path>
                  </svg>
                </div>
                <div>
                  <h4 data-feat-title class="mb-1 text-[17px] leading-[1.2] text-yale-dark">Healthcare</h4>
                  <p data-feat-desc class="m-0 max-w-[360px] text-[12.5px] leading-[1.45] text-muted">Techtiz streamlines admin tasks for healthcare teams, enhancing efficiency and safety.</p>
                </div>
              </div>
              <div class="mega-sublinks grid grid-cols-2 gap-x-2 gap-y-0.5 py-1" data-sublinks="industries">
                <a href="/" class="rounded-md px-3 py-2 text-[13.5px] font-medium text-muted transition-[background,color] duration-[180ms] ease-out hover:bg-seasalt hover:text-yale">AI Appointment Management</a>
                <a href="/" class="rounded-md px-3 py-2 text-[13.5px] font-medium text-muted transition-[background,color] duration-[180ms] ease-out hover:bg-seasalt hover:text-yale">AI-Powered Communication</a>
                <a href="/" class="rounded-md px-3 py-2 text-[13.5px] font-medium text-muted transition-[background,color] duration-[180ms] ease-out hover:bg-seasalt hover:text-yale">Reporting Optimization</a>
                <a href="/" class="rounded-md px-3 py-2 text-[13.5px] font-medium text-muted transition-[background,color] duration-[180ms] ease-out hover:bg-seasalt hover:text-yale">Patient Records</a>
              </div>
              <div class="mega-footer mt-3.5 flex items-center justify-between border-t border-line-soft pt-3.5">
                <span class="mega-tag font-mono text-[10.5px] tracking-[0.14em] text-cyan-strong uppercase">U.S. SLED prime contractor?</span>
                <a class="mega-cta inline-flex items-center gap-2 border-b-2 border-cyan pb-0.5 text-[13px] font-bold text-yale" href="/us-sled/">See SLED Partnerships →</a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <a
        href="/us-sled/case-studies/"
        class="nav-link inline-flex cursor-pointer items-center gap-1.5 whitespace-nowrap rounded-lg border border-transparent bg-transparent px-4 py-2.5 font-sans text-[14.5px] font-semibold leading-none text-ink transition-[color,background,border-color] duration-[180ms] ease-out hover:bg-yale/4 hover:text-yale"
      >
        Case Studies
      </a>
      <a
        href="/"
        class="nav-link inline-flex cursor-pointer items-center gap-1.5 whitespace-nowrap rounded-lg border border-transparent bg-transparent px-4 py-2.5 font-sans text-[14.5px] font-semibold leading-none text-ink transition-[color,background,border-color] duration-[180ms] ease-out hover:bg-yale/4 hover:text-yale"
      >
        Careers
      </a>
    </nav>

    <div class="right-cta flex items-center justify-self-end max-[900px]:hidden">
      <a
        href="/us-sled/"
        class="us-pill inline-flex items-center gap-2 rounded-lg border border-line bg-white px-4 py-2.5 font-mono text-[13px] font-bold tracking-[0.04em] text-yale transition-[border-color,background] duration-[180ms] ease-out hover:border-yale hover:bg-seasalt"
      >
        <span class="sled-dot inline-block size-2 shrink-0 rotate-[15deg] bg-cyan" aria-hidden="true"></span>
        SLED Partnerships
      </a>
    </div>
  </div>
</header>
