---
import SledPageWrap from '../shared/SledPageWrap.astro';
import { WHO_WE_ARE_NOT } from '../../../lib/constants/pages/sled-hub';
---

<div class="border-b border-line bg-gradient-to-r from-seasalt via-white to-seasalt py-5" data-sled-reveal>
  <SledPageWrap>
    <div class="flex flex-wrap items-center gap-5 rounded-xl border border-line/90 bg-white px-5 py-4 shadow-[0_12px_32px_-24px_rgba(21,58,95,0.14)]">
      <span class="shrink-0 rounded-lg border border-cyan/25 bg-cyan-soft px-3 py-1.5 font-mono text-[10.5px] tracking-[0.14em] text-cyan-strong uppercase">
        {WHO_WE_ARE_NOT.label}
      </span>
      <p class="m-0 min-w-[280px] flex-1 text-[13.5px] leading-[1.62] text-muted">
        {WHO_WE_ARE_NOT.body}
      </p>
    </div>
  </SledPageWrap>
</div>
